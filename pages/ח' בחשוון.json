D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי נחומ'קה קפלן מהורודנא, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%96\" title=\"תרע&quot;ז\">תרע\"ז</a> (4/11/1916 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%95%D7%99%D7%9C%D7%A0%D7%A7%D7%99%D7%9F\" title=\"שלום אליהו וילנקין\">שלום אליהו וילנקין</a>, <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בסניפים המחתרתיים של ישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> ב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>, ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> קהילת חב\"ד ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a> (4/11/1954 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"טוביה זילברשטרום\">טוביה זילברשטרום</a>, רב <a href=\"/index.php/%D7%A9%D7%99%D7%9B%D7%95%D7%9F_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" class=\"mw-redirect\" title=\"שיכון חב&quot;ד בירושלים\">שיכון חב\"ד בירושלים</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%98\" title=\"תש&quot;ט\">תש\"ט</a> (10/11/1948 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A4%D7%9C%D7%90%D7%98%D7%A7%D7%99%D7%9F\" class=\"mw-redirect\" title=\"אברהם אליהו פלאטקין\">אברהם אליהו פלאטקין</a>, מרבני חב\"ד בדור השישי ויו\"ר אגודת חסידי חב\"ד במחנה המעבר <a href=\"/index.php/%D7%A4%D7%95%D7%A7%D7%99%D7%A0%D7%92\" title=\"פוקינג\">פוקינג</a> שבגרמניה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a> - הרה\"ח <a href=\"/index.php/%D7%94%D7%9C%D7%9C_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91\" title=\"הלל ליברוב\">הלל ליברוב</a>, מתלמידי התמימים בליובאוויטש, משפיע בתו\"ת באורשא,לאחר המלחמה היה שוחט ורב באלמא אטא בשנות הזעם,ולא נטש את משמרתו במס\"נ עד יומו האחרון.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a> (31/10/1987 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%9C%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"אליעזר פרלשטיין\">אליעזר פרלשטיין</a>, ממייסדי סניף צא\"ח בירושלים, ומזכיר <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%95%D7%AA_%D7%94%D7%A8%D7%90%D7%A9%D7%99%D7%AA_%D7%9C%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"הרבנות הראשית לישראל\">הרבנות הראשית לישראל</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a> (1/11/1995 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%94_%D7%A2%D7%9C%D7%91%D7%A8%D7%92\" title=\"שמחה עלברג\">שמחה עלברג</a>, יו\"ר <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%9D_%D7%93%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA_%D7%95%D7%A7%D7%A0%D7%93%D7%94\" title=\"אגודת הרבנים דארצות הברית וקנדה\">אגודת הרבנים דארצות הברית וקנדה</a>, שעמד בקשר קרוב ביותר עם <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%95%D7%99%D7%92%D7%9C%D7%A8\" title=\"שלמה יהודה ויגלר\">שלמה יהודה ויגלר</a> <a href=\"/index.php/%D7%9E%D7%96%D7%9B%D7%99%D7%A8\" class=\"mw-redirect\" title=\"מזכיר\">מזכיר</a> ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" class=\"mw-redirect\" title=\"ישיבת תומכי תמימים לוד\">ישיבת תומכי תמימים לוד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרה\"ח <a href=\"/index.php/%D7%99%D7%95%D7%97%D7%A0%D7%9F_%D7%A1%D7%A4%D7%A8%D7%A0%D7%90%D7%99\" title=\"יוחנן ספרנאי\">יוחנן ספרנאי</a> - מחנך וניצול שואה חסיד חב\"ד.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ח' בחשוון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>'<a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%95%D7%94\" title=\"מצווה\">מצוה</a>' לשון צוותא וחיבור, והעושה מצוה מתחבר עם ה<a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA\" class=\"mw-redirect\" title=\"עצמות\">עצמות</a> ברוך הוא, שהוא ה<a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%95%D7%94\" title=\"מצווה\">מצווה</a> את הציווי הוא. וזהו \"<a href=\"/index.php?title=%D7%A9%D7%9B%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9E%D7%A6%D7%95%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שכר מצוה מצוה (הדף אינו קיים)\">שכר מצוה מצוה</a>\", דזה מה שנתחבר עם עצמות <a href=\"/index.php/%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" title=\"אין סוף\">אין סוף</a> מצווה הציווי, זהו שכרו.\n<p>ויובן במשל גשמי: איש פשוט ביותר יש לו <a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C\" title=\"ביטול\">ביטול</a> פנימי אל ה<a href=\"/index.php/%D7%97%D7%9B%D7%9E%D7%94\" class=\"mw-redirect\" title=\"חכמה\">חכמה</a> ומעלת <a href=\"/index.php/%D7%97%D7%9B%D7%9D\" class=\"mw-redirect\" title=\"חכם\">חכם</a>, ב<a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C\" title=\"ביטול\">ביטול</a> דהעדר תפיסת מקום לגמרי וכן גם בהרגש ההחכם הרי איש הפשוט אינו נכנס אצלו בגדר אנושי כלל - ואין זה דמבטלו ודוחה אותו, חס ושלום, דזהו מידה רעה - ונחשב בעיניו שאין לו קשר של יחס עמו כלל. והיה כאשר החכם יצווה לאיש הפשוט לעשות איזה דבר בשבילו, הנה בציווי זה נולד מציאותו של האיש הפשוט, הן לעצמו - שמרגיש מציאותו אשר ההוא יכול לקיים מצות החכם ולו ציווה החכם לעשות דבר, והן בעיני החכם נחשב ל<a href=\"/index.php/%D7%9E%D7%A6%D7%99%D7%90%D7%95%D7%AA\" title=\"מציאות\">מציאות</a> אשר אליו ידבר ויצווה, ולבד זאת הרי ציווי זה מאחד החכם הרם ונעלה עם ההאיש הפשוט ביותר, והנמשל המובן.\n</p><p>ומובן גם כן אשר ביחס להנ\"ל, אין הבדל כלל במה יהיה הציווי, אם דבר גדול ונעלה או קטן ופשוט.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414112602\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.036 seconds\nReal time usage: 0.526 seconds\nPreprocessor visited node count: 94/1000000\nPost‐expand include size: 7469/2097152 bytes\nTemplate argument size: 561/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnst