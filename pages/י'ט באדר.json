/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"ОЌОЋОЊОЕ ОљОЊОе\">ОЌОЋОЊОЕ ОљОЊОе</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"ОљОЎОеОЋОбОЎОЮ_ОЉОЎОћОЊОЋОф\">ОљОЎОеОЋОбОЎОЮ ОЉОЎОћОЊОЋОф</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОљОЎОеОЋОбОЎОЮ ОЉОЎОћОЊОЋОф&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОљОЎОеОЋОбОЎОЮ ОЉОЎОћОЊОЋОф\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%91\" title=\"ОфОеОд&quot;ОЉ\">ОфОеОд\"ОЉ</a> (ОљОЊОе ОЕОаОЎ) - ОеОЉОЎ <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%96%D7%95%D7%A0%D7%A0%D7%A4%D7%9C%D7%93\" title=\"ОЎОЋОАОБ ОЌОЎОЎОЮ ОќОЋОаОаОцОюОЊ\">ОЎОЋОАОБ ОЌОЎОЎОЮ ОќОЋОаОаОцОюОЊ</a>, ОаОцОўОе ОеОЉОћ ОЕОю <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ОЎОеОЋОЕОюОЎОЮ\">ОЎОеОЋОЕОюОЎОЮ</a>, ОаОцОўОе.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ОЎОъОЎ_ОЌОЉ&quot;ОЊ\">ОЎОъОЎ ОЌОЉ\"ОЊ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОЎОъОЎ ОЌОЉ&quot;ОЊ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОЎОъОЎ ОЌОЉ&quot;ОЊ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"ОаОЋОюОЊОЋ\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"ОЎОЋОЮ ОћОЋОюОЊОф\">ОаОЋОюОЊОЋ</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОаОЋОюОЊОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОаОЋОюОЊОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%9B\" title=\"ОфОе&quot;ОЏ\">ОфОе\"ОЏ</a> - ОћОеОЉОаОЎОф <a href=\"/index.php/%D7%A8%D7%97%D7%9C_%D7%99%D7%A0%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"ОеОЌОю ОЎОаОЋОЉОАОДОЎ\">ОеОЌОю ОЎОаОЋОЉОАОДОЎ</a>, ОќОДОаОф <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a>, ОЋОљОЕОф Ое' <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9C%D7%9E%D7%94_%D7%99%D7%A0%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"ОъОљОЎОе ОЕОюОъОћ ОЎОаОЋОЉОАОДОЎ\">ОъОљОЎОе ОЕОюОъОћ ОЎОаОЋОЉОАОДОЎ</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"ОфОЕ&quot;Оќ\">ОфОЕ\"Оќ</a> - ОћОеОЉ <a href=\"/index.php/%D7%93%D7%91_%D7%90%D7%9C%D7%A8%D7%90%D7%99\" title=\"ОЊОЉ ОљОюОеОљОЎ\">ОЊОЉ ОљОюОеОљОЎ</a>, ОЌОЉОе ОћОдОЋОЋОф ОћОЌОЎОаОЋОЏОЎ ОЕОю ОЉОЎОф ОћОАОцОе ОЉОъОЋОЕОЉ ОЉОеОЋОЕ ОЕОфОЌОф <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"ОеОЕОф ОљОћОюОЎ ОЎОЋОАОБ ОЎОдОЌОД\">ОеОЕОф ОљОћОюОЎ ОЎОЋОАОБ ОЎОдОЌОД</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%97\" title=\"ОфОЕОЎ&quot;ОЌ\">ОфОЕОЎ\"ОЌ</a> - ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%99%D7%A6%D7%97%D7%A7_%D7%A4%D7%A8%D7%99%D7%A9%D7%9E%D7%9F\" title=\"ОЎОЕОеОљОю ОЎОдОЌОД ОцОеОЎОЕОъОЪ\">ОЎОЕОеОљОю ОЎОдОЌОД ОцОеОЎОЕОъОЪ</a>, ОЌОЉОе ОћОаОћОюОф ОдОбОЎОеОЎ ОљОњОЋОЊОф ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ОЎОеОЋОЕОюОЎОЮ\">ОЎОеОЋОЕОюОЎОЮ</a>, ОЋОъОеОљОЕОЎ ОбОАОДОаОЎ ОЌОЉ\"ОЊ ОЉОбОЎОе.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"ОфОЕОЏ&quot;Оњ\">ОфОЕОЏ\"Оњ</a> - ОћОеОЉ <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A4%D7%A8%D7%95%D7%A1\" title=\"ОЌОЎОЎОЮ ОцОеОЋОА\">ОЌОЎОЎОЮ ОцОеОЋОА</a>, ОеОљОЕ <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%90%D7%95%D7%A8_%D7%A9%D7%9E%D7%97%D7%94\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОф ОљОЋОе ОЕОъОЌОћ\">ОЎОЕОЎОЉОф ОљОЋОе ОЕОъОЌОћ</a> <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"ОаОцОўОеОЋ\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"ОцОўОЎОеОћ\">ОаОцОўОеОЋ</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОаОцОўОеОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОаОцОўОеОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"ОфОЕОЎ&quot;Ољ\">ОфОЕОЎ\"Ољ</a> <sup><span class=\"clarification-needed\" style=\"cursor: help; font-size: 90%;\" title=\"ОљОЊОе Ољ&#39; ОљОЋ ОЉ&#39;?\">[ОЊОеОЋОЕОћ ОћОЉОћОеОћ]</span></sup> - ОћОеОЉ <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F\" title=\"ОдОЉОЎ ОюОЎОЉОеОъОЪ\">ОдОЉОЎ ОюОЎОЉОеОъОЪ</a>, ОъОфОюОъОЎОЊОЎ <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ</a>, ОЋОъОеОљОЕОЎ ОћОъОЌОфОеОф ОћОЌОАОЎОЊОЎОф ОЉ<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ОЉОеОЎОф ОћОъОЋОбОдОЋОф\">ОЉОеОЎОф ОћОъОЋОбОдОЋОф</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"ОфОЕОю&quot;Оћ\">ОфОЕОю\"Оћ</a> - ОћОеОЉ <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9C%D7%91%D7%A0%D7%94%D7%A8%D7%A5\" title=\"ОљОЉОеОћОЮ ОЕОъОЋОљОю ОюОЉОаОћОеОЦ\">ОљОЉОеОћОЮ ОЕОъОЋОљОю ОюОЉОаОћОеОЦ</a>, ОъОљОаОЕОЎ ОћОДОћОЎОюОћ ОћОЌОЉ\"ОЊОЎОф ОЉ<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"ОъОЋОАОДОЉОћ\">ОъОЋОАОДОЉОћ</a> <a href=\"/index.php/%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"Од&#39;ОеОаОЋОЉОЎОЦ\">Од'ОеОаОЋОЉОЎОЦ</a> ОЋ<a href=\"/index.php/%D7%98%D7%A9%D7%A7%D7%A0%D7%98\" title=\"ОўОЕОДОаОў\">ОўОЕОДОаОў</a>, ОЕОћОфОњОЋОеОе ОЉОЕОаОЋОфОЎОЋ ОћОљОЌОеОЋОаОЋОф ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"ОфОЕОа&quot;ОЊ\">ОфОЕОа\"ОЊ</a> - ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9C%D7%99%D7%99%D7%91%D7%95%D7%91\" title=\"ОЎОЕОеОљОю ОюОЎОЎОЉОЋОЉ\">ОЎОЕОеОљОю ОюОЎОЎОЉОЋОЉ</a>, ОъОЎОЎОАОЊ ОЋОЎОЋ\"Ое ОъОеОЏОќ <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОдОбОЎОеОЎ ОљОњОЋОЊОф ОЌОЉ&quot;ОЊ ОљОеОЦ ОћОДОЋОЊОЕ\">ОдОбОЎОеОЎ ОљОњОЋОЊОф ОЌОЉ\"ОЊ ОљОеОЦ ОћОДОЋОЊОЕ</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"ОфОЕОа&quot;Оў\">ОфОЕОа\"Оў</a> - Ое' <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F\" title=\"ОдОЉОЎ ОћОЎОеОЕ ОеОЎОЉОДОЎОЪ\">ОдОЉОЎ ОћОЎОеОЕ ОеОЎОЉОДОЎОЪ</a>, ОъОЉОЋОаОЎ ОЋОъОЎОЎОАОЊОЎ <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"ОфОЕ&quot;Об\">ОфОЕ\"Об</a> - ОћОеОЉ <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%96%D7%99%D7%9C%D7%91%D7%A8\" title=\"ОљОюОЎОбОќОе ОќОЎОюОЉОе\">ОљОюОЎОбОќОе ОќОЎОюОЉОе</a>, ОъОЎОЎОАОЊ ОЋОЎОЋ\"Ое 'ОљОЎОњОЋОЊ ОдОљОдОљОЎ <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%99%D7%99%D7%9D_%D7%A0%D7%90%D7%94\" title=\"ОљОЉОеОћОЮ ОЌОЎОЎОЮ ОаОљОћ\">ОћОњОеОљ\"ОЌ ОаОљОћ</a>'.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"ОфОЕОб&quot;Оњ\">ОфОЕОб\"Оњ</a> - ОћОеОЉ <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A8%D7%95%D7%99%D7%98%D7%91%D7%9C%D7%98\" title=\"ОљОЉОеОћОЮ ОеОЋОЎОўОЉОюОў\">ОљОЉОеОћОЮ ОеОЋОЎОўОЉОюОў</a>, ОфОюОъОЎОЊ ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОЋОъОеОљОЕОЋОаОЎ ОћОъОфОЎОЎОЕОЉОЎОЮ ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"ОфОЕОц&quot;ОЉ\">ОфОЕОц\"ОЉ</a> - ОаОеОдОЌ ОбОДОћ\"ОЕ ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99\" class=\"mw-redirect\" title=\"ОъОЕОћ ОДОеОЉОЎОдОДОЎ\">ОъОЕОћ ОДОеОЉОЎОдОДОЎ</a>, ОЕОюОЎОЌ ОћОеОЉОЎ Ою<a href=\"/index.php/%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2\" title=\"ОЉОљОе ОЕОЉОб\">ОЉОљОе ОЕОЉОб</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">ОћОцОфОњОЮ ОћОЎОЋОъОЎ - ОЎ\"Оў ОЉОљОЊОе Ољ' - Оъ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"ОюОЋОЌ ОћОЎОЋОЮ ОЎОЋОЮ\">ОюОЋОЌ ОћОЎОЋОЮ ОЎОЋОЮ</a>\n</th></tr>\n<tr>\n<td>Оћ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"ОЌОАОЎОЊ\">ОЌОАОЎОЊОЎОЮ</a>, ОљОцОЎОюОЋ Оћ<a href=\"/index.php/%D7%91%D7%99%D7%A0%D7%95%D7%A0%D7%99\" title=\"ОЉОЎОаОЋОаОЎ\">ОЉОЎОаОЋОаОЎОЮ</a>, ОћОЎОЋ ОЉОДОЎОљОЎОЮ ОЉ<a href=\"/index.php/%D7%AA%D7%A0%22%D7%9A\" title=\"ОфОа&quot;Оџ\">ОфОа\"Оџ</a>. ОЋ<a href=\"/index.php/%D7%9E%D7%A0%D7%94%D7%92\" title=\"ОъОаОћОњ\">ОъОаОћОњ</a> ОъОАОЋОЊОе ОћОЎОћ ОљОдОюОЮ, ОљОЕОе ОљОЌОе ОюОЎОъОЋОЊ ОЕОЎОбОЋОе <a href=\"/index.php/%D7%9E%D7%A9%D7%A0%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ОъОЕОаОЎОЋОф\">ОъОЕОаОЎОЋОф</a> ОЕОљОЌОеОЎ ОфОцОЎОюОф <a href=\"/index.php/%D7%A9%D7%97%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ОЕОЌОеОЎОф\">ОЕОЌОеОЎОф</a>, ОЉОЕОбОф ОДОцОЎОюОф ОћОўОюОЎОф ОЋ<a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ОфОцОЎОюОЎОЪ\">ОфОцОЎОюОЎОЪ</a> ОћОЎОЋ ОљОЋОъОеОЎОЮ ОЕОЎОбОЋОе ОфОа\"Оџ, ОЉОљОЋОцОЪ ОљОЕОе ОЉОъОЕОџ ОЕОюОЕОћ ОЌОЊОЕОЎОЮ ОћОЎОЋ ОњОЋОъОеОЎОЮ ОљОф ОћОфОа\"Оџ.\n</td></tr></tbody></table>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">ОћОцОфОњОЮ ОћОЎОЋОъОЎ - ОЎ\"Оў ОЉОљОЊОе ОЉ' - Оъ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"ОюОЋОЌ ОћОЎОЋОЮ ОЎОЋОЮ\">ОюОЋОЌ ОћОЎОЋОЮ ОЎОЋОЮ</a>\n</th></tr>\n<tr>\n<td>Ое' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%9E%D7%99%D7%99%D7%96%D7%9C%D7%99%D7%A9\" title=\"ОъОЕОћ ОъОЎОЎОќОюОЎОЕ\">ОъОЕОћ ОъОЎОЎОќОюОЎОЕ</a> ОАОЎОцОе: ОЊОбОе ОеОЉОЎ (<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"ОеОЉОЎОаОЋ ОћОќОДОЪ\">ОеОЉОЎОаОЋ ОћОќОДОЪ</a>) ОћОљОў ОљОЋОаОќ ОњОбОюОбОеОбОаОў, ОљОќ ОЊОбОе <a href=\"/index.php/%D7%90%D7%9C%22%D7%A3\" class=\"mw-redirect\" title=\"ОљОю&quot;ОБ\">ОљОю\"ОБ</a> ОцОЋОЪ <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ОЌОАОЎОЊОЋОф\">ОЌОАОЎОЊОЋОф</a> ОљОЎОќ, ОљОЋОЎОАОдОЋОаОЎОдОбОЪ ОЊОЎ <a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"ОўОЉОб\">ОўОЉОбОЎОЋОф</a> ОљОЎОЪ <a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"ОбОЉОЋОЊОф Оћ&#39;\">ОбОЉОЋОЊОћ</a>. ОљОЋОЪ ОеОљОЕОЎОф ОћОбОЉОЋОЊОћ ОќОљОю ОќОЎОЎОЪ ОљОЋОЎОАОдОЋОаОЎОдОбОЪ ОЊОЎ ОўОЉОб Оћ<a href=\"/index.php?title=%D7%9B%D7%97%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЏОЌОЋОф (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЏОЌОЋОф</a>, ОЋОЋОЎ ОюОъОЕОю ОЊОЎ ОўОЉОб ОцОЋОЪ <a href=\"/index.php/%D7%9E%D7%95%D7%97\" title=\"ОъОЋОЌ\">ОъОЋОЌ</a> ОЕОюОЎОў ОбОю Оћ<a href=\"/index.php/%D7%9C%D7%91\" title=\"ОюОЉ\">ОюОЉ</a>.\n<hr />\n<p><b>ОфОеОњОЋОЮ Оъ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"ОљОЎОЊОЎОЕ\">ОљОЎОЊОЎОЕ</a></b>: Ое' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%9E%D7%99%D7%99%D7%96%D7%9C%D7%99%D7%A9\" title=\"ОъОЕОћ ОъОЎОЎОќОюОЎОЕ\">ОъОЕОћ ОъОЎОЎОќОюОЎОЕ</a> ОАОЎОцОе: Оћ<a href=\"/index.php/%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОеОЉОЎ\">ОеОЉОЎ</a> (<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"ОеОЉОЎОаОЋ ОћОќОДОЪ\">ОеОЉОЎОаОЋ ОћОќОДОЪ</a>) ОюОЎОъОЊ ОљОЋОфОаОЋ, ОЕОћ<a href=\"/index.php/%D7%90%D7%9C%22%D7%A3\" class=\"mw-redirect\" title=\"ОљОю&quot;ОБ\">ОљОю\"ОБ</a> ОЕОю <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ОЌОАОЎОЊОЋОф\">ОЌОАОЎОЊОЋОф</a> ОћОЋОљ, ОюОаОдОю ОљОф Оћ<a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"ОўОЉОб\">ОўОЉОбОЎОЋОф</a> ОЉ<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"ОбОЉОЋОЊОф Оћ&#39;\">ОбОЉОЋОЊОћ</a>. ОЋОеОљОЕОЎОф ОћОбОЉОЋОЊОћ ОЕОЎОћОЎОћ ОюОаОдОю ОљОф ОўОЉОб Оћ<a href=\"/index.php?title=%D7%9B%D7%95%D7%97%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЏОЋОЌОЋОф (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЏОЋОЌОЋОф</a>, ОЏОъОЋ ОюОъОЕОю ОљОф ОћОўОЉОб ОЕ<a href=\"/index.php/%D7%9E%D7%95%D7%97\" title=\"ОъОЋОЌ\">ОъОЋОЌ</a> ОЕОюОЎОў ОбОю Оћ<a href=\"/index.php/%D7%9C%D7%91\" title=\"ОюОЉ\">ОюОЉ</a>.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414053734\nCache expiry: 86400\nReduced expiry: false\nComplications: [showРђљtoc]\nCPU time usage: 0.056 seconds\nReal time usage: 0.348 seconds\nPreprocessor visited node count: 137/1000000\nPostРђљexpand include size: 7471/2097152 bytes\nTemplate argument size: 582/2097152 bytes\nHighest expansion depth: 7/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip postРђљexpand size: 0/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5214208/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  311.890      1 -total\n 84.57%  263.770      1 ОфОЉОаОЎОф:ОћОЉОћОеОћ\n  7.36%   22.966      1 ОфОЉОаОЎОф:ОЌОЋОЊОЕ_ОљОЊОе\n  6.59%   20.557      2 ОфОЉОаОЎОф:ОюОћОЎОЋОЮ_ОЎОЋОЮ\n  5.28%   16.475      1 ОфОЉОаОЎОф:ОДОЎОЊОЋОЊ\n  4.51%   14.072      1 ОфОЉОаОЎОф:ОюОЋОЌ_ОЕОаОћ\n  2.96%    9.241      1 ОфОЉОаОЎОф:ОДОўОњОЋОеОЎОћ_ОЉОфОЉОаОЎОф\n  2.58%    8.033      1 ОфОЉОаОЎОф:ОћОЎОЋОЮ_ОЎОЋОЮ/ОЎ&quot;Оў_ОљОЊОе_ОЉ&#039;\n  1.63%    5.072      1 ОфОЉОаОЎОф:ОћОЎОЋОЮ_ОЎОЋОЮ/ОЎ&quot;Оў_ОљОЊОе_Ољ&#039;\n  1.36%    4.252      1 ОфОЉОаОЎОф:ОљОЊОеОЎОЮ\n-->\n\n<!-- Saved in parser cache with k