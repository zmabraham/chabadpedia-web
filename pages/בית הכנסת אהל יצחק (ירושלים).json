vg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span><span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">קדמו לו בית הכנסת חב\"ד חברון, <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7_(%D7%A6%D7%A4%D7%AA)\" title=\"בית כנסת צמח צדק (צפת)\">בית כנסת 'צמח צדק' בצפת</a>, ו<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" title=\"בית הכנסת צמח צדק (ירושלים)\">בית הכנסת 'צמח צדק' בירושלים</a>, אך אף שבתי כנסת אלו שרדו את כל המאורעות לאורך השנים - במשך שנים רבות היו שוממים.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">המשמשת כיום כחנות הספרים 'שרייבר'</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">בית הכנסת הראשון בשכונה שהתפללו בו בנוסח חסידי, נוסד בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%95\" title=\"תרמ&quot;ו\">תרמ\"ו</a>.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">אגרות קודש אדמו\"ר הריי\"צ חלק ח' אגרת ב'תנז: \"אל ידידנו אנ\"ש מתפללי בהכנ\"ס חב\"ד ב\"מאה שערים\".. בנועם קבלתי את המברקה שבה מודיעים לי על אודות מילוי בקשתי להכניס את ישיבת \"תורת אמת\" יצ\"ו לבהכנ\"ס\".</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">על פי דיווח בעיתונים 'הארץ' ו'המבשר'. נדפס ב'נודע בשיעורים' עמודים 328-329.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">אגרות קודש חי\"א ע' שכה.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">בשנים שלפני חתונתו</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414042945\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.138 seconds\nReal time usage: 0.676 seconds\nPreprocessor visited node count: 362/1000000\nPost‐expand include size: 3150/2097152 bytes\nTemplate argument size: 1075/2097152 bytes\nHighest expansion depth: 8/100\nExpensive parser function count: 3/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 2983/5000000 bytes\nLua time usage: 0.060/7 seconds\nLua virtual size: 6000640/52428800 bytes\nLua estimated mem