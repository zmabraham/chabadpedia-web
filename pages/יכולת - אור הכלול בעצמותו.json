      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"infobox\" style=\"width:25%; border: 1px solid #aaaaaa; background-color: #f9f9f9; margin-bottom: 0.5em; margin-right: 1em; padding: 0.2em; color: black; float: left; text-align: center; font-size: 85%; clear:right;\">\n\n<tbody><tr style=\"background:lightblue;\">\n<th><font size=\"4\"><a href=\"/index.php/%D7%A1%D7%93%D7%A8_%D7%94%D7%A9%D7%AA%D7%9C%D7%A9%D7%9C%D7%95%D7%AA\" title=\"סדר השתלשלות\">סדר השתלשלות</a></font>\n</th></tr>\n\n<tr style=\"background:lightblue;\">\n<th>לפני הצמצום\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_%D7%95%D7%9E%D7%94%D7%95%D7%AA\" title=\"עצמות ומהות\">עצמות ומהות</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%99%D7%9B%D7%95%D7%9C%D7%AA\" class=\"mw-redirect\" title=\"יכולת\">יכולת (מאור כפי שכלול בעצמות)</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9E%D7%90%D7%95%D7%A8\" class=\"mw-redirect\" title=\"מאור\">מאור</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%90%D7%95%D7%90%22%D7%A1_%D7%9B%D7%A4%D7%99_%D7%A9%D7%9B%D7%9C%D7%95%D7%9C_%D7%91%D7%9E%D7%90%D7%95%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אוא&quot;ס כפי שכלול במאור (הדף אינו קיים)\">אוא\"ס כפי שכלול במאור</a><span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span><a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" title=\"אור אין סוף\">אור אין סוף</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span><a href=\"/index.php/%D7%97%D7%A4%D7%A5_%D7%97%D7%A1%D7%93\" class=\"mw-redirect\" title=\"חפץ חסד\">חפץ חסד</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A2%D7%A9%D7%A8_%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA_%D7%94%D7%92%D7%A0%D7%95