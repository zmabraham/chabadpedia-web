d>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ז בניסן\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ח בניסן\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ט בניסן\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"ל&#39; בניסן\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י' בניסן</b> הוא היום העשירי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח - <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"בני ישראל\">בני ישראל</a> לקחו כבשים להקריב ל<a href=\"/index.php/%D7%A7%D7%A8%D7%91%D7%9F_%D7%94%D7%A4%D7%A1%D7%97\" class=\"mw-redirect\" title=\"קרבן הפסח\">קרבן הפסח</a> ב<a href=\"/index.php/%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"מצרים\">מצרים</a>.</li>\n<li>ב'תמ\"ט - אחיעזר בן עמישדי, <a href=\"/index.php/%D7%A0%D7%A9%D7%99%D7%90\" title=\"נשיא\">נשיא</a> <a href=\"/index.php/%D7%A9%D7%91%D7%98_%D7%93%D7%9F\" class=\"mw-redirect\" title=\"שבט דן\">שבט דן</a>, הקריב <a href=\"/index.php/%D7%A7%D7%A8%D7%91%D7%9F\" class=\"mw-redirect\" title=\"קרבן\">קרבן</a> לחנוכת ה<a href=\"/index.php/%D7%9E%D7%A9%D7%9B%D7%9F\" class=\"mw-redirect\" title=\"משכן\">משכן</a>.</li>\n<li>ב'תפ\"ח - <a href=\"/index.php/%D7%9E%D7%A8%D7%99%D7%9D_%D7%94%D7%A0%D7%91%D7%99%D7%90%D7%94\" title=\"מרים הנביאה\">מרים הנביאה</a>, אחותם של <a href=\"/index.php/%D7%9E%D7%A9%D7%94\" class=\"mw-redirect\" title=\"משה\">משה</a> ו<a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%94%D7%9B%D7%94%D7%9F\" title=\"אהרן הכהן\">אהרן הכהן</a>, נפטרה.</li>\n<li>ב'תפ\"ט - <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2\" class=\"mw-redirect\" title=\"יהושע\">יהושע</a> ובני ישראל <a href=\"/index.php/%D7%94%D7%9B%D7%A0%D7%99%D7%A1%D7%94_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%A0%D7%94_%D7%9C%D7%90%D7%A8%D7%A5\" title=\"הכניסה הראשונה לארץ\">עברו את נהר הירדן</a> ונכנסו ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> - רבי <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%9E%D7%A9%D7%90%D7%A9\" title=\"שלום משאש\">שלום משאש</a>, מרבני יהדות <a href=\"/index.php/%D7%9E%D7%A8%D7%95%D7%A7%D7%95\" title=\"מרוקו\">מרוקו</a> ורבה של <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%90\" title=\"תקס&quot;א\">תקס\"א</a> – הצאר הרוסי חתם על פקודת השחרור ל<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> ולכלל החסידים, בסיום <a href=\"/index.php/%D7%9E%D7%90%D7%A1%D7%A8%D7%95_%D7%94%D7%A9%D7%A0%D7%99_%D7%A9%D7%9C_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"מאסרו השני של אדמו&quot;ר הזקן\">מאסרו השני של אדמו\"ר הזקן</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%94\" title=\"תרע&quot;ה\">העת\"ר</a> – ר' <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A4%D7%91%D7%96%D7%A0%D7%A8\" title=\"ישראל פבזנר\">ישראל פבזנר</a>, חסיד חב\"ד מ<a href=\"/index.php/%D7%A8%D7%9E%D7%AA_%D7%92%D7%9F\" title=\"רמת גן\">רמת גן</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> – הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9E%D7%90%D7%99%D7%95%D7%A8\" class=\"mw-redirect\" title=\"אברהם מאיור\">אברהם מאיור</a> (דרייזין), <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בשכונת <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A9%D7%94_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"יעקב משה פרידמן\">יעקב משה פרידמן</a>, חבר ההנהלה הגשמית של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a> – הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%9E%D7%A1\" title=\"יצחק נמס\">יצחק נמס</a>, איש עסקים ושליח נודד של הרבי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> – הרב <a href=\"/index.php/%D7%96%D7%9B%D7%A8%D7%99%D7%94_%D7%92%D7%95%D7%A8%D7%99\" title=\"זכריה גורי\">זכריה גורי</a>, רב המושב <a href=\"/index.php/%D7%90%D7%91%D7%99%D7%98%D7%9C\" title=\"אביטל\">אביטל</a> שבחבל תענך.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> – הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9E%D7%A9%D7%94_%D7%A0%D7%A4%D7%A8%D7%A1%D7%98%D7%A7\" title=\"אברהם משה נפרסטק\">אברהם משה נפרסטק</a>, משפיע בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> – הרב <a href=\"/index.php/%D7%99%D7%92%D7%90%D7%9C_%D7%A4%D7%99%D7%96%D7%9D\" title=\"יגאל פיזם\">יגאל פיזם</a>, שליח הרבי הראשון לקריות, רב קהילת חב\"ד בקריית שמואל וראש ישיבת חב\"ד בקריות.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a> - הרבנית מרת <a href=\"/index.php/%D7%93%D7%91%D7%95%D7%A8%D7%94_%D7%91%D7%95%D7%98%D7%9E%D7%9F\" title=\"דבורה בוטמן\">דבורה בוטמן</a> , יו\"ר נשי חב\"ד בארץ הקודש ומייסדת בית רבקה בקראון הייטס.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A1%D7%99%D7%A8%D7%95%D7%98%D7%94\" title=\"משה סירוטה\">משה סירוטה</a> מזקני חב\"ד בנחלת הר חב\"ד.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י' בניסן - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>בדבר התעמולה בענין <a href=\"/index.php/%D7%98%D7%94%D7%A8%D7%AA_%D7%94%D7%9E%D7%A9%D7%A4%D7%97%D7%94\" title=\"טהרת המשפחה\">טהרת המשפחה</a> במושבו, יתבונן בזה: אילו יצוייר, אשר ה' אנה לידו להציל מושב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%99\" class=\"mw-redirect\" title=\"יהודי\">יהודים</a> מכליון, רחמנא ליצלן, הנה בטח היה <a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%A8%D7%95%D7%AA_%D7%A0%D7%A4%D7%A9\" title=\"מסירות נפש\">מוסר נפשו</a> על זה, והיה מהלל ומשבח את השם יתברך, על גודל ה<a href=\"/index.php/%D7%97%D7%A1%D7%93\" class=\"mw-redirect\" title=\"חסד\">חסד</a> לזכותו בזכות גדול כזה. ויותר מכן היא תעמולה זו, שהיא הצלת נפשות ממש.\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414123451\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.028 seconds\nReal time usage: 0.139 seconds\nPreprocessor visited node count: 99/1000000\nPost‐expand include size: 5305/2097152 bytes\nTemplate argument size: 493/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   82.804      1 -total\n 61.83%   51.194      1 תבנית:חודש_ניסן\n 48.42%   40.090      1 תבנית:לוח_שנה\n 37.98%   31.453      1 תבנית:להיום_יום\n 17.92%   14.839      1 תבנית:כתב_קטן\n 14.31%   11.851      1 תבנית:היום_יום/י&#039;_ניסן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:21442-0!canonical and timestamp 20260414123451 and revision id 831307. Rendering was triggered because: api-parse\n -->\n</div>"
