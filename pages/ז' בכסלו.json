pan><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ג'תשס\"א (-0 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - הורדוס מת. יום מותו מוזכר במגילת תענית כיום טוב.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%93%22%D7%9E\" title=\"תשד&quot;מ\">תשד\"מ</a> (13/11/1983 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php?title=%D7%A9%D7%9C%D7%9E%D7%94_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%90%D7%A9%D7%9C%D7%92&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלמה בנימין אשלג (הדף אינו קיים)\">שלמה בנימין אשלג</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%94\" title=\"תקצ&quot;ה\">תקצ\"ה</a> (09/12/1834 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%A2%D7%A7%D7%91_%D7%95%D7%95%D7%99%D7%93%D7%A8%D7%91%D7%99%D7%A5\" title=\"חיים יעקב ווידרביץ\">חיים יעקב ווידרביץ</a>, מחסידי <a href=\"/index.php/%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"הצמח צדק\">הצמח צדק</a> שכיהן כרבה של <a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a> ולאחר מכן כרב ב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ניו יורק\">ניו יורק</a>, וערך חלק מספרו '<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a>'.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a> (02/12/1954 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%9E%D7%90%D7%99%D7%A8_%D7%A1%D7%95%D7%A1%D7%95%D7%91%D7%A8\" title=\"יצחק מאיר סוסובר\">יצחק מאיר סוסובר</a>, מזכיר בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> ומגבאי בית הכנסת חב\"ד ב<a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" title=\"ראשון לציון\">ראשון לציון</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%92\" title=\"תשל&quot;ג\">תשל\"ג</a> (13/11/1972 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"חיים אליעזר גורביץ\">חיים אליעזר גורביץ</a>, מתלמידי התמימים ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a>, ששימש במשך מספר שנים כ<a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> בנגלה.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ז' בכסלו - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>שלש <a href=\"/index.php/%D7%97%D7%9B%D7%9E%D7%94\" class=\"mw-redirect\" title=\"חכמה\">חכמות</a> הן:\n<dl><dd>חכמת <a href=\"/index.php?title=%D7%91%D7%99%D7%98%D7%95%D7%9C_%D7%94%D7%97%D7%95%D7%9E%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ביטול החומר (הדף אינו קיים)\">ביטול החומר</a>, על ידי הוראת שקוץ ותיעוב כל הענינים <a href=\"/index.php/%D7%92%D7%95%D7%A3\" class=\"mw-redirect\" title=\"גוף\">הגופניים</a> וה<a href=\"/index.php/%D7%97%D7%95%D7%9E%D7%A8\" class=\"mw-redirect\" title=\"חומר\">חומריים</a> - חכמת ה<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A8\" class=\"mw-redirect\" title=\"מוסר\">מוסר</a>.</dd></dl>\n<dl><dd>חכמת הכרת מעלת ה<a href=\"/index.php/%D7%A6%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"צורה\">צורה</a> וה<a href=\"/index.php/%D7%A8%D7%95%D7%97%D7%A0%D7%99\" class=\"mw-redirect\" title=\"רוחני\">רוחני</a> ב<a href=\"/index.php/%D7%9E%D7%93%D7%95%D7%AA\" class=\"mw-redirect mw-disambig\" title=\"מדות\">מדות</a> וב<a href=\"/index.php?title=%D7%9E%D7%95%D7%A9%D7%9B%D7%9C%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מושכלות (הדף אינו קיים)\">מושכלות</a> והוראת אופני הקירוב אליהם - חכמת ה<a href=\"/index.php/%D7%97%D7%A7%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"חקירה\">חקירה</a>.</dd></dl>\n<dl><dd>חכמת <a href=\"/index.php?title=%D7%94%D7%92%D7%91%D7%A8%D7%AA_%D7%94%D7%A6%D7%95%D7%A8%D7%94_%D7%A2%D7%9C_%D7%94%D7%97%D7%95%D7%9E%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"הגברת הצורה על החומר (הדף אינו קיים)\">הגברת הצורה על החומר</a>, הוראה במעלת חומר מזוכך ובמעלת הצורה כשנקבעה בהחומרי, והתכללותם יחד מבלי אשר ימצא ראש וסוף, להיות כי <a href=\"/index.php?title=%D7%A0%D7%A2%D7%95%D7%A5_%D7%AA%D7%97%D7%9C%D7%AA%D7%9F_%D7%91%D7%A1%D7%95%D7%A4%D7%9F_%D7%95%D7%A1%D7%95%D7%A4%D7%9F_%D7%91%D7%AA%D7%97%D7%9C%D7%AA%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"נעוץ תחלתן בסופן וסופן בתחלתן (הדף אינו קיים)\">נעוץ תחלתן בסופן וסופן בתחלתן</a>, אל אחד בראם, ולכוונה אחת לגלות <a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a> <a href=\"/index.php/%D7%A7%D7%93%D7%95%D7%A9\" class=\"mw-redirect mw-disambig\" title=\"קדוש\">קדושת</a> חביון עוזו יתברך נבראו, ושניהם כאחד דוקא משלימים אותה השלימות, אשר עלה ברצונו יתברך - חכמת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a>.</dd></dl>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414111800\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.030 seconds\nReal time usage: 0.076 seconds\nPreprocessor visited node count: 89/1000000\nPost‐expand include size: 6245/2097152 bytes\nTemplate argument size: 495/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   17.556      1 -total\n 53.10%    9.322      1 תבנית:להיום_יום\n 46.13%    8.098      1 תבנית:חודש_כסלו\n 30.85%    5.416      1 תבנית:לוח_שנה\n 27.81%    4.883      1 תבנית:היום_יום/ז&#039;_כסלו\n 13.35%    2.344      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19814-0!canonical and timestamp 20260414111800 and revision id 479507. Rendering was triggered because: api-parse\n -->\n</div>"
