d>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ז בניסן\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ח בניסן\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ט בניסן\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"ל&#39; בניסן\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>א' בניסן</b> הוא היום הראשון ו<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח - מצוות <a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9_%D7%94%D7%97%D7%95%D7%93%D7%A9\" title=\"קידוש החודש\">קידוש החודש</a>, ה<a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%95%D7%94\" title=\"מצווה\">מצווה</a> הראשונה שניתנה ל<a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">עם ישראל</a>, נאמרה ל<a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%99%D7%A0%D7%95\" title=\"משה רבינו\">משה רבינו</a> ול<a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%94%D7%9B%D7%94%D7%9F\" title=\"אהרן הכהן\">אהרן הכהן</a>.</li>\n<li>ב'תמ\"ט - הקמת ה<a href=\"/index.php/%D7%9E%D7%A9%D7%9B%D7%9F\" class=\"mw-redirect\" title=\"משכן\">משכן</a> במדבר סיני על ידי משה רבינו מפי ה'. מיום זה החלו שנים עשר ימי חנוכת המזבח על ידי נשיאי העם.</li>\n<li>ב'תמ\"ט - <a href=\"/index.php/%D7%A0%D7%97%D7%A9%D7%95%D7%9F_%D7%91%D7%9F_%D7%A2%D7%9E%D7%99%D7%A0%D7%93%D7%91\" title=\"נחשון בן עמינדב\">נחשון בן עמינדב</a>, <a href=\"/index.php/%D7%A0%D7%A9%D7%99%D7%90\" title=\"נשיא\">נשיא</a> <a href=\"/index.php/%D7%A9%D7%91%D7%98_%D7%99%D7%94%D7%95%D7%93%D7%94\" class=\"mw-redirect\" title=\"שבט יהודה\">שבט יהודה</a>, הקריב קרבן לחנוכת המשכן.</li>\n<li>ב'תמ\"ט - <a href=\"/index.php/%D7%A0%D7%93%D7%91_%D7%95%D7%90%D7%91%D7%99%D7%94%D7%95%D7%90\" title=\"נדב ואביהוא\">נדב ואביהוא</a>, בני <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%94%D7%9B%D7%94%D7%9F\" title=\"אהרן הכהן\">אהרן הכהן</a>, נפטרו.</li>\n<li>ג'שמ\"ו - <a href=\"/index.php/%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C\" class=\"mw-redirect\" title=\"יחזקאל\">יחזקאל</a> התנבא על נפילת <a href=\"/index.php/%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"מצרים\">מצרים</a> בידי נבוכדנצר.</li>\n<li>ג'תי\"ב - התחילו שבעת ימי המילואים בחנוכת בית שני.</li>\n<li>ג'תי\"ג - <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%90\" class=\"mw-redirect\" title=\"עזרא\">עזרא</a> וסייעתו מתחילים את מסעם מ<a href=\"/index.php/%D7%91%D7%91%D7%9C\" title=\"בבל\">בבל</a> ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a>.</li>\n<li>ג'תכ\"ו - <a href=\"/index.php?title=%D7%A0%D7%97%D7%9E%D7%99%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"נחמיה (הדף אינו קיים)\">נחמיה</a> ביקש רשות מארתחששתא לעלות ולבנות את חרבות <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%95\" title=\"תקס&quot;ו\">תקס\"ו</a> - רבי שמואל קלין, מחבר הספר 'מחצית השקל', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A2\" title=\"תר&quot;ע\">תר\"ע</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%91%D7%A8%D7%95%D7%95%D7%9E%D7%9F\" title=\"דוד ברוומן\">דוד ברוומן</a>, מנהל סניף <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a> באירופה, ויו\"ר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ועד כפר חב&quot;ד\">ועד כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> – הרב <a href=\"/index.php/%D7%A0%D7%AA%D7%9F_%D7%95%D7%95%D7%9C%D7%A3\" title=\"נתן וולף\">נתן וולף</a>, מנהל ומשפיע ישיבת <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"בית הר&quot;מ\">בית הר\"מ</a> ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> – הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%96%D7%95%D7%A9%D7%90_%D7%96%D7%99%D7%A1%D7%A7%D7%99%D7%A0%D7%93\" title=\"אברהם זושא זיסקינד\">אברהם זושא זיסקינד</a>, ראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D_%D7%A9%D7%A2%D7%9C_%D7%99%D7%93%D7%99_%D7%9E%D7%96%D7%9B%D7%99%D7%A8%D7%95%D7%AA_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"כולל אברכים שעל ידי מזכירות הרבי\">כולל אברכים שעל ידי מזכירות הרבי</a> מאת הקמתו בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> עד לפטירתו הפתאומית.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"יוסף סלומון (כפר חב&quot;ד)\">יוסף סלומון</a> מוותיקי אנ\"ש בכפר חב\"ד, בעל שמועה ובעל תפילה חב\"די ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%91%D7%99%D7%AA_%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"בית הכנסת בית נחום יצחק (כפר חב&quot;ד)\">בית הכנסת בית נחום יצחק</a>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/beis-medrash/776766/\">מכון הלכה חב\"ד: קיצור דיני ר\"ח ניסן שחל בשבת פרשת החודש</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - א' בניסן - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i><a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a>. כל החדש אין אומרים <a href=\"/index.php/%D7%AA%D7%97%D7%A0%D7%95%D7%9F\" title=\"תחנון\">תחנון</a>. אחר אמירת ה'נשיא' אומרים \"יהי רצון\" הנדפס ב<a href=\"/index.php/%D7%A1%D7%99%D7%93%D7%95%D7%A8_%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" title=\"סידור תורה אור\">סידור תורה אור</a>, וגם כהנים ולוים אומרים אותו.</i>\n<p><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> ציוה לגיסו <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F_(%D7%97%D7%AA%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9)\" class=\"mw-redirect\" title=\"משה הורנשטיין (חתן אדמו&quot;ר המהר&quot;ש)\">הרמ\"ה</a> הכהן לאמר ה\"יהי רצון\" שאחר ה'נשיא', ואמר לו כי אפילו כהן ולוי צריך לאמרו, כי זה שייך לעיבור.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413131252\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.029 seconds\nReal time usage: 0.041 seconds\nPreprocessor visited node count: 113/1000000\nPost‐expand include size: 5451/2097152 bytes\nTemplate argument size: 493/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   15.117      1 -total\n 50.72%    7.668      1 תבנית:חודש_ניסן\n 34.57%    5.226      1 תבנית:לוח_שנה\n 32.76%    4.952      1 תבנית:להיום_יום\n 14.98%    2.264      1 תבנית:היום_יום/א&#039;_ניסן\n 14.88%    2.250      1 תבנית:כתב_קטן\n 14.74%    2.228      1 תבנית:אינפו\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:21246-0!canonical and timestamp 20260413131252 and revision id 835098. Rendering was triggered because: page-view\n -->\n</div>"
