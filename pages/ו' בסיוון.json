%95%D7%9F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ו&#39; בסיוון</b> הוא היום השישי\nבחודש התשיעי<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;ובו חל <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a>.\n</p><p>תאריך זה חל בתקופת ניסן&#160;והוא יכול לחול בימים&#160;ראשון, שני, רביעי ושישי.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח – <a href=\"/index.php/%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%A8_%D7%A1%D7%99%D7%A0%D7%99\" class=\"mw-redirect\" title=\"מעמד הר סיני\">ה' ירד על הר סיני</a> לעיני כל <a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">עם ישראל</a> ונתן <a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%AA_%D7%94%D7%93%D7%91%D7%A8%D7%95%D7%AA\" title=\"עשרת הדברות\">עשרת הדברות</a> ו<a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%9E%D7%A9%D7%A4%D7%98%D7%99%D7%9D\" title=\"פרשת משפטים\">פרשת משפטים</a> על ידי <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%99%D7%A0%D7%95\" title=\"משה רבינו\">משה רבינו</a>. את שני הדיברות הראשונים שמע העם מאלוקים בעצמו.</li>\n<li>ד'תתנ\"ו – מסע הצלב הראשון בו נרצחה קהילת יהודי מגנצא.</li>\n<li><a href=\"/index.php/%D7%AA%22%D7%A9\" title=\"ת&quot;ש\">ת\"ש</a> – רבי אברהם שלום הלברשטם, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php/%D7%A1%D7%98%D7%A8%D7%95%D7%A4%D7%A7%D7%95%D7%91\" class=\"mw-redirect\" title=\"סטרופקוב\">סטרופקוב</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> – רבי יהודה סגל רוזנר מסקלהיד, מחבר ספר 'אמרי יהודה', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> – רבי אברהם מרדכי אלתר, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php/%D7%92%D7%95%D7%A8\" class=\"mw-redirect\" title=\"גור\">גור</a> ומחבר ספר 'אמרי אמת', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a> – <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> הכריז על הקמת <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%9C%D7%94%D7%9B%D7%A0%D7%AA_%D7%93%D7%A8%D7%95%D7%A9%D7%99_%D7%93%D7%90%22%D7%97_%D7%9C%D7%93%D7%A4%D7%95%D7%A1\" title=\"מכון להכנת דרושי דא&quot;ח לדפוס\">מכון להכנת דרושי דא\"ח לדפוס</a>, תחת <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> – הרבי יצא לראשונה מחדרו, מאז <a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%93%D7%A8_%D7%90%27\" class=\"mw-redirect\" title=\"כ&quot;ז באדר א&#39;\">כ\"ז באדר א'</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a>, אל החוזרים מ<a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%95%D7%9B%D7%94\" title=\"תהלוכה\">תהלוכה</a> ברחובות <a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ניו יורק\">ניו יורק</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>? – ר' <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%9C%D7%9E%D7%93\" class=\"mw-redirect\" title=\"שמואל יחיאל מלמד\">שמואל יחיאל מלמד</a>, נגיד חסידי מעסקני חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%98\" title=\"תשכ&quot;ט\">תשכ\"ט</a> – הרב <a href=\"/index.php/%D7%90%D7%A1%D7%99_%D7%A9%D7%A4%D7%99%D7%92%D7%9C\" title=\"אסי שפיגל\">אסי שפיגל</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><b><a href=\"/index.php/%D7%AA%D7%A7%22%D7%9B\" title=\"תק&quot;כ\">תק\"כ</a> – <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a> הסתלק ביום טוב ראשון של <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a>, ומנוחתו כבוד ב<a href=\"/index.php/%D7%9E%D7%96%27%D7%99%D7%91%D7%95%D7%96%27\" title=\"מז&#39;יבוז&#39;\">מז'יבוז'</a></b>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%92\" title=\"תרמ&quot;ג\">תרמ\"ג</a> – הרב יהודה לייב רסקין, מחסידי חב\"ד ב<a href=\"/index.php/%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%91%D7%A0%D7%90\" class=\"mw-redirect\" title=\"דוברובנא\">דוברובנא</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%97\" class=\"mw-redirect\" title=\"תרצ&quot;ח\">תרח\"צ</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%95%D7%99%D7%9F\" title=\"חיים אברהם דובער לוין\">חיים אברהם דובער לוין</a>, מחסידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> ומייסד פלג '<a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%99%D7%9D_(%D7%A7%D7%94%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA)\" title=\"מלאכים (קהילה חסידית)\">המלאכים</a>' שפרש מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"חסידות חב&quot;ד ליובאוויטש\">חסידות חב\"ד ליובאוויטש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a> – הרב <a href=\"/index.php/%D7%92%D7%A8%D7%A9%D7%95%D7%9F_%D7%97%D7%9F\" title=\"גרשון חן\">גרשון חן</a> רב שיכון חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> וחבר בית הדין הרבני ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>.</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ו' בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>א' ד<a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a></i>. בשעת קריאת עשרת הדברות עומדים ופניהם אל הספר תורה, אין אומרים אקדמות.<i></i>\n<p><a href=\"/index.php/%D7%94%D7%A1%D7%AA%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הסתלקות\">הסתלקות</a> ה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a> - ביום הרביעי א דחג השבועות <a href=\"/index.php/%D7%AA%D7%A7%22%D7%9B\" title=\"תק&quot;כ\">תק\"כ</a> ומנוחתו כבוד ב<a href=\"/index.php/%D7%9E%D7%96%27%D7%99%D7%91%D7%95%D7%96%27\" title=\"מז&#39;יבוז&#39;\">מז'יבוז'</a>. <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> אמר על זה - יום ד' כ' ב<a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> <a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%98\" title=\"תקנ&quot;ט\">תקנ\"ט</a> ב<a href=\"/index.php/%D7%A4%D7%98%D7%A8%D7%91%D7%95%D7%A8%D7%92\" title=\"פטרבורג\">פטרבורג</a> - ביום הרביעי נטלו המאורות. \n</p>\n<div style=\"clear: right; float: right;\"><b><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D/%D7%94%27_%D7%A1%D7%99%D7%95%D7%9F\" title=\"תבנית:היום יום/ה&#39; סיון\">ליום הקודם</a></b></div>\n<div style=\"clear: left; float: left;\"><b><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D/%D7%96%27_%D7%A1%D7%99%D7%95%D7%9F\" title=\"תבנית:היום יום/ז&#39; סיון\">ליום הבא</a></b></div>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השלישי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414090406\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.118 seconds\nReal time usage: 1.720 seconds\nPreprocessor visited node count: 436/1000000\nPost‐expand include size: 9226/2097152 bytes\nTemplate argument size: 787/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 471/5000000 bytes\nLua time usage: 0.080/7 seconds\nLua virtual size: 6160384/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00% 1430.332      1 -total\n 95.21% 1361.829      1 תבנית:פתיח_יום\n 27.43%  392.299      5 תבנית:מילה_אחרונה\n 16.89%  241.653      1 תבנית:הערה\n  7.98%