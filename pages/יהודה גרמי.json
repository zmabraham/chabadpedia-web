_%D7%92%D7%A8%D7%90%D7%9E%D7%99_%D7%91%D7%A1%D7%A4%D7%A8%D7%99%D7%99%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9.jpg/500px-%D7%94%D7%A8%D7%91_%D7%92%D7%A8%D7%90%D7%9E%D7%99_%D7%91%D7%A1%D7%A4%D7%A8%D7%99%D7%99%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9.jpg 2x\" /></a><figcaption>הרב יהודה גראמי מבקר בתערוכה של <a href=\"/index.php/%D7%A1%D7%A4%D7%A8%D7%99%D7%99%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"ספריית ליובאוויטש\">ספריית ליובאוויטש</a>, בקומה השלישית של <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a></figcaption></figure>\n<p>הרב <b>יהודה גראמי</b> הינו הרב הראשי ל<a href=\"/index.php/%D7%90%D7%99%D7%A8%D7%90%D7%9F\" title=\"איראן\">איראן</a> וחבר ארגון '<a href=\"/index.php/%D7%90%D7%99%D7%97%D7%95%D7%93_%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%9D_%D7%91%D7%9E%D7%93%D7%99%D7%A0%D7%95%D7%AA_%D7%94%D7%90%D7%99%D7%A1%D7%9C%D7%90%D7%9D\" title=\"איחוד הרבנים במדינות האיסלאם\">איחוד הרבנים במדינות האיסלאם</a>'.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%A8%D7%9E%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%A8%D7%9E%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%93%22%D7%9E\" title=\"תשד&quot;מ\">תשד\"מ</a> בטהראן מספר שנים לאחר המהפכה האיסלאמית, למשפחה שומרת מצוות בעלת שורשים עתיקים בפרס. אביו ד\"ר שלמה גראמי שימש כרופא מנתח במספר מרכזים רפואיים בטהראן ביניהם המרכז הרפואי היהודי 'ספיר'.\n</p><p>בילדותו למד בבית ספר מקומי והשתתף בתלמוד תורה שהתקיים מחוץ לשעות הלימודים.\n</p><p>בגיל 15 הגיע ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a> דרך טורקיה, ולמד במשך שנה בישיבת 'עטרת ישראל' ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.\n</p><p>לאחר מכן עבר לישיבת נר ישראל ב<a href=\"/index.php/%D7%91%D7%95%D7%9C%D7%98%D7%99%D7%9E%D7%95%D7%A8\" title=\"בולטימור\">בולטימור</a> שבמרילנד, שם למד במשך מספר שנים, במהלכם קיבל <a href=\"/index.php/%D7%A1%D7%9E%D7%99%D7%9B%D7%94_%D7%9C%D7%A8%D7%91%D7%A0%D7%95%D7%AA\" title=\"סמיכה לרבנות\">סמיכה לרבנות</a>.\n</p><p>בגיל 25 חזר לאיראן ונישא לציפורה, ילידת איראן גם היא.\n</p><p>לאחר חתונתו החל למסור שיעורי תורה, החל להתעסק בענייני כשרות, בתי דין ומקוואות.\n</p><p>הרב גראמי מונה על ידי הקהילה היהודית באיראן לשמש כרב הראשי, מינוי בו מכיר גם המשטר האיראני.\n</p>\n<h2><span id=\".D7.94.D7.A7.D7.A9.D7.A8_.D7.A2.D7.9D_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"הקשר_עם_חב&quot;ד\">הקשר עם <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%A8%D7%9E%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;הקשר עם חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%A8%D7%9E%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: הקשר עם חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בשנים <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> ו<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a> הגיע הרב גראמי ל-770 לרגל <a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1_%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"כינוס השלוחים העולמי\">כינוס השלוחים העולמי</a> כאורח כבוד של ה<a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9C%D7%A2%D7%A0%D7%99%D7%A0%D7%99_%D7%97%D7%99%D7%A0%D7%95%D7%9A\" title=\"מרכז לעניני חינוך\">מרכז לעניני חינוך</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>. בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> הוא קיבל את ספר ה'דבר מלכות - חידושים וביאורים בהלכות מלכים לרמב\"ם'<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. . הוא גם חבר באיחוד הרבנים במדינות האסאלם שנוסד על ידי שליח הרבי <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"מנחם מענדל חיטריק\">מנחם מענדל חיטריק</a> ומנהל קשרים ענפים ומיוחדים עם חברי האיחוד. כמו כן, במסעותיו שהתקיימו ביקר במוסדות אותם מנהלים שלוחי הרבי הקשורים ביהודי איראן בפרט וביהדות המזרח בכלל.\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%A8%D7%9E%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%A8%D7%9E%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/tag/%d7%94%d7%a8%d7%91-%d7%99%d7%94%d7%95%d7%93%d7%94-%d7%92%d7%a8%d7%90%d7%9e%d7%99/\">תגית: הרב יהודה גראמי</a></b> באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/seven-seventy/858244/\">ביקור מרגש: רבה של איראן ביקר במרכז חב\"ד העולמי - 770</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/crown_heights/731081/\">ספר ה'דבר מלכות' הוענק לרב הראשי לאיראן</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413173846\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.054 seconds\nReal time usage: 0.113 seconds\nPreprocessor visited node count: 114/1000000\nPost‐expand include size: 583/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 2073/5000000 bytes\nLua time usage: 0.030/7 seconds\nLua virtual size: 5480448/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   92.273      1 -total\n 76.51%   70.595      2 תבנית:הערה\n 23.06%   21.275      1 תבנית:הערות_שוליים\n  2.54%    2.344      3 תבנית:אינפו\n  2.19%    2.025      1 תבנית:הערות_שוליים/מרחב_שם\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:66361-0!canonical and timestamp 20260413173846 and revision id 758197. Rendering was triggered because: diff-page\n -->\n</div>"
