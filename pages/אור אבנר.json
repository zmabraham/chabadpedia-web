      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/df/%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8.jpg/220px-%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8.jpg\" decoding=\"async\" width=\"220\" height=\"121\" class=\"mw-file-element\" srcset=\"/images/thumb/d/df/%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8.jpg/330px-%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8.jpg 1.5x, /images/thumb/d/df/%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8.jpg/440px-%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8.jpg 2x\" /></a><figcaption>בית הספר אור אבנר בדנייפרופטרובסק שבאוקראינה</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%90%D7%A8%D7%99%D7%A0%D7%90_%D7%A8%D7%95%D7%A9%D7%90_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/94/%D7%9E%D7%90%D7%A8%D7%99%D7%A0%D7%90_%D7%A8%D7%95%D7%A9%D7%90_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94.jpg/220px-%D7%9E%D7%90%D7%A8%D7%99%D7%A0%D7%90_%D7%A8%D7%95%D7%A9%D7%90_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94.jpg\" decoding=\"async\" width=\"220\" height=\"259\" class=\"mw-file-element\" srcset=\"/images/thumb/9/94/%D7%9E%D7%90%D7%A8%D7%99%D7%A0%D7%90_%D7%A8%D7%95%D7%A9%D7%90_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94.jpg/330px-%D7%9E%D7%90%D7%A8%D7%99%D7%A0%D7%90_%D7%A8%D7%95%D7%A9%D7%90_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94.jpg 1.5x, /images/9/94/%D7%9E%D7%90%D7%A8%D7%99%D7%A0%D7%90_%D7%A8%D7%95%D7%A9%D7%90_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94.jpg 2x\" /></a><figcaption>המרכז הקהילתי <a href=\"/index.php/%D7%9E%D7%90%D7%A8%D7%99%D7%A0%D7%94_%D7%A8%D7%95%D7%A9%D7%A6%27%D7%94\" class=\"mw-redirect\" title=\"מארינה רושצ&#39;ה\">מארינה רושצ'ה</a> נבנה בתקופת אור אבנר</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A7%D7%95%D7%91.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/8f/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A7%D7%95%D7%91.jpg/250px-%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A7%D7%95%D7%91.jpg\" decoding=\"async\" width=\"250\" height=\"166\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8f/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A7%D7%95%D7%91.jpg/375px-%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A7%D7%95%D7%91.jpg 1.5x, /images/thumb/8/8f/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A7%D7%95%D7%91.jpg/500px-%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A7%D7%95%D7%91.jpg 2x\" /></a><figcaption>בית כנסת חב\"ד בחרקוב</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94_%D7%91%D7%9C%D7%99%D7%9C%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f3/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94_%D7%91%D7%9C%D7%99%D7%9C%D7%94.jpg/250px-%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94_%D7%91%D7%9C%D7%99%D7%9C%D7%94.jpg\" decoding=\"async\" width=\"250\" height=\"161\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f3/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94_%D7%91%D7%9C%D7%99%D7%9C%D7%94.jpg/375px-%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94_%D7%91%D7%9C%D7%99%D7%9C%D7%94.jpg 1.5x, /images/thumb/f/f3/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94_%D7%91%D7%9C%D7%99%D7%9C%D7%94.jpg/500px-%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94_%D7%91%D7%9C%D7%99%D7%9C%D7%94.jpg 2x\" /></a><figcaption><a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9E%D7%A0%D7%95%D7%A8%D7%94\" title=\"מרכז מנורה\">מרכז מנורה</a> - המרכז היהודי הגדול בעולם השוכן בעיר <a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8%D7%95%D7%A4%D7%98%D7%A8%D7%95%D7%91%D7%A1%D7%A7\" class=\"mw-redirect\" title=\"דנייפרופטרובסק\">דנייפרופטרובסק</a></figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/9a/%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg/250px-%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg\" decoding=\"async\" width=\"250\" height=\"185\" class=\"mw-file-element\" srcset=\"/images/thumb/9/9a/%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg/375px-%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg 1.5x, /images/thumb/9/9a/%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg/500px-%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg 2x\" /></a><figcaption><a href=\"/index.php/%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"לב לבייב\">לב לבייב</a> יו\"ר אור אבנר, עם מורו ורבו הרב <a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"אבא דוד גורביץ\">אבא דוד גורביץ</a> שליח ורב הראשי של אוזבקיסטן, ונשיא אוזבקיסטן איסלם קרימוב</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A1%D7%95%D7%9F_%D7%9B%D7%99%D7%95%D7%9D.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/5a/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A1%D7%95%D7%9F_%D7%9B%D7%99%D7%95%D7%9D.jpg/250px-%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A1%D7%95%D7%9F_%D7%9B%D7%99%D7%95%D7%9D.jpg\" decoding=\"async\" width=\"250\" height=\"250\" class=\"mw-file-element\" srcset=\"/images/thumb/5/5a/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A1%D7%95%D7%9F_%D7%9B%D7%99%D7%95%D7%9D.jpg/375px-%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A1%D7%95%D7%9F_%D7%9B%D7%99%D7%95%D7%9D.jpg 1.5x, /images/5/5a/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%D7%93_%D7%91%D7%97%D7%A8%D7%A1%D7%95%D7%9F_%D7%9B%D7%99%D7%95%D7%9D.jpg 2x\" /></a><figcaption>בית כנסת חב\"ד בחרסון כיום</figcaption></figure>\n<p>קרן <b>אור אבנר וחנה</b> הינו ארגון פילנטרופי שנוסד על ידי הנגיד ר' <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%9C%D7%91%D7%99%D7%99%D7%91\" title=\"לוי לבייב\">לוי לבייב</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> בתיאום עם <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9C%D7%A2%D7%A0%D7%99%D7%A0%D7%99_%D7%97%D7%99%D7%A0%D7%95%D7%9A\" title=\"מרכז לעניני חינוך\">מרכז לעניני חינוך</a>, במטרה להחליף את ארגון <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%AA_%D7%90%D7%97%D7%99%D7%9D\" class=\"mw-redirect\" title=\"עזרת אחים\">עזרת אחים</a>, בארגון פעילות <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">השלוחים</a> במדינות <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> לשעבר.\n</p><p>קרן 'אור אבנר - חבר העמים' מנוהלת על ידי שלוחי הרבי: המנכ\"ל הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9E%D7%95%D7%A0%D7%93%D7%A9%D7%99%D7%99%D7%9F\" title=\"דוד מונדשיין\">דוד מונדשיין</a> ופועלת תחת הנחייתו של הרב הראשי ל<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a> <a href=\"/index.php/%D7%91%D7%A2%D7%A8%D7%9C_%D7%9C%D7%90%D7%96%D7%90%D7%A8\" title=\"בערל לאזאר\">בערל לאזאר</a>. הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%91%D7%9C%D7%95%D7%99\" class=\"mw-redirect\" title=\"יוסף בלוי\">יוסף בלוי</a> פעל רבות לתקציבים מצד משרד החינוך הישראלי עבור בתי ספר המנוהלים על ידי שלוחי הרבי.\n</p><p>קרן אור אבנר ניהלה את רוב מערך השליחות בחבר העמים מאמצע שנות הנ' ובמשך כעשרים שנה, וכיום הארגון כמעט ואינו פעיל. חלק מהמוסדות שהוקמו בשנות הפעילות נקראים אור אבנר.\n</p><p>'אור אבנר - ישראל' מנוהלת על ידי הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%91%D7%9C%D7%95%D7%99\" title=\"ברוך יהודה בלוי\">יהודה בלוי</a>.\nהקרן קרויה על שם הוריו של לבייב, ר' אבנר וחנה לבייב.\n</p><p>אור אבנר בארצות הברית פועלת באימפריית מוסדות ברובע קווינס שבניו יורק ובניהול השלוחים הרב זלמן זבולונוב והרב לוי יצחק וולוביק.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.95.D7.A8_.D7.90.D7.91.D7.A0.D7.A8_.D7.91.D7.97.D7.91.D7.A8_.D7.94.D7.A2.D7.9E.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אור_אבנר_בחבר_העמים\">אור אבנר בחבר העמים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אור אבנר בחבר העמים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אור אבנר בחבר העמים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.94.D7.99.D7.A1.D7.98.D7.95.D7.A8.D7.99.D7.94\"></span><span class=\"mw-headline\" id=\"היסטוריה\">היסטוריה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;היסטוריה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: היסטוריה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>קרן אור אבנר בחבר העמים עובדת בשיתוף פעולה עם כמה גופים מרכזים, ביניהם <a href=\"/index.php?title=%D7%90%D7%99%D7%92%D7%95%D7%93_%D7%94%D7%A7%D7%94%D7%99%D7%9C%D7%95%D7%AA_%D7%94%D7%99%D7%94%D7%95%D7%93%D7%99%D7%95%D7%AA_%D7%91%D7%97%D7%91%D7%A8_%D7%94%D7%A2%D7%9E%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"איגוד הקהילות היהודיות בחבר העמים (הדף אינו קיים)\">איגוד הקהילות היהודיות בחבר העמים</a>, וקרן משפחת רוהר, בראשות ר' <a href=\"/index.php/%D7%92%27%D7%95%D7%A8%D7%92%27_%D7%A8%D7%95%D7%94%D7%A8\" class=\"mw-redirect\" title=\"ג&#39;ורג&#39; רוהר\">ג'ורג' רוהר</a>. קרן זו נחשבה תומכת מרכזית בשלוחי הרבי ובחיים היהודיים בברית-המועצות לשעבר.\n</p><p>בערים באזורים שהיוו את ברית המועצות ישנם <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליחוקהילה</a> של חב\"ד. בחסות איגוד הקהילות היהודיות בחבר העמים פועלים גני ילדים של אור אבנר, בתי ספר יסודיים, בתי ספר תיכוניים וכן מוסדות להשכלה גבוהה וישיבות. מספר הלומדים במוסדות אלו הגיע לאלפים.\n</p><p>המשרד הראשי של אור אבנר בחבר העמים ממוקם בעיר <a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>. \n</p><p>בנוסף לפעילות השוטפת היו שנים בהן בתקופת החגים וב<a href=\"/index.php/%D7%A4%D7%A1%D7%97\" title=\"פסח\">פסח</a> מאות בחורי ישיבה מישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> בארץ ישראל וב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a> הגיעו לחזק את הקהילות היהודיות שבהן אין שליח באופן קבוע ועורכים בהן תפילות וסדרים ציבורים. \n</p><p>גם בתקופת המשבר הכלכלי העולמי בשנים תשס\"ח- תשס\"ט, המשיכה קרן אור אבנר בראשות ר' לוי לבייב לתרום לשלוחים במדינות חבר העמים, אם כי התרומות צומצמו וכיום כל שליח דואג לתרומות בכח עצמו.\n</p><p>בתמוז <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> נערך כינוס השלוחים של חבר העמים, ובשונה מתמיד הוא לא אורגן תחת שם 'אור אבנר' אלא הארגון התאום, איגוד הקהילות היהודיות בחבר העמים.\n</p>\n<h2><span id=\".D7.A9.D7.9C.D7.95.D7.97.D7.99.D7.9D_.D7.91.D7.90.D7.A8.D7.92.D7.95.D7.9F_.D7.90.D7.95.D7.A8_.D7.90.D7.91.D7.A0.D7.A8\"></span><span class=\"mw-headline\" id=\"שלוחים_בארגון_אור_אבנר\">שלוחים בארגון אור אבנר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;שלוחים בארגון אור אבנר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: שלוחים בארגון אור אבנר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>שלוחי הרבי בארגון אור אבנר:\n</p>\n<ul><li>הרב <a href=\"/index.php/%D7%91%D7%A2%D7%A8%D7%9C_%D7%9C%D7%90%D7%96%D7%90%D7%A8\" title=\"בערל לאזאר\">בערל לאזאר</a> - <a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>, <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%91%D7%96%D7%A0%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מענדל פבזנר (הדף אינו קיים)\">מענדל פבזנר</a> - <a href=\"/index.php/%D7%A4%D7%98%D7%A8%D7%91%D7%95%D7%A8%D7%92\" title=\"פטרבורג\">פטרבורג</a>, <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a></li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%9E%D7%95%D7%A1%D7%A7%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"משה מוסקוביץ\">משה מוסקוביץ</a> - <a href=\"/index.php/%D7%97%D7%A8%D7%A7%D7%95%D7%91\" title=\"חרקוב\">חרקוב</a>, <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a></li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%95%D7%95%D7%9C%D7%A3\" title=\"אברהם וולף\">אברהם וולף</a> - <a href=\"/index.php/%D7%97%D7%A8%D7%A7%D7%95%D7%91\" title=\"חרקוב\">חרקוב</a>, <a href=\"/index.php/%D7%90%D7%95%D7%93%D7%A1%D7%94\" title=\"אודסה\">אודסה</a>, <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%99_%D7%95%D7%95%D7%9C%D7%A3&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יוסי וולף (הדף אינו קיים)\">יוסי וולף</a> - <a href=\"/index.php/%D7%97%D7%A8%D7%A1%D7%95%D7%9F\" title=\"חרסון\">חרסון</a>, <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a></li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%95%D7%99%D7%9C%D7%94%D7%9C%D7%9D\" title=\"שלמה וילהלם\">שלמה וילהלם</a> - <a href=\"/index.php/%D7%96%27%D7%99%D7%98%D7%95%D7%9E%D7%99%D7%A8\" title=\"ז&#39;יטומיר\">ז'יטומיר</a>, <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a></li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"שמואל קמינצקי\">שמואל קמינצקי</a> - <a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8%D7%95%D7%A4%D7%98%D7%A8%D7%95%D7%91%D7%A1%D7%A7\" class=\"mw-redirect\" title=\"דנייפרופטרובסק\">דנייפרופטרובסק</a>, <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a></li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"אבא דוד גורביץ\">אבא דוד גורביץ</a> - <a href=\"/index.php/%D7%98%D7%A9%D7%A7%D7%A0%D7%98\" title=\"טשקנט\">טשקנט</a>, <a href=\"/index.php/%D7%90%D7%95%D7%96%D7%91%D7%A7%D7%99%D7%A1%D7%98%D7%9F\" title=\"אוזבקיסטן\">אוזבקיסטן</a></li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%99%D7%99%D7%A2_%D7%9B%D7%94%D7%9F\" class=\"mw-redirect\" title=\"שייע כהן\">שייע כהן</a> - <a href=\"/index.php/%D7%90%D7%9C%D7%9E%D7%90_%D7%90%D7%98%D7%90\" title=\"אלמא אטא\">אלמא אטא</a>, <a href=\"/index.php/%D7%A7%D7%96%D7%97%D7%A1%D7%98%D7%9F\" title=\"קזחסטן\">קזחסטן</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%A8%D7%95%D7%96%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יוסף גרוזמן (הדף אינו קיים)\">יוסף גרוזמן</a> - <a href=\"/index.php/%D7%9E%D7%99%D7%A0%D7%A1%D7%A7\" title=\"מינסק\">מינסק</a>, <a href=\"/index.php/%D7%91%D7%9C%D7%90%D7%A8%D7%95%D7%A1\" title=\"בלארוס\">בלארוס</a></li></ul>\n<h3><span id=\".D7.9B.D7.99.D7.95.D7.9D\"></span><span class=\"mw-headline\" id=\"כיום\">כיום</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;כיום&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: כיום\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>קרן אור אבנר ניהלה את רוב מערך השליחות בחבר העמים מאמצע שנות הנ' ובמשך כעשרים שנה. \n</p><p>חלק מהמוסדות שהוקמו בשנות הפעילות נקראים אור אבנר.\n</p><p>השלוחים ברוסיה וביילורוס עובדים בתיאום עם הרב בערל לאזאר, השלוחים באוקראינה פועלים כל אחד באופן עצמאי. במולדביה תחת עזרת אחים. \n</p><p>לב לבייב מתארח מספר פעמים בשנה באירועי חב\"ד מוסקבה.\n</p>\n<h2><span id=\".D7.90.D7.95.D7.A8_.D7.90.D7.91.D7.A0.D7.A8_.D7.91.D7.99.D7.A9.D7.A8.D7.90.D7.9C\"></span><span class=\"mw-headline\" id=\"אור_אבנר_בישראל\">אור אבנר בישראל</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;אור אבנר בישראל&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: אור אבנר בישראל\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>רשת החינוך <b>אור אבנר וחנה</b> הוקמה בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a> - במטרה לחזק ולבסס את המורשת היהודית והזיקה לתורה, לעם ולארץ בעיקר בקרב עולי חבר העמים, וכן לרומם את מעמדם הרוחני, הכלכלי והחברתי של בני הקהילה הבוכרית בישראל.\n</p><p>רשת החינוך התמחתה והפכה להיות מובילה בפעילות חינוכית איכותית לקליטה מוצלחת של תלמידים עולים חדשים. פעילות זו גובתה בתרומות עתק לפיתוח תוכניות לימודים, בהקמת סביבה לימודית איכותית ומשוכללת, בהדרכה והטמעה של תוכניות חברתיות ובליווי מאסיבי של השקעות בתוספת שעות לימודים ובמתן שירותים תומכי חינוך נוספים על מנת לקדם את מוסד החינוך עד להיותו לדוגמה וסמל באזור פעילותו.\n</p><p>במסגרת זו פעלה ופועלת רשת החינוך - בשיתוף עם משרד החינוך והרשויות המקומיות - וסייעה בהצלחה רבה לבתי ספר קולטי עלייה מכל מגזרי החינוך (ממלכתי דתי, מוכרים ובבעלות רשתות חינוך המוכרות) בכל רמות הגיל: גני ילדים, בתי\"ס יסודיים ועי\"ס למשך תקופות קצובות אשר ברובם הוגדרו מראש עד אשר מוסדות חינוך אלו עמדו בכוחות עצמם על הרגליים. \n</p><p>בין בתי הספר הללו ניתן למנות בעיקר בתי ספר הפועלים ברשויות המוכרות כפריפריה חינוכית כקריית מלאכי, אשדוד, לוד, אילת, דרום תל אביב, רמלה, אור יהודה, קריית ים ודימונה.\n</p><p>כיום מפעילה אור אבנר מוסדות חינוך בכל רמות הגיל בערים <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" title=\"אור יהודה\">אור יהודה</a>, <a href=\"/index.php/%D7%A8%D7%9E%D7%9C%D7%94\" title=\"רמלה\">רמלה</a> ו<a href=\"/index.php?title=%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"קריית ים (הדף אינו קיים)\">קריית ים</a>. כמו כן תומכת אור אבנר בתיכון הפנימייתי היוקרתי לבנים - נעל\"ה ובמכון להכשרת רבנים 'אור אבנר - חב\"ד' הפועלים בכפר הנוער <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%A6%D7%91%D7%99_%D7%A1%D7%99%D7%98%D7%A8%D7%99%D7%9F\" title=\"כפר צבי סיטרין\">כפר צבי סיטרין</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> הקימה רשת <b>אור אבנר וחנה</b> גם את פרויקט \"זמן מסע\" שמטרתו העצמת הזהות היהודית בבתי ספר יסודיים ממלכתיים בישראל בכיתות א'-ו'. הפרויקט יושם בלמעלה מ-70 בתי ספר ברחבי ישראל וזכה לתגובות אוהדות בציבור ולתגובות מעורבות בעיתונות, שרת החינוך לשעבר הגב' יולי תמיר שהבהילה אותה ה<a href=\"/index.php/%D7%9E%D7%97%D7%A9%D7%91%D7%94\" title=\"מחשבה\">מחשבה</a> שדווקא תקופתה תיזכר כעידן הפריחה של ארגון זה הכריזה מלחמה על הפרויקט לאחר שכעשרים רשויות מקומיות נוספות ביקשו להצטרף לפרויקט השאפתני.\n</p><p>כך זכה הארגון שלראשונה בתולדות המדינה נאסר בחוזר מנכ\"ל מיוחד על קיום והפעלת תוכנית לימודים ספציפית להעשרה בבתי הספר היסודיים.\n</p><p>רשת החינוך בישראל מנוהלת על ידי המנכ\"ל הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%91%D7%9C%D7%95%D7%99\" title=\"ברוך יהודה בלוי\">יהודה בלוי</a>.\n</p>\n<h2><span id=\".D7.90.D7.95.D7.A8_.D7.90.D7.91.D7.A0.D7.A8_.D7.91.D7.90.D7.A8.D7.A6.D7.95.D7.AA_.D7.94.D7.91.D7.A8.D7.99.D7.AA\"></span><span class=\"mw-headline\" id=\"אור_אבנר_בארצות_הברית\">אור אבנר ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;אור אבנר בארצות הברית&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: אור אבנר בארצות הברית\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a> מפעילה רשת אור אבנר את \"קווינס גמנסיה\" אשר מאחדת סביבה אשכול מוסדות חינוך ברוח חב\"ד בשילוב מסורת עדת בוכרה, אשר פועלים לחינוך מאות רבות של תלמידים אשר למדו בעבר במערכת ה\"פאבליק סקול\" (בתי ספר ממלכתיים לכ יהודים) אשר הרשת פעלה לקליטתם בתוכה על מנת להצילם מהתבוללות.\n</p><p>מערכת חינוך מפוארת זו הוקמה גם היא בתרומתו הנדיבה והמתמשכת של מר לבייב אשר יזם אותה והביא אותה להצלחה מסחררת.\n</p><p>רשת החינוך ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a> מנוהלת על ידי המנכ\"ל הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%96%D7%91%D7%95%D7%9C%D7%95%D7%A0%D7%95%D7%91\" title=\"זלמן זבולונוב\">זלמן זבולונוב</a> יחד עם סגנו הרב <a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%95%D7%91%D7%99%D7%A7&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יצחק וולוביק (הדף אינו קיים)\">יצחק וולוביק</a> שלוחי הרבי לעדה הבוכרית.\n</p>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>אדמו\"ר חב\"ד ויהדות בוכרה</b>, פעילות חמ\"ה בארץ הקודש, עמוד 581.</li>\n<li>מאיר סגל <b>קויינס פינת ופרצת</b> <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a> גיליון 2062 עמוד 88.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;veaction=edit&amp;section=8\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;section=8\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אתר רשת <a rel=\"nofollow\" class=\"external text\" href=\"http://www.oravner.org.il/\">אור אבנר וחנה</a> בישראל.</li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://hebrew.fjc.ru/default.asp\">איגוד הקהילות היהודיות בחבר העמים</a>.</li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://or-avner.net\">אתר בית הספר אור אבנר - קריית ים</a></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/146268\">\"לא שלנו, של הרבי\": ההתוועדות הסוחפת עם הנגיד ר' לוי לבייב</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<!-- \nNewPP limit report\nCached time: 20260413102312\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.042 seconds\nReal time usage: 0.473 seconds\nPreprocessor visited node count: 95/1000000\nPost‐expand include size: 82/2097152 by