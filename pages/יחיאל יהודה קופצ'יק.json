    "pageid": 60185,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7_%D7%A0%D7%95%D7%90%D7%9D.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/97/%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7_%D7%A0%D7%95%D7%90%D7%9D.jpg/250px-%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7_%D7%A0%D7%95%D7%90%D7%9D.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/9/97/%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7_%D7%A0%D7%95%D7%90%D7%9D.jpg/375px-%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7_%D7%A0%D7%95%D7%90%D7%9D.jpg 1.5x, /images/thumb/9/97/%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7_%D7%A0%D7%95%D7%90%D7%9D.jpg/500px-%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7_%D7%A0%D7%95%D7%90%D7%9D.jpg 2x\" /></a><figcaption>הרב קופצייק נואם בזאל ישיבת תומכי תמימים בית שמש</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/7b/%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7.jpg/250px-%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7.jpg\" decoding=\"async\" width=\"250\" height=\"195\" class=\"mw-file-element\" srcset=\"/images/thumb/7/7b/%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7.jpg/375px-%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7.jpg 1.5x, /images/thumb/7/7b/%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7.jpg/500px-%D7%94%D7%A8%D7%91_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7.jpg 2x\" /></a><figcaption>ר' יחיאל קופצ'יק מתוועד בסוכת <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a></figcaption></figure>\n<p>הרב <b>יחיאל יהודה (חיליק) קופצ'יק</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a>, 1982) הוא מנהל תלמוד תורה חב\"ד ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9\" title=\"בית שמש\">בית שמש</a>, משפיע כללי בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים בית שמש (קטנה)\">תומכי תמימים בית שמש</a>, ושליח בשכונת רמה ד2 שבעיר.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> לאביו הרב <a href=\"/index.php/%D7%91%D7%A6%D7%9C%D7%90%D7%9C_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7\" class=\"mw-redirect\" title=\"בצלאל קופצ&#39;יק\">בצלאל קופצ'יק</a> והתחנך ב<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%93%D7%95%D7%AA_%D7%90%D7%95%D7%A8_%D7%9E%D7%A0%D7%97%D7%9D_(%D7%A6%D7%A4%D7%AA)\" title=\"מוסדות אור מנחם (צפת)\">מוסדות חב\"ד המקומיים</a>.\n</p><p>למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים נתניה</a> וב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת\">ישיבת חסידי חב\"ד ליובאוויטש צפת</a>.\n</p><p>לקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> נסע ללמוד ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ישיבת תומכי תמימים המרכזית\">ישיבת תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> נסע לסייע בשליחות אצל הוריו בעיר פונה שב<a href=\"/index.php/%D7%94%D7%95%D7%93%D7%95\" title=\"הודו\">הודו</a> שם נשאר עד לחתונתו בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a>.\n</p><p>התחתן עם רעייתו מרת טובה בתו של הרב <a href=\"/index.php/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F\" title=\"טוביה דורון\">טוביה דורון</a> מ<a href=\"/index.php/%D7%91%D7%AA_%D7%99%D7%9D\" title=\"בת ים\">בת ים</a>.\n</p>\n<h3><span id=\".D7.91.D7.91.D7.99.D7.AA_.D7.A9.D7.9E.D7.A9\"></span><span class=\"mw-headline\" id=\"בבית_שמש\">בבית שמש</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;בבית שמש&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: בבית שמש\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a> נענה לבקשת הנהלת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9_(%D7%AA%D7%A9%D7%A1%22%D7%91-%D7%AA%D7%A9%D7%A2%22%D7%92)\" title=\"תומכי תמימים בית שמש (תשס&quot;ב-תשע&quot;ג)\">תומכי תמימים בית שמש</a> והחל לשמש כמשגיח והתפרסם בעקבות עקשנותו לפתיחת הישיבה מחדש ב<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a>, בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a> מונה גם למשפיע בישיבה, תפקיד בו כיהן עד לסגירתה (בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a>).\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> החל ללמד בתלמוד תורה חב\"ד \"תפארת שמואל\" בעיר וכיום הוא עומד בראשו בתור מנהל התלמוד תורה.\n</p><p>הרב קופצ'יק פעיל גם כ<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> בשכונת יפה נוף בבית שמש ביחד עם הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9E%D7%99%D7%A9%D7%95%D7%9C%D7%95%D7%91%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלום דובער מישולובין (הדף אינו קיים)\">שלום דובער מישולובין</a>, והוא מוסר שיעור תניא שבועי ופעיל מאוד בפעילויות הבית חב\"ד.\n</p><p>לקראת שנת הלימודים תשפ\"ב נענה לבקשת הנהלת ישיבה קטנה <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים בית שמש (קטנה)\">תומכי תמימים בית שמש</a> לשמש כמשפיע כללי של הישיבה<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> עבר לשכונה ד'2 בבית שמש ומשמש שם כשליח.\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/tag/הרב-יחיאל-קופציק/\">ידיעות נוספות על הרב קופצ'יק</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">לאחר שהמשפיע הקודם, הרב קורנוויץ ביקש לסיים את תפקידו</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413173009\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.063 seconds\nReal time usage: 0.349 seconds\nPreprocessor visited node count: 106/1000000\nPost‐expand include size: 366/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 445/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5218304/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  232.798      1 -total\n 74.37%  173.133      1 תבנית:הערה\n 21.18%   49.300      1 תבנית:הערות_שוליים\n  4.28%    9.965      1 תבנית:אינפו\n  3.81%    8.880      1 תבנית:הערות_שוליים/מרחב_