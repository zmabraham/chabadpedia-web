      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"א&#39; באדר\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ב&#39; באדר\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ג&#39; באדר\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ד&#39; באדר\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ו&#39; באדר\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ז&#39; באדר\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ח&#39; באדר\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ט&#39; באדר\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&#39; באדר\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&quot;א באדר\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&quot;ב באדר\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&quot;ג באדר\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&quot;ד באדר\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%90%D7%93%D7%A8\" title=\"ט&quot;ו באדר\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%90%D7%93%D7%A8\" title=\"ט&quot;ז באדר\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&quot;ז באדר\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&quot;ח באדר\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%90%D7%93%D7%A8\" title=\"י&quot;ט באדר\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&#39; באדר\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;א באדר\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ב באדר\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ג באדר\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ד באדר\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ה באדר\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ו באדר\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ז באדר\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ח באדר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ט באדר\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ל&#39; באדר\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ה&#39; באדר</b> הוא היום החמישי\nבחודש השישי<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי.\n</p><p>תאריך זה חל בתקופת טבת\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a> - רבי <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A9%D7%9C%D7%9E%D7%94_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"מרדכי שלמה פרידמן\">מרדכי שלמה פרידמן</a>, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php/%D7%91%D7%95%D7%99%D7%90%D7%9F\" class=\"mw-redirect\" title=\"בויאן\">בויאן</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%95\" title=\"תרצ&quot;ו\">תרצ\"ו</a> - הרב <a href=\"/index.php/%D7%96%D7%95%D7%A9%D7%90_%D7%A4%D7%95%D7%96%D7%A0%D7%A8\" title=\"זושא פוזנר\">זושא פוזנר</a>, מ<a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"שלוחי הרבי לארץ הקודש\">שלוחי הרבי לארץ הקודש</a>, חבר בהנהלת <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect mw-disambig\" title=\"אגודת חסידי חב&quot;ד\">אגודת חסידי חב\"ד</a>, יושב ראש \"<a href=\"/index.php/%D7%95%D7%A2%D7%93%D7%AA_%D7%94%D7%97%D7%99%D7%A0%D7%95%D7%9A_%D7%94%D7%97%D7%91%22%D7%93%D7%99\" title=\"ועדת החינוך החב&quot;די\">ועדת החינוך החב\"די</a>\", <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בקהילת חב\"ד בעיר <a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a> וכן בישיבות תומכי תמימים ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"תומכי תמימים בני ברק\">בני ברק</a>, חולון ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים קריות\">קריית שמואל</a>, ומשפיע <a href=\"/index.php/%D7%97%D7%93%D7%A8_%D7%90%D7%95%D7%A8_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"חדר אור ליובאוויטש\">חדר אור ליובאוויטש</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%94\" title=\"תשכ&quot;ה\">תשכ\"ה</a> - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%9B%D7%A0%D7%90_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"ישראל שכנא דוברוסקין\">ישראל שכנא דוברוסקין</a>, משפיע ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, רב ברבנות תל אביב, מרצה במכללת <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A8%D7%91%D7%A7%D7%94_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"בית רבקה כפר חב&quot;ד\">בית רבקה כפר חב\"ד</a> ומחבר סדרת הספרים 'המאור שבתורה' על מאמרי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"הרבי הצמח צדק\">הרבי הצמח צדק</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> (אדר שני) - הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%94%D7%A7%D7%98%D7%9F)\" title=\"לוי יצחק שניאורסון (הקטן)\">לוי יצחק שניאורסון</a>, בן דודו של <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%91_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" class=\"mw-redirect\" title=\"רבי לוי יצחק שניאורסון (אב אדמו&quot;ר שליט&quot;א)\">רבי לוי יצחק</a> אביו של הרבי, שנפטר ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> באמצע ריצוי עונש גלות על הפצת יהדות.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%93%22%D7%9E\" title=\"תשד&quot;מ\">תשד\"מ</a> (אדר ראשון) - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%94%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"שניאור זלמן אליעזר הורביץ\">שניאור זלמן אליעזר הורביץ</a>, בנו של ר' <a href=\"/index.php/%D7%90%D7%99%D7%A6%27%D7%94_%D7%93%D7%A2%D7%A8_%D7%9E%D7%AA%D7%9E%D7%99%D7%93\" class=\"mw-redirect\" title=\"איצ&#39;ה דער מתמיד\">איצ'ה דער מתמיד</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> ו<a href=\"/index.php/%D7%9E%D7%92%D7%99%D7%93_%D7%A9%D7%99%D7%A2%D7%95%D7%A8\" class=\"mw-redirect\" title=\"מגיד שיעור\">מגיד שיעור</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">ישיבות תומכי תמימים</a> בברית המועצות ובארץ ישראל, ועסקן חסידי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> (אדר ראשון) - הרב <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%99%D7%90%D7%9C_%D7%96%D7%A2%D7%9C%D7%99%D7%92_%D7%A9%D7%A8%D7%A4%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"עזריאל זעליג שרפשטיין\">עזריאל זעליג שרפשטיין</a>, שליח הרבי ומרבני העיר <a href=\"/index.php/%D7%A1%D7%99%D7%A0%D7%A1%D7%99%D7%A0%D7%98%D7%99\" title=\"סינסינטי\">סינסינטי</a>, אוהיו, וחבר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%A8%D7%91%D7%A0%D7%99_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ועד רבני ליובאוויטש\">ועד רבני ליובאוויטש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> <sup><span class=\"clarification-needed\" style=\"cursor: help; font-size: 90%;\" title=\"אדר א&#39; או ב&#39;?\">[דרושה הבהרה]</span></sup> - הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%91%D7%9C%D7%99%D7%96%27%D7%99%D7%A0%D7%A1%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל בליז&#39;ינסקי (הדף אינו קיים)\">מנחם מענדל בליז'ינסקי</a>, גבאי <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> ב<a href=\"/index.php/%D7%94%D7%96%D7%90%D7%9C_%D7%94%D7%A7%D7%98%D7%9F\" title=\"הזאל הקטן\">זאל הקטן</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%91%D7%95%D7%A7%D7%99%D7%A2%D7%98\" title=\"אברהם שמואל בוקיעט\">אברהם שמואל בוקיעט</a>, מ<a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"שלוחי הרבי לארץ הקודש\">שלוחי הרבי לארץ הקודש</a> ומשפיע בישיבת 'אור שמחה' ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> (אדר שני) - הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%91%D7%A2%D7%A8_%D7%A4%D7%A8%D7%A1%D7%9E%D7%9F\" title=\"נחום בער פרסמן\">נחום בער פרסמן</a>, שליח הרבי וראש הקהילה היהודית בבפוטסדאם, בירת מחוז ברנדנבורג שב<a href=\"/index.php/%D7%92%D7%A8%D7%9E%D7%A0%D7%99%D7%94\" title=\"גרמניה\">גרמניה</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ה' באדר א' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>בלי שום צל ספק וספק ספיקא, בכל מקום מדרך כף רגלינו, הכל הוא לזכות ולטהר את הארץ ב<a href=\"/index.php/%D7%90%D7%95%D7%AA%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אותיות\">אותיות</a> ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> וה<a href=\"/index.php/%D7%AA%D7%A4%D7%9C%D7%94\" class=\"mw-redirect\" title=\"תפלה\">תפלה</a>, ואנחנו כל <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"ישראל\">ישראל</a> שלוחי דרחמנא אנו, איש איש כאשר גזרה עליו <a href=\"/index.php/%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%A2%D7%9C%D7%99%D7%95%D7%A0%D7%94\" class=\"mw-redirect\" title=\"השגחה העליונה\">השגחה העליונה</a>, אין חפשי מ<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"עבודת ה&#39;\">עבודת</a> ה<a href=\"/index.php/%D7%A7%D7%95%D7%93%D7%A9\" title=\"קודש\">קודש</a>, אשר הועמסה על שכמנו.\n</td></tr></tbody></table>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ה' באדר ב' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>לימוד ה<a href=\"/index.php/%D7%A0%D7%92%D7%9C%D7%94\" class=\"mw-redirect\" title=\"נגלה\">נגלה</a> לימוד ה<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> ו<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"עבודת ה&#39;\">עבודה</a> בפועל, כולם כאחד מוכרחים המה. ולא זו בלבד דאינו שייך לומר שהאחד ידחה או יודחה מפני חברו, אלא אדרבא הם מסייעים זה לזה, וכמאמר \"ולא עם הארץ חסיד\" - שצריך להיות לימוד הנגלה. \"איזהו חסיד המתחסד עם קונו\" - שצריך להיות לימוד החסידות, ותכלית הלימוד הלא הוא העבודה בפועל.\n<p><br />\n</p>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השנים עשר\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414065739\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.102 seconds\nReal time usage: 0.211 seconds\nPreprocessor visited node count: 380/1000000\nPost‐expand include size: 9488/2097152 bytes\nTemplate argument size: 700/2097152 bytes\nHighest expansion depth: 8/100\nExpensive parser function count: 6/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 476/5000000 bytes\nLua time usage: 0.070/7 seconds\nLua virtual size: 6131712/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  188.287      1 -total\n 80.47%  151.514      1 תבנית:פתיח_יום\n 17.28%   32.534      4 תבנית:מילה_אחרונה\n 16.26%   30.614      1 תבנית:הערה\n  8.73%   16.432      1 תבנית:הבהרה\n  8.30%   15.620      1 תבנית:הסר_מילה_ראשונה\n  7.06%   13.286      1 תבנית:מילה_ראשונה\n  6.41%   12.067      1 תבנית:הערות_שוליים\n  4.72%    8.878      1 תבנית:חודש_אדר\n  3.20