      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table cellpadding=\"2.5\" cellspacing=\"0\" style=\"width: 280px; float: left; border: 1px solid #CBD3DD; margin: 0 1em 1em 0em; background: #F9FAFB; font-size: 95%;\">\n<tbody><tr>\n<th colspan=\"2\" style=\"font-size: larger; background-color: #b0ffb5; color: #000000;\">הרב חיים אהרון\n</th></tr>\n<tr valign=\"top\">\n<td colspan=\"2\" align=\"center\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/fe/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F.jpg/220px-%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"226\" class=\"mw-file-element\" srcset=\"/images/thumb/f/fe/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F.jpg/330px-%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F.jpg 1.5x, /images/thumb/f/fe/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F.jpg/440px-%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F.jpg 2x\" /></a></span>\n</td></tr>\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">לידה</span></b>\n</td>\n<td><a href=\"/index.php/%D7%99%22%D7%93_%D7%90%D7%93%D7%A8_%D7%91%27\" class=\"mw-redirect\" title=\"י&quot;ד אדר ב&#39;\">י\"ד אדר ב'</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%98\" title=\"תשי&quot;ט\">תשי\"ט</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"></span></b>\n</td>\n<td><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%A1%D7%91%D7%90\" title=\"כפר סבא\">כפר סבא</a>\n</td></tr>\n\n\n\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">השכלה</span></b>\n</td>\n<td><a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">מקום מגורים</span></b>\n</td>\n<td><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>\n</td></tr>\n\n\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">תחומי עיסוק</span></b>\n</td>\n<td>ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"תומכי תמימים רחובות\">תומכי תמימים רחובות</a>\n</td></tr>\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">תפקידים נוספים</span></b>\n</td>\n<td>חבר הועד הרוחני דכפר חב\"ד\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n</tbody></table>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c9/%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg/220px-%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c9/%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg/330px-%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg 1.5x, /images/thumb/c/c9/%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg/440px-%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg 2x\" /></a><figcaption>הרב חיים אהרון בתוכנית הוידאו של ארגון '<a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\">לחלוחית גאולתית</a>'</figcaption></figure>\n<p>הרב <b>חיים אהרן</b> (נולד ב<a href=\"/index.php/%D7%99%22%D7%93_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"י&quot;ד אדר\">י\"ד אדר א'</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%98\" title=\"תשי&quot;ט\">תשי\"ט</a>, 1959) הוא ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"תומכי תמימים רחובות\">תומכי תמימים רחובות</a> וחבר הוועד הרוחני ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%99%22%D7%93_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"י&quot;ד אדר\">י\"ד אדר ב'</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%98\" title=\"תשי&quot;ט\">תשי\"ט</a> לר' שלום<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ששימש כרב קהילת 'תפארת ישראל' ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%A1%D7%91%D7%90\" title=\"כפר סבא\">כפר סבא</a>, ולאמו מרת גליה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. בשעת ה<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ברית\">ברית</a> נקרא על שם סבו מצד אביו.\n</p><p>למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.\n</p><p>נשא את רעייתו מאירה בת ר' <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%96%D7%95%D7%94%D7%A8\" title=\"יעקב זוהר\">יעקב זוהר</a> מ<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>, התיישב בסמיכות לבית חמיו ושימש במשך מספר שנים כמורה ומחנך ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94\" title=\"תלמוד תורה\">תלמוד תורה</a> חב\"ד בעיר.\n</p><p>עם התמנותו כראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%90%D7%95%D7%A8_%D7%9E%D7%A0%D7%97%D7%9D_%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים מאור מנחם רחובות\">תומכי תמימים מאור מנחם רחובות</a>, עבר להתגורר ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a> מונה על ידי המרא דאתרא הרב <a href=\"/index.php?title=%D7%9E%D7%90%D7%99%D7%A8_%D7%90%D7%A9%D7%9B%D7%A0%D7%96%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאיר אשכנזי (הדף אינו קיים)\">מאיר אשכנזי</a> לחבר הועד הרוחני ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%90%D7%94%D7%A8%D7%95%D7%9F\" class=\"mw-redirect\" title=\"מאיר אהרון\">מאיר אהרון</a> - שימש כראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%95%D7%A8_%D7%99%D7%A2%D7%A7%D7%91_%D7%95%D7%90%D7%95%D7%A8_%D7%96%D7%A8%D7%95%D7%A2\" class=\"mw-redirect\" title=\"כולל אור יעקב ואור זרוע\">כולל אור יעקב ואור זרוע</a> ובית מדרש להוראה ומשפט ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a></li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%90%D7%94%D7%A8%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שניאור זלמן אהרן (הדף אינו קיים)\">שניאור זלמן אהרן</a> - מנהל <a href=\"/index.php?title=%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%97%D7%91%22%D7%93_%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"תלמוד תורה חב&quot;ד תל אביב (הדף אינו קיים)\">תלמוד תורה חב\"ד תל אביב</a></li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%97%D7%92%D7%99_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%90%D7%94%D7%A8%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חגי שמואל אהרן (הדף אינו קיים)\">חגי שמואל אהרן</a> - מחנך ב<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%98%D7%9B%D7%A0%D7%95%D7%9C%D7%95%D7%92%D7%99\" title=\"מכון חסידי טכנולוגי\">מכון חסידי טכנולוגי</a> ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a></li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%94%D7%A8%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יוסף יצחק אהרן (הדף אינו קיים)\">יוסף יצחק אהרן</a> - מחנך ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תלמוד תורה מגדל העמק\">תלמוד תורה חב\"ד</a> ב<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a></li>\n<li>חתנו, ר' <a href=\"/index.php?title=%D7%A9%D7%99%D7%9C%D7%94_%D7%A9%D7%90%D7%A2%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שילה שאער (הדף אינו קיים)\">שילה שאער</a> - מנכ\"ל ומייסד קריאייטיב מיזם - <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a></li>\n<li>חתנו, ר' לוי גדסי</li>\n<li>חתנו, ר' אוריאל זוהר</li>\n<li>חתנו, ר' צמח נדב</li>\n<li>חתנו, ר' מענדל נדב</li>\n<li>חתנו, ר' דובער נדב</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadlive.org/2025/03/%d7%94%d7%a8%d7%91-%d7%90%d7%94%d7%a8%d7%95%d7%9f-%d7%9e%d7%a9%d7%aa%d7%a4%d7%9a-%d7%91%d7%9c%d7%91%d7%91%d7%99%d7%95%d7%aa-%d7%91%d7%95%d7%99%d7%93%d7%90%d7%95-%d7%90%d7%99%d7%9f-%d7%a2%d7%a0%d7%99.html\">הרב חיים אהרון משתפך בלבביות בתוכנית הוידאו של חב\"ד: אין עניין יותר מהותי ומרומם מ'עבודת התפילה' - ינסו ויווכחו</a></b>, באתר '<a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"חב&quot;ד לייב\">חב\"ד לייב</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/41px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 1.5x, /images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/54px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 2x\" /></a></span> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span></li></ul>\n<h2><span id=\".D7.94.