d>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ז בניסן\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ח בניסן\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ט בניסן\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"ל&#39; בניסן\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table><p><b>ד' בניסן</b> הוא היום הרביעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.\n</p><meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ט - אליצור בן שדיאור, <a href=\"/index.php/%D7%A0%D7%A9%D7%99%D7%90\" title=\"נשיא\">נשיא</a> <a href=\"/index.php/%D7%A9%D7%91%D7%98_%D7%A8%D7%90%D7%95%D7%91%D7%9F\" class=\"mw-redirect\" title=\"שבט ראובן\">שבט ראובן</a>, הקריב <a href=\"/index.php/%D7%A7%D7%A8%D7%91%D7%9F\" class=\"mw-redirect\" title=\"קרבן\">קרבן</a> לחנוכת ה<a href=\"/index.php/%D7%9E%D7%A9%D7%9B%D7%9F\" class=\"mw-redirect\" title=\"משכן\">משכן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%94\" title=\"תרנ&quot;ה\">תרנ\"ה</a> - רבי יוחנן טברסקי, מייסד שושלת <a href=\"/index.php/%D7%A8%D7%97%D7%9E%D7%A1%D7%98%D7%A8%D7%99%D7%95%D7%95%D7%A7%D7%90\" class=\"mw-redirect\" title=\"רחמסטריווקא\">רחמסטריווקא</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%91\" title=\"תרפ&quot;ב\">תרפ\"ב</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%96%D7%95%D7%A9%D7%90_%D7%95%D7%99%D7%9C%D7%99%D7%9E%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"חיים זושא וילימובסקי\">חיים זושא וילימובסקי</a> (\"הפרטיזן\"), מגדולי עסקני חב\"ד בארץ הקודש.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%94\" title=\"תשכ&quot;ה\">תשכ\"ה</a> – הרב <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A7%D7%95%D7%A4%D7%A8%D7%9E%D7%9F\" title=\"בנימין קופרמן\">בנימין קופרמן</a>, ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"תומכי תמימים בני ברק\">תומכי תמימים בני ברק</a>, ודיין ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"בית דין רבני חב&quot;ד בארץ הקודש\">בית דין רבני חב\"ד בארץ הקודש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%9C\" title=\"תש&quot;ל\">תש\"ל</a> – הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9C%D7%99%D7%99%D7%91_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5_(%D7%A8%D7%9E%D7%AA_%D7%92%D7%9F)\" title=\"ישראל לייב ליפשיץ (רמת גן)\">ישראל לייב ליפשיץ</a>, יו\"ר <a href=\"/index.php/%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D\" title=\"יד לאחים\">יד לאחים</a> ורב קהילת חב\"ד <a href=\"/index.php/%D7%A8%D7%9E%D7%AA_%D7%92%D7%9F\" title=\"רמת גן\">רמת גן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%91%D7%A8%D7%95%D7%99%D7%9F\" title=\"יוסף ישעיה ברוין\">יוסף ישעיה ברוין</a>, מרא דאתרא וחבר ה<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A6%D7%93%D7%A7_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"בית דין צדק קראון הייטס\">בד\"צ</a> של שכונת <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A0%D7%99%D7%A1%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A9%D7%A4%D7%A8%D7%9C%D7%99%D7%9F\" title=\"יעקב מנחם מענדל שפרלין\">יעקב מנחם מענדל שפרלין</a>, רב בכמה עיירות ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> ולאחר מכן <a href=\"/index.php/%D7%A9%D7%95%22%D7%91\" class=\"mw-redirect\" title=\"שו&quot;ב\">שו\"ב</a> ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> – ר' <a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%91%D7%99_%D7%A7%D7%95%D7%A0%D7%99%D7%A7%D7%95%D7%91_(%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חיים צבי קוניקוב (קראון הייטס) (הדף אינו קיים)\">חיים צבי קוניקוב</a>, <a href=\"/index.php/%D7%9E%D7%9C%D7%9E%D7%93_%D7%AA%D7%99%D7%A0%D7%95%D7%A7%D7%95%D7%AA\" title=\"מלמד תינוקות\">מלמד</a> מ<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>, שזכה להיות '<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A7%D7%95%D7%A8%D7%90\" title=\"בעל קורא\">בעל קורא</a>' עבור הרבי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - השליח ר' <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%90%D7%95%D7%99%D7%A8%D7%9B%D7%9E%D7%9F_(%D7%A7%D7%A8%D7%99%D7%95%D7%AA)\" class=\"mw-redirect\" title=\"שניאור זלמן אוירכמן (קריות)\">שניאור זלמן אוירכמן (קריות)</a>, שליח בקריות וחבר וועד אות בספר התורה הכללי.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ד' בניסן - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"עבודת ה&#39;\">עבודת</a> בעלי עסקים מתחלקת לשני סעיפים עיקרים:\n<p>א) העבודה עם עצמו. בעת עסקו ממש בשעה הפנויה, בישבו בחנות וכדומה, ילמוד משנה משניות, פרק <a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"תניא\">תניא</a>, ויהיו לו איזה דברי <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>, כמו חומש משניות, תהלים ותניא, שיהיה בקי בהם בעל פה, למען שיוכל לחזור עליהם בהלכו ברחוב, בשוק וכדומה.\n</p><p>ב)העבודה עם זולתו. בעת הדבור בעניני עסק יסבב הדיבור לספר איזה סיפור תוכני, ולמצוא עילה וסיבה לעורר על דבר למוד וכיוצא בזה.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413135400\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.027 seconds\nReal time usage: 0.096 seconds\nPreprocessor visited node count: 93/1000000\nPost‐expand include size: 5747/2097152 bytes\nTemplate argument size: 493/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   66.409      1 -total\n 62.48%   41.490      1 תבנית:חודש_ניסן\n 51.48%   34.185      1 תבנית:לוח_שנה\n 39.03%   25.919      1 תבנית:כתב_קטן\n 37.23%   24.724      1 תבנית:להיום_יום\n 24.93%   16.556      1 תבנית:היום_יום/ד&#039;_ניסן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:21367-0!canonical and timestamp 20260413135400 and revision id 752356. Rendering was triggered because: page-view\n -->\n</div>"
