      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li><a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"אבא דוד גורביץ\">אבא דוד גורביץ</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח הרבי</a> לאוזבקיסטן.</li>\n<li><a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"חיים אליעזר גורביץ\">חיים אליעזר גורביץ</a> - מבכירי תלמידי התמימים ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a> ומאוחר יותר <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> בישיבה.</li>\n<li><a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יוסף יצחק גורביץ\">יוסף יצחק גורביץ</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a></li>\n<li><a href=\"/index.php/%D7%99%D7%A9%D7%A9%D7%9B%D7%A8_%D7%93%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27\" title=\"יששכר דב גורביץ&#39;\">יששכר דב גורביץ'</a> - מנהל <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A8%D7%91%D7%A7%D7%94\" class=\"mw-redirect mw-disambig\" title=\"בית רבקה\">בית רבקה</a> ב<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27_(%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94)\" title=\"מנחם מענדל גורביץ&#39; (ברינואה)\">מנחם מענדל גורביץ' (ברינואה)</a> - המנהל הגשמי של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90\" class=\"mw-redirect\" title=\"תומכי תמימים ברינוא\">תומכי תמימים ברינוא</a>.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"מנחם מענדל גורביץ&#39; (כפר חב&quot;ד)\">מנחם מענדל גורביץ' (כפר חב\"ד)</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%A9%D7%9E%D7%97%D7%94\" class=\"mw-redirect\" title=\"אור שמחה\">אור שמחה</a> וחבר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ועד כפר חב&quot;ד\">ועד כפר חב\"ד</a></li>\n<li><a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27\" class=\"mw-redirect\" title=\"נחום זלמן גורביץ&#39;\">נחום זלמן גורביץ'</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> ב<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a>.</li>\n<li><a href=\"/index.php?title=%D7%A8%D7%A4%D7%90%D7%9C_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רפאל דובער גורביץ&#39; (הדף אינו קיים)\">רפאל דובער גורביץ'</a>.</li>\n<li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27_(%D7%9E%D7%90%D7%96%D7%99%D7%A0%D7%A7%D7%A2%D7%A8)\" class=\"mw-redirect\" title=\"שמואל גורביץ&#39; (מאזינקער)\">שמואל גורביץ' (מאזינקער)</a> - מה<a href=\"/index.php/%D7%99%D7%95%D7%A9%D7%91%D7%99%D7%9D\" title=\"יושבים\">יושבים</a> בזמן <a href=\"/index.php/%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"הצמח צדק\">הצמח צדק</a>, מחסידי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"הרבי המהר&quot;ש\">הרבי המהר\"ש</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"הרש&quot;ב\">הרש\"ב</a>, <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9E%D7%95%D7%A2%D7%94\" title=\"בעל שמועה\">בעל שמועה</a> מוסמך</li>\n<li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27_(%D7%9C%D7%95%D7%93)\" title=\"שמואל גורביץ&#39; (לוד)\">שמואל גורביץ' (לוד)</a> - בנו של ר' <a href=\"/index.php/%D7%90%D7%99%D7%A6%27%D7%94_%D7%93%D7%A2%D7%A8_%D7%9E%D7%AA%D7%9E%D7%99%D7%93\" class=\"mw-redirect\" title=\"איצ&#39;ה דער מתמיד\">איצ'ה דער מתמיד</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a></li>\n<li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"שמואל גורביץ (כפר חב&quot;ד)\">שמואל גורביץ (כפר חב\"ד)</a> - מנהל ה<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94\" title=\"תלמוד תורה\">תלמוד תורה</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_(%D7%9C%D7%99%D7%90%D7%95%D7%9F)\" title=\"שמואל גורביץ (ליאון)\">שמואל גורביץ (ליאון)</a> - שליח ב<a href=\"/index.php?title=%D7%9C%D7%99%D7%90%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ליאון (הדף אינו קיים)\">ליאון</a></li>\n<li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_(%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F)\" title=\"שמואל גורביץ (מלבורן)\">שמואל גורביץ (מלבורן)</a> - מנהל בית רבקה <a href=\"/index.php/%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F\" title=\"מלבורן\">מלבורן</a> שב<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a></li>\n<li><a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"שניאור זלמן גורביץ\">שניאור זלמן גורביץ</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח הרבי</a> בפרנקפורט ומייסד <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%A8%D7%A0%D7%A7%D7%A4%D7%95%D7%A8%D7%98\" title=\"תומכי תמימים פרנקפורט\">הישיבה המקומית</a>.</li>\n<li><a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"חיים גורביץ\">חיים גורביץ</a> - מנהל כולל חב\"ד ושליח ותיק של הרבי בארה\"ב.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg