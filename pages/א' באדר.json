D7%93%D7%A8\" title=\"כ&quot;ח באדר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ט באדר\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ל&#39; באדר\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<dl><dd><dl><dd><small>הבהרה: ערך זה עוסק גם בא&#39; באדר א' וגם בא&#39; באדר ב'.</small></dd></dl></dd></dl>\n<p><b>א' באדר</b> הוא היום הראשון וב' ד<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a> <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a>. ביום זה היו מכריזים על השקלים, לקראת גביית '<a href=\"/index.php/%D7%9E%D7%97%D7%A6%D7%99%D7%AA_%D7%94%D7%A9%D7%A7%D7%9C\" title=\"מחצית השקל\">מחצית השקל</a>' עבור <a href=\"/index.php/%D7%A7%D7%A8%D7%91%D7%A0%D7%95%D7%AA\" title=\"קרבנות\">קרבנות</a> ל<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9\" title=\"בית המקדש\">בית המקדש</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח – ביום זה החלה מכת חושך, מ<a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%AA_%D7%94%D7%9E%D7%9B%D7%95%D7%AA\" title=\"עשרת המכות\">עשרת המכות</a> שהביא <a href=\"/index.php/%D7%94%D7%A7%D7%91%22%D7%94\" class=\"mw-redirect\" title=\"הקב&quot;ה\">הקב\"ה</a> על <a href=\"/index.php/%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"מצרים\">מצרים</a>.</li>\n<li>תכ\"ב (אדר ראשון) – רבי <a href=\"/index.php/%D7%A9%D7%91%D7%AA%D7%99_%D7%9B%D7%94%D7%9F\" title=\"שבתי כהן\">שבתי כהן</a>, מחבר הספרים 'שפתי כהן' ו'נקודות הכסף' על ה<a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A\" title=\"שולחן ערוך\">שולחן ערוך</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%92\" title=\"תק&quot;ג\">תק\"ג</a> – רבי <a href=\"/index.php/%D7%A8%D7%A4%D7%90%D7%9C_%D7%A2%D7%9E%D7%A0%D7%95%D7%90%D7%9C_%D7%97%D7%99_%D7%A8%D7%99%D7%A7%D7%99\" class=\"mw-redirect\" title=\"רפאל עמנואל חי ריקי\">רפאל עמנואל חי ריקי</a>, מקובל ומחבר הספרים '<a href=\"/index.php/%D7%9E%D7%A9%D7%A0%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"משנת חסידים\">משנת חסידים</a>' ו'הון עשיר', נרצח על קידוש ה'.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%90\" title=\"תרצ&quot;א\">תרצ\"א</a> – <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a> מתחיל את <a href=\"/index.php/%D7%91%D7%99%D7%A7%D7%95%D7%A8_%D7%A8%D7%90%D7%A7%D7%A9%D7%99%D7%A7\" title=\"ביקור ראקשיק\">ביקורו</a> בעיירה <a href=\"/index.php/%D7%A8%D7%90%D7%A7%D7%A9%D7%99%D7%A7\" title=\"ראקשיק\">ראקשיק</a> שב<a href=\"/index.php/%D7%9C%D7%99%D7%98%D7%90\" title=\"ליטא\">ליטא</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%96\" title=\"תרס&quot;ז\">תרס\"ז</a> – הרב <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%99%D7%9B%D7%9C_%D7%92%D7%95%D7%9C%D7%93%D7%A9%D7%9E%D7%99%D7%93\" title=\"יחיאל מיכל גולדשמיד\">יחיאל מיכל גולדשמיד</a>, <a href=\"/index.php/%D7%A9%D7%95%D7%97%D7%98_%D7%95%D7%91%D7%95%D7%93%D7%A7\" class=\"mw-redirect\" title=\"שוחט ובודק\">שוחט ובודק</a> של קהילת חסידי חב\"ד בגוש דן.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%98\" title=\"תש&quot;ט\">תש\"ט</a> - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%92%D7%93%D7%9C%D7%99%D7%94_%D7%98%D7%90%D7%9C%D7%A8\" title=\"שלמה גדליה טאלר\">שלמה גדליה טאלר</a>, מראשי <a href=\"/index.php/%D7%A0%D7%A9%D7%99_%D7%97%D7%91%22%D7%93\" title=\"נשי חב&quot;ד\">נשי חב\"ד</a> ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a></li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a> (אדר שני) - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A4%D7%A0%D7%97%D7%A1_%D7%9B%22%D7%A5\" title=\"משה פנחס כ&quot;ץ\">משה פנחס כ\"ץ</a>, חבר <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"אגודת חסידי חב&quot;ד בארצות הברית\">אגודת חסידי חב\"ד בארצות הברית</a> ו<a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"גבאי\">גבאי</a> ראשי ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%98\" title=\"תשמ&quot;ט\">תשמ\"ט</a> (אדר ראשון) – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A8%D7%90%D7%93%D7%90%D7%9C\" class=\"mw-redirect\" title=\"יוסף ראדאל\">יוסף ראדאל</a>, משלוחי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> ל<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"מונטריאול\">מונטריאול</a>, ממייסדי וראשי <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"תומכי תמימים מונטריאול\">ישיבת חב\"ד המקומית</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"יעקב פרידמן\">יעקב פרידמן</a>, מראשי הפעילים בהחזקת מוסדות <a href=\"/index.php/%D7%97%D7%93%D7%A8%D7%99_%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" title=\"חדרי תורה אור\">חדרי תורה אור</a>, ופעיל בהפצת מעיינות החסידות בשכונת <a href=\"/index.php/%D7%91%D7%90%D7%A8%D7%90_%D7%A4%D7%90%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"בארא פארק\">בארא פארק</a> בהוראת הרבי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> – הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%A7%D7%9C%D7%9E%D7%A0%D7%A1%D7%95%D7%9F\" title=\"ישראל שמעון קלמנסון\">ישראל שמעון קלמנסון</a>, חבר הצוות החינוכי בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>, וה<a href=\"/index.php/%D7%A9%D7%95%D7%97%D7%98\" title=\"שוחט\">שוחט</a> של תרנגול ה<a href=\"/index.php/%D7%9B%D7%A4%D7%A8%D7%95%D7%AA\" title=\"כפרות\">כפרות</a> של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בערב <a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%9B%D7%99%D7%A4%D7%95%D7%A8\" class=\"mw-redirect\" title=\"יום כיפור\">יום כיפור</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> – הרב <a href=\"/index.php/%D7%92%D7%A8%D7%A9%D7%95%D7%9F_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"גרשון מענדל גרליק\">גרשון מענדל גרליק</a>, שליח הרבי והשליח הראשי ל<a href=\"/index.php/%D7%90%D7%99%D7%98%D7%9C%D7%99%D7%94\" title=\"איטליה\">איטליה</a>.</li>\n<li>תשפ\"א – הרב <a href=\"/index.php/%D7%93%D7%95%D7%A8%D7%95%D7%9F_%D7%A9%D7%A4%D7%99\" title=\"דורון שפי\">דורון שפי</a>, מפעילי <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/wp-content/uploads/2021/02/12-02-2021-13-27-23-ראש-חודש-אדר-שחל-בשבת-תשפא.pdf\">דיני שבת שקלים שחלה בראש חודש אדר</a></b>, בעריכת <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%22%D7%93\" title=\"מכון הלכה חב&quot;ד\">מכון הלכה חב\"ד</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span><span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - א' באדר א' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i><a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a></i>\n<p><a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8_(%D7%A1%D7%A4%D7%A8)\" class=\"mw-redirect\" title=\"תורה אור (ספר)\">תורה אור</a> <a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C\" title=\"דיבור המתחיל\">דיבור המתחיל</a> \"לא תהיה משכלה\" סעיף המתחיל \"והנה אחר\": \"ב<a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A0%D7%A4%D7%A9\" class=\"mw-redirect\" title=\"מסירת נפש\">מסירת נפש</a> בפ\"ע\" פירוש הראשי תיבות הוא \"ב<a href=\"/index.php/%D7%A4%D7%A0%D7%99%D7%9E%D7%99\" class=\"mw-redirect\" title=\"פנימי\">פנימית</a> <a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA\" class=\"mw-redirect\" title=\"עצמות\">עצמותו</a>\".\n</p><p>כתיב \"יצא אדם לפעלו ולעבודתו עדי ערב\". הנה כל <a href=\"/index.php/%D7%A0%D7%A9%D7%9E%D7%94\" class=\"mw-redirect\" title=\"נשמה\">נשמה</a> בירידתה למטה, יש לה מלאכות כלליות ופרטיות. וזהו \"יצא אדם לפעלו\", דיציאת ה<a href=\"/index.php/%D7%A0%D7%A9%D7%9E%D7%94\" class=\"mw-redirect\" title=\"נשמה\">נשמה</a> מעמידתה בשמי רום באוצר הנשמות, וירידתה מדרגא לדרגא עד בואה להתלבש ב<a href=\"/index.php/%D7%92%D7%95%D7%A3\" class=\"mw-redirect\" title=\"גוף\">גוף</a> ו<a href=\"/index.php/%D7%A0%D7%A4%D7%A9_%D7%94%D7%98%D7%91%D7%A2%D7%99%D7%AA\" class=\"mw-redirect\" title=\"נפש הטבעית\">נפש הטבעית</a> והבהמית, הוא בשביל <a href=\"/index.php/%D7%90%D7%93%D7%9D_(%D7%9E%D7%99%D7%9F_%D7%94%D7%9E%D7%93%D7%91%D7%A8)\" title=\"אדם (מין המדבר)\">אדם</a> לפעלו במלאכות הכלליות להגביר ה<a href=\"/index.php/%D7%A6%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"צורה\">צורה</a> על ה<a href=\"/index.php/%D7%97%D7%95%D7%9E%D7%A8\" class=\"mw-redirect\" title=\"חומר\">חומר</a>, להאיר את ה<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94_%D7%94%D7%92%D7%A9%D7%9E%D7%99\" title=\"עולם העשייה הגשמי\">עולם</a> ב<a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a> <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> ונר <a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%94\" class=\"mw-redirect\" title=\"מצוה\">מצוה</a>. ולעבודתו שהיא מלאכה הפרטית, דכל נשמה יש לה עבודה פרטית ב<a href=\"/index.php/%D7%9E%D7%95%D7%97\" title=\"מוח\">מוחין</a> וב<a href=\"/index.php/%D7%9E%D7%99%D7%93%D7%95%D7%AA_(%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA)\" title=\"מידות (ספירות)\">מדות</a> כפי <a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"טבע\">טבעה</a> וענינה . . \"עדי ערב\" - בעוד יש זמן לעשות כמו-שכתוב \"היום לעשותם\". ובעומק הענין ביאור הכתוב .. דקאי על כללות ענין העליה שנעשה על ידי ירידת הנשמה למטה דיצא אדם, דבעלות הנשמה מהיותה למטה מלובשת בגוף, לפעלו היא עוסקת ב<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%91%D7%90\" title=\"עולם הבא\">עולם הבא</a> באופן התעסקותה ב<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%96%D7%94\" class=\"mw-redirect\" title=\"עולם הזה\">עולם הזה</a>, ואם היה קובע עתים לתורה, גם שם מכניסים אותו באהלי תורה, לעבודתו, אם עסק בעבודתו כראוי אז הנה עליתו עדי ערב שעולה בעילוי אחר עילוי עד הנועם והעריבות ד<a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" class=\"mw-redirect\" title=\"עצמות אין סוף\">עצמות אין סוף</a> ברוך הוא.\n</p>\n</td></tr></tbody></table>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - א' באדר ב' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i><a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a>. ב\"יעלה ויבוא\": \"זכרנו ה' אלוקינו בו\" - <a href=\"/index.php/%D7%91%D7%99%22%D7%AA\" class=\"mw-redirect\" title=\"בי&quot;ת\">בי\"ת</a> דגושה - \"ופקדינו בו\" - בי\"ת רפוי</i>.\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413202430\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.059 seconds\nReal time usage: 0.291 seconds\nPreprocessor visited node count: 150/1000000\nPost‐expand include size: 8903/2097152 bytes\nTemplate argument size: 461/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  115.731      1 -total\n 41.23%   47.721      1 תבנית:חודש_אדר\n 33.32%   38.563      2 תבנית:להיום_יום\n 21.20%   24.536      1 תבנית:לוח_שנה\n 15.38%   17.798      1 תבנית:היום_יום/א&#039;_אדר_ב&#039;\n 15.32%   17.727      1 תבנית:אינפו\n 10.84%   12.541      1 תבנית:היום_יום/א&#039;_אדר_א&#039;\n 10.03%   11.611      1 תבנית:כתב_קטן\n  5.53%    6.402      1 תבנית:אדרים\n  4.04%    4.670      1 תבנית:PDF\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:20686-0!canonical and t