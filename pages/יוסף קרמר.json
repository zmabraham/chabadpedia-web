    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/d5/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d5/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg 1.5x, /images/thumb/d/d5/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg 2x\" /></a><figcaption>ОћОеОЉ ОДОеОъОе</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/8c/%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg/220px-%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg\" decoding=\"async\" width=\"220\" height=\"152\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg/330px-%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg 1.5x, /images/thumb/8/8c/%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg/440px-%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8.jpeg 2x\" /></a><figcaption>ОћОеОЉ ОЎОЋОАОБ ОДОеОъОе ОЉОўОДОА ОАОЎОЋОЮ ОћОеОъОЉ\"ОЮ ОЉОўОЉОеОЎОћ</figcaption></figure>\n<p>ОћОеОЉ <b>ОЎОЋОАОБ ОДОеОъОе</b> (<a href=\"/index.php/%D7%92%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"Оњ&#39; ОЉОфОъОЋОќ\">Оњ' ОЉОфОъОЋОќ</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%92\" title=\"ОфОЕОЎ&quot;Оњ\">ОфОЕОЎ\"Оњ</a>, 1953 - <a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ОЏ&quot;ОЌ ОЉОљОЎОЎОе\">ОЏ\"ОЌ ОЉОљОЎОЎОе</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"ОфОЕОц&quot;Оћ\">ОфОЕОц\"Оћ</a>, 2025) ОћОЎОћ ОЕОюОЎОЌ ОћОеОЉОЎ ОћОеОљОЕОЎ ОюОбОЎОе <a href=\"/index.php/%D7%98%D7%91%D7%A8%D7%99%D7%94\" title=\"ОўОЉОеОЎОћ\">ОўОЉОеОЎОћ</a> <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОЕОюОЋОЌОЎ ОћОеОЉОЎ ОюОљОеОЦ ОћОДОЋОЊОЕ\">ОЋОъОЕОюОЋОЌОЎ ОћОеОЉОЎ ОюОљОеОЦ ОћОДОЋОЊОЕ</a> ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"ОфОЕОю&quot;ОЋ\">ОфОЕОю\"ОЋ</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОфОЋОюОЊОЋОф_ОЌОЎОЎОЮ\">ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"ОъОЋОаОўОеОЎОљОЋОю\">ОъОЋОаОўОеОЎОљОЋОю</a> ОЉОЪ ОюОеОЉ <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A7%D7%A8%D7%9E%D7%A8\" title=\"ОљОеОЎОћ ОюОЎОЎОЉ ОДОеОъОе\">ОљОеОЎОћ ОюОЎОЎОЉ ОДОеОъОе</a> ОЕОаОъОаОћ ОбОю ОъОЎОЎОАОЊОЎ ОЋОЌОЕОЋОЉОЎ ОДОћОЎОюОф ОЌОЉ\"ОЊ ОћОъОДОЋОъОЎОф ОЋОюОЌОЎОћ ОќОюОЊОћ.\n</p><p>ОЉОЎОюОЊОЋОфОЋ ОюОъОЊ ОЉОЌОЎОЎОЊОе ОюОЎОЋОЉОљОЋОЋОЎОўОЕ ОЕОЉОбОЎОе, ОЋОЉОъОфОЎОЉОфОљ ОюОЎОЕОЎОЉОћ ОњОЊОЋОюОћ ОЉ<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"ОъОЋОаОўОеОЎОљОЋОю\">ОъОЋОаОўОеОЎОљОЋОю</a> ОЕОЉ<a href=\"/index.php/%D7%A7%D7%A0%D7%93%D7%94\" title=\"ОДОаОЊОћ\">ОДОаОЊОћ</a>.\n</p><p>ОЉОАОЋОБ ОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"ОфОЕОю&quot;ОЉ\">ОфОЕОю\"ОЉ</a> ОаОАОб ОюОаОЎОЋ ОЎОЋОеОД ОбОю ОъОаОф ОюОюОъОЋОЊ ОЉОЌОдОеОЋ ОЕОю ОћОеОЉОЎ, ОЋОфОЏОаОЪ ОюОћОЎОЋОф ОцОеОД ОќОъОЪ ОљОеОЋОџ ОЉОъОЌОЎОдОф ОћОеОЉОЎ, ОљОџ ОюОљОЌОе <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A4%D7%A1%D7%97\" class=\"mw-redirect\" title=\"ОЌОњ ОћОцОАОЌ\">ОЌОњ ОћОцОАОЌ</a> ОЕОю ОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%92\" title=\"ОфОЕОю&quot;Оњ\">ОфОЕОю\"Оњ</a> ОаОЉОЌОе ОюОћОЎОЋОф ОъОћОфОюОъОЎОЊОЎОЮ ОћОЕОюОЋОЌОЎОЮ ОюОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ</a> ОЉОъОюОЉОЋОеОЪ ОЕОЉ<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"ОљОЋОАОўОеОюОЎОћ\">ОљОЋОАОўОеОюОЎОћ</a>. \n</p><p>ОюОЕОюОЎОЌОЋОф ОќОЋ ОаОАОб ОЎОЌОЊ ОбОЮ ОЌОЉОеОЎОЋ ОћОеОЉ <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A6%D7%99%D7%99%D7%98%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ОљОћОеОЋОЪ ОљОюОЎОбОќОе ОдОЎОЎОўОюОЎОЪ\">ОљОћОеОЋОЪ ОљОюОЎОбОќОе ОдОЎОЎОўОюОЎОЪ</a>, ОћОеОЉ <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"ОЎОЋОАОБ ОЎОдОЌОД ОЌОЎОўОеОЎОД\">ОЎОЋОАОБ ОЎОдОЌОД ОЌОЎОўОеОЎОД</a>, ОћОеОЉ <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_%D7%91%D7%90%D7%A8%D7%90%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОюОЋОЮ ОЉОљОеОљОЕ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЕОюОЋОЮ ОЉОљОеОљОЕ</a>, ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A8%D7%99%D7%99%D7%A6%D7%A1\" class=\"mw-redirect\" title=\"ОЎОбОДОЉ ОеОЎОЎОдОА\">ОЎОбОДОЉ ОеОЎОЎОдОА</a>, ОЋОћОеОЉ <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%A9%D7%A4%D7%9C%D7%98%D7%A8\" title=\"ОЕОюОЋОЮ ОЕОцОюОўОе\">ОЕОюОЋОЮ ОЕОцОюОўОе</a>, ОЉОъОћОюОџ ОЕОюОЎОЌОЋОф ОќОЋ ОбОАОДОЋ ОеОЉОЋОф ОюОЌОЎОќОЋОД ОћОЎОћОЊОЋОф ОЉОбОЎОе ОЋОюОЌОЎОќОЋОД ОћОћОфОДОЕОеОЋОф ОюОаОЕОЎОљ ОћОЊОЋОе. \n</p><p>ОюОљОЌОе <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A4%D7%A1%D7%97\" class=\"mw-redirect\" title=\"ОЌОњ ОћОцОАОЌ\">ОЌОњ ОћОцОАОЌ</a> ОЕОю ОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"ОфОЕОю&quot;Оћ\">ОфОЕОю\"Оћ</a> ОЌОќОеОЋ ОћОЕОюОЋОЌОЎОЮ ОюОаОЎОЋ ОЎОЋОеОД.\n</p><p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"ОфОЕОю&quot;ОЋ\">ОфОЕОю\"ОЋ</a> ОћОдОўОеОБ ОюОДОЉОЋОдОћ ОћОеОљОЕОЋОаОћ ОЕОю <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОЕОюОЋОЌОЎ ОћОеОЉОЎ ОюОљОеОЦ ОћОДОЋОЊОЕ\">ОЕОюОЋОЌОЎ ОћОеОЉОЎ ОюОљОеОЦ ОћОДОЋОЊОЕ</a>.\n</p><p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"ОфОЕОю&quot;ОЌ\">ОфОЕОю\"ОЌ</a> ОаОЕОљ ОљОф ОљОЎОўОћ ОЉОф ОћОеОЉ <a href=\"/index.php/%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%99%D7%95%D7%A1%D7%A3_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"ОбОДОЎОЉОљ ОЎОЋОАОБ ОцОеОЎОЊОъОЪ\">ОбОДОЎОЉОљ ОЎОЋОАОБ ОцОеОЎОЊОъОЪ</a> ОЋОћОфОЎОЎОЕОЉ ОЉ<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"ОдОцОф\">ОдОцОф</a>, ОћОеОЉ ОДОеОъОе ОюОъОЊ ОЉОЏОЋОюОю ОъОДОЋОъОЎ ОЋОцОбОю ОЉ<a href=\"/index.php/%D7%94%D7%A4%D7%A6%D7%AA_%D7%94%D7%9E%D7%A2%D7%99%D7%99%D7%A0%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ОћОцОдОф ОћОъОбОЎОЎОаОЋОф\">ОћОцОдОф ОћОъОбОЎОЎОаОЋОф</a> ОЉОљОъОдОбОЋОф ОъОАОЎОеОф ОЕОЎОбОЋОеОЎОЮ ОЉОъОЋОАОЊОЋОф ОЕОЋОаОЎОЮ, ОъОЉОЎОаОЎОћОЮ <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%90%D7%9C%D7%98%D7%A2\" title=\"ОъОЏОЋОЪ ОљОюОўОб\">ОъОЏОЋОЪ ОљОюОўОб</a> ОЋ<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%A0%D7%94_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"ОЉОЎОф ОЌОаОћ ОдОцОф\">ОЉОЎОф ОЌОаОћ ОдОцОф</a>.\n</p><p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"ОфОЕОъ&quot;Оќ\">ОфОЕОъ\"Оќ</a> ОЉОбОДОЉОЋОф ОЕОЎОЌОЋОфОЎОЋ ОЕОю ОћОеОЉОЎ ОбОю ОцОфОЎОЌОф ОЉОфОЎ ОЌОЉ\"ОЊ ОћОЌОю ОюОцОбОЋОю ОЉОўОЉОеОЎОћ ОЉОбОЋОЊОЋ ОъОфОњОЋОеОе ОЉОдОцОф, ОЏОбОЉОЋОе ОЕОаОћ, ОЉ<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"ОфОЕОъ&quot;ОЌ\">ОфОЕОъ\"ОЌ</a> ОбОЉОе ОњОЮ ОюОћОфОњОЋОеОе ОЉОўОЉОеОЎОћ ОЋОћОЌОю ОюОЕОъОЕ ОЏОЕОюОЎОЌ ОћОеОЉОЎ ОЉОбОЎОе ОЋОъОаОћОю ОъОЋОАОЊОЋОф ОЌОЉ\"ОЊ ОћОъОДОЋОъОЎОЎОЮ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ОъОљОќ ОЎОЎОАОЋОЊ ОфОДОаОф ОћОеОъОЉ\"ОЮ, ОљОеОњОЪ ОљОф ОћОАОЎОЋОъОЎОЮ ОћОаОбОеОЏОЎОЮ ОбОю ОдОЎОЋОаОЋ ОЉОћОЋОеОљОф ОћОеОЉОЎ.\n</p><p>ОЉОўОЉОеОЎОћ ОћОЉОЎОљ ОЕОюОЋОЌОЎОЮ ОеОЉОЎОЮ ОюОЕОЏОЋОаОЋОф ОћОбОЎОе ОЏОЕОўОЉОеОЎОћ ОћОЎОљ ОћОбОЎОе ОЉОбОюОф ОЏОъОЋОф ОћОЕОюОЋОЌОЎОЮ ОћОЏОЎ ОњОЉОЋОћ ОЎОЌОАОЎОф ОюОњОЋОЊОю ОћОљОЋОЏОюОЋОАОЎОЎОћ. ОћОДОЎОЮ ОљОф ОъОЋОАОЊОЋОф ОћОЌОЎОаОЋОџ ОЕОю ОЌОЉО┤ОЊ, ОњОаОЎ ОЎОюОЊОЎОЮ, ОЎОЕОЎОЉОћ, ОфОюОъОЋОЊ ОфОЋОеОћ ОЉОаОЎОЮ ОЋОЉОЎОф ОАОцОе ОЉОаОЋОф. \n</p><p>ОаОцОўОе ОЉ<a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ОЏ&quot;ОЌ ОЉОљОЎОЎОе\">ОЏ\"ОЌ ОЉОљОЎОЎОе</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"ОфОЕОц&quot;Оћ\">ОфОЕОц\"Оћ</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. ОЉОбОф ОъОАОб ОћОюОЋОЋОЎОћ ОћОЏОеОЎОќ ОеОЉ ОДОћОЎОюОф ОЌОЉ\"ОЊ ОдОцОф ОћОеОЉ ОЉОЎОАОўОеОЎОдОДОЎ ОЏОЎ ОюОцОЎ ОдОЋОЋОљОф ОћОеОЉ ОДОеОъОе - ОЉОаОЋ ОћОеОЉ ОљОеОЎОћ ОЎОъОЕОЎОџ ОЊОеОЏОЋ ОЉОћОаОћОюОф ОћОъОЋОАОЊОЋОф ОЋОЉОаОЎОћОЋОю ОЉОЎОф ОЌОЉ\"ОЊ ОЋОцОЋОбОюОфОЎОЋ,  ОЋОЌОфОаОЋ ОћОеОЉ ОдОЉОЎ ОћОЎОеОЕ ОќОюОъОаОЋОЉ ОЎОъОЋОаОћ ОюОеОЉ <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"ОЉОЎОф ОЌОЉ&quot;ОЊ\">ОЉОЎОф ОЌОЉ\"ОЊ</a> ОЋОДОћОЎОюОф ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%98%D7%91%D7%A8%D7%99%D7%94\" title=\"ОўОЉОеОЎОћ\">ОўОЉОеОЎОћ</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ОъОЕОцОЌОфОЋ\">ОъОЕОцОЌОфОЋ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОъОЕОцОЌОфОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОъОЕОцОЌОфОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ОЉОаОЋ, ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A7%D7%A8%D7%9E%D7%A8\" title=\"ОъОаОЌОЮ ОъОбОаОЊОю ОДОеОъОе\">ОъОаОЌОЮ ОъОбОаОЊОю ОДОеОъОе</a> - ОъОъОаОћОюОЎ <a href=\"/index.php/%D7%94%D7%9E%D7%A8%D7%9B%D7%96_%D7%9C%D7%A2%D7%96%D7%A8%D7%99_%D7%A9%D7%9C%D7%99%D7%97%D7%95%D7%AA\" title=\"ОћОъОеОЏОќ ОюОбОќОеОЎ ОЕОюОЎОЌОЋОф\">ОћОъОеОЏОќ ОюОбОќОеОЎ ОЕОюОЎОЌОЋОф</a> ОЋ<a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОдОбОЎОеОЎ ОЌОЉ&quot;ОЊ ОЉОљОеОЦ ОћОДОЋОЊОЕ\">ОдОбОЎОеОЎ ОЌОЉ\"ОЊ ОЉОљОеОЦ ОћОДОЋОЊОЕ</a> ОЋОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЕОЏОЋОаОф ОеОЋОЉОб ОЊ' ОЉ<a href=\"/index.php/%D7%90%D7%A9%D7%93%D7%95%D7%93\" title=\"ОљОЕОЊОЋОЊ\">ОљОЕОЊОЋОЊ</a></li>\n<li>ОЉОаОЋ, ОћОеОЉ ОљОюОЎОћОЋ ОДОеОъОе - ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЎОЎОЕОЋОЉ ОцОЋОеОЎОћ-ОаОЋОЋОћ ОбОЋОЉОЊ, ОЋОеОЉ ОЉОЎОф ОћОеОцОЋОљОћ ОцОЋОеОЎОћ</li>\n<li>ОЉОаОЋ, ОћОеОЉ ОбОДОЎОЉОљ ОДОеОъОе - ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОеОЎОњОљ, ОюОўОЉОЎОћ</li>\n<li>ОЉОаОЋ, ОъОъОЕОЎОџ ОЊОеОЏОЋ ОћОеОЉ <a href=\"/index.php?title=%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A7%D7%A8%D7%9E%D7%A8_(%D7%98%D7%91%D7%A8%D7%99%D7%94)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОљОеОЎОћ ОюОЎОЎОЉ ОДОеОъОе (ОўОЉОеОЎОћ) (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОљОеОЎОћ ОюОЎОЎОЉ ОДОеОъОе</a>- ОЎОЋ\"Ое ОъОЋОАОЊОЋОф ОЌОЉ\"ОЊ, ОъОаОћОю ОЉОЎОф ОЌОЉ\"ОЊ ОћОъОеОЏОќОЎ ОЋОЕОюОЎОЌ ОћОеОљОЕОЎ ОюОбОЎОе ОўОЉОеОЎОћ.</li>\n<li>ОЌОфОаОЋ, ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99\" title=\"ОъОаОЌОЮ ОъОбОаОЊОю ОњОеОюОЎОдОДОЎ\">ОъОаОЌОЮ ОъОбОаОЊОю ОњОеОюОЎОдОДОЎ</a> - ОъОаОћОю ОъОЋОАОЊОЋОф ОЌОЎОаОЋОџ ОЌОЉ\"ОЊ ОЉОфОю ОљОЉОЎОЉ, ОЋОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЕОЏОЋОаОЋОф ОћОдОцОЋОЪ ОћОЌОЊОЕ ОЉОбОЎОе</li>\n<li>ОЌОфОаОЋ, ОћОеОЉ ОЎОЋОАОБ ОЎОдОЌОД ОЉОюОЋОЎ - ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЎОЎОЕОЋОЉ ОЏОаОеОф</li>\n<li>ОЌОфОаОЋ, ОћОеОЉ <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91\" title=\"ОдОЉОЎ ОћОЎОеОЕ ОќОюОъОаОЋОЉ\">ОдОЉОЎ ОћОЎОеОЕ ОќОюОъОаОЋОЉ</a> - ОъОъОюОљ ОъОДОЋОЮ ОЌОъОЎОЋ ОЉОеОЉОаОЋОф ОћОДОћОЎОюОћ ОЋОЉОЎОф ОЌОЉ\"ОЊ ОћОъОеОЏОќОЎ ОЉОўОЉОеОЎОћ, ОъОъОаОћОюОЎ <a href=\"/index.php/%D7%9E%D7%A2%D7%99%D7%99%D7%A0%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ОъОбОЎОЎОаОЎ ОЎОЕОеОљОю\">ОъОбОЎОЎОаОЎ ОЎОЕОеОљОю</a> ОЉОўОЉОеОЎОћ, Ое\"Оъ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%98%D7%91%D7%A8%D7%99%D7%94\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОўОЉОеОЎОћ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОўОЉОеОЎОћ</a>, ОбОЋОеОџ ОАОцОеОЎ ОЌОЉ\"ОЊ ОЋОАОеОўОЎОЮ ОЕОю <a href=\"/index.php/JEM\" title=\"JEM\">JEM</a>.</li>\n<li>ОЌОфОаОЋ, ОћОеОЉ <a href=\"/index.php?title=%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОаОЎОљОЋОе ОќОюОъОЪ ОњОбОеОюОЎОдОДОЎ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЕОаОЎОљОЋОе ОќОюОъОЪ ОњОбОеОюОЎОдОДОЎ</a>- ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЎОЎОЕОЋОЉ ОцОЋОеОЎОћ ОбОюОЎОф</li>\n<li>ОЌОфОаОЋ, ОћОеОЉ ОЕОюОЋОЮ ОЊОЋОЉОбОе ОљОюОцОеОЋОЉОЎОЦ - ОЕОюОЎОЌ ОЉОЕОЏОЋОаОф ОћОъОЋОЕОЉОћ ОЉОўОЉОеОЎОћ</li>\n<li>ОЌОфОаОЋ, ОћОеОЉ ОъОљОЎОе ОъОаОЊОюОќОЋОЪ - ОЕОюОЎОЌ ОЉОбОеОЊ</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"ОюОДОеОЎОљОћ_ОаОЋОАОцОф\">ОюОДОеОЎОљОћ ОаОЋОАОцОф</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОюОДОеОЎОљОћ ОаОЋОАОцОф&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОюОДОеОЎОљОћ ОаОЋОАОцОф\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ОЎОЕОеОљОю ОљОюОцОеОЋОЉОЎОЦ, <b>ОћОЎОАОўОЋОеОЎОћ ОЉОљОЋОАОўОеОюОЎОћ</b>, 50 ОЕОаОћ ОюОДОЉОЋОдОћ ОћОеОЉОЎОбОЎОф ОЕОю ОћОфОюОъОЎОЊОЎОЮ ОћОЕОюОЋОЌОЎОЮ ОюОЎОЕОЎОЉОф ОЌОЉ\"ОЊ ОЉОъОюОЉОЋОеОЪ, ОЕОЉОЋОбОЋОЪ ОЏОцОе ОЌОЉ\"ОЊ ОњОюОЎОЋОЪ 2004 ОбОъОЋОЊ 158</li>\n<li>ОАОЋОцОе ОЏОцОе ОЌОЉ\"ОЊ, <b>ОЎОЋОАОБ ОћОЕОЮ ОбОюОЎОЏОЮ</b>, ОЕОЉОЋОбОЋОЪ ОЏОцОе ОЌОЉ\"ОЊ ОњОюОЎОЋОЪ 2111 ОбОъОЋОЊ 44</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОДОЎОЕОЋОеОЎОЮ_ОЌОЎОдОЋОаОЎОЎОЮ\">ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;veaction=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%9E%D7%A8&amp;action=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/uploads/original/2023/03/64212e04f1d1e_1679896068.pdf\">ОћОеОЉ ОДОеОъОе: ОљОаОЎ ОЌОЕ ОЏОЎ ОбОюОЎОаОЋ ОъОЋОўОюОф ОљОЌОеОЎОЋОф ОЏОцОЋОюОћ ОЋОъОЏОЋОцОюОф ОюОћОЕОъОЎОб ОЉОеОъОћ ОЉОўОЉОеОЎОљ ОљОф ОЉОЕОЋОеОф ОћОњОљОЋОюОћ</a></b> (ОбОъ' 47).</li></ul>\n<p><br />\n</p>\n<table class=\"navbox nowraplinks mw-collapsible autocollapse\" style=\"width: 90%; clear: both; margin: 0.5em auto; margin-top: 0.5em; margin-bottom: 0.5em; padding: 0.2em; text-align: right;\">\n\n<tbody><tr>\n<th colspan=\"3\" style=\"text-align: center; padding-top: 0.1em; padding-bottom: 0.1em; color: black; background:#d1eeee; font-weight: bold;\"><a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОЕОюОЋОЌОЎ ОћОеОЉОЎ ОюОљОеОЦ ОћОДОЋОЊОЕ\"><b>ОћОДОЉОЋОдОЋОф ОЕОЕОюОЌ ОћОеОЉОЎ ОюОљОеОЦ ОћОДОЋОЊОЕ</b></a>\n</th></tr>\n\n\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\"><a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"ОДОўОњОЋОеОЎОћ:ОћОЕОюОЋОЌОЎОЮ ОюОљОеОЦ ОћОДОЋОЊОЕ ОфОЕОў&quot;Оќ\">О