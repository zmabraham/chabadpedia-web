    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99_%D7%A4%27%27%D7%93.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/71/%D7%94%D7%A8%D7%91_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99_%D7%A4%27%27%D7%93.jpg/250px-%D7%94%D7%A8%D7%91_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99_%D7%A4%27%27%D7%93.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/7/71/%D7%94%D7%A8%D7%91_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99_%D7%A4%27%27%D7%93.jpg/375px-%D7%94%D7%A8%D7%91_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99_%D7%A4%27%27%D7%93.jpg 1.5x, /images/thumb/7/71/%D7%94%D7%A8%D7%91_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99_%D7%A4%27%27%D7%93.jpg/500px-%D7%94%D7%A8%D7%91_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99_%D7%A4%27%27%D7%93.jpg 2x\" /></a><figcaption>הרב גערליצקי נואם בעצרת תפילה לנצחון <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%97%D7%A8%D7%91%D7%95%D7%AA_%D7%91%D7%A8%D7%96%D7%9C\" title=\"מלחמת חרבות ברזל\">מלחמת חרבות ברזל</a> ולהשבת חטופי המלחמה (<a href=\"/index.php/%D7%90%D7%93%D7%A8_%D7%90%27\" class=\"mw-redirect\" title=\"אדר א&#39;\">אדר א'</a>, <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a>)</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/86/%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg/250px-%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg\" decoding=\"async\" width=\"250\" height=\"166\" class=\"mw-file-element\" srcset=\"/images/thumb/8/86/%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg/375px-%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg 1.5x, /images/thumb/8/86/%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg/500px-%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg 2x\" /></a><figcaption>הרב גערליצקי נואם בחגיגת <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%9D_%D7%94%D7%A8%D7%9E%D7%91%22%D7%9D\" title=\"סיום הרמב&quot;ם\">סיום הרמב\"ם</a> ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a> (<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a>)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A9%D7%99_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/ca/%D7%99%D7%A9%D7%99_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg/220px-%D7%99%D7%A9%D7%99_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/c/ca/%D7%99%D7%A9%D7%99_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg/330px-%D7%99%D7%A9%D7%99_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg 1.5x, /images/thumb/c/ca/%D7%99%D7%A9%D7%99_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg/440px-%D7%99%D7%A9%D7%99_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99.jpg 2x\" /></a><figcaption>הרב גערליצקי לוחץ את ידו של ראש העיר תל אביב מר רון חולדאי (<a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a>)</figcaption></figure>\n<p>הרב <b>יוסף שמואל יהושע גערליצקי</b> (נולד ב<a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בחשוון\">כ\"ו בחשוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%93\" title=\"תשי&quot;ד\">תשי\"ד</a>, 1954) הוא <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"שליח הרבי\">שליח הרבי</a> הראשי ל<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91-%D7%99%D7%A4%D7%95\" title=\"תל אביב-יפו\">תל אביב</a>, מ<a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">שלוחי הרבי לארץ הקודש</a> ויו\"ר <a href=\"/index.php/%D7%A7%D7%95%D7%A0%D7%92%D7%A8%D7%A1_%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%9D_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%A9%D7%9C%D7%95%D7%9D\" title=\"קונגרס הרבנים למען השלום\">קונגרס הרבנים למען השלום</a> לשמירה על <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%95%D7%AA_%D7%94%D7%90%D7%A8%D7%A5\" title=\"שלמות הארץ\">שלמות הארץ</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בחשוון\">כ\"ו בחשוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%93\" title=\"תשי&quot;ד\">תשי\"ד</a> ב<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"מונטריאול\">מונטריאול</a> לרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99\" title=\"משה אליהו גרליצקי\">משה אליהו גרליצקי</a> ולחנה עטקא.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%98\" title=\"תשי&quot;ט\">תשי\"ט</a> נסע לראשונה לרבי עם משפחתו לקראת יו\"ד שבט, וביחידות המשפחתית לה זכו, פנה הרבי אל אביו ושאל מדוע לא ציין את שמו של הבן בפ\"נ, והוסיף זאת בכתב יד קודשו בעצמו. בהמשך שאל אותו הרבי האם הוא יודע שמע ישראל, וכמענה על כך הניח ידו על עיניו ואמר את כל הפרשה עד 'ובשעריך', והרבי נענה על כך בהנאה באומרו 'טוב מאוד... טוב מאוד...'.\n</p><p>לאחר יו\"ד שבט השתתף ביחידות נוספת במהלכה נכנסו לחדר הרבי כל הילדים שהגיעו ממונטריאול והרבי אמר בפניהם שיחה.\n</p><p>בבחרותו למד ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"תומכי תמימים מונטריאול\">תומכי תמימים מונטריאול</a> וב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" title=\"תומכי תמימים המרכזית 770\">תומכי תמימים המרכזית 770</a>. התחתן עם מרת הינדה, בת למשפחת גופין.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"תשל&quot;ו\">תשל\"ו</a> נשלח על ידי הרבי ל<a href=\"/index.php/%D7%A4%D7%A8%D7%A1\" class=\"mw-redirect\" title=\"פרס\">פרס</a> ולמזרח הרחוק.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a> נשלח על ידי הרבי לעיר <a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a> כחלק מקבוצת '<a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">השלוחים לארץ הקודש</a>' ובשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a> קיבל הוראה מהרבי למצוא לעצמו שליחות קבועה באחת מערי הארץ. בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> קיבל את ברכת הרבי להקים את מרכז חב\"ד ליובאוויטש בתל אביב, ולפתח מוסדות חינוך ובתי חב\"ד ברחבי העיר ת\"א – יפו.\n</p><p>בנוסף, מכהן כרב מרכז העיר תל אביב וכרב ובית הכנסת חב\"ד \"<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"בית כנסת גאולת ישראל\">גאולת ישראל</a>\".\n</p><p>הרב גרליצקי ייסד בתל אביב תלמוד תורה 'אהלי מנחם' על טהרת הקודש, גני ילדים, ישיבת חב\"ד \"חזון אליהו\" לבעלי תשובה, 'מכון שושנה' לבנות בעלות תשובה, כולל \"תפארת זקנים\" ומעל לחמישים בתי חב\"ד. מהשלוחים הבודדים שזכו להיות מכונים על ידי הרבי כ\"בא כוחי\"<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>שימש במשך תקופה כחבר <a href=\"/index.php/%D7%90%D7%A8%D7%92%D7%95%D7%9F_%D7%94%D7%92%D7%92\" class=\"mw-redirect\" title=\"ארגון הגג\">ארגון הגג</a> עד פירוקו על ידי הרבי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"חודש\">חודש</a> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a>. לאחר ביטול הארגון קיבל מענה קודש מיוחד מהרבי: <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"שכר על הפרישה מהארגון גג אבל לא ח\"ו פרישה מפעולות נגד פיקוח נפש דבני ישראל שיחיו. <a href=\"/index.php/%D7%90%D7%96%D7%9B%D7%99%D7%A8_%D7%A2%D7%9C_%D7%94%D7%A6%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"אזכיר על הציון\">אזכיר על הציון</a>\"</span> לאור תשובה זו הקים בהמשך את <a href=\"/index.php/%D7%A2%D7%9E%D7%95%D7%AA%D7%AA_%D7%A4%D7%99%D7%A7%D7%95%D7%97_%D7%A0%D7%A4%D7%A9\" class=\"mw-redirect\" title=\"עמותת פיקוח נפש\">עמותת פיקוח נפש</a> - ארגון קונגרס הרבנים למען השלום הכולל למעלה מ-400 גדולי רבני ישראל, שהוא עומד בראשו.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> חתם על פסק הקובע שהתקיימו אצל הרבי כל סימני ה<a href=\"/index.php/%D7%A8%D7%9E%D7%91%22%D7%9D\" title=\"רמב&quot;ם\">רמב\"ם</a> והוא \"בחזקת משיח\" ולכן מברכים אותו בברכת \"<a href=\"/index.php/%D7%99%D7%97%D7%99_%D7%94%D7%9E%D7%9C%D7%9A\" title=\"יחי המלך\">יחי המלך</a>\".\n</p><p>הרב גרליצקי השתתף ב<a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97_-_%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"כינוסי גאולה ומשיח - תשנ&quot;ה\">כינוס גאולה ומשיח</a> שהתקיים בכיכר מלכי ישראל ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"כ&quot;ח סיוון\">כ\"ח סיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> באירגונו של הרב <a href=\"/index.php/%D7%96%D7%9E%D7%A8%D7%95%D7%A0%D7%99_%D7%A6%D7%99%D7%A7\" class=\"mw-redirect\" title=\"זמרוני ציק\">זמרוני ציק</a>. ובהמשך אף חתם על <a href=\"/index.php/%D7%A4%D7%A1%D7%A7_%D7%94%D7%93%D7%99%D7%9F_%D7%A9%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%95%D7%90_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"פסק הדין שהרבי הוא מלך המשיח\">פסק הדין שהרבי הוא מלך המשיח</a>.\n</p><p>במשך השנים צבר הרב גרליצקי קשר קרוב ואישי עם אישי ציבור רבים, והוא מנצל את קשריו לעזרת השלוחים ברחבי הארץ, ולביסוס ופיתוח מוסדות חב\"ד <a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">בארץ</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p><b>בניו</b>\n</p>\n<ul><li>הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99\" title=\"מנחם מענדל גרליצקי\">מנחם מענדל גרליצקי</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"שליח הרבי\">שליח הרבי</a> ומנכ\"ל מוסדות חב\"ד ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a> ורב בית הכנסת סי אנד סאן</li>\n<li>הרב ישעיהו גרליצקי - משלוחי הרבי בתל אביב ומנהל <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> באוניברסיטת תל אביב<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99\" class=\"mw-redirect\" title=\"לוי יצחק גערליצקי\">לוי יצחק גערליצקי</a> - משלוחי הרבי בתל אביב ומנהל בית חב\"ד בשכונת צהלה בעיר</li>\n<li>הרב <a href=\"/index.php/%D7%A0%D7%98%D7%A2_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99\" title=\"נטע גרליצקי\">נטע גרליצקי</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a></li>\n<li>הרב נחום גרליצקי - <a href=\"/index.php?title=%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%9C%D7%91_%D7%94%D7%A2%D7%99%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שליח הרבי בלב העיר (הדף אינו קיים)\">שליח הרבי בלב העיר</a></li>\n<li>הרב ישראל גרליצקי - משלוחי הרבי בתל אביב ומנהל חב\"ד סנטר במרכז העיר</li>\n<li>הרב <a href=\"/index.php?title=%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שניאור זלמן גרליצקי (הדף אינו קיים)\">שניאור זלמן גרליצקי</a> - שליח הרבי ליישוב <a href=\"/index.php?title=%D7%A4%D7%95%D7%A8%D7%99%D7%94_%D7%A2%D7%99%D7%9C%D7%99%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"פוריה עילית (הדף אינו קיים)\">פוריה עילית</a> (הסמוכה לעיר טבריה)</li>\n<li>הרב שלום גרליצקי - לוד</li>\n<li>הרב ברוך גרליצקי - משפיע בישיבת <a href=\"/index.php/%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"אהלי תמימים כפר חב&quot;ד\">אהלי תמימים כפר חב\"ד</a> ומנהל אגף המבצעים ב<a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_(%D7%99%D7%A9%D7%A8%D7%90%D7%9C)\" class=\"mw-redirect\" title=\"צעירי אגודת חב&quot;ד (ישראל)\">צעירי חב\"ד</a></li></ul>\n<p><b>חתניו</b>\n</p>\n<ul><li>הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%90%D7%A8%D7%99%D7%94_%D7%A9%D7%9E%D7%A2%D7%A8%D7%9C%D7%99%D7%A0%D7%92\" class=\"mw-redirect\" title=\"מאיר אריה שמערלינג\">מאיר אריה שמערלינג</a> - משלוחי הרבי בתל אביב, וראש <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%96%D7%95%D7%9F_%D7%90%D7%9C%D7%99%D7%94%D7%95\" title=\"ישיבת חזון אליהו\">ישיבת חזון אליהו</a> <a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a></li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%90%D7%95%D7%9C_%D7%A8%D7%99%D7%99%D7%A6%D7%A2%D7%A1\" class=\"mw-redirect\" title=\"שאול רייצעס\">שאול רייצעס</a> - משלוחי הרבי בתל אביב, וראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D\" class=\"mw-redirect\" title=\"כולל אברכים\">כולל</a> <a href=\"/index.php/%D7%AA%D7%A4%D7%90%D7%A8%D7%AA_%D7%96%D7%A7%D7%A0%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7\" title=\"תפארת זקנים לוי יצחק\">תפארת זקנים לוי יצחק</a> בתל אביב</li>\n<li>הרב מרדכי חזן - משלוחי הרבי בחולון</li>\n<li>הרב מנחם מענדל אלטיין -