    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li>הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"שניאור זלמן גרליק\">שניאור זלמן גרליק</a> - <a href=\"/index.php/%D7%9E%D7%A8%D7%90_%D7%93%D7%90%D7%AA%D7%A8%D7%90\" class=\"mw-redirect\" title=\"מרא דאתרא\">רבה הראשון</a> של <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%97%D7%9D_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"ירוחם גרליק\">ירוחם גרליק</a> - מה<a href=\"/index.php/%D7%97%D7%95%D7%96%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"חוזרים\">חוזרים</a> של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"הרבי הרש&quot;ב\">הרבי הרש\"ב</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"אברהם שמואל גורליק\">אברהם שמואל גורליק</a> - ע\"פ הוראת הרבי בעל פרדס אתרוגים בכפר חב\"ד.</li>\n<li>הרב <a href=\"/index.php/%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" class=\"mw-redirect\" title=\"בן ציון גורליק\">בן ציון גורליק</a>- אבי משפחת גורליק החב\"דית הנחלי\"ת.</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%90%D7%99%D7%A8_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"חיים מאיר גרליק\">חיים מאיר גרליק</a> - מחסידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> שמסרו נפשם על הפצת יהדות ב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%94%D7%A1%D7%95%D7%91%D7%99%D7%99%D7%98%D7%99%D7%AA\" class=\"mw-redirect\" title=\"רוסיה הסובייטית\">רוסיה הסובייטית</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%92%D7%A8%D7%A9%D7%95%D7%9F_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"גרשון מענדל גרליק\">גרשון מענדל גרליק</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ורב העיר <a href=\"/index.php/%D7%9E%D7%99%D7%9C%D7%90%D7%A0%D7%95\" title=\"מילאנו\">מילאנו</a>, <a href=\"/index.php/%D7%90%D7%99%D7%98%D7%9C%D7%99%D7%94\" title=\"איטליה\">איטליה</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"לוי יצחק גרליק\">לוי יצחק גרליק</a> - רב קהילת האיחוד האירופי בבריסל, מרצה בעל שם עולמי.</li>\n<li>ר' <a href=\"/index.php/%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"בן ציון גרליק\">בן ציון גרליק</a> - תושב <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> שעסק בכריכת ספרים.</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"חיים אלעזר גורליק\">חיים אלעזר גורליק</a> - אביו של שד\"ב גרליק.</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" class=\"mw-redirect\" title=\"שלום דובער גרליק\">שלום דובער גרליק</a> - חבר של הלל זלצמן מנהל ארגון <a href=\"/index.php/%D7%97%D7%9E%22%D7%94\" class=\"mw-redirect\" title=\"חמ&quot;ה\">חמ\"ה</a></li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%9E%D7%A0%D7%A9%D7%94_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"מרדכי מנשה גורליק\">מרדכי מנשה גורליק</a> - אדריכל שעסק בשיפוץ האוהל של רבי <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"לוי יצחק שניאורסון\">לוי יצחק שניאורסון</a>, בניית <a href=\"/index.php/770_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"770 כפר חב&quot;ד\">770</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, ותכנון ה<a href=\"/index.php/%D7%90%D7%A8%D7%9E%D7%95%D7%9F_%D7%9C%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"ארמון למלך המשיח\">ארמון למלך המשיח</a></li>\n<li>הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"נחום יצחק גורליק\">נחום יצחק גורליק</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בקאזאן, <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a></li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_(%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94)\" title=\"מנחם מענדל גורליק (אור יהודה)\">מנחם מענדל גורליק (אור יהודה)</a> - מנהל רוחני בישיבה גדולה <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"תומכי תמימים אור יהודה (גדולה)\">תומכי תמימים אור יהודה</a> (בעבר, <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבה קטנה <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים אור יהודה (קטנה)\">תומכי תמימים אור יהודה</a>.)</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"שניאור זלמן גורליק\">שניאור זלמן גורליק</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ל<a href=\"/index.php/%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2\" title=\"באר שבע\">באר שבע</a></li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"אלעזר גורליק\">אלעזר גורליק</a> - חסיד ומגדל אתרוגים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a></li>\n<li>הרב <a href=\"/index.php/%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"זושא גורליק\">זושא גורליק</a> - משפיע בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים אור יהודה\">תומכי תמימים אור יהודה</a> (בעבר, משפיע בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"תומכי תמימים מוסקבה\">תומכי תמימים במוסקבה</a>)</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A8%D7%97%D7%9E%D7%99%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"ירחמיאל גורליק\">ירחמיאל גורליק</a> שליח הרבי בטיומן, סיביר</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_(%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F)\" title=\"חיים אלעזר גורליק (מלבורן)\">חיים אלעזר (לוזיק) גורליק</a> - מייסד ומנהל F.R.E.E - בית חב\"ד ליוצאי רוסיה במלבורן שבאוסטרליה.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/42px-Gnome-searchtool.svg.png 2x\" /></a></span> אם לא מצאתם ברשימת הפירושונים את הערך שהתכוונתם אליו, נסו:\n</p>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%93%D7%A4%D7%99%D7%9D_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C%D7%99%D7%9D_%D7%91/%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"מיוחד:דפים המתחילים ב/גרליק\">דפים ששמם מתחיל ב”גרליק“</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/intitle:%D7%92%D7%A8%D7%9C%D7%99%D7%A7%22\" title=\"מיוחד:חיפוש/intitle:גרליק&quot;\">דפים ששמם מכיל ”גרליק“</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/~%22%D7%92%D7%A8%D7%9C%D7%99%D7%A7%22\" title=\"מיוחד:חיפוש/~&quot;גרליק&quot;\">חיפוש ”גרליק“ בחב\"דפדיה</a></li></ul>\n</div>\n</td>\n</tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413050433\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.051 seconds\nReal time usage: 0.288 seconds\nPreprocessor visited no