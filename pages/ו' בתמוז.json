%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ו בתמוז\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ז בתמוז\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ח בתמוז\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ט בתמוז\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ו' בתמוז</b> הוא היום השישי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"תשל&quot;ו\">תשל\"ו</a> – הסתיים <a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%90%D7%A0%D7%98%D7%91%D7%94\" title=\"מבצע אנטבה\">מבצע אנטבה</a>, שזכה להתייחסויות נרחבות מ<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> כ<a href=\"/index.php/%D7%A0%D7%A1\" title=\"נס\">נס</a> גלוי המחייב התעוררות בתורה ומצוות (למרות טענות הפוכות שהעלו <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%90%D7%98%D7%9E%D7%A8\" title=\"חסידות סאטמר\">חסידי סאטמר</a>).</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a> – החלה הוצאתו לאור של <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a> - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_(%D7%9C%D7%99%D7%90%D7%95%D7%9F)\" title=\"שמואל גורביץ (ליאון)\">שמואל גורביץ</a>, שליח הרבי לעיר ליון שב<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%96\" title=\"תשי&quot;ז\">תשי\"ז</a> - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A0%D7%99%D7%A1%D7%9F_%D7%95%D7%95%D7%9C%D7%91%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"משה ניסן וולבובסקי\">משה ניסן וולבובסקי</a>, מפעילי צעירי אגודת חב\"ד בניו יורק, ורב בית הכנסת 'פרנקל שול' ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%97\" title=\"תשכ&quot;ח\">תשכ\"ח</a> - הרב <a href=\"/index.php/%D7%90%D7%9C%D7%9B%D7%A1%D7%A0%D7%93%D7%A8_%D7%91%D7%A8%D7%93%D7%94\" title=\"אלכסנדר ברדה\">אלכסנדר לייב ברדה</a>, נשיא <a href=\"/index.php/%D7%90%D7%99%D7%92%D7%95%D7%93_%D7%94%D7%A7%D7%94%D7%99%D7%9C%D7%95%D7%AA_%D7%94%D7%99%D7%94%D7%95%D7%93%D7%99%D7%95%D7%AA_%D7%A9%D7%9C_%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"איגוד הקהילות היהודיות של רוסיה\">איגוד הקהילות היהודיות של רוסיה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a> - הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%97%D7%94_%D7%A7%D7%A8%D7%99%D7%A6%27%D7%91%D7%A1%D7%A7%D7%99\" title=\"מאיר שמחה קריצ&#39;בסקי\">מאיר שמחה קריצ'בסקי</a>, מנהל בית חב\"ד 'בית משיח' בשכונה ה' ב<a href=\"/index.php/%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2\" title=\"באר שבע\">באר שבע</a>, ומשפיע לשעבר ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים באר שבע (קטנה)\">ישיבת תומכי תמימים בעיר</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a> - ר' <a href=\"/index.php/%D7%A0%D7%93%D7%91_%D7%91%D7%9B%D7%A8\" title=\"נדב בכר\">נדב בכר</a>, מוזיקאי חסיד חב\"ד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%98\" title=\"תשמ&quot;ט\">תשמ\"ט</a> - הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A9%D7%95%D7%95%D7%A8%D7%A5\" title=\"יעקב יהודה שוורץ\">יעקב יהודה שוורץ</a>, שליח הרבי ומנהל <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> ומרכז 'בית מנחם' בשכונת חפציבה ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9\" title=\"בית שמש\">בית שמש</a>, ומייסד מכון 'הפרשה בחיי' וקו טלפוני לשיעורי חסידות.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> - הרב <a href=\"/index.php/%D7%93%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"דב אליעזר הבלין\">דב אליעזר הבלין</a>, חסיד חב\"ד תושב <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, בעל תפילה ואיש חסד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%93\" class=\"mw-redirect\" title=\"תשמ&quot;ד\">תשד\"מ</a> – הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%96%D7%95%D7%91%D7%A8%D7%95%D7%91%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"אהרון זוברובסקי\">אהרון זוברובסקי</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"סמרקנד\">סמרקנד</a> שפעל ב<a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%A8%D7%95%D7%AA_%D7%A0%D7%A4%D7%A9\" title=\"מסירות נפש\">מסירות נפש</a> להכשיר <a href=\"/index.php/%D7%A1%D7%95%D7%A4%D7%A8_%D7%A1%D7%AA%22%D7%9D\" title=\"סופר סת&quot;ם\">סופרי סת\"ם</a> <a href=\"/index.php/%D7%99%D7%A8%D7%90%D7%AA_%D7%A9%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"יראת שמים\">יראי שמים</a> ב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a> הסובייטית.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A9%D7%94_%D7%97%D7%A0%D7%96%D7%99%D7%9F\" title=\"יעקב משה חנזין\">יעקב משה חנזין</a>, חסיד חב\"ד תושב <a href=\"/index.php/%D7%A4%D7%AA%D7%97_%D7%AA%D7%A7%D7%95%D7%95%D7%94\" title=\"פתח תקווה\">פתח תקווה</a> שהיה בעל ידע עצום ונחשב לאחד מגדולי הגאונים החב\"דיים בדור האחרון.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ו' בתמוז - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ה<a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%94\" class=\"mw-redirect\" title=\"מצוה\">מצוה</a> נמשכת על ידי ה<a href=\"/index.php/%D7%9E%D7%A7%D7%99%D7%A3\" class=\"mw-redirect\" title=\"מקיף\">מקיף</a> שבמצות עצמם. מצות <a href=\"/index.php/%D7%A6%D7%93%D7%A7%D7%94\" title=\"צדקה\">צדקה</a>, על דרך משל, היא מצוה כוללת, אשר כל המצות נקראות בשם צדקה. ומהאי טעמא נכון במאד לתת קודם כל מצוה פרוטה לצדקה, שהוא המשכת המקיף ב<a href=\"/index.php/%D7%A4%D7%A0%D7%99%D7%9E%D7%99\" class=\"mw-redirect\" title=\"פנימי\">פנימי</a>. ומכל מקום הוי מקיף הקרוב, מה שאין כן <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> שהיא מקיף הרחוק ופעולתו נעלה יותר.\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413185640\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.031 seconds\nReal time usage: 0.127 seconds\nPreprocessor visited node count: 101/1000000\nPost‐expand include size: 5863/2097152 bytes\nTemplate argument size: 698/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   76.694      1 -total\n 59.64%   45.740      1 תבנית:חודש_תמוז\n 43.33%   33.232      1 תבנית:לוח_שנה_חסר\n 40.11%   30.765      1 תבנית:להיום_יום\n 27.47%   21.065      1 תבנית:כתב_קטן\n 17.72%   13.588      1 תבנית:היום_יום/ו&#039;_תמוז\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:17116-0!canonical and timestamp 20260413185640 and revision id 790086. Rendering was triggered because: unknown\n -->\n</div>"
