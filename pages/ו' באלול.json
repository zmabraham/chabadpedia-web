\n<p><b>ו' באלול</b> הוא היום השישי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>תי\"ד – רבינו <a href=\"/index.php?title=%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91_%D7%9C%D7%99%D7%A4%D7%9E%D7%9F_%D7%94%D7%9C%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יום טוב ליפמן הלר (הדף אינו קיים)\">יום טוב ליפמן הלר</a>, רבה של <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%A7%D7%90\" class=\"mw-redirect\" title=\"קראקא\">קראקא</a>, מחבר ספר 'תוספות יום טוב', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_(%D7%A9%D7%99%D7%99%D7%A2)_%D7%A1%D7%92%D7%9C\" title=\"יהושע (שייע) סגל\">יהושע (שייע) סגל</a>, חבר הנהלת <a href=\"/index.php/%D7%A1%D7%A0%D7%99%D7%A3_%D7%A7%D7%94%22%D7%AA_%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"סניף קה&quot;ת ארץ הקודש\">סניף קה\"ת ארץ הקודש</a>, חבר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ועד כפר חב&quot;ד\">ועד כפר חב\"ד</a> ומקהלת <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"אגודת חסידי חב&quot;ד בישראל\">אגודת חסידי חב\"ד בארץ הקודש</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%94\" title=\"תשכ&quot;ה\">תשכ\"ה</a> – הרב <a href=\"/index.php/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%A4%D7%99%D7%A9%D7%9C_%D7%93%D7%9E%D7%99%D7%9B%D7%95%D7%91%D7%A1%D7%A7%D7%99_(%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%9F)\" class=\"mw-redirect\" title=\"אפרים פישל דמיכובסקי (הראשון)\">אפרים פישל דמיכובסקי (הראשון)</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A0%D7%97_%D7%A7%D7%A8%D7%90%D7%A0%D7%A5\" title=\"יעקב נח קראנץ\">יעקב נח קראנץ</a>, משלוחי הרבי ב<a href=\"/index.php/%D7%93%D7%98%D7%A8%D7%95%D7%99%D7%98\" title=\"דטרויט\">דטרויט</a> ובריצ'מונד שבוירג'יניה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%96\" title=\"תשנ&quot;ז\">תשנ\"ז</a> – הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%93%D7%91_%D7%A1%D7%95%D7%A4%D7%A8%D7%99%D7%9F\" title=\"אהרן דב סופרין\">אהרן דוב סופרין</a>, מ<a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"שלוחי הרבי\">שלוחי הרבי</a> ומנהל החינוך ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_(%D7%9C%D7%95%D7%A0%D7%93%D7%95%D7%9F)\" title=\"בית ליובאוויטש (לונדון)\">בית ליובאוויטש</a> ב<a href=\"/index.php/%D7%9C%D7%95%D7%A0%D7%93%D7%95%D7%9F\" title=\"לונדון\">לונדון</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%98\" title=\"תרצ&quot;ט\">תרצ\"ט</a> – הילד <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%A0%D7%90%D7%94\" title=\"שניאור זלמן דובער נאה\">שניאור זלמן דובער נאה</a> בנו של הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%99%D7%99%D7%9D_%D7%A0%D7%90%D7%94\" title=\"אברהם חיים נאה\">אברהם חיים נאה</a>, נרצח על ידי ערבים.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%94%D7%9B%D7%94%D7%9F\" title=\"מנחם הכהן\">מנחם הכהן</a> רב במושבים וח\"כ במערך.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%91%D7%9C%D7%A1%D7%95%D7%A4%D7%A1%D7%A7%D7%99\" title=\"אהרון בלסופסקי\">אהרון בלסופסקי</a>,היה אמן ובעל מנגן רב רגש שחיבר את הניגון <a href=\"/index.php/%D7%90%D7%95%D7%94%D7%91_%D7%94%27_%D7%A9%D7%A2%D7%A8%D7%99_%D7%A6%D7%99%D7%95%D7%9F_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" class=\"mw-redirect\" title=\"אוהב ה&#39; שערי ציון (ניגון)\">אוהב ה' שערי ציון (ניגון)</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ו' באלול - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">צמח צדק</a> סיפר: דער <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a> האָט זייער האַלט געהאַט ליכטיקייט, ואמר: '<a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a>' ב<a href=\"/index.php/%D7%92%D7%99%D7%9E%D7%98%D7%A8%D7%99%D7%90\" class=\"mw-redirect\" title=\"גימטריא\">גימטריא</a> 'רז', דער וואָס ווייס דעם <a href=\"/index.php?title=%D7%A1%D7%95%D7%93&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"סוד (הדף אינו קיים)\">סוד</a> וואָס אין יעדער זאַך, קאָן ליכטיג מאַכן.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a> סיפר: ה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a> מאד חיבב <a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a>, ואמר: 'אור' ב<a href=\"/index.php/%D7%92%D7%99%D7%9E%D7%98%D7%A8%D7%99%D7%90\" class=\"mw-redirect\" title=\"גימטריא\">גימטריא</a> 'רז', מי שיודע את ה<a href=\"/index.php?title=%D7%A1%D7%95%D7%93&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"סוד (הדף אינו קיים)\">סוד</a> שבכל דבר, מסוגל להאיר.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414045058\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.024 seconds\nReal time usage: 0.031 seconds\nPreprocessor visited node count: 79/1000000\nPost‐expand include size: 6035/2097152 bytes\nTemplate argument size: 696/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   13.038      1 -total\n 61.79%    8.056      1 תבנית:חודש_אלול\n 45.92%    5.987      1 תבנית:לוח_שנה_חסר\n 37.01%    4.826      1 תבנית:להיום_יום\n 20.83%    2.716      1 תבנית:כתב_קטן\n 15.26%    1.989      1 תבנית:היום_יום/ו&#039;_אלול\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:18795-0!canonical and timestamp 20260414045058 and revision id 831336. Rendering was triggered because: page-view\n -->\n</div>"
