tyle=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%A8%D7%91%D7%94\" class=\"mw-redirect\" title=\"רבה\">רבה</a> • <a href=\"/index.php/%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3\" title=\"רב יוסף\">רב יוסף</a> • <a href=\"/index.php/%D7%A8%D7%91%D7%94_%D7%91%D7%A8_%D7%A8%D7%91_%D7%94%D7%95%D7%A0%D7%90\" title=\"רבה בר רב הונא\">רבה בר רב הונא</a> • <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%99%D7%A8%D7%9E%D7%99%D7%94\" title=\"רבי ירמיה\">רבי ירמיה</a> • <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%AA%D7%A0%D7%97%D7%95%D7%9E%D7%90\" title=\"רבי תנחומא\">רבי תנחומא</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\"><span style=\"white-space: nowrap;\">דור שישי</span>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%90%D7%91%D7%99%D7%99\" title=\"אביי\">אביי</a> • <a href=\"/index.php/%D7%A8%D7%91%D7%90\" title=\"רבא\">רבא</a> • <a href=\"/index.php?title=%D7%A8%D7%9E%D7%99_%D7%91%D7%A8_%D7%97%D7%9E%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רמי בר חמא (הדף אינו קיים)\">רמי בר חמא</a> • <a href=\"/index.php?title=%D7%A8%D7%91_%D7%90%D7%97%D7%90_%D7%91%D7%A8_%D7%99%D7%A2%D7%A7%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רב אחא בר יעקב (הדף אינו קיים)\">רב אחא בר יעקב</a> • <a href=\"/index.php/%D7%A8%D7%91_%D7%A1%D7%A4%D7%A8%D7%90\" title=\"רב ספרא\">רב ספרא</a> • <a href=\"/index.php?title=%D7%A8%D7%91_%D7%90%D7%99%D7%93%D7%99_%D7%91%D7%A8_%D7%90%D7%91%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רב אידי בר אבין (הדף אינו קיים)\">רב אידי בר אבין</a> • <a href=\"/index.php?title=%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%90_%D7%91%D7%A8_%D7%90%D7%91%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רב חייא בר אבין (הדף אינו קיים)\">רב חייא בר אבין</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\"><span style=\"wh