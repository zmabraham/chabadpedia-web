itle=\"כ&quot;ז בטבת\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%98%D7%91%D7%AA\" title=\"כ&quot;ח בטבת\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%98%D7%91%D7%AA\" title=\"כ&quot;ט בטבת\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ב' בטבת</b> הוא היום השני ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">חודש טבת</a> והיום השביעי של <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%97%D7%A0%D7%95%D7%9B%D7%94\" class=\"mw-redirect\" title=\"חג החנוכה\">חג החנוכה</a>. בליל יום זה מדליקים שמונה נרות (בשנים שיש בהם גם <a href=\"/index.php/%D7%9C%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"ל&#39; בכסלו\">ל' בכסלו</a>, יום זה הוא היום השמיני והאחרון של חג החנוכה (<a href=\"/index.php/%D7%96%D7%90%D7%AA_%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"זאת חנוכה\">זאת חנוכה</a>)).\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%98\" title=\"תרמ&quot;ט\">תרמ\"ט</a> - רבי יעקב צבי מפוריסוב, מחבר ספר 'עטרה לראש צדיק', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%22%D7%A9\" title=\"ת&quot;ש\">ת\"ש</a> - <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> ניצל מ<a href=\"/index.php/%D7%A4%D7%95%D7%9C%D7%99%D7%9F\" title=\"פולין\">פולין</a> בימי <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%99%D7%94\" title=\"מלחמת העולם השנייה\">מלחמת העולם השנייה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a> - נשיא ארה\"ב <a href=\"/index.php/%D7%93%D7%95%D7%A0%D7%9C%D7%93_%D7%98%D7%A8%D7%90%D7%9E%D7%A4\" title=\"דונלד טראמפ\">דונלד טראמפ</a> הכריז על שחרורו של ר' <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A8%D7%95%D7%91%D7%A9%D7%A7%D7%99%D7%9F\" title=\"שלום מרדכי רובשקין\">שלום מרדכי רובשקין</a> מהכלא.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A4\" title=\"תר&quot;פ\">תר\"פ</a> - ר' <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%9C%D7%95%D7%99%D7%9F\" title=\"בנימין לוין\">בנימין לוין</a> ממייסדי <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%97\" class=\"mw-redirect\" title=\"תרצ&quot;ח\">תרח\"צ</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A9%D7%95%D7%A0%D7%A7%D7%99%D7%9F\" title=\"אברהם יצחק ששונקין\">אברהם יצחק ששונקין</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> קהילת חב\"ד ביישוב <a href=\"/index.php/%D7%90%D7%91%D7%99%D7%98%D7%9C\" title=\"אביטל\">אביטל</a> שבחבל תענך, ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> במחלקה לדוברי רוסית בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%98%D7%91%D7%AA&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%99%22%D7%96\" title=\"תרי&quot;ז\">תרי\"ז</a> - הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9B%D7%95%D7%9C%D7%99_%D7%A1%D7%9C%D7%95%D7%A0%D7%99%D7%9D\" class=\"mw-redirect\" title=\"יעקב כולי סלונים\">יעקב כולי סלונים</a>, בעלה של <a href=\"/index.php/%D7%9E%D7%A0%D7%95%D7%97%D7%94_%D7%A8%D7%97%D7%9C_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99)\" class=\"mw-redirect\" title=\"מנוחה רחל (בת אדמו&quot;ר האמצעי)\">מנוחה רחל</a>, בתו של האדמו\"ר האמצעי, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A0%D7%94_%D7%90%D7%99%D7%99%D7%93%D7%9C%D7%A7%D7%95%D7%A4\" title=\"יונה איידלקופ\">יונה איידלקופ</a>, ממייסדי כפר חב\"ד,ממנהלי חיידרי תורה אור ושהרבי התבטא עליו יונה עושה איידישקייט.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> - הרב <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"צבי הירש חיטריק\">צבי הירש חיטריק</a>, השליח הראשון למדינת בראזיל, ונשיא ארגון '<a href=\"/index.php/%D7%A4%D7%A8%22%D7%99\" class=\"mw-redirect\" title=\"פר&quot;י\">פר\"י</a>', נפטר.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ב' בטבת - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>ז' ד<a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"חנוכה\">חנוכה</a></i>\n<p>מלחמת היונים היתה \"להשכיחם תורתך ולהעבירם מחוקי רצונך\" וכמאמר (בראשית רבא פרק ט\"ז) כתבו כו' שאין לכם חלק באלקי ישראל. כל המלחמה היתה נגד <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אלקות\">אלקות</a>, זאל מען לערנען תורה, זאל מען מקיים זיין <a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מצות\">מצות</a> ה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%98%D7%99%D7%9D\" title=\"משפטים\">משפטים</a> וה<a href=\"/index.php/%D7%A2%D7%93%D7%95%D7%AA\" title=\"עדות\">עדות</a>, רק שלא להזכיר שהיא תורת ה' ושהמצות הם חקי רצונו יתברך, ניט דערמאנען אין תורה ומצוות דעם ענין פון ג-טלכקייט (=<b>תרגום ה<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: שילמדו <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>, שיקיימו <a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מצוות\">מצוות</a> ה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%98%D7%99%D7%9D\" title=\"משפטים\">משפטים</a> וה<a href=\"/index.php/%D7%A2%D7%93%D7%95%D7%AA\" title=\"עדות\">עדות</a> . . לא להזכיר את עניין ה<a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A7%D7%95%D7%AA\" title=\"אלוקות\">אלוקות</a> שבתורה ומצוות).\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413183544\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.028 seconds\nReal time usage: 0.036 seconds\nPreprocessor visited node count: 95/1000000\nPost‐expand include size: 6385/2097152 bytes\nTemplate argument size: 625/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   14.825      1 -total\n 65.21%    9.668      1 תבנית:חודש_טבת\n 43.57%    6.459      1 תבנית:לוח_שנה_חסר\n 33.78%    5.008      1 תבנית:להיום_יום\n 20.07%    2.976      1 תבנית:כתב_קטן\n 15.57%    2.308      1 תבנית:היום_יום/ב&#039;_טבת\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:20094-0!canonical and timestamp 20260413183544 and revision id 756943. Rendering was triggered because: page-view\n -->\n</div>"
