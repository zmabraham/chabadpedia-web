      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c0/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c0/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg 1.5x, /images/thumb/c/c0/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg 2x\" /></a><figcaption>הרב רוזנבלט (<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a>)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/0/02/%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98.jpg/220px-%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/0/02/%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98.jpg/330px-%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98.jpg 1.5x, /images/thumb/0/02/%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98.jpg/440px-%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98.jpg 2x\" /></a><figcaption>הרב רוזנבלט בכינוס הרבנים נגד <a href=\"/index.php/%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%99\" title=\"מיהו יהודי\">רפורמות הגיור</a>, לצד חמיו הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A2%D7%99%D7%94%D7%95_%D7%94%D7%A8%D7%A6%D7%9C\" title=\"ישעיהו הרצל\">ישעיהו הרצל</a> (<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a>)</figcaption></figure>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Rozenblat_hachtara.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/32/Rozenblat_hachtara.jpg/220px-Rozenblat_hachtara.jpg\" decoding=\"async\" width=\"220\" height=\"138\" class=\"mw-file-element\" srcset=\"/images/thumb/3/32/Rozenblat_hachtara.jpg/330px-Rozenblat_hachtara.jpg 1.5x, /images/thumb/3/32/Rozenblat_hachtara.jpg/440px-Rozenblat_hachtara.jpg 2x\" /></a><figcaption>הרב יוסף חיים רוזנבלט בטקס ההכתרה, לצד חמיו הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A2%D7%99%D7%94%D7%95_%D7%94%D7%A8%D7%A6%D7%9C\" title=\"ישעיהו הרצל\">ישעיהו הרצל</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%95%D7%AA_%D7%94%D7%A8%D7%90%D7%A9%D7%99%D7%AA\" class=\"mw-redirect\" title=\"הרבנות הראשית\">הרב הראשי</a> הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%91%D7%A7%D7%A9%D7%99_%D7%93%D7%95%D7%A8%D7%95%D7%9F\" title=\"אליהו בקשי דורון\">אליהו בקשי דורון</a></figcaption></figure>\n<p>הרב <b>יוסף חיים רוזנבלט</b> (נולד ב<a href=\"/index.php/%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ט&#39; בסיוון\">ט' בסיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%98\" title=\"תשכ&quot;ט\">תשכ\"ט</a>, 1969) הוא <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> לגליל התחתון, רבה של המועצה האזורית גליל תחתון וחבר <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%22%D7%93\" title=\"מכון הלכה חב&quot;ד\">מכון הלכה חב\"ד</a>.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%98%27_%D7%A1%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ט&#39; סיון\">ט' סיון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%98\" title=\"תשכ&quot;ט\">תשכ\"ט</a> לרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98\" title=\"מרדכי רוזנבלט\">מרדכי רוזנבלט</a> ולמלכה.\n</p><p>בצעירותו למד בישיבת קול תורה בירושלים ולאחר מכן עבר לישיבת תומכי תמימים בכפר חב\"ד, ולקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%98\" title=\"תשמ&quot;ט\">תשמ\"ט</a> נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" title=\"תומכי תמימים המרכזית 770\">תומכי תמימים המרכזית 770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>לאחר נישואיו עם רעייתו מרת חוה בת הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A2%D7%99%D7%94%D7%95_%D7%94%D7%A8%D7%A6%D7%9C\" title=\"ישעיהו הרצל\">ישעיהו הרצל</a> רב העיר <a href=\"/index.php/%D7%A0%D7%95%D7%A3_%D7%94%D7%92%D7%9C%D7%99%D7%9C\" title=\"נוף הגליל\">נוף הגליל</a>, החל לפעול בשליחות הרבי ביישוב <a href=\"/index.php/%D7%92%D7%91%D7%A2%D7%AA_%D7%90%D7%91%D7%A0%D7%99\" title=\"גבעת אבני\">גבעת אבני</a>, וכעבור מספר שנים התמנה כשליח אזורי וכרבה של המועצה האזורית גליל תחתון.\n</p><p>תחת השגחתו, פועל מערך כשרות המעניק השגחה למוצרים המיוצרים במפעלים המצויים בשטח השיפוט של המועצה האזורית בה מכהן כרב, ביניהם מפעלים מפורסמים כדוגמת <a href=\"/index.php/%D7%AA%D7%94\" title=\"תה\">תה</a> ויסוצקי, פרי ניר, משקאות בלו ועוד.\n</p><p>הצטרף לרבנים שחתמו על <a href=\"/index.php/%D7%A4%D7%A1%D7%A7_%D7%94%D7%93%D7%99%D7%9F_%D7%A9%D7%94%D7%A8%D7%91%D7%99_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"פסק הדין שהרבי מלך המשיח\">פסק הדין שהרבי מלך המשיח</a> ואף על <a href=\"/index.php/%D7%A4%D7%A1%D7%A7_%D7%94%D7%93%D7%99%D7%9F_%D7%A9%D7%94%D7%A8%D7%91%D7%99_%D7%97%D7%99_%D7%95%D7%A7%D7%99%D7%99%D7%9D\" title=\"פסק הדין שהרבי חי וקיים\">פסק הדין שהרבי חי וקיים</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> הצטרף לרבני <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%22%D7%93\" title=\"מכון הלכה חב&quot;ד\">מכון הלכה חב\"ד</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> מונה על ידי מועצת הרבנות הראשית לישראל למ\"מ ורב נותן ההכשר גם במועצה האזורית מטה אשר.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>חתנו, הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%A8%D7%91%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל פרבר (הדף אינו קיים)\">מנחם מענדל פרבר</a> - ר\"מ בישיבה קטנה <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד ליובאוויטש צפת (קטנה)\">חסידי חב\"ד ליובאוויטש צפת</a>, עורך הספר \"פרדס ישעיהו\" של חמיו של הרב רוזנבלט, ומחבר קונטרס \"ברכות ההתגלות\" - על הברכות בעת ראית פני מלך המשיח</li>\n<li>חתנו, הרב משה יצחק העכט - שליח הרבי בקיבוץ בית קשת שבגליל התחתון</li>\n<li>חתנו, הרב שמואל ליסון - מחנך בתלמוד תורה חב\"ד נוף הגליל ור\"מ בישיבת חב\"ד בעיר</li>\n<li>בנו, הרב מרדכי רוזנבלט - שליח הרבי במושב מצפה שבגליל התחתון</li>\n<li>בנו, הרב דובער רוזנבלט - שליח הרבי לשכונה ב<a href=\"/index.php/%D7%A0%D7%AA%D7%99%D7%91%D7%95%D7%AA\" title=\"נתיבות\">נתיבות</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%98&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://machon-halacha.co.il/רבנים/הרב-יוסף-חיים-רוזנבלט/\"><b>פסיקות, תשובות, מאמרים וסרטונים</b></a> של הרב רוזנבלט באתר פורטל ההלכה של מכון הלכה חב\"ד <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%22%D7%93\" title=\"קישור לאתר מכון הלכה\"><img alt=\"קישור לאתר מכון הלכה\" src=\"/images/thumb/a/ad/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg/32px-%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg\" decoding=\"async\" width=\"32\" height=\"22\" class=\"mw-file-element\" srcset=\"/images/thumb/a/ad/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg/48px-%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg 1.5x, /images/thumb/a/ad/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg/64px-%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg 2x\" /></a></span>.</li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/tag/הרב-יוסף-חיים-רוזנבלט\">תגיות: הרב יוסף חיים רוזנבלט</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li></ul>\n<p><br />\n</p>\n<table class=\"mw-collapsible autocollapse\" style=\"border: 1px #aaaaaa solid; background-color: #f9f9f9; text-align: center; clear: both; width: 75%; margin: 0.5em auto;\" cellspacing=\"3\">\n<tbody><tr>\n<th style=\"background-color:#b0c4de; background:#b0c4de; padding-top: 0.1em; padding-bottom: 0.1em; text-align: center; color: black; font-weight: bold; font-size: 100%\"><a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%22%D7%93\" title=\"מכון הלכה חב&quot;ד\">רבני מכון הלכה חב\"ד</a>\n</th></tr>\n<tr>\n<td style=\"padding-top: 3px; padding-bottom: 3px; background-color: #f9f9f9; font-size: 95%\">\n<table style=\"width: 98%; background-color: transparent; margin: auto; padding: 0; text-align: center;\" cellpadding=\"0\" cellspacing=\"0\">\n<tbody><tr>\n<td style=\"padding-left: 1em;\"><a href=\"/index.php/%D7%9E%D7%99%D7%9B%D7%90%D7%9C_%D7%90%D7%91%D7%99%D7%A9%D7%99%D7%93\" title=\"מיכאל אבישיד\">מיכאל אבישיד</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%92%D7%93%D7%9C%D7%99%D7%94_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"גדליה אקסלרוד\">גדליה אקסלרוד</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%91%D7%A8%D7%95%D7%93\" class=\"mw-redirect\" title=\"אליעזר ברוד\">אליעזר ברוד</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%90%D7%9C_%D7%92%D7%A8%D7%90%D7%91%D7%A1%D7%A7%D7%99\" ti