      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li><a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"יצחק אבינו\">יצחק אבינו</a> - בן <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"אברהם אבינו\">אברהם אבינו</a> ו<a href=\"/index.php/%D7%A9%D7%A8%D7%94_%D7%90%D7%9E%D7%A0%D7%95\" title=\"שרה אמנו\">שרה אמנו</a> אביהם של <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"יעקב אבינו\">יעקב אבינו</a> ו<a href=\"/index.php/%D7%A2%D7%A9%D7%95\" class=\"mw-redirect\" title=\"עשו\">עשו</a> וחמיה של <a href=\"/index.php/%D7%A8%D7%97%D7%9C_%D7%90%D7%9E%D7%A0%D7%95\" title=\"רחל אמנו\">רחל אמנו</a> ו<a href=\"/index.php/%D7%9C%D7%90%D7%94_%D7%90%D7%9E%D7%A0%D7%95\" title=\"לאה אמנו\">לאה אמנו</a></li>\n<li><a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%A4%D7%97%D7%90\" title=\"רבי יצחק נפחא\">רבי יצחק נפחא</a> תנא</li>\n<li><a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%99%D7%A6%D7%97%D7%A7_(%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D)\" class=\"mw-disambig\" title=\"רבי יצחק (פירושונים)\">רבי יצחק (פירושונים)</a></li>\n<li><a href=\"/index.php/%D7%A8%D7%99%22%D7%A3\" title=\"רי&quot;ף\">רבינו יצחק אלפסי (הרי\"ף)</a> - מרבותינו הראשונים ומגדולי פוסקי ההלכה בכל הדורות, ואחד משלושת עמודי ההוראה של ה<a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A\" title=\"שולחן ערוך\">שולחן ערוך</a>.</li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%90%D7%91%D7%95%D7%A7%D7%A1%D7%99%D7%A1\" title=\"יצחק מרדכי אבוקסיס\">יצחק מרדכי אבוקסיס</a></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%91%D7%99%D7%92%D7%93%D7%95%D7%A8_%D7%90%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"יצחק אביגדור אורנשטיין\">יצחק אביגדור אורנשטיין</a></li>\n<li><a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%91%D7%A8%D7%91%D7%A0%D7%90%D7%9C\" title=\"רבי יצחק אברבנאל\">רבי יצחק אברבנאל</a></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%94%D7%A8%D7%9F_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"יצחק אהרן אקסלרוד\">יצחק אהרן אקסלרוד</a></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%90%D7%95%D7%A4%D7%A0%D7%A8\" title=\"יצחק אליהו אופנר\">יצחק אליהו אופנר</a></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%90%D7%A4%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"יצחק אייזיק אפשטיין\">יצחק אייזיק אפשטיין</a></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%91%D7%94%D7%A8%22%D7%93\" title=\"יצחק אייזיק בהר&quot;ד\">יצחק אייזיק בהר\"ד</a></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%94%D7%9B%D7%94%D7%9F\" title=\"יצחק אייזיק הכהן\">יצחק אייזיק הכהן</a></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%94%D7%A8%D7%A6%D7%95%D7%92\" title=\"יצחק אייזיק הרצוג\">יצחק אייזיק הלוי הרצוג הרב הראשי לישראל</a>\n<ul><li>נכדו <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%A8%D7%A6%D7%95%D7%92\" title=\"יצחק הרצוג\">יצחק בוז'י הרצוג נשיא מדינת ישראל</a></li></ul></li>\n<li>רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%9C%D7%97%D7%A0%D7%9F_%D7%A1%D7%A4%D7%A7%D7%98%D7%95%D7%A8\" title=\"יצחק אלחנן ספקטור\">יצחק אלחנן ספקטור</a> רשכבה\"ג</li>\n<li><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%91%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יצחק נבון (הדף אינו קיים)\">יצחק נבון</a> נשיא מדינת ישראל</li>\n<li><a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%9E%D7%99%D7%A8\" title=\"יצחק שמיר\">יצחק שמיר</a> ראש ממשלת ישראל ה-7</li>\n<li><a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%91%D7%99%D7%9F\" title=\"יצחק רבין\">יצחק רבין</a> ראש ממשלת ישראל ה-5</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/42px-Gnome-searchtool.svg.png 2x\" /></a></span> אם לא מצאתם ברשימת הפירושונים את הערך שהתכוונתם אליו, נסו:\n</p>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%93%D7%A4%D7%99%D7%9D_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C%D7%99%D7%9D_%D7%91/%D7%99%D7%A6%D7%97%D7%A7\" title=\"מיוחד:דפים המתחילים ב/יצחק\">דפים ששמם מתחיל ב”יצחק“</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/intitle