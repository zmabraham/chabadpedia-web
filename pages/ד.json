      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table border=\"0\" cellpadding=\"2\" cellspacing=\"0\" style=\"margin: 0 1.5em 0 0; float:left; clear:left; border:1px solid #aaa; background-color:#f9f9f9; width:200px; direction:rtl;\">\n\n<tbody><tr>\n<th colspan=\"7\" style=\"background:#9BCB65; text-align:center\">האות ד\n</th></tr>\n<tr>\n<td colspan=\"7\" style=\"background:white; text-align:center; padding:0;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%9C%D7%99%D7%AA.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/41/%D7%93%D7%9C%D7%99%D7%AA.jpg/150px-%D7%93%D7%9C%D7%99%D7%AA.jpg\" decoding=\"async\" width=\"150\" height=\"85\" class=\"mw-file-element\" srcset=\"/images/thumb/4/41/%D7%93%D7%9C%D7%99%D7%AA.jpg/225px-%D7%93%D7%9C%D7%99%D7%AA.jpg 1.5x, /images/thumb/4/41/%D7%93%D7%9C%D7%99%D7%AA.jpg/300px-%D7%93%D7%9C%D7%99%D7%AA.jpg 2x\" /></a></span>\n</td></tr>\n<tr>\n<th colspan=\"7\" style=\"background:#BFD7FF; text-align:center\"><a href=\"/index.php/%D7%90%D7%95%D7%AA%D7%99%D7%95%D7%AA_(%D7%91%D7%A0%D7%A4%D7%A9)\" title=\"אותיות (בנפש)\">אותיות</a> <a href=\"/index.php/%D7%90%D7%95%D7%AA%D7%99%D7%95%D7%AA_%D7%94%D7%90%D7%9C%22%D7%A3_%D7%91%D7%99%22%D7%AA\" title=\"אותיות האל&quot;ף בי&quot;ת\">האל\"ף בי\"ת</a>\n</th></tr>\n<tr style=\"text-align:center;\">\n<td style=\"width:17%\"><a href=\"/index.php/%D7%90\" title=\"א\">א</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%91\" title=\"ב\">ב</a>\n</td>\n<td style=\"width:16%\"><a href=\"/index.php/%D7%92\" title=\"ג\">ג</a>\n</td>\n<td style=\"width:16%\"><a class=\"mw-selflink selflink\">ד</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%94\" title=\"ה\">ה</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%95\" title=\"ו\">ו</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td><a href=\"/index.php/%D7%96\" title=\"ז\">ז</a>\n</td>\n<td><a href=\"/index.php/%D7%97\" title=\"ח\">ח</a>