/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ז בתשרי\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ח בתשרי\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ט בתשרי\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ל&#39; בתשרי\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ט&#34;ז בתשרי</b> הוא היום השישה עשר\nבחודש הראשון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;והיום השני של <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A1%D7%95%D7%9B%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג הסוכות\">חג הסוכות</a> (חול המועד ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a> ובחו\"ל <a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91_%D7%A9%D7%A0%D7%99_%D7%A9%D7%9C_%D7%92%D7%9C%D7%95%D7%99%D7%95%D7%AA\" title=\"יום טוב שני של גלויות\">יום טוב שני של גלויות</a>).\n</p><p>תאריך זה חל בתקופת תשרי&#160;והוא יכול לחול בימים&#160;ראשון, שלישי, רביעי ושישי.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A0%22%D7%97\" title=\"תנ&quot;ח\">תנ\"ח</a> (01/10/1697 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי משה זכות ממנטובה - <a href=\"/index.php/%D7%90%D7%99%D7%98%D7%9C%D7%99%D7%94\" title=\"איטליה\">איטליה</a>, מחבר ספר 'שורשי השמות', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%98\" title=\"תרל&quot;ט\">תרל\"ט</a> (13/10/1878 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יצחק דב הלוי במברגר, אב\"ד וירצבורג, מחבר ספר 'מלאכת שמים', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%93\" title=\"תרע&quot;ד\">תרע\"ד</a> (17/10/1913 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי צבי הירש שפירא ממונקטש, מחבר ספר 'דרכי תשובה', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a> (10/10/1976 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי נחמן כהנא מספינקא - <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%92\" title=\"תרמ&quot;ג\">תרמ\"ג</a> (29/09/1882 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - התחלת הנשיאות של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> (על ידי אמירת <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמר</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. אמנם לא קיבל את הנשיאות באופן רשמי לגמרי - עד שנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%93\" title=\"תרנ&quot;ד\">תרנ\"ד</a>).</li></ul>\n<h2><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\">נולדו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%98\" title=\"תרל&quot;ט\">תרל\"ט</a> (13/10/1878 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%97%D7%9F\" title=\"שלמה מנחם מענדל חן\">שלמה מנחם מענדל חן</a>, רבה של <a href=\"/index.php/%D7%A0%D7%99%D7%A2%D7%96%27%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ניעז&#39;ין\">ניעז'ין</a> ומגדולי חסידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%93\" title=\"תשי&quot;ד\">תשי\"ד</a> (25/09/1953 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A8%D7%99%D7%99%D7%A6%D7%A1\" class=\"mw-redirect\" title=\"יעקב רייצס\">יעקב רייצס</a>, מהקבוצה הראשונה של <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"שלוחי הרבי לארץ הקודש\">שלוחי הרבי לארץ הקודש</a>, ורבה של יסוד המעלה והגליל התחתון.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a> (10/10/1976 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%A1%D7%A3_%D7%A9%D7%9E%D7%A9%D7%95%D7%9F_%D7%90%D7%A0%D7%92%D7%9C%D7%9E%D7%9F\" title=\"אסף שמשון אנגלמן\">אסף שמשון אנגלמן</a>, ראש כולל 'עיון ההלכה' שעל ידי מוסדות <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%92%D7%93%D7%95%D7%9C%D7%94_%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA\" title=\"ישיבה גדולה תורת אמת\">תורת אמת</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> ורב קהילת חב\"ד ברמת <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9\" title=\"בית שמש\">בית שמש</a> ב'.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\">נפטרו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%98\" title=\"תרס&quot;ט\">תרס\"ט</a> (11/10/1908 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%A0%D7%9B%D7%93_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7)\" class=\"mw-redirect\" title=\"שלום דובער שניאורסון (נכד אדמו&quot;ר הצמח צדק)\">שלום דובער שניאורסון</a>, נכד <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a> (19/10/1986 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%96%D7%95%D7%A9%D7%90_%D7%95%D7%99%D7%9C%D7%99%D7%9E%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"חיים זושא וילימובסקי\">חיים זושא וילימובסקי</a> 'הפרטיזן', מראשי עסקני חב\"ד ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ הקודש</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> (08/10/2006 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%9C%D7%95%D7%99%D7%9F\" title=\"זלמן מרדכי לוין\">זלמן מרדכי לוין</a>, מנהל הגמ\"ח של <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ועד נחלת הר חב&quot;ד\">ועד נחלת הר חב\"ד</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a> (02/10/2012 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%98%D7%9C%D7%99%D7%A9%D7%91%D7%A1%D7%A7%D7%99\" title=\"משה טלישבסקי\">משה טלישבסקי</a>, \"ה<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97_%D7%A6%D7%99%D7%91%D7%95%D7%A8\" title=\"שליח ציבור\">חזן</a> של <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%9B%22%D7%A7_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" title=\"רבי מנחם מענדל שניאורסון (כ&quot;ק אדמו&quot;ר שליט&quot;א)\">הרבי</a>\".</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ט\"ז בתשרי - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>ב<a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9\" title=\"קידוש\">קידוש</a> הלילה: <a href=\"/index.php/%D7%A9%D7%94%D7%97%D7%99%D7%99%D7%A0%D7%95\" class=\"mw-redirect\" title=\"שהחיינו\">שהחיינו</a> ואח\"כ לישב ב<a href=\"/index.php/%D7%A1%D7%95%D7%9B%D7%94\" class=\"mw-redirect\" title=\"סוכה\">סוכה</a>. ב<a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%94\" class=\"mw-redirect\" title=\"מנחה\">מנחה</a> אין אומרים הודו אבל אומרים <a href=\"/index.php/%D7%A4%D7%AA%D7%97_%D7%90%D7%9C%D7%99%D7%94%D7%95\" title=\"פתח אליהו\">פתח אליהו</a>.</i>\n<p>ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a> סיפר: <a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%98\" title=\"תקס&quot;ט\">תקס\"ט</a> האבען מיר געהערט פון זיידעם דעם זעקסטען מאל דעם ושאבתם מים - הראשון - פון <a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"לקוטי תורה\">לקוטי תורה</a>, און עס איז געווען על דרך ווי די גמרא זאגט (ירושלמי סוכה פ\"ה ה\"א) שמשם שואבים. יונה האט מקבל געווען בשמחת בית השואבה גילוי ה<a href=\"/index.php/%D7%A0%D7%91%D7%95%D7%90%D7%94\" title=\"נבואה\">נבואה</a>, מיר האבען מקבל געווען עד אין סוף, דער סוף איז אז <a href=\"/index.php/%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"משיח\">משיח</a> וועט קומען, ש<a href=\"/index.php/%D7%A0%D7%A2%D7%95%D7%A5_%D7%AA%D7%97%D7%9C%D7%AA%D7%9F_%D7%91%D7%A1%D7%95%D7%A4%D7%9F\" class=\"mw-redirect\" title=\"נעוץ תחלתן בסופן\">נעוץ תחלתן בסופן</a>.\n</p>\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a> סיפר: בשנת <a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%98\" title=\"תקס&quot;ט\">תקס\"ט</a> שמענו מה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">סבא</a> בפעם השישית את ה\"ושאבתם מים\" - הראשון - שב\"<a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"לקוטי תורה\">לקוטי תורה</a>\", והיה זה על דרך מה שהגמרא אומרת (ירושלמי סוכה פרק ה' ה\"א) - שמשם שואבים. יונה קיבל בשמחת בית השואבה את גילוי ה<a href=\"/index.php/%D7%A0%D7%91%D7%95%D7%90%D7%94\" title=\"נבואה\">נבואה</a>, אנו קבלנו עד אין סוף, הסוף הוא ש<a href=\"/index.php/%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"משיח\">משיח</a> יבא, ש<a href=\"/index.php/%D7%A0%D7%A2%D7%95%D7%A5_%D7%AA%D7%97%D7%9C%D7%AA%D7%9F_%D7%91%D7%A1%D7%95%D7%A4%D7%9F\" class=\"mw-redirect\" title=\"נעוץ תחלתן בסופן\">נעוץ תחלתן בסופן</a>.\n</p>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השביעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">המאמר - ד\"ה \"כתר יתנו לך\" - לא הגיע לידינו לע\"ע.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413223627\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.117 seconds\nReal time usage: 1.207 seconds\nPreprocessor visited node count: 448/1000000\nPost‐expand include size: 10451/2097152 bytes\nTemplate argument size: 951/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 831/5000000 bytes\nLua time usage: 0.070/7 seconds\nLua virtual size: 6139904/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00% 1020.740      1 -total\n 85.36%  871.276      1 תבנית:פתיח_יום\n 26.82%  273.782      2 תבנית:הערה\n 22.63%  231.042      5 תבנית:מילה_אחרונה\n  7.29%   74.387      1 תבנית:הערות_שוליים\n  6.18%   63.068      1 תבנית:הסר_מילה_ראשונה\n  5.43%   55.377      2 תבנית:מילה_ראשונה\n  3.37%   34.427      1 תבנית:חודש_תשרי\n  2.99%   30.567      1 תבנית:הערות_שוליים/מרחב_שם\n  2.93%   29.897      3 תבנית:רווח\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19192-0!canonical and timestamp 20260413223627 and revision id 793179. Rendering was triggered becaus