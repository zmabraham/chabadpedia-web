    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b><a href=\"/index.php?title=%D7%99%D7%A0%D7%95%D7%A7%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЎОаОЋОДОљ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЎОаОЋОДОљ</a></b> ОћОЎОљ ОъОЎОюОћ ОЉОљОеОъОЎОф ОЕОцОЎОеОЋОЕОћ <a href=\"/index.php?title=%D7%AA%D7%99%D7%A0%D7%95%D7%A7&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОфОЎОаОЋОД (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОфОЎОаОЋОД</a>. ОЉОъОЕОџ ОћОЊОЋОеОЋОф ОЏОЋОаОЋ ОеОЉОаОЎОЮ ОЕОЋОаОЎОЮ ОЉОЏОЎОаОЋОЎ \"ОћОЎОаОЋОДОљ\" ОЉОЊОеОџ ОЏОюОю ОъОњОЎОю ОдОбОЎОе.\n</p><p><b>ОћОљОЮ ОћОфОЏОЋОЋОаОфОЮ Ою...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li>ОеОЉОЎ <a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%A1%D7%98%D7%95%D7%9C%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЎОЕОеОљОю ОъОАОўОЋОюОЎОЪ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЎОЕОеОљОю ОъОАОўОЋОюОЎОЪ</a> - <a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%98\" title=\"ОфОеОЏ&quot;Оў\">ОфОеОЏ\"Оў</a></li>\n<li><a href=\"/index.php?title=%D7%94%D7%99%D7%A0%D7%95%D7%A7%D7%90_%D7%94%D7%A4%D7%9C%D7%90%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОћОЎОаОЋОДОљ ОћОцОюОљОЎ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОћОЎОаОЋОДОљ ОћОцОюОљОЎ</a> - ОЎОюОЊ ОЌОеОЊОЎ ОљОЕОе ОљОъОеОЋ ОбОюОЎОЋ ОЏОЎ ОЎОЊОб ОљОф ОЏОю Оћ<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%91%D7%91%D7%9C%D7%99\" title=\"ОфОюОъОЋОЊ ОЉОЉОюОЎ\">ОЕ\"ОА</a> ОЏОЉОе ОъОњОЎОю ОдОбОЎОе.</li>\n<li><a href=\"/index.php?title=%D7%94%D7%99%D7%A0%D7%95%D7%A7%D7%90_%D7%9E%D7%9B%D7%A4%D7%A8_%D7%A1%D7%9B%D7%A0%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОћОЎОаОЋОДОљ ОъОЏОцОе ОАОЏОаОЎОЪ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОћОЎОаОЋОДОљ ОъОЏОцОе ОАОЏОаОЎОЪ</a></li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%91%D7%90%D7%A8%D7%99\" title=\"ОЕОюОъОћ ОЎОћОЋОЊОћ ОЉОљОеОЎ\">ОЕОюОъОћ ОЎОћОЋОЊОћ ОЉОљОеОЎ</a></li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A9%D7%9B%D7%A8_%D7%93%D7%91_%D7%A8%D7%95%D7%A7%D7%97_(%D7%94%D7%A9%D7%A0%D7%99)\" class=\"mw-redirect\" title=\"ОЎОЕОЏОе ОЊОЉ ОеОЋОДОЌ (ОћОЕОаОЎ)\">ОЎОЕОЏОе ОЊОЉ ОеОЋОДОЌ</a> ОћОљОЊОъОЋ\"Ое Оъ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%91%D7%A2%D7%9C%D7%96\" title=\"ОЌОАОЎОЊОЋОф ОЉОбОюОќ\">ОЉОбОюОќ</a></li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%94%D7%A2%D7%A9%D7%99%D7%9C_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"ОЎОдОЌОД ОЎОћОЋОЕОб ОћОбОЕОЎОю ОцОеОЎОЊОъОЪ\">ОЎОдОЌОД ОЎОћОЋОЕОб ОћОбОЕОЎОю ОцОеОЎОЊОъОЪ</a> ОћОљОЊОъОЋ\"Ое Оъ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%93%D7%99%D7%92%D7%95%D7%A8%D7%94\" title=\"ОЌОАОЎОЊОЋОф ОАОЊОЎОњОЋОеОћ\">ОАОЊОЎОњОЋОеОћ</a></li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\"><img alt=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>ОцОЎОеОЋОЕОЋОаОЎОЮ</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> ОќОћОЋ ОЊОБ <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"ОЌОЉ&quot;ОЊОцОЊОЎОћ:ОцОЎОеОЋОЕОЋОаОЎОЮ\">ОцОЎОеОЋОЕОЋОаОЎОЮ</a>, ОЕОъОўОеОфОЋ ОюОћОЉОЌОЎОЪ ОЉОЎОЪ ОбОеОЏОЎОЮ ОЕОЋОаОЎОЮ ОЉОбОюОЎ ОЕОЮ ОЊОЋОъОћ.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/42px-Gnome-searchtool.svg.png 2x\" /></a></span> ОљОЮ ОюОљ ОъОдОљОфОЮ ОЉОеОЕОЎОъОф ОћОцОЎОеОЋОЕОЋОаОЎОЮ ОљОф ОћОбОеОџ ОЕОћОфОЏОЋОЋОаОфОЮ ОљОюОЎОЋ, ОаОАОЋ:\n</p>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%93%D7%A4%D7%99%D7%9D_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C%D7%99%D7%9D_%D7%91/%D7%94%D7%99%D7%A0%D7%95%D7%A7%D7%90\" title=\"ОъОЎОЋОЌОЊ:ОЊОцОЎОЮ ОћОъОфОЌОЎОюОЎОЮ ОЉ/ОћОЎОаОЋОДОљ\">ОЊОцОЎОЮ ОЕОЕОъОЮ ОъОфОЌОЎОю ОЉРђЮОћОЎОаОЋОДОљРђю</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/intitle:%D7%94%D7%99%D7%A0%D7%95%D7%A7%D7%90%22\" title=\"ОъОЎОЋОЌОЊ:ОЌОЎОцОЋОЕ/intitle:ОћОЎОаОЋОДОљ&quot;\">ОЊОцОЎОЮ ОЕОЕОъОЮ ОъОЏОЎОю РђЮОћОЎОаОЋОДОљРђю</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/~%22%D7%94%D7%99%D7%A0%D7%95%D7%A7%D7%90%22\" title=\"ОъОЎОЋОЌОЊ:ОЌОЎОцОЋОЕ/~&quot;ОћОЎОаОЋОДОљ&quot;\">ОЌОЎОцОЋОЕ РђЮОћОЎОаОЋОДОљРђю ОЉОЌОЉ\"ОЊОцОЊОЎОћ</a></li></ul>\n</div>\n</td>\n</tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413204546\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.051 seconds\nReal time usage: 0.724 seconds\nPreprocessor visited node count: 63/1000000\nPostРђљexpand include size: 2229/2097152 bytes\nTemplate argument size: 707/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip postРђљexpand size: 0/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5353472/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  579.372      1