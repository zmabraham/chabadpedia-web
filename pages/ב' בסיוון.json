      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"א&#39; בסיוון\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ג&#39; בסיוון\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ד&#39; בסיוון\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ה&#39; בסיוון\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ו&#39; בסיוון\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ז&#39; בסיוון\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ח&#39; בסיוון\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ט&#39; בסיוון\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&#39; בסיוון\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;א בסיוון\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ב בסיוון\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ג בסיוון\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ד בסיוון\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ט&quot;ו בסיוון\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ט&quot;ז בסיוון\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ז בסיוון\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ח בסיוון\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ט בסיוון\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&#39; בסיוון\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;א בסיוון\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ב בסיוון\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ג בסיוון\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ד בסיוון\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ב&#39; בסיוון</b> הוא היום השני\nבחודש התשיעי<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;והוא מכונה בשם 'יום המיוחס'.\n</p><p>תאריך זה חל בתקופת ניסן&#160;והוא יכול לחול בימים&#160;שני, רביעי, חמישי ושבת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.99.D7.95.D7.9D_.D7.94.D7.9E.D7.99.D7.95.D7.97.D7.A1\"></span><span class=\"mw-headline\" id=\"יום_המיוחס\">יום המיוחס</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;יום המיוחס&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: יום המיוחס\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>תאריך זה מכונה בשם <b>יום המיוחס</b><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>, ובטעם הדבר נאמרו מספר הסברים:\n</p>\n<ul><li>בהודעתו הראשונה של <a href=\"/index.php/%D7%9E%D7%A9%D7%94\" class=\"mw-redirect\" title=\"משה\">משה</a> ב<a href=\"/index.php?title=%D7%9E%D7%93%D7%91%D7%A8_%D7%A1%D7%99%D7%A0%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מדבר סיני (הדף אינו קיים)\">מדבר סיני</a> לאחר <a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"יציאת מצרים\">יציאת מצרים</a> על התוכנית למעמד '<a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%AA_%D7%94%D7%93%D7%99%D7%91%D7%A8%D7%95%D7%AA\" class=\"mw-redirect\" title=\"עשרת הדיברות\">עשרת הדיברות</a>', ועל 'שלושת ימי ההגבלה' שהחלו מיד למחרת, לקראת <a href=\"/index.php/%D7%9E%D7%AA%D7%9F_%D7%AA%D7%95%D7%A8%D7%94\" title=\"מתן תורה\">מתן תורה</a>, נאמר לעם ישראל: \"ואתם תהיו לי ממלכת כהנים וגוי קדוש\"<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>, ובכך הפכו בני ישראל לעם מיוחד, שרק מי שמתייחס אליו שייך לחלק מעם ישראל, ודבר זה נקרא בלשון חכמים בהלכה 'יחוס'<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>על פי הפסוק \"ואתם תהיו לי ממלכת כהנים וגוי קדוש\", הוא שביום זה יוחסו בני ישראל משאר אומות העולם.</li>\n<li>משום שהיום בשבוע שחל בו יום המיוחס (ב' סיון) יחול בו <a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%9B%D7%99%D7%A4%D7%95%D7%A8%D7%99%D7%9D\" title=\"יום הכיפורים\">יום הכיפורים</a> שלאחריו, ויום כיפור נקרא יום המיוחס בפיוט \"יום מימים הוחס\".</li>\n<li>מפני שעל פי המסורת, יום זה נמצא בין ימים חשובים לעם ישראל (ר\"ח סיוון מלפניו ושלושת ימי ההגבלה לאחריו) אבל בפני עצמו אין בו כלום, ועל כן הוא כאדם שאין בו כלום אבל מתהדר בייחוסו<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח – <a href=\"/index.php/%D7%9E%D7%A9%D7%94\" class=\"mw-redirect\" title=\"משה\">משה</a> עלה להר סיני, שם אמר לו אלוקים שהוא בחר ב<a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">עם ישראל</a> כ\"עם סגולה\", \"ממלכת כהנים\" ו\"גוי קדוש\".</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%93\" title=\"תקע&quot;ד\">תקע\"ד</a> – רבי אריה לייב ברלין, אב\"ד קאסל שב<a href=\"/index.php/%D7%92%D7%A8%D7%9E%D7%A0%D7%99%D7%94\" title=\"גרמניה\">גרמניה</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%98\" title=\"תרע&quot;ט\">תרע\"ט</a> – רבי יעקב שאול דוויק (ה\"חכם באשי\"), מחכמי ארם צובא ומחבר ספר \"דרך אמונה\", נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%95\" title=\"תרצ&quot;ו\">תרצ\"ו</a> – רבי <a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%94%D7%92%D7%A8_(%D7%90%D7%94%D7%91%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ישראל הגר (אהבת ישראל) (הדף אינו קיים)\">ישראל הגר (אהבת ישראל)</a>, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php/%D7%95%D7%99%D7%96%27%D7%A0%D7%99%D7%A5\" class=\"mw-redirect\" title=\"ויז&#39;ניץ\">ויז'ניץ</a> ומחבר ספר 'אהבת ישראל', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%96\" title=\"תרצ&quot;ז\">תרצ\"ז</a> – רבי <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A9%D7%A4%D7%99%D7%A8%D7%90\" title=\"חיים אלעזר שפירא\">חיים אלעזר שפירא</a>, האדמו\"ר מ<a href=\"/index.php?title=%D7%9E%D7%95%D7%A0%D7%A7%D7%98%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מונקטש (הדף אינו קיים)\">מונקטש</a> ומחבר ספר 'מנחת אלעזר', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> – רבי מרדכי חזקיהו בן שמעון, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> – הרב <a href=\"/index.php/%D7%A8%D7%A4%D7%90%D7%9C_%D7%A9%D7%9E%D7%A9%D7%95%D7%9F_%D7%9C%D7%95%D7%99%D7%A0%D7%A1%D7%95%D7%9F\" title=\"רפאל שמשון לוינסון\">רפאל שמשון לוינסון</a>, שליח ורב היישוב <a href=\"/index.php?title=%D7%AA%D7%9C_%D7%A2%D7%93%D7%A9%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"תל עדשים (הדף אינו קיים)\">תל עדשים</a> ומחנך ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תלמוד תורה מגדל העמק\">תלמוד תורה מגדל העמק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%AA%D7%9E%D7%A9:%D7%9E%D7%95%D7%99%D7%A9%D7%99_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7/%D7%94%D7%9C%D7%9C_%D7%92%D7%95%D7%90%D7%98%D7%94\" title=\"משתמש:מוישי גורליק/הלל גואטה\">הלל גואטה</a>, משפיע בשיעור א' ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%A8%D7%A1%D7%A7%D7%99%D7%9F_(%D7%A8%D7%95%D7%93%D7%A0%D7%99%D7%90)\" title=\"שלמה רסקין (רודניא)\">שלמה רסקין</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A8%D7%95%D7%93%D7%A0%D7%99%D7%90\" title=\"רודניא\">רודניא</a> ובגורקיי שנפטר ב<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%99%D7%94\" title=\"מלחמת העולם השנייה\">מלחמת העולם השנייה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> – הרב <a href=\"/index.php/%D7%91%D7%A6%D7%9C%D7%90%D7%9C_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"בצלאל וילשאנסקי\">בצלאל וילשאנסקי</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a> ל<a href=\"/index.php/%D7%92%D7%A8%D7%95%D7%96%D7%99%D7%94\" class=\"mw-redirect\" title=\"גרוזיה\">גרוזיה</a> ולאחר מכן עסקן ומנהל מוסדות חב\"ד ב<a href=\"/index.php/%D7%A4%D7%A8%D7%99%D7%96\" title=\"פריז\">פריז</a> וב<a href=\"/index.php/%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F\" title=\"מלבורן\">מלבורן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%90%D7%99%D7%99%D7%93%D7%9C%D7%9E%D7%9F\" title=\"שלמה איידלמן\">שלמה איידלמן</a>, ממייסדי קהילת חב\"ד ו<a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"גבאי\">גבאי</a> <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> חב\"ד ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://www.mafteiach.app/likkutei_sichos/by_moad/2_sivan\">לקוטי שיחות מועדים - ב' סיוון</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9E%D7%A4%D7%AA%D7%97\" title=\"קישור לאתר מפתח\"><img alt=\"קישור לאתר מפתח\" src=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/30px-%D7%9E%D7%A4%D7%AA%D7%97.png\" decoding=\"async\" width=\"30\" height=\"30\" class=\"mw-file-element\" srcset=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/45px-%D7%9E%D7%A4%D7%AA%D7%97.png 1.5x, /images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/60px-%D7%9E%D7%A4%D7%AA%D7%97.png 2x\" /></a></span></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ב' בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>מו לעומר. \"אנא בכח\" - דקבלת <a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבת</a> - אומרים בלחש. \"ופרוש עלינו\" כו' - בקבלת שבת - בעמידה.</i>\n<p>בשנת <a href=\"/index.php/%D7%AA%D7%A7%D7%A4%22%D7%98\" title=\"תקפ&quot;ט\">תקפ\"ט</a> חל שבת פרשת במדבר ה' ב<a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיון\">סיון</a>. קודם הדלקת נרות של שבת אמר ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a> <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמר</a> \"שאו את ראש גו' אבותם\". פירוש \"שאו\" כפירוש הראב\"ע מענין כי תשא את ראש. וביאור הענין שעל ידי <a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודת</a> הארת ה<a href=\"/index.php/%D7%A0%D7%A9%D7%9E%D7%94\" class=\"mw-redirect\" title=\"נשמה\">נשמה</a> שב<a href=\"/index.php/%D7%92%D7%95%D7%A3\" class=\"mw-redirect\" title=\"גוף\">גוף</a>, נעשה עליה בראש ועצם הנשמה כמו שהיא למעלה והסביר כמה פסוקים ומאמרי זהר ומדרש. בשבת בצהרים אמר רבינו הדרוש \"וארשתיך לי לעולם\" וביאורו שנדפסו ב<a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"לקוטי תורה\">לקוטי תורה</a>. ביום א' ד<a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a> אמר רבינו את הדרוש \"וספרתם לכם\" וביאורו - שנדפסו בלקוטי תורה. ביום השני דחג השבועות בסעודת יום טוב אמר רבינו את הדרוש \"ו<a href=\"/index.php/%D7%94%D7%97%D7%9B%D7%9E%D7%94\" class=\"mw-redirect\" title=\"החכמה\">החכמה</a> מאין תמצא\", והוא ביאור השני בענין תספרו חמשים יום הנדפס בלקוטי תורה.\n</p>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השלישי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">בקהילות מסויימות מכנים אותו בשם <b>יום יחוס</b>.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">שמות יט, ו.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">ערוך השולחן אורח חיים תצד.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">האדמו\"ר מרוז'ין, עירין קדישין – ווארשה 1885, עמ' 45, המבשר תורני, כ\"ו אייר תשע\"ט.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413201657\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.117 seconds\nReal time usage: 1.518 seconds\nPreprocessor visited node count: 524/1000000\nPost‐expand include size: 10544/2097152 bytes\nTemplate argument size: 813/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 1876/5000000 bytes\nLua time usage: 0.090/7 seconds\nLua virtual size: 6160384/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00% 1291.605      1 -total\n 76.86%  992.694      1 תבנית:פתיח_יום\n 34.13%  440.860      5 תבנית:הערה\n 17.89%  231.105      5 תבנית:מילה_אחרונה\n 11.21%  144.743      2 תבנית:מילה_ראשונה\n  4.10%   52.998      1 תבנית:הסר_מילה_ראשונה\n  2.30%   29.745      1 תבנית:חודש_סיוון\n  1.65%   21.307      1 תבנית:לוח_שנה\n  1.56%   20.157      1 תבנית:להיום_יום\n  1.50%   19.419      3 תבנית:רווח\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:22531-0!canonical and timestamp 20260413201657 and revision id 833734. Rendering was triggered because: page-view\n -->\n</div>"
