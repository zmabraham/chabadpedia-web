    "pageid": 60848,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"\" style=\"border: 1px #aaaaaa solid; background-color: #f9f9f9; text-align: center; clear: both; width: 20%; margin: 0.5em; float: left;\" cellspacing=\"3\">\n<tbody><tr>\n<th style=\"background-color:#b0c4de; background:#abcbcc; padding-top: 0.1em; padding-bottom: 0.1em; text-align: center; color: black; font-weight: bold; font-size: 100%\"><a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%95%D7%99%D7%A8%D7%90%D7%94\" title=\"אהבה ויראה\">אהבה ויראה</a>\n</th></tr>\n<tr>\n<td style=\"background-color: #F2F3F4; font-size: 97%;\"><b>בחינות באהבה</b>\n</td></tr>\n<tr>\n<td style=\"padding-top: 3px; padding-bottom: 3px; background-color: #f9f9f9; font-size: 95%\">\n<table style=\"width: 98%; background-color: transparent; margin: auto; padding: 0; text-align: center;\" cellpadding=\"0\" cellspacing=\"0\">\n<tbody><tr>\n<td><a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94\" title=\"אהבה\">אהבה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%AA_%D7%A2%D7%95%D7%9C%D7%9D\" title=\"אהבת עולם\">אהבת עולם</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%96%D7%95%D7%98%D7%90\" title=\"אהבה זוטא\">אהבה זוטא</a> ו<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%A8%D7%91%D7%94\" title=\"אהבה רבה\">רבה</a>  <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%91%D7%AA%D7%A2%D7%A0%D7%95%D7%92%D7%99%D7%9D\" title=\"אהבה בתענוגים\">אהבה בתענוגים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%94%D7%9E%D7%A1%D7%95%D7%AA%D7%A8%D7%AA\" title=\"אהבה המסותרת\">אהבה מסותרת</a> ו<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%91%D7%AA%D7%A2%D7%9C%D7%95%D7%9E%D7%95%D7%AA_%D7%9C%D7%91\" title=\"אהבה בתעלומות לב\">בתעלומות לב</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a class=\"mw-selflink selflink\">אהבה כמים</a> ו<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%A8%D7%A9%D7%A4%D7%99_%D7%90%D7%A9\" title=\"אהבה כרשפי אש\">כרשפי אש</a>   <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%AA_%D7%94%27\" title=\"אהבת ה&#39;\">אהבת ה'</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%95%D7%99%D7%A8%D7%90%D7%94\" title=\"אהבה ויראה\">היחסים בין אהבה ויראה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%95%D7%99%D7%A8%D7%90%D7%94_%D7%A9%D7%9B%D7%9C%D7%99%D7%AA_%D7%95%D7%98%D7%91%D7%A2%D7%99%D7%AA\" title=\"אהבה ויראה שכלית וטבעית\">אהבה ויראה שכלית וטבעית</a>\n</td></tr></tbody></table>\n</td></tr>\n<tr>\n<td style=\"background-color: #F2F3F4; font-size: 97%;\"><b>בחינות ביראה</b>\n</td></tr>\n<tr>\n<td style=\"background-color: #f9f9f9; font-size: 95%;\"><a href=\"/index.php/%D7%99%D7%A8%D7%90%D7%94\" title=\"יראה\">יראה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%99%D7%A8%D7%90%D7%AA_%D7%94%D7%A2%D7%95%D7%A0%D7%A9\" title=\"יראת העונש\">יראת העונש</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%99%D7%A8%D7%90%D7%94_%D7%A2%D7%99%D7%9C%D7%90%D7%94\" class=\"mw-redirect\" title=\"יראה עילאה\">יראה עילאה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%99%D7%A8%D7%90%D7%94_%D7%AA%D7%AA%D7%90%D7%94\" class=\"mw-redirect\" title=\"יראה תתאה\">יראה תתאה</a>\n</td></tr></tbody></table>\n<p><b>אהבה כמים</b> זהו סוג ב<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94\" title=\"אהבה\">אהבה</a> של יהודי כלפי הקדושה המסמל אהבה בהתבוננות והתיישבות<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>. אהבה זו מקורה הוא ב<a href=\"/index.php/%D7%9B%D7%94%D7%A0%D7%99%D7%9D\" title=\"כהנים\">כהנים</a> משוייכת <a href=\"/index.php/%D7%A7%D7%95_%D7%94%D7%99%D7%9E%D7%99%D7%9F\" title=\"קו הימין\">קו הימין</a>, בשונה מסוג האהבה השני <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%A8%D7%A9%D7%A4%D7%99_%D7%90%D7%A9\" title=\"אהבה כרשפי אש\">אהבה כרשפי אש</a> שמשויכת ל<a href=\"/index.php/%D7%9C%D7%95%D7%99\" title=\"לוי\">לווים</a> ומקורה הוא ב<a href=\"/index.php/%D7%A7%D7%95_%D7%94%D7%A9%D7%9E%D7%90%D7%9C\" title=\"קו השמאל\">קו השמאל</a>. \n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.A2.D7.A0.D7.99.D7.99.D7.A0.D7.94\"></span><span class=\"mw-headline\" id=\"עניינה\">עניינה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%9E%D7%99%D7%9D&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;עניינה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%9E%D7%99%D7%9D&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: עניינה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%A4%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/de/%D7%9E%D7%A4%D7%9C.jpg/220px-%D7%9E%D7%A4%D7%9C.jpg\" decoding=\"async\" width=\"220\" height=\"176\" class=\"mw-file-element\" srcset=\"/images/thumb/d/de/%D7%9E%D7%A4%D7%9C.jpg/330px-%D7%9E%D7%A4%D7%9C.jpg 1.5x, /images/thumb/d/de/%D7%9E%D7%A4%D7%9C.jpg/440px-%D7%9E%D7%A4%D7%9C.jpg 2x\" /></a><figcaption>כשם שהמים זורמים מלמעלה למטה ככה היא דרך העבודה באהבה כמים</figcaption></figure>\n<p>אהבה כמים נקראת כך כי שכשם שמים נשפכים ממקום גבוהה למקום נמוך (מלמעלה למטה) כך על-ידי עבודת הכוהנים (מקור האהבה כמים) באהבה מעומק הלב הם ממשיכים <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" title=\"אור אין סוף\">אור אין סוף</a> מ<a href=\"/index.php/%D7%94%D7%A7%D7%93%D7%95%D7%A9_%D7%91%D7%A8%D7%95%D7%9A_%D7%94%D7%95%D7%90\" title=\"הקדוש ברוך הוא\">הקדוש ברוך הוא</a> למעלה - ל<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"בני ישראל\">בני ישראל</a> למטה. ועוד סיבה שנקראת כי כמו שהמים מדבקים דברים כך גם אהבה זו היא 'מדבקת' את היהודי במהלך עבודתו את השם והשגתו<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>אהבה כמים מגיעה רק לאחר עבודה של יהודי שמשיג בשכל את זה שהשם הוא גדול על כולם ורואה עד כמה העולם הזה הוא קטן לעומת השם ולמרות זאת הוא מרגיש קרוב לאלוקות דבר שגורם לו לאהבת השם גדולה, אך אהבה זו דורשת מאמץ ועבודה מצד היהודי התיישבות והתבוננות ואז הוא מגיע לדרגת אהבה כמים. בשל כך אהבה זו נהדרת את ההתלהבות הגדולה שיש ב<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%A8%D7%A9%D7%A4%D7%99_%D7%90%D7%A9\" title=\"אהבה כרשפי אש\">אהבה כרשפי אש</a> כי היא מוגבלת בשל היותה שייכת לעניין של הבנה והשגה<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>. בעוד האהבה של בחינה זו מגיעה בשל הרגשתו של היהודי כ-<b>קרוב</b> להשם, האהבה של אהבה כרשפי אש מגיעה בשל הרגשתו של היהודי כ-<b>רחוק</b> מהשם<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>. אהבה כמים לא מצריך שינוי רגילות צל האדם<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>האהבה כמים נמשכת אל היהודי במשך כל היום ולא רק בזמנים מסוימים כמו האהבה כרשפי אש<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>אהבה כמים יש בה גם בחינת <a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C\" title=\"ביטול\">ביטול</a>, ועל-ידי העבודה של אהבה כמים בבחינת ביטול נמשכים לעולם הזה אורות שלמעלה מהכלים ולמעלה מ<a href=\"/index.php/%D7%A1%D7%93%D7%A8_%D7%94%D7%A9%D7%AA%D7%9C%D7%A9%D7%9C%D7%95%D7%AA\" title=\"סדר השתלשלות\">סדר השתלשלות</a><sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.A7.D7.95.D7.A8_.D7.94.D7.90.D7.94.D7.91.D7.94_.D7.9B.D7.9E.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"מקור_האהבה_כמים\">מקור האהבה כמים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%9E%D7%99%D7%9D&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;מקור האהבה כמים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%9E%D7%99%D7%9D&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: מקור האהבה כמים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>מקורה של אהבה זו הוא בעבודת ה<a href=\"/index.php/%D7%9B%D7%94%D7%A0%D7%99%D7%9D\" title=\"כהנים\">כהנים</a> שנעשית ב<a href=\"/index.php/%D7%A7%D7%95_%D7%94%D7%99%D7%9E%D7%99%D7%9F\" title=\"קו הימין\">קו הימין</a> בספירות <a href=\"/index.php/%D7%97%D7%9B%D7%9E%D7%94\" class=\"mw-redirect\" title=\"חכמה\">חכמה</a> <a href=\"/index.php/%D7%97%D7%A1%D7%93\" class=\"mw-redirect\" title=\"חסד\">חסד</a> ו<a href=\"/index.php/%D7%A0%D7%A6%D7%97\" class=\"mw-redirect\" title=\"נצח\">נצח</a>, ל<a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"אברהם אבינו\">אברהם אבינו</a> הייתה אהבה כמים<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>. אדמו\"ר הזקן ממשיל את האהבה כמים ל<a href=\"/index.php/%D7%9B%D7%A1%D7%A3\" title=\"כסף\">כסף</a> בעוד את האהבה כרשפי אש ממשיל לזהב<sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\"><span class=\"cite-bracket\">&#91;</span>9<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בסיפור מכירת יוסף בתורה משויך שר המשקים לבחינת האהבה כמים, ואילו שר האופים לאהבה כרשפי אש<sup id=\"cite_ref-10\" class=\"reference\"><a href=\"#cite_note-10\"><span class=\"cite-bracket\">&#91;</span>10<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%9E%D7%99%D7%9D&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%9E%D7%99%D7%9D&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94_%D7%9B%D7%A8%D7%A9%D7%A4%D7%99_%D7%90%D7%A9\" title=\"אהבה כרשפי אש\">אהבה כרשפי אש</a></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראה <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%AA%D7%A2%D7%A8%22%D7%91\" class=\"mw-redirect\" title=\"המשך תער&quot;ב\">המשך תער\"ב</a> חלק שני עמוד תתמט</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ראה תורת מנחם חלק י\"א עמוד 124, וכן תורת מנחם חלק י\"ב עמוד 65</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">תורת מנחם חלק י\"ב עמודים 64 - 65</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">תורת מנחם חלק י\"ב עמוד 65</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%AA%D7%A2%D7%A8%22%D7%91\" class=\"mw-redirect\" title=\"המשך תער&quot;ב\">המשך תער\"ב</a> חלק שלישי עמוד א'שלה</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"לקוטי תורה\">לקוטי תורה</a> על <a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%97%D7%95%D7%A7%D7%AA\" title=\"פרשת חוקת\">פרשת חוקת</a> ס\"ג א, <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" title=\"אור התורה\">אור התורה</a> פרשת במבדבר, כרך ג' עמוד תתסח, ועוד</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">תורת מנחם חלק כ\"א עמוד 253</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%A9%D7%99%D7%97%D7%95%D7%AA\" title=\"לקוטי שיחות\">לקוטי שיחות</a> מפתח עניינים אות י' - יצחק.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" class=\"mw-redirect\" title=\"תורה אור\">תורה אור</a> תצווה, פ\"ד א., <a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"לקוטי תורה\">לקוטי תורה</a> נשוא, כ\"ג, ג. ועוד</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%9E%D7%90%D7%9E%D7%A8%D7%99%D7%9D_%D7%9E%D7%9C%D7%95%D7%A7%D7%98\" class=\"mw-redirect\" title=\"ספר המאמרים מלוקט\">ספר המאמרים מלוקט</a> חלק ד' עמוד 305</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413081702\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.132 seconds\nReal time usage: 2.793 seconds\nPreprocessor visited node count: 414/1000000\nPost‐expand include size: 7377/2097152 bytes\nTemplate argument size: 1796/2097152 bytes\nHighest expansion depth: 7/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 3552/5000000 bytes\nLua time usage: 0.100/7 seconds\nLua virtual size: 6148096/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00% 2400.769      1 -total\n 68.46% 1643.517     10 תבנית:הערה\n 26.64%  639.497      1 תבנית:אהבה_ויראה\n 25.19%  604.857      1 תבנית:ניווט_כפול\n  4.82%  115.821      1 תבנית:הערות_שוליים\n  0.79%   19.032      1 תבנית:הערות_שוליים/מרחב_שם\n  0.58%   13.906     11 תבנית:*\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pc