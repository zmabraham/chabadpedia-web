      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%90%D7%9C%D7%93%D7%91%D7%A2%D7%A8%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/ee/%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%90%D7%9C%D7%93%D7%91%D7%A2%D7%A8%D7%92.jpg/220px-%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%90%D7%9C%D7%93%D7%91%D7%A2%D7%A8%D7%92.jpg\" decoding=\"async\" width=\"220\" height=\"288\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ee/%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%90%D7%9C%D7%93%D7%91%D7%A2%D7%A8%D7%92.jpg/330px-%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%90%D7%9C%D7%93%D7%91%D7%A2%D7%A8%D7%92.jpg 1.5x, /images/thumb/e/ee/%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%90%D7%9C%D7%93%D7%91%D7%A2%D7%A8%D7%92.jpg/440px-%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%90%D7%9C%D7%93%D7%91%D7%A2%D7%A8%D7%92.jpg 2x\" /></a><figcaption>הרב יוסף גולדברג</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/86/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg\" decoding=\"async\" width=\"220\" height=\"148\" class=\"mw-file-element\" srcset=\"/images/thumb/8/86/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg 1.5x, /images/thumb/8/86/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg 2x\" /></a><figcaption>הרב יוסף גולדברג (במרכז) מוסר שיעור לבחורים בישיבה</figcaption></figure>\n<p>הרב <b>יוסף גולדברג</b> (מכונה גם: <b>יאסקע טיראספולר</b>, <a href=\"/index.php/%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&#39; באייר\">י' באייר</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%93\" title=\"תרע&quot;ד\">תרע\"ד</a> - <a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ב בסיוון\">כ\"ב בסיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%94\" title=\"תשמ&quot;ה\">תשמ\"ה</a>) בוגר ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"ליובאויטש\">ליובאויטש</a> ושימש כראש ישיבת <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"ברינואה\">ברינואה</a> תקופה ארוכה. מונה על ידי הרבי ב<a href=\"/index.php/%D7%A9%D7%9E%D7%99%D7%A0%D7%99_%D7%A2%D7%A6%D7%A8%D7%AA\" title=\"שמיני עצרת\">שמיני עצרת</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a> ל\"בעל הבית\"<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> על מדינת צרפת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.99.D7.9C.D7.93.D7.95.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ילדותו\">ילדותו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ילדותו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ילדותו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>נולד ב<a href=\"/index.php/%D7%99%27_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"י&#39; אייר\">י' אייר</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%93\" title=\"תרע&quot;ד\">תרע\"ד</a> בטיראספול שבפלך אודסה (אז במולדובה) לאביו ר' יעקב קאפיל שהיה חסיד ראדזין.\n</p><p>התייתם מאביו בהיותו בן ארבע שנים וגדל בן יחיד לאימו עם ארבע אחיותיו שנעשו קומוניסטיות.\n</p><p>בגיל 13 נסע לישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%9E%D7%A0%D7%A6%27%D7%95%D7%92\" class=\"mw-redirect\" title=\"תומכי תמימים קרמנצ&#39;וג\">תומכי תמימים קרמנצ'וג</a> ומאוחר יותר ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%9C%D7%99%D7%A0%D7%A6%D7%99\" title=\"תומכי תמימים קלינצי\">קלינצי</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%90%D7%93%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"תומכי תמימים האדיטש\">והאדיטש</a>.\nבזכות ר' <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A0%D7%97_%D7%91%D7%9C%D7%99%D7%A0%D7%99%D7%A6%D7%A7%D7%99\" title=\"ישראל נח בליניצקי\">ישראל נח בליניצקי</a>, המשיך ללמוד בקרעמנצ'וג, והפך לחסיד <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a>. ר' יוסף הגיע בגיל 13 ללמוד בישיבה בקרעמנצ'וג. כעבור חצי שנה כאשר הגיע 'בין-הזמנים', ר' ישראל נח [מנהל הישיבה בקרעמנצ'וג] חשש שעקב התנאים הקשים בישיבה, לא יחזור ר' יוסף אחרי החופשה לישיבה. לכן, הוא קראו לביתו, כיבדו בסעודה דשנה ודיבר על ליבו על החשיבות של לימוד <a href=\"/index.php/%D7%A0%D7%92%D7%9C%D7%94\" class=\"mw-redirect\" title=\"נגלה\">נגלה</a> וחסידות בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a>. לאחר שעה ארוכה, הדברים נכנסו ללבו של ר' יוסף, והוא הודיע לר' ישראל נח, כי הוא ישוב ללימודים מיד בתום 'בין הזמנים'.\n</p><p>בהמשך למד בסניפים השונים של תומכי תמימים בוויטבסק, כותאיס, נובוזיבקוב' וקרלביץ'<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. \n</p>\n<h3><span id=\".D7.9E.D7.A0.D7.94.D7.9C_.D7.99.D7.A9.D7.99.D7.91.D7.AA_.D7.AA.D7.95.D7.9E.D7.9B.D7.99_.D7.AA.D7.9E.D7.99.D7.9E.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"מנהל_ישיבת_תומכי_תמימים\">מנהל ישיבת תומכי תמימים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;מנהל ישיבת תומכי תמימים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: מנהל ישיבת תומכי תמימים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>אחרי תקופה ממושכת של לימודים, החל בגיל 18 לעבוד ב<a href=\"/index.php?title=%D7%94%D7%9E%D7%97%D7%AA%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%A8%D7%95%D7%A1%D7%99%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"המחתרת החסידית ברוסיה (הדף אינו קיים)\">מחתרת</a> כסגנו של ר' <a href=\"/index.php/%D7%99%D7%95%D7%A0%D7%94_%D7%9B%D7%94%D7%9F\" title=\"יונה כהן\">יונה כהן</a>. לימים התבטא כי אלו היו הימים הטובים ביותר שלו.\n</p><p>בשנת תרצ\"ו הקים את <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%91%D7%95%D7%99_%D7%A8%D7%95%D7%92\" title=\"תומכי תמימים קריבוי רוג\">תומכי תמימים קריבוי רוג</a>. בתרצ\"ז היא נסגרה ונפתחה שוב באייר תרח\"צ. בחודש תמוז נסגרה הישיבה.\n</p><p>יצא מברית המועצות ב<a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%96\" class=\"mw-redirect\" title=\"יציאת רוסיה תש&quot;ז\">יציאת רוסיה תש\"ז</a> והתיישבו בפריז.\n</p><p>במשך שלושים ושבע שנים כיהן הרב גולדברג כראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" title=\"תומכי תמימים ברינואה\">תומכי תמימים ברינואה</a> שם העמיד תלמידים הרבה מתוך <a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%A8%D7%95%D7%AA_%D7%A0%D7%A4%D7%A9\" title=\"מסירות נפש\">מסירות נפש</a>.\n</p><p><a href=\"/index.php/%D7%A0%D7%A4%D7%98%D7%A8\" class=\"mw-redirect\" title=\"נפטר\">נפטר</a> ב<a href=\"/index.php/%D7%9B%22%D7%91_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"כ&quot;ב סיוון\">כ\"ב סיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%94\" title=\"תשמ&quot;ה\">תשמ\"ה</a> בגיל 71.\n</p>\n<h3><span id=\".D7.A9.D7.99.D7.A2.D7.95.D7.A8.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"שיעוריו\">שיעוריו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;שיעוריו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: שיעוריו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>דרכו בלימוד אותו קיבל מרבותיו ר' אברהם (מאיאר) דריזין ור' יודל עבער היתה דרך הפשט להבין היטב השקלא וטריא של הגמרא עם רש\"י ותוס'. היה יכול להתעמק זמן רב במהר\"ם שי\"ף. גם היה לו חיות קאך מיוחד בקצות החושן.\n</p><p>בשיעוריו היה מסביר באופן ברור את חשבון הפשט של הגמ' רש\"י ותוספות. כל תלמיד היה צריך ללמוד לפני השיעור את כל הגמרא רש\"י ותוספות וכל מהרש\"א ומהר\"ם שי\"ף. בשיעור הוא היה אומר לאחד הבחורים לקרוא את הגמרא איך שהוא הבין וכשהוא היה קורא היה ר' יוסף מתקן אם הוא לא אמר הפשט הנכון וגם מוסיף ביאור אם היה צורך. ולפעמים אם היה צורך היה חוזר על קצות או מפורש אחר הנוגע באופן ישיר אל הסוגיא.\n</p>\n<h3><span id=\".D7.AA.D7.9C.D7.9E.D7.99.D7.93.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"תלמידיו\">תלמידיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;תלמידיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: תלמידיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>הרב <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A7%D7%9C%D7%9E%D7%A0%D7%A1%D7%95%D7%9F\" title=\"יחיאל מנחם מענדל קלמנסון\">יחיאל מנחם מענדל קלמנסון</a> - ראש ישיבת תומכי תמימים ברינוא.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9C%D7%9E%D7%A0%D7%A1%D7%95%D7%9F\" title=\"יוסף יצחק קלמנסון\">יוסף יצחק קלמנסון</a> - ראש ישיבת בית דוד שלמה.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יצחק גולדברג\">יצחק גולדברג</a> - ראש ישיבת תומכי תמימים מגדל העמק.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A7%D7%90%D7%A4%D7%99%D7%9C_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יעקב קאפיל גולדברג\">יעקב קאפיל גולדברג</a> - ראש ישיבת הדר התורה.</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"שניאור זלמן וילשאנסקי\">שניאור זלמן וילשאנסקי</a> - ראש ישיבת תומכי תמימים מוריסטאון.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"יוסף יצחק וילשאנסקי\">יוסף יצחק וילשאנסקי</a> - ראש ישיבת חסידי חב\"ד ליובאוויטש צפת.</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%9C%D7%91%D7%A7%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"שניאור זלמן לבקובסקי\">שניאור זלמן לבקובסקי</a> - ראש ישיבת תומכי תמימים המרכזית 770.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"ישראל פרידמן\">ישראל פרידמן</a> - ראש ישיבת אהלי תורה.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%9E%D7%A0%D7%95%D7%91\" title=\"יצחק נמנוב\">יצחק נמנוב</a> מנהל ישיבת תומכי תמימים ברינואה</li>\n<li>הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%93%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנדל גורביץ (הדף אינו קיים)\">מנדל גורביץ</a> מנהל ישיבת תומכי תמימים ברינואה</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יוסף יצחק גורביץ\">יוסף יצחק גורביץ</a> משפיע ישיבת תומכי תמימים מגדל העמק</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>רעייתו צביה - בתה של מרת <a href=\"/index.php/%D7%A9%D7%A8%D7%94_%D7%A7%D7%A6%D7%A0%D7%9C%D7%91%D7%95%D7%99%D7%92%D7%9F\" title=\"שרה קצנלבויגן\">שרה קצנלבויגן</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<dl><dt>בניו</dt></dl>\n<ul><li>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A7%D7%90%D7%A4%D7%99%D7%9C_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יעקב קאפיל גולדברג\">יעקב קאפיל גולדברג</a> - <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש ישיבת</a> <a href=\"/index.php/%D7%94%D7%93%D7%A8_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"הדר התורה\">הדר התורה</a>, <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יצחק גולדברג\">יצחק גולדברג</a> - <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש ישיבת</a> <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a>.</li></ul>\n<dl><dt>חתניו ובנותיו</dt></dl>\n<ul><li>ביתו בלומה אשת הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%96%D7%93%D7%91%D7%90\" title=\"אברהם אזדבא\">אברהם אזדבא</a> - מד\"א וחבר ה<a href=\"/index.php/%D7%91%D7%93%22%D7%A5_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" class=\"mw-redirect\" title=\"בד&quot;ץ קראון הייטס\">בד\"ץ</a>, <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li>ביתו רבקה ע\"ה אשת הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C_%D7%9B%D7%94%D7%9F\" title=\"שמואל יחזקאל כהן\">שמואל יחזקאל כהן</a> - ראש כולל תפארת זקנים (לשעבר, מנהל התלמוד תורה), <a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a> (נישא שנית למרים בלוי תליט\"א).</li>\n<li>ביתו שרה אשת הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%9C%D7%95%D7%9D_%D7%A7%D7%9C%D7%99%D7%99%D7%9F\" class=\"mw-redirect\" title=\"יצחק שלום קליין\">יצחק שלום קליין</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת חב\"ד מנצ'סטר.</li>\n<li>ביתו ברכה אשת הרב <a href=\"/index.php?title=%D7%90%D7%94%D7%A8%D7%9F_%D7%95%D7%95%D7%90%D7%9C%D7%A3&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אהרן וואלף (הדף אינו קיים)\">אהרן וואלף</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> הרבי בשיקגו.</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://www.scribd.com/doc/194483234/R-Yosef-Goldberg-Brunoy\">תולדות והליכותיו</a></b> - לקט עדויות מתלמידיו ובני משפחתו</li>\n<li>יוסף אשכנזי, <a href=\"/index.php/%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D_(%D7%A1%D7%A4%D7%A8)\" class=\"mw-redirect\" title=\"אוצר החסידים (ספר)\">אוצר החסידים</a> - אישיותם ומשנתם החסידית של משפיעי חב\"ד ברחבי תבל, בהוצאת <a href=\"/index.php/%D7%97%D7%96%D7%A7_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)\" class=\"mw-redirect\" title=\"חזק (בית הוצאה לאור)\">חזק</a>, תשע\"ד</li>\n<li><b>מוסר הנפש</b>, שבועון כפר חב\"ד גליון 1961 עמוד 44.</li></ul>\n<ul><li>מנחם כהנא,&#160;‏<b>מישיבות המחתרת לאלפי תלמידים</b>, שבועון בית משיח, גיליון 1463 עמוד 34 (תשפ\"ה) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"