    "pageid": 47402,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/72/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D.jpg/250px-%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/7/72/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D.jpg/375px-%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D.jpg 1.5x, /images/thumb/7/72/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D.jpg/500px-%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D.jpg 2x\" /></a><figcaption><a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"שלוחי הרבי\">שלוחי הרבי</a> לפיליפינים בתמונה מול <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> (<a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1_%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"כינוס השלוחים העולמי\">כינוס השלוחים העולמי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a>)</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:770_%D7%9E%D7%A0%D7%99%D7%9C%D7%94.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/26/770_%D7%9E%D7%A0%D7%99%D7%9C%D7%94.jpeg/250px-770_%D7%9E%D7%A0%D7%99%D7%9C%D7%94.jpeg\" decoding=\"async\" width=\"250\" height=\"140\" class=\"mw-file-element\" srcset=\"/images/thumb/2/26/770_%D7%9E%D7%A0%D7%99%D7%9C%D7%94.jpeg/375px-770_%D7%9E%D7%A0%D7%99%D7%9C%D7%94.jpeg 1.5x, /images/thumb/2/26/770_%D7%9E%D7%A0%D7%99%D7%9C%D7%94.jpeg/500px-770_%D7%9E%D7%A0%D7%99%D7%9C%D7%94.jpeg 2x\" /></a><figcaption><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> המרכזי בעיר הבירה מנילה, פיליפינים</figcaption></figure>\n<p><b>רפובליקת הפיליפינים</b> היא מדינת איים המורכבת מ־7,641 איים. היא שוכנת במערב האוקיינוס השקט, כ־1,000 ק\"מ דרומית מזרחית ליבשת אסיה.\n</p><p>שטחה של המדינה הוא כ-300,000 קמ\"ר. נכון לשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> מונה המדינה כ-117 מיליון תושבים.\n</p><p>בפיליפינים יש קהילה <a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">יהודית</a> קטנה המונה כחמש מאות משפחות. מוצאן של המשפחות הוא מ<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a>, <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%98%D7%A0%D7%99%D7%94\" title=\"בריטניה\">בריטניה</a>, <a href=\"/index.php/%D7%A7%D7%A0%D7%93%D7%94\" title=\"קנדה\">קנדה</a>, <a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>, ארגנטינה וגם מ<a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"ישראל\">ישראל</a>. רובם אנשי עסקים אשר בחרו לגור בבירת האי מנילה מסיבות עסקיות, ומעטים מיהודי האי הם בני משפחות מדורות קודמים של האנוסים ואף ניצולי <a href=\"/index.php/%D7%94%D7%A9%D7%95%D7%90%D7%94\" title=\"השואה\">השואה</a>.\n</p><p>בנוסף, למעלה מ-20,000 מטיילים ישראלים ועוד כ-10,000 יהודים תיירים שאינם ישראלים, מטיילים במדינה מידי שנה. <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בתי חב\"ד</a> במדינה פועלים גם כ<a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93_%D7%9C%D7%9E%D7%98%D7%99%D7%99%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בית חב&quot;ד למטייל (הדף אינו קיים)\">בית חב\"ד למטייל</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.91.D7.AA.D7.99_.D7.97.D7.91.22.D7.93_.D7.91.D7.9E.D7.93.D7.99.D7.A0.D7.94\"></span><span class=\"mw-headline\" id=\"בתי_חב&quot;ד_במדינה\">בתי חב\"ד במדינה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;בתי חב&quot;ד במדינה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: בתי חב&quot;ד במדינה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בית חב\"ד המרכזי במדינה נפתח במנילה בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> על ידי הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%95%D7%99\" title=\"יוסף יצחק לוי\">יוסף יצחק לוי</a> ורעייתו שהחלו את הפעילות <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">החב\"דית</a> במדינה ופתחו <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> בעיר.\n</p><p>פעילותם מתרכזת בעבודה עם היהודים המקומיים, הישראלים שעובדים במדינה וכן בהפצת <a href=\"/index.php/%D7%A9%D7%91%D7%A2_%D7%9E%D7%A6%D7%95%D7%95%D7%AA_%D7%91%D7%A0%D7%99_%D7%A0%D7%97\" title=\"שבע מצוות בני נח\">שבע מצוות בני נח</a>.\n</p><p>עשר שנים לאחר מכן נחנך במקום בניין בית חב\"ד בדוגמת בניין <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> שב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7_%D7%A1%D7%99%D7%98%D7%99\" title=\"ניו יורק סיטי\">ניו יורק</a>, המתנשא לגובה תשע קומות ובו ישנם <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA\" title=\"בית כנסת\">בית כנסת</a>, מסעדה כשרה, חנות לממכר אוכל כשר למהדרין, מטבח ואולם אירועים, גן ילדים, כיתות לימוד, חדרי אירוח, <a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94\" title=\"מקווה\">מקווה טהרה</a> ועוד.\n</p><p>במקביל לבניית הבניין והרחבת הפעילות במנילה, גייס הרב לוי שלוחים נוספים שהתפרסו בערים נוספות ברחבי המדינה:\n2. סבו – הרב מנחם מענדל אקסלרוד<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n3. קלארק – נפתח על ידי הרב שמואל יוסף לוזון ומשפחתו. במקום נבנה <a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94_%D7%98%D7%94%D7%A8%D7%94\" class=\"mw-redirect\" title=\"מקווה טהרה\">מקווה טהרה</a> שנבנה ונחנך על ידי הרב <a href=\"/index.php/%D7%91%D7%95%D7%A2%D7%96_%D7%9C%D7%A8%D7%A0%D7%A8\" title=\"בועז לרנר\">בועז לרנר</a> שנפטר בבית חב\"ד במנילה, בהתוועדות לאחר שכובד בהנחת אבן הפינה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>, וכיום מנהלו הרב מנחם מענדל הלוי לוי.\n4. אל נידו – הרב שמעון משה נוטיק<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n5. בורקאי – הרב דניאל יאיר מוסקוביץ<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.\n6. שירגאו – הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A9%D7%A4%D7%99%D7%A0%D7%93%D7%9C%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל שפינדלר (הדף אינו קיים)\">מנחם מענדל שפינדלר</a>.\n7. בוהול – הרב ברוך שמואל קרשינזפט.\n8. BGC – החדש! – הרב שלום דובער צייטלין.\n</p>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>שליחות מחלום למציאות</b>, נחשון פרץ, שבועון <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"בית משיח (שבועון)\">בית משיח</a> מס' 1323 עמוד 22-28.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>[www.chabad.ph לאתר הבית חב\"ד]</li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/magazine/420723/\">הנס שהקים את 770 בפיליפינים</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/tag/%D7%A4%D7%99%D7%9C%D7%99%D7%A4%D7%99%D7%A0%D7%99%D7%9D/\">ידיעות וכתבות בנושא בתי חב\"ד בפיליפינים</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">נפתח על ידי הרב ניר דוננפלד ומשפחתו.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">בי\"ד אייר תשע\"ה.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <sp