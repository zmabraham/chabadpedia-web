    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/a2/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg\" decoding=\"async\" width=\"220\" height=\"220\" class=\"mw-file-element\" srcset=\"/images/thumb/a/a2/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg 1.5x, /images/thumb/a/a2/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg 2x\" /></a><figcaption></figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%99%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7%D7%9E%D7%A2%D7%95%D7%93%D7%9B%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/88/%D7%99%D7%95%D7%A1%D7%99%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7%D7%9E%D7%A2%D7%95%D7%93%D7%9B%D7%9F.jpg/220px-%D7%99%D7%95%D7%A1%D7%99%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7%D7%9E%D7%A2%D7%95%D7%93%D7%9B%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"164\" class=\"mw-file-element\" srcset=\"/images/thumb/8/88/%D7%99%D7%95%D7%A1%D7%99%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7%D7%9E%D7%A2%D7%95%D7%93%D7%9B%D7%9F.jpg/330px-%D7%99%D7%95%D7%A1%D7%99%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7%D7%9E%D7%A2%D7%95%D7%93%D7%9B%D7%9F.jpg 1.5x, /images/thumb/8/88/%D7%99%D7%95%D7%A1%D7%99%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7%D7%9E%D7%A2%D7%95%D7%93%D7%9B%D7%9F.jpg/440px-%D7%99%D7%95%D7%A1%D7%99%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7%D7%9E%D7%A2%D7%95%D7%93%D7%9B%D7%9F.jpg 2x\" /></a><figcaption>הרב חיטריק</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/20/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg\" decoding=\"async\" width=\"220\" height=\"124\" class=\"mw-file-element\" srcset=\"/images/thumb/2/20/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg 1.5x, /images/thumb/2/20/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7.jpg 2x\" /></a><figcaption></figcaption></figure>\n<p>הרב <b>יוסף יצחק חיטריק</b> (נולד ב<a href=\"/index.php/%D7%9B%22%D7%92_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"כ&quot;ג חשוון\">כ\"ג חשוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%91\" title=\"תשי&quot;ב\">תשי\"ב</a>, 22 בנובמבר 1951), הינו מ<a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">השלוחים לארץ הקודש</a>, מנהל סמינר <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%A0%D7%94_(%D7%A6%D7%A4%D7%AA)\" title=\"בית חנה (צפת)\">בית חנה בצפת</a>, יו\"ר <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%97%D7%91%22%D7%93_%D7%A6%D7%A4%D7%AA\" title=\"כולל חב&quot;ד צפת\">כולל חב\"ד צפת</a>, חבר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%94%D7%9E%D7%A0%D7%94%D7%9C%D7%99%D7%9D_(%D7%A6%D7%A4%D7%AA)\" class=\"mw-redirect\" title=\"ועד המנהלים (צפת)\">ועד מנהלי המוסדות</a> בצפת, וכותב טור דעה שבועי ב<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a> לר' <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"צבי הירש חיטריק\">צבי הירש</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ולרבקה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> חיטריק. ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%9E%D7%99%D7%9C%D7%94\" title=\"ברית מילה\">ברית המילה</a> שלו שהתקיימה בבית מספר 446 ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91_%D7%A7%D7%99%D7%A0%D7%92%D7%A1%D7%98%D7%95%D7%9F\" class=\"mw-redirect\" title=\"רחוב קינגסטון\">רחוב קינגסטון</a>, היה <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ה<a href=\"/index.php/%D7%A1%D7%A0%D7%93%D7%A7\" title=\"סנדק\">סנדק</a>, ואף אמר <a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%94\" title=\"שיחה\">שיחה</a> ארוכה ונתן 5 דולר כתרומה להיכנסו לישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>. \n</p><p>בילדותו אביו היה השליח הראשון של הרבי ל<a href=\"/index.php/%D7%91%D7%A8%D7%96%D7%99%D7%9C\" title=\"ברזיל\">ברזיל</a>, ובשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%9B\" title=\"תש&quot;כ\">תש\"כ</a> חזרו לגור ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> שב<a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%A7%D7%9C%D7%99%D7%9F\" title=\"ברוקלין\">ברוקלין</a>. \n</p><p>ב<a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%95\" title=\"תשכ&quot;ו\">תשכ\"ו</a> נכנס עם הוריו, אחיו ואחיותיו ל<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> אל הרבי לרגל ה<a href=\"/index.php/%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%95%D7%94\" title=\"בר מצווה\">בר מצווה</a> של אחיו, הרבי שוחח עימו לרגל נסיעתו העתידית בחודשי הקיץ לישראל ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a> וכיוון אותו למקד את הנסיעה ללימוד תורה מתוך שקידה והתמדה ללא שיקולים נוספים<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנים <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%97\" title=\"תשכ&quot;ח\">תשכ\"ח</a>-<a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%98\" title=\"תשכ&quot;ט\">תשכ\"ט</a> למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A8%D7%99%D7%A1%D7%98%D7%90%D7%9F\" class=\"mw-redirect\" title=\"תומכי תמימים מוריסטאן\">תומכי תמימים מוריסטאן</a> (שפעלה באותן שנים בנוארק), ובחודש אלול <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%98\" title=\"תשכ&quot;ט\">תשכ\"ט</a> עבר ללמוד בישיבה ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> <sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>באחת משנות לימודיו ב-770, נבחר לשמש כקנה מ<a href=\"/index.php/%D7%A9%D7%91%D7%A2%D7%AA_%D7%94%D7%A7%D7%A0%D7%99%D7%9D\" class=\"mw-redirect\" title=\"שבעת הקנים\">שבעת הקנים</a> ב<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a>, ר' <a href=\"/index.php/%D7%99%D7%95%D7%90%D7%9C_%D7%9B%D7%94%D7%9F\" title=\"יואל כהן\">יואל כהן</a> בחר בו לתפקיד והדריכו ללמוד לעומק לשם כך<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בניסן <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%92\" title=\"תשל&quot;ג\">תשל\"ג</a> הצטרף לקבוצת <a href=\"/index.php/%D7%94%D7%AA%D7%9C%D7%9E%D7%99%D7%93%D7%99%D7%9D_%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D\" title=\"התלמידים השלוחים\">התלמידים השלוחים</a> ל<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%92%D7%93%D7%95%D7%9C%D7%94_%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F\" title=\"ישיבה גדולה מלבורן\">ישיבת חב\"ד במלבורן, אוסטרליה</a> שם נותר כשנתיים לאחריהם חזר לשקוד על לימודיו ב-770.\n</p><p>ב<a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"תשל&quot;ו\">תשל\"ו</a> <a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9F\" title=\"נישואין\">נישא</a> לרחל בת הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9E%D7%A9%D7%94_%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F\" title=\"דוד משה ליברמן\">דוד משה ליברמן</a>, בזמנו <a href=\"/index.php/%D7%A8%D7%91_(%D7%AA%D7%95%D7%90%D7%A8)\" class=\"mw-redirect\" title=\"רב (תואר)\">רב</a> ו<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> של הרבי <a href=\"/index.php/%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הריי&quot;צ\">הריי\"צ</a> ב<a href=\"/index.php/%D7%93%D7%98%D7%A8%D7%95%D7%99%D7%98\" title=\"דטרויט\">דטרויט</a> ולאחר מכן <a href=\"/index.php/%D7%92%D7%90%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"גאב&quot;ד\">גאב\"ד</a> <a href=\"/index.php/%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"אנטוורפן\">אנטוורפן</a> במשך 44 שנה. \n</p><p>לפני חתונתו כתב לרבי בקשת ברכה לשכירת דירה בקראון הייטס וקיבל מענה התומך בקנייה<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>, אביו רכש עבורו בית בקראון הייטס<sup id=\"cite_ref-טורו_8-0\" class=\"reference\"><a href=\"#cite_note-טורו-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h3><span id=\".D7.A4.D7.A2.D7.95.D7.9C.D7.95.D7.AA.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"פעולותיו\">פעולותיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;פעולותיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: פעולותיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>בשבט <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a>, נשלח יחד עם קבוצת <a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">שלוחים לארץ קודש</a> כ<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> ל<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>. הרבי התנה את השליחות בהתחייבותו להיות ב<a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%94\" title=\"שמחה\">שמחה</a><sup id=\"cite_ref-טורו_8-1\" class=\"reference\"><a href=\"#cite_note-טורו-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a>, לאחר שהיה מנהלו של התיכון ב\"<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%A0%D7%94_(%D7%A6%D7%A4%D7%AA)\" title=\"בית חנה (צפת)\">בית חנה\" בצפת</a> הקים את הסמינר והפך לשמש כמנהל הסמינר.\n</p><p>באותה תקופה גם מונה כסגן יו\"ר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%94%D7%9E%D7%A0%D7%94%D7%9C%D7%99%D7%9D_(%D7%A6%D7%A4%D7%AA)\" class=\"mw-redirect\" title=\"ועד המנהלים (צפת)\">ועד המנהלים</a> על ידי גיסו הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%91_%D7%A7%D7%A4%D7%9C%D7%9F\" class=\"mw-redirect\" title=\"אריה ליב קפלן\">אריה ליב קפלן</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a>, מונה על ידי <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"בית דין רבני חב&quot;ד\">בית דין רבני חב\"ד</a> לחבר ב<a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"אגודת חסידי חב&quot;ד בישראל\">אגודת חסידי חב\"ד בישראל</a>.\n</p><p>לאחר שהורה <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> להקים את <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%97%D7%91%22%D7%93_%D7%A6%D7%A4%D7%AA\" title=\"כולל חב&quot;ד צפת\">כולל חב\"ד צפת</a> נתמנה ליו\"ר הכולל, תחתיו מנהל את הכולל הרב <a href=\"/index.php/%D7%99%D7%95%D7%A8%D7%9D_%D7%9E%D7%A2%D7%95%D7%93%D7%94\" title=\"יורם מעודה\">יורם מעודה</a>.\n</p><p>בשנת תשנ\"ה חתם על פסק דין הפוסק שצריכה להיות \"התגלות הרבי מלך המשיח שיל\"ו\"<sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\"><span class=\"cite-bracket\">&#91;</span>9<span class=\"cite-bracket\">&#93;</span></a></sup>. ובהמשך אף חתם על <a href=\"/index.php/%D7%A4%D7%A1%D7%A7_%D7%94%D7%93%D7%99%D7%9F_%D7%A9%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%95%D7%90_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"פסק הדין שהרבי הוא מלך המשיח\">פסק הדין שהרבי הוא מלך המשיח</a>.\n</p><p>בין השנים <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a>-<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> כתב בקביעות במדור דעות ב<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a>. בין <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">חודש אייר</a> שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a> ל<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a> שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a> חזר לכתוב מדור פופולארי בשם 'זו רק דעתי' שזכה לתגובות רבות. בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a> פנתה מערכת <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">כפר חב\"ד</a> בשאלה לקוראיה האם להחזירו שוב לכתוב. הקוראים השיבו בחיוב ועד היום ממשיך הרב חיטריק בכתיבה בשבועון.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"מנחם מענדל חיטריק\">מנחם מענדל חיטריק</a> - שליח הרבי ורב הקהילה האשכנזית באיסטנבול, טורקיה</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"חיים אליעזר חיטריק\">חיים אליעזר חיטריק</a> - שליח הרבי ורב העיר נירנברג, <a href=\"/index.php/%D7%92%D7%A8%D7%9E%D7%A0%D7%99%D7%94\" title=\"גרמניה\">גרמניה</a></li>\n<li>חתנו ר' מנחם מענדל סקרדר - <a href=\"/index.php/%D7%A4%D7%9C%D7%95%D7%A8%D7%99%D7%93%D7%94\" title=\"פלורידה\">פלורידה</a></li>\n<li>חתנו, הרב מנחם מענדל גולדשמיד - שליח הרבי בקוסומוי, תאילנד</li>\n<li>בנו, הרב שמואל חיטריק - שליח הרבי ב<a href=\"/index.php/%D7%A4%D7%98%D7%A8%D7%91%D7%95%D7%A8%D7%92\" title=\"פטרבורג\">פטרבורג</a>, <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a></li>\n<li>חתנו, הרב חיים דוד וילהלם - כפר ויתקין</li>\n<li>חתנו, ר' פרץ ליין - <a href=\"/index.php/%D7%A4%D7%9C%D7%95%D7%A8%D7%99%D7%93%D7%94\" title=\"פלורידה\">פלורידה</a><sup id=\"cite_ref-10\" class=\"reference\"><a href=\"#cite_note-10\"><span class=\"cite-bracket\">&#91;</span>10<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>חתנו, הרב מנחם מענדל מרינובסקי - שליח הרבי ב<a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8%D7%95\" class=\"mw-redirect\" title=\"דנייפרו\">דנייפר</a>, <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ישראל אלפרוביץ, <b>היסטוריה באוסטרליה</b>, 50 שנה לקבוצה הרביעית של התלמידים השלוחים לישיבת חב\"ד במלבורן, שבועון כפר חב\"ד גליון 2004 עמוד 158</li></ul>\n<p><br />\n</p>\n<table class=\"navbox nowraplinks mw-collapsible autocollapse\" style=\"width: 90%; clear: both; margin: 0.5em auto; margin-top: 0.5em; margin-bottom: 0.5em; padding: 0.2em; text-align: right;\">\n\n<tbody><tr>\n<th colspan=\"3\" style=\"text-align: center; padding-top: 0.1em; paddin