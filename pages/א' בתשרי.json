      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ב&#39; בתשרי\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ג&#39; בתשרי\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ד&#39; בתשרי\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ה&#39; בתשרי\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ו&#39; בתשרי\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ז&#39; בתשרי\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ח&#39; בתשרי\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&#39; בתשרי\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&#39; בתשרי\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;א בתשרי\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ב בתשרי\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ג בתשרי\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ד בתשרי\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&quot;ו בתשרי\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&quot;ז בתשרי\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ז בתשרי\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ח בתשרי\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ט בתשרי\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&#39; בתשרי\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;א בתשרי\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ב בתשרי\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ג בתשרי\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ד בתשרי\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ה בתשרי\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ו בתשרי\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ז בתשרי\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ח בתשרי\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ט בתשרי\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ל&#39; בתשרי\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>א&#39; בתשרי</b> הוא היום הראשון\nבחודש הראשון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;ונקרא <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94\" title=\"ראש השנה\">ראש השנה</a>.\n</p><p>תאריך זה חל בתקופת תשרי&#160;והוא יכול לחול בימים&#160;שני, שלישי, חמישי ושבת.\n</p>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/41/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94.jpg/220px-%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94.jpg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/4/41/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94.jpg/330px-%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94.jpg 1.5x, /images/thumb/4/41/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94.jpg/440px-%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94.jpg 2x\" /></a><figcaption>יהודים מתפללים ב<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94\" title=\"ראש השנה\">ראש השנה</a>. ציורו של ר' <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%A7%D7%9C%D7%99%D7%99%D7%A0%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"זלמן קליינמן\">זלמן קליינמן</a>.</figcaption></figure>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>א' (-3760 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - יום השישי ל<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%90%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"בריאת העולם\">בריאת העולם</a> בו נבראו החיות, הבהמות ו<a href=\"/index.php/%D7%90%D7%93%D7%9D_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" title=\"אדם הראשון\">אדם הראשון</a> ואשתו <a href=\"/index.php/%D7%97%D7%95%D7%94_%D7%90%D7%9E%D7%A0%D7%95\" title=\"חוה אמנו\">חוה אמנו</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> ונקראת חווה \"כי היא הייתה אם כל חי\".</li>\n<li>א'תרנ\"ז (-2104 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - יציאת <a href=\"/index.php/%D7%A0%D7%97\" title=\"נח\">נח</a> מן התיבה בתום המבול.<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>א'תתקנ\"ט (-1802 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%A9%D7%A8%D7%94_%D7%90%D7%99%D7%9E%D7%A0%D7%95\" class=\"mw-redirect\" title=\"שרה אימנו\">שרה אימנו</a>, הראשונה מבין <a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2%D7%AA_%D7%94%D7%90%D7%9E%D7%94%D7%95%D7%AA\" title=\"ארבעת האמהות\">ארבעת האמהות</a> ואשת <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D\" class=\"mw-redirect\" title=\"אברהם\">אברהם</a>, נולדה.</li>\n<li>ב'רכ\"ט (-1532 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%94%D7%A6%D7%93%D7%99%D7%A7\" title=\"יוסף הצדיק\">יוסף</a> פתר את חלומות <a href=\"/index.php/%D7%A4%D7%A8%D7%A2%D7%94\" title=\"פרעה\">פרעה</a> ונעשה משנה למלך ב<a href=\"/index.php/%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"מצרים\">מצרים</a>.</li>\n<li>ג'שמ\"א (-420 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - הנביא <a href=\"/index.php?title=%D7%92%D7%93%D7%9C%D7%99%D7%94%D7%95_%D7%91%D7%9F_%D7%90%D7%97%D7%99%D7%A7%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"גדליהו בן אחיקם (הדף אינו קיים)\">גדליהו בן אחיקם</a>, מנהיג שרידי העם שלא גלו ב<a href=\"/index.php/%D7%92%D7%9C%D7%95%D7%AA_%D7%91%D7%91%D7%9C\" class=\"mw-redirect\" title=\"גלות בבל\">גלות בבל</a>, נפטר<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>ד'תרמ\"ז (07/09/886 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבינו שפטיה בן אמיתי, נפטר.</li>\n<li>ד'תשע\"ב (07/09/1011 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבינו <a href=\"/index.php?title=%D7%90%D7%9E%D7%A0%D7%95%D7%9F_%D7%9E%D7%9E%D7%92%D7%A0%D7%A6%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אמנון ממגנצא (הדף אינו קיים)\">אמנון ממגנצא</a>, מחבר הפיוט '<a href=\"/index.php/%D7%95%D7%A0%D7%AA%D7%A0%D7%94_%D7%AA%D7%95%D7%A7%D7%A3\" title=\"ונתנה תוקף\">ונתנה תוקף</a>', נהרג על <a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9_%D7%94%D7%A9%D7%9D\" title=\"קידוש השם\">קידוש ה'</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%9B%22%D7%90\" title=\"תקכ&quot;א\">תקכ\"א</a> (11/09/1760 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יהודה עייאש, רבה של אלג'יר ובאחרית ימיו ראש ישיבת 'מדרש כנסת ישראל' ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, מחבר ספר 'בני יהודה', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%22%D7%9E\" title=\"תר&quot;מ\">תר\"מ</a> (18/09/1879 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי מאיר ליבוש בן יחיאל מיכל, ה<a href=\"/index.php/%D7%9E%D7%9C%D7%91%D7%99%22%D7%9D\" title=\"מלבי&quot;ם\">מלבי\"ם</a>, נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%22%D7%A0\" title=\"תר&quot;נ\">תר\"נ</a> (26/09/1889 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הצדיק ה<a href=\"/index.php/%D7%A7%D7%91%D7%9C%D7%94\" class=\"mw-redirect\" title=\"קבלה\">מקובל</a> האלוקי <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%95%D7%97%D7%A6%D7%99%D7%A8%D7%90_%D7%94%D7%91%D7%91%D7%90_%D7%A1%D7%90%D7%9C%D7%99\" class=\"mw-redirect\" title=\"רבי ישראל אבוחצירא הבבא סאלי\">רבי ישראל אבוחצירא הבבא סאלי</a>, נולד.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%93\" title=\"תרע&quot;ד\">תרע\"ד</a> (2/10/1913 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%93%D7%95%D7%93_%D7%95%D7%99%D7%9C%D7%91%D7%A1%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יעקב דוד וילבסקי (הדף אינו קיים)\">יעקב דוד וילבסקי</a>, הרידב\"ז, נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%91\" title=\"תרצ&quot;ב\">תרצ\"ב</a> (12/09/1931 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יצחק מאיר השל מקופישניץ, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\">נולדו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%94\" title=\"תרס&quot;ה\">תרס\"ה</a> - הרב <a href=\"/index.php/%D7%92%D7%A2%D7%98%D7%A9%D7%A2_%D7%95%D7%99%D7%9C%D7%A0%D7%A1%D7%A7%D7%99\" title=\"געטשע וילנסקי\">געצל וילנסקי</a>, מראשי הפעילים להחזקת היהדות ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> שעסק במסירות נפש בהפעלת המחתרת היהודית, זכה לקשר אישי עם הרבי, וקירב מאות צעירים ליהדות.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%94\" title=\"תשכ&quot;ה\">תשכ\"ה</a> - הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%9E%D7%A9%D7%94_%D7%AA%D7%9E%D7%A8%D7%99%D7%9F\" title=\"מאיר משה תמרין\">מאיר משה תמרין</a> שליח הרבי ורב העיר מאלאחובקא שבפרוורי <a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>, <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%A4%D7%90%D7%9C_%D7%99%D7%A6%D7%97%D7%A7_%D7%91%D7%9C%D7%99%D7%A0%D7%99%D7%A6%D7%A7%D7%99\" title=\"חיים רפאל יצחק בליניצקי\">חיים רפאל יצחק בליניצקי</a>, <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a> (27/09/2003 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"שניאור זלמן גוראריה\">שניאור זלמן גוראריה</a> יו\"ר מועצת המנהלים של <a href=\"/index.php?title=%D7%9E%D7%A8%D7%9B%D7%96_%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מרכז ישיבת תומכי תמימים ליובאוויטש (הדף אינו קיים)\">מרכז ישיבת תומכי תמימים ליובאוויטש</a>, ממנהלי הוצאת ספרים <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a>, וממונה על ההנהלה הראשית של <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99%D7%AA\" title=\"אגודת חסידי חב&quot;ד העולמית\">אגודת חסידי חב\"ד העולמית</a>.</li>\n<li><a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%22%D7%A2\" class=\"mw-redirect\" title=\"ה&#39;תש&quot;ע\">ה'תש\"ע</a> (19/09/2009 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"מאיר פרידמן\">מאיר פרידמן</a>, <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%90\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;א\">ה'תשפ\"א</a> (19/09/2020 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%93%D7%A8_(%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1)\" title=\"אברהם לידר (קראון הייטס)\">אברהם לידר</a>, איש חסד, מנהל ארגון <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%AA_%D7%97%D7%A1%D7%93\" title=\"אהבת חסד\">אהבת חסד</a> ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> - הרב <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%99%D7%9B%D7%9C_%D7%95%D7%99%D7%A9%D7%A6%D7%A7%D7%99\" title=\"יחיאל מיכל וישצקי\">מיכל וישצקי</a> - משפיע חסידי ונואם מבוקש, בעל מסירות נפש ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">רוסיה הקומוניסטית</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a>- הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9C%D7%9E%D7%A0%D7%A1%D7%95%D7%9F\" title=\"יוסף יצחק קלמנסון\">יוסף יצחק קלמנסון</a> - ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> \"<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%95%D7%93_%D7%A9%D7%9C%D7%9E%D7%94\" class=\"mw-redirect\" title=\"בית דוד שלמה\">בית דוד שלמה</a>\" ניו הייבן ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a>, מחבר סדרת הספרים <a href=\"/index.php/%D7%A8%D7%A9%D7%99%D7%9E%D7%95%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8%D7%99%D7%9D\" title=\"רשימות שיעורים\">רשימות שיעורים</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - א' בתשרי - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>א' ד<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94\" title=\"ראש השנה\">ראש השנה</a></i>\n<p>ברכת <a href=\"/index.php/%D7%94%D7%93%D7%9C%D7%A7%D7%AA_%D7%A0%D7%A8%D7%95%D7%AA_%D7%A9%D7%91%D7%AA\" class=\"mw-redirect\" title=\"הדלקת נרות שבת\">הדלקת הנרות</a>: של יום הזכרון. <a href=\"/index.php/%D7%A9%D7%94%D7%97%D7%99%D7%99%D7%A0%D7%95\" class=\"mw-redirect\" title=\"שהחיינו\">שהחיינו</a>. אין כופלין \"לעילא\" בקדיש, לבד מ<a href=\"/index.php/%D7%A0%D7%A2%D7%99%D7%9C%D7%94\" class=\"mw-redirect\" title=\"נעילה\">נעילה</a>. \"לדוד גו' הארץ ומלואה גו'\" - קודם \"עלינו\". ב<a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9\" title=\"קידוש\">קידוש</a> היום: \"תקעו\", \"כי חק\". ואין אומרים \"אלה מועדי\" ו\"אתקינו\". ל<a href=\"/index.php/%D7%AA%D7%A9%D7%9C%D7%99%D7%9A\" title=\"תשליך\">תשליך</a>: מנערים שולי ה<a href=\"/index.php/%D7%A6%D7%99%D7%A6%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ציצית\">טלית קטן</a>. \"יהי רצון\" שעל ה<a href=\"/index.php/%D7%AA%D7%A4%D7%95%D7%97\" title=\"תפוח\">תפוח</a> - אחר ה<a href=\"/index.php/%D7%91%D7%A8%D7%9B%D7%94\" title=\"ברכה\">ברכה</a> וקודם האכילה. אוכלים ראש אייל, אבל אין אומרים \"יהי רצון\" כי אם על ה<a href=\"/index.php/%D7%AA%D7%A4%D7%95%D7%97\" title=\"תפוח\">תפוח</a>.\n</p>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השביעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">לדעת <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8\" class=\"mw-redirect\" title=\"רבי אליעזר\">רבי אליעזר</a></span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">‏לדעת ר' אליעזר. ‏‏<a href=\"/index.php/%D7%9E%D7%A1%D7%9B%D7%AA_%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94\" title=\"מסכת ראש השנה\">מסכת ראש השנה</a>, דף י\"א עמוד ב'‏</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">לגירסא אחת</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413125007\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.126 seconds\nReal time usage: 0.660 seconds\nPreprocessor visited node count: 477/1000000\nPost‐expand include size: 9022/2097152 bytes\nTemplate argument size: 701/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 1440/5000000 bytes\nLua time usage: 0.090/7 seconds\nLua virtual size: 6123520/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  587.799      1 -total\n 78.03%  458.651      1 תבנית:פתיח_יום\n 26.30%  154.568      4 תבנית:הערה\n 20.78%  122.163      5 תבנית:מילה_אחרונה\n  9.11%   53.561      2 תבנית:מילה_ראשונה\n  5.57%   32.768      1 תבנית:הסר_מילה_ראשונה\n  4.36%   25.656      1 תבנית:חודש_תשרי\n  3.30%   19.426      1 תבנית:הערות_שוליים\n  3.01%   17.669      1 תבנית:לוח_שנה\n  2.70%   15.852      1 תבנית:להיום_יום\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:16947-0!canonical and timestamp 20260413125007 and revision id 830721. Rendering was triggered because: page-view\n -->\n</div>"
