\n<p><b>ב' באלול</b> הוא היום השני ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>שט\"ו – ה<a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A\" title=\"שולחן ערוך\">שולחן ערוך</a> של רבי <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%90%D7%A8%D7%95\" title=\"יוסף קארו\">יוסף קארו</a>, מודפס.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> – רבי אברהם יעקב פרידמן מבויאן – <a href=\"/index.php/%D7%9C%D7%91%D7%95%D7%91\" title=\"לבוב\">לבוב</a>, נהרג על קידוש ה'.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> – רבי אליעזר הגר מ<a href=\"/index.php/%D7%95%D7%99%D7%96%27%D7%A0%D7%99%D7%A5\" class=\"mw-redirect\" title=\"ויז&#39;ניץ\">ויז'ניץ</a>, מחבר ספר 'דמשק אליעזר', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%95\" title=\"תשכ&quot;ו\">תשכ\"ו</a> – רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%94%D7%95%D7%A4%D7%A9%D7%98%D7%99%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ישראל אלעזר הופשטיין\">ישראל אלעזר הופשטיין</a> מקוז'ניץ, מחבר ספר 'עבודת אלעזר', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%93\" title=\"תרע&quot;ד\">תרע\"ד</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> החל לכתוב את הקונטרס <a href=\"/index.php/%D7%93%D7%91%D7%A8%D7%99_%D7%99%D7%9E%D7%99_%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%A8%D7%91%D7%A7%D7%94\" title=\"דברי ימי הרבנית רבקה\">דברי ימי הרבנית רבקה</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> - <a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97_-_%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"כינוסי גאולה ומשיח - תשנ&quot;ה\">כינוס גאולה ומשיח</a> בנשר ל<a href=\"/index.php/%D7%A7%D7%91%D7%9C%D7%AA_%D7%A4%D7%A0%D7%99_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"קבלת פני משיח\">קבלת פני משיח</a></li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%9C%D7%93%D7%9E%D7%9F_(%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"אברהם פלדמן (נחלת הר חב&quot;ד)\">אברהם פלדמן</a> - <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> וחבר הנהלה ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ישיבת בית הר&quot;מ\">ישיבת בית הר\"מ</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a> – הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%94%D7%9F_(%D7%90%D7%9C%D7%A2%D7%93)\" title=\"מנחם כהן (אלעד)\">מנחם כהן</a>, עורך <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\">שבועון כפר חב\"ד</a>, שבעבר שימש כעורך אתרי החדשות <a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\">חב\"ד און ליין</a> (COL) ו'כיכר השבת'.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a> – הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%9E%D7%98%D7%9C%D7%99%D7%9F\" title=\"ישעיה מטלין\">ישעיה מטלין</a>, <a href=\"/index.php/%D7%A1%D7%95%D7%A4%D7%A8_%D7%A1%D7%AA%22%D7%9D\" title=\"סופר סת&quot;ם\">הסופר</a> של הרבי.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ב' באלול - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"בני ישראל\">בני ישראל</a> נקראו ארץ חפץ, שיש בהם כמה חפצים יקרים ב<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%AA_%D7%94%27\" title=\"אהבת ה&#39;\">אהבת ה'</a> יתברך ו<a href=\"/index.php/%D7%99%D7%A8%D7%90%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"יראת ה&#39;\">יראתו</a> ו<a href=\"/index.php/%D7%9E%D7%99%D7%93%D7%95%D7%AA_%D7%98%D7%95%D7%91%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מידות טובות\">מידות</a> טובות, ואין דבר גילוי המידות הטובות תלוי אלא במעורר. דבר ברור הוא, אשר בכל חלקי ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%94\" title=\"אדמה\">אדמה</a> נמצאים מעינות <a href=\"/index.php/%D7%9E%D7%99%D7%9D\" title=\"מים\">מים</a> חיים, וההבדל הוא רק בקירוב וריחוק, ואם כן הלא הכל תלוי בהחופר וכח סבלנותו ומתינותו.\n<p>וכיון שה<a href=\"/index.php/%D7%A8%D7%A6%D7%95%D7%9F\" title=\"רצון\">רצון</a> הוא כח עליון הגוזר ומפקד על כל ה<a href=\"/index.php?title=%D7%9B%D7%97&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כח (הדף אינו קיים)\">כוחות</a>, ומכריחם לעשות ולפעול כפי הפקודות שלו, אם כן איפוא עיקר ה<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%94\" title=\"עבודה\">עבודה</a> הוא לעורר את הרצון לפעול ולעשות הן ב<a href=\"/index.php?title=%D7%A2%D7%A6%D7%9E%D7%95&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עצמו (הדף אינו קיים)\">עצמו</a> הן ב<a href=\"/index.php?title=%D7%96%D7%95%D7%9C%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"זולת (הדף אינו קיים)\">זולתו</a>.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414020827\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.023 seconds\nReal time usage: 0.054 seconds\nPreprocessor visited node count: 97/1000000\nPost‐expand include size: 6629/2097152 bytes\nTemplate argument size: 696/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   27.952      1 -total\n 60.95%   17.038      1 תבנית:חודש_אלול\n 40.91%   11.43