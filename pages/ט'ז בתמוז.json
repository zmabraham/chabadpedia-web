הוא היום השישה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח – עם ישראל <a href=\"/index.php/%D7%97%D7%98%D7%90_%D7%94%D7%A2%D7%92%D7%9C\" title=\"חטא העגל\">חטא בעגל</a>.</li>\n<li>ב'תמ\"ח – חור, בן מרים הנביאה וכלב בן יפונה, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> – רבי <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%94%D7%A2%D7%A9%D7%99%D7%9C_%D7%9E%D7%A7%D7%95%D7%A4%D7%99%D7%98%D7%A9%D7%A0%D7%99%D7%A5\" title=\"אברהם יהושע העשיל מקופיטשניץ\">אברהם יהושע העשיל מקופיטשניץ</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"תשל&quot;ה\">תשל\"ה</a> – <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> פתח ב<a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%98%D7%94%D7%A8%D7%AA_%D7%94%D7%9E%D7%A9%D7%A4%D7%97%D7%94\" title=\"מבצע טהרת המשפחה\">מבצע טהרת המשפחה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a> – <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ביקר בסניף הראשון של <a href=\"/index.php/%D7%A7%D7%A2%D7%9E%D7%A4_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"קעמפ גן ישראל\">קעמפ גן ישראל</a> ששכן בעלנוויל, וחנך את רשת מחנות הקיץ החב\"דיים.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a> – הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%91%D7%A8%D7%95%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"שניאור זלמן ברונשטיין\">שניאור זלמן ברונשטיין</a>, מראשוני המתיישבים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%99%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" title=\"חיים לוי יצחק גינזבורג\">חיים לוי יצחק גינזבורג</a>, משפיע בישיבות חב\"ד ומחבר ספרים ב<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> ובענייני <a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"גאולה ומשיח\">גאולה ומשיח</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%97%D7%A0%D7%9F_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%95%D7%91%D7%99%D7%A5%27\" title=\"אלחנן יעקובוביץ&#39;\">אלחנן יעקובוביץ'</a> מותיקי אנ\"ש ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a> זכה לברכה לבנים מ<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ט\"ז בתמוז - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%94%D7%91%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"אהבת ישראל\">אהבת ישראל</a> של ה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a> - אין לשער.\n<p><a href=\"/index.php/%D7%94%D7%A8%D7%91_%D7%94%D7%9E%D7%92%D7%99%D7%93\" class=\"mw-redirect\" title=\"הרב המגיד\">הרב המגיד</a> אמר: \"הלואי היו נושקים הספר תורה באותה ה<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94\" title=\"אהבה\">אהבה</a>, שהיה מורי מנשק את הילדים בהוליכו אותם אל ה\"חדר\" כשהי' \"באהעלפער\" (= עוזר).\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414070311\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.024 seconds\nReal time usage: 0.064 seconds\nPreprocessor visited node count: 81/1000000\nPost‐expand include size: 5521/2097152 bytes\nTemplate argument size: 702/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   33.377      1 -total\n 59.74%   19.938      1 תבנית:חודש_תמוז\n 40.17%   13.408      1 תבנית:לוח_שנה_חסר\n 39.79%   13.282      1 תבנית:להיום_יום\n 19.60%    6.541      1 תבנית:כתב_קטן\n 18.39%    6.137      1 תבנית:היום_יום/ט&quot;ז_תמוז\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:17359-0!canonical and timestamp 20260414070311 and revision id 704120. Rendering was triggered because: page-view\n -->\n</div>"
