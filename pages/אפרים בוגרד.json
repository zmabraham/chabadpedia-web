    "pageid": 11683,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/0/0b/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93.jpg/250px-%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93.jpg\" decoding=\"async\" width=\"250\" height=\"169\" class=\"mw-file-element\" srcset=\"/images/thumb/0/0b/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93.jpg/375px-%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93.jpg 1.5x, /images/thumb/0/0b/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93.jpg/500px-%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93.jpg 2x\" /></a><figcaption>הרב אפרים בוגרד</figcaption></figure>\n<p>הרב <b>אפרים בוגרד</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a>, 1963) הינו רב הקהילה ורב בית הכנסת חבד ברמות ב' בירושלים ודיין בבית הדין הרבני האזורי וב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"בית דין רבני חב&quot;ד בארץ הקודש\">בית דין רבני חב\"ד בארץ הקודש</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולד</a> ב<a href=\"/index.php/%D7%98%22%D7%96_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ט&quot;ז חשוון\">ט\"ז חשוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> לאביו הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%91%D7%95%D7%92%D7%A8%D7%93\" title=\"שמואל בוגרד\">שמואל בוגרד</a> מ<a href=\"/index.php/%D7%94%D7%A8%D7%A6%D7%9C%D7%99%D7%94\" title=\"הרצליה\">הרצליה</a> ולמרים רוניא בתו של ר' <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%9C%D7%99%D7%A1\" class=\"mw-redirect\" title=\"יצחק מענדל ליס\">יצחק מענדל ליס</a>.\n</p><p>למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>, ובשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%93\" class=\"mw-redirect\" title=\"תשמ&quot;ד\">תשמ\"ד</a> נסע ללמוד ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ישיבת תומכי תמימים המרכזית\">ישיבת תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>לאחר נישואיו עם שיינא נחמה בת ר' יצחק גבירץ, קבע את מגוריו בשכונת רמות ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, השלים את לימודי הסמיכה לדיינות, ובהמשך התמנה כדיין ורב מורה הוראה ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"בית דין רבני חב&quot;ד בארץ הקודש\">בית דין רבני חב\"ד בארץ הקודש</a>. כמו כן התמנה כרב שכונת רמות בירושלים ומרבני הקהילה החב\"דית המקומית.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> עלה על הפרק מינויו כדיין בהרכב בית הדין הרבני הפועל מטעם <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%95%D7%AA_%D7%94%D7%A8%D7%90%D7%A9%D7%99%D7%AA\" class=\"mw-redirect\" title=\"הרבנות הראשית\">הרבנות הראשית</a>. כהקדמה למערכת הבחירות, התאחדו רבני חב\"ד בקריאה לרבנים הראשיים הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%95%D7%A1%D7%A3\" title=\"יצחק יוסף\">יצחק יוסף</a> והרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9C%D7%90%D7%95\" title=\"דוד לאו\">דוד לאו</a> בו מביעים את תמיכתם בבחירתו של הרב בוגרד לתפקיד<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\nבסופו של דבר נתמנה לדיין בכ\"ו אלול תשע\"ח, משמש כדיין בבית הדין הרבני האיזורי בחיפה.\n</p>\n<h2><span id=\".D7.AA.D7.A4.D7.A7.D7.99.D7.93.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"תפקידיו\">תפקידיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;תפקידיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: תפקידיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> בשכונת רמות (<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>).</li>\n<li>מרבני קהילת <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> ברמות.</li>\n<li>דיין ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"בית דין רבני חב&quot;ד בארץ הקודש\">בית דין רבני חב\"ד בארץ הקודש</a>.</li>\n<li>תשס\"ב - תשע\"ח חבר צוות העורכים והבודקים של מבחני ה<a href=\"/index.php/%D7%A1%D7%9E%D7%99%D7%9B%D7%94\" class=\"mw-redirect\" title=\"סמיכה\">סמיכה</a> מטעם <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%95%D7%AA_%D7%94%D7%A8%D7%90%D7%A9%D7%99%D7%AA_%D7%9C%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"הרבנות הראשית לישראל\">הרבנות הראשית לישראל</a>.</li>\n<li>בעבר שימש כראש <a href=\"/index.php?title=%D7%9B%D7%95%D7%9C%D7%9C_%D7%99%D7%95%D7%A6%D7%90%D7%99_%D7%A8%D7%95%D7%A1%D7%99%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כולל יוצאי רוסיה (הדף אינו קיים)\">כולל יוצאי רוסיה</a> - <a href=\"/index.php/%D7%A9%D7%9E%D7%99%22%D7%A8\" title=\"שמי&quot;ר\">שמי\"ר</a>, <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li>ראש כולל <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%AA%D7%95%D7%A8%D7%94_%D7%A9%D7%9C%D7%9E%D7%94\" class=\"mw-redirect\" title=\"מכון תורה שלמה\">מכון תורה שלמה</a> בחדרה ובכפר סבא.</li>\n<li>דיין בבית הדין האזורי - נבחר בשלהי שנת תשע\"ח.</li></ul>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ספריו\">ספריו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ספריו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ספריו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב אפרים בוגרד, <b><a href=\"/index.php?title=%D7%A4%D7%A1%D7%A7%D7%99_%D7%94%D7%A8%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"פסקי הרב (הדף אינו קיים)\">פסקי הרב</a></b>, לקט מפסקי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> על שו\"ע יורה-דעה, הוצאת <a href=\"/index.php/%D7%A9%D7%9E%D7%99%22%D7%A8\" title=\"שמי&quot;ר\">שמי\"ר</a>, <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%91%D7%95%D7%92%D7%A8%D7%93&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.shturem.net/index.php?section=news&amp;id=75059\">הרב בוגרד מתארח במדור 'מילה של חסיד'</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D_(%D7%90%D7%AA%D7%A8)\" title=\"קישור שטורעם\"><img alt=\"קישור שטורעם\" src=\"/images/thumb/8/89/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG/15px-%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG\" decoding=\"async\" width=\"15\" height=\"14\" class=\"mw-file-element\" srcset=\"/images/8/89/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG 1.5x\" /></a></span> <span class=\"grayText\"><small>(הקישור אינו פעיל)</small></span> כ\"ז <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> <span class=\"grayText\"><small>(הקישור אינו פעיל)</small></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://chabad.info/magazine/%D7%A8%D7%90%D7%99%D7%95%D7%9F-%D7%A2%D7%95%D7%9E%D7%A7-%D7%AA%D7%A4%D7%A7%D7%99%D7%93%D7%95-%D7%94%D7%9E%D7%99%D7%95%D7%97%D7%93-%D7%A9%D7%9C-%D7%93%D7%99%D7%99%D7%9F-%D7%97%D7%91%D7%93%D7%99/\">ראיון עומק: תפקידו המיוחד של דיין חב\"די</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" />