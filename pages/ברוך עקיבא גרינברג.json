      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%27_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/5d/%D7%A8%27_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg/250px-%D7%A8%27_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg\" decoding=\"async\" width=\"250\" height=\"335\" class=\"mw-file-element\" srcset=\"/images/thumb/5/5d/%D7%A8%27_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg/375px-%D7%A8%27_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg 1.5x, /images/thumb/5/5d/%D7%A8%27_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg/500px-%D7%A8%27_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg 2x\" /></a><figcaption>ר' ברוך עקיבא גרינברג</figcaption></figure>\n<figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/5e/%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg/250px-%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg\" decoding=\"async\" width=\"250\" height=\"290\" class=\"mw-file-element\" srcset=\"/images/5/5e/%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg 1.5x\" /></a><figcaption>ר' ברוך עקיבא גרינברג בצעירותו</figcaption></figure>\n<figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92_%D7%91%D7%97%D7%95%D7%A4%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e5/%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92_%D7%91%D7%97%D7%95%D7%A4%D7%94.jpg/250px-%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92_%D7%91%D7%97%D7%95%D7%A4%D7%94.jpg\" decoding=\"async\" width=\"250\" height=\"414\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e5/%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92_%D7%91%D7%97%D7%95%D7%A4%D7%94.jpg/375px-%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92_%D7%91%D7%97%D7%95%D7%A4%D7%94.jpg 1.5x, /images/thumb/e/e5/%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92_%D7%91%D7%97%D7%95%D7%A4%D7%94.jpg/500px-%D7%94%D7%A8%D7%91_%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92_%D7%91%D7%97%D7%95%D7%A4%D7%94.jpg 2x\" /></a><figcaption>ר' ברוך עקיבא גרינברג אומר ברכה בחופה.</figcaption></figure>\n<p>הרב פרופסור <b>ברוך עקיבא גרינברג</b> (<a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%92\" title=\"תרצ&quot;ג\">תרצ\"ג</a> – <a href=\"/index.php/%D7%9B%27_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"כ&#39; אייר\">כ' אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a>) היה חסיד חב\"ד, מרצה ורב ב\"טורו קולג'\"<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, וממייסדי <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%90%D7%A1%D7%A0%D7%98\" title=\"מכון אסנט\">מכון אסנט</a> ל<a href=\"/index.php/%D7%97%D7%96%D7%A8%D7%94_%D7%91%D7%AA%D7%A9%D7%95%D7%91%D7%94\" class=\"mw-redirect\" title=\"חזרה בתשובה\">בעלי תשובה</a> בעיר <a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a> וחבר הצוות החינוכי במקום.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%92\" title=\"תרצ&quot;ג\">תרצ\"ג</a> (1933) למשה גרינברג.\n</p><p>בבחרותו התקרב לחיי שמירת תורה ומצוות ולמד אצל האדמו\"ר מויז'ניץ ה'אמרי חיים', ולאורך כל חייו זכה לאמונם של גדולי ישראל דוגמת האדמו\"ר מסקולען, האדמו\"רים מרימיניץ, בוהוש ורבי יהודל'ה מדז'יקוב.\n</p><p>במשך השנים התקרב לעולמה של חסידות חב\"ד ו<a href=\"/index.php/%D7%94%D7%AA%D7%A7%D7%A9%D7%A8%D7%95%D7%AA\" title=\"התקשרות\">התקשר לרבי</a>, והיה מראשוני הפעילים בשדה הקירוב בארצות הברית, כאשר היה נוסע בכל רחבי ארצות הברית להרצות בפני סטודנטים וזכה לקרב רבים מהם ליהדות ולחסידות עד שזכה שהרבי עצמו יעיד עליו 'כי רבים השיב מעוון'.\n</p><p>בהגיעו לגיל הנישואין, נשא את הדסה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> בת הרב פנחס סגלוב.\n</p><p>ניהל בהצלחה מחנות קיץ שנודעו לשם ולתהילה, וכן שימש כמרצה ורב ב\"טורו קולג'\", ומחנך ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%94%D7%93%D7%A8_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" title=\"ישיבת הדר התורה\">ישיבת 'חנוך לנער' הדר התורה בקראון הייטס</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%98\" title=\"תשכ&quot;ט\">תשכ\"ט</a> התגורר ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>.\n</p><p>בשעת הקמת <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%90%D7%A1%D7%A0%D7%98\" title=\"מכון אסנט\">מכון אסנט</a> בעיר <a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a> נמנה על מייסדי המקום, ואף שימש שם שנים ארוכות בצוות החינוכי.\n</p><p>התגורר בשנותיו האחרונות בסמיכות לבני משפחתו ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>, ובתקופה האחרונה לחייו אושפז עקב מצב בריאותו הרופף, ונפטר בשבת פרשת בהר <a href=\"/index.php/%D7%9B%27_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"כ&#39; אייר\">כ' אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a>, ומסע <a href=\"/index.php/%D7%94%D7%9C%D7%95%D7%95%D7%99%D7%94\" title=\"הלוויה\">הלוויה</a> שהחל ב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ניו יורק\">ניו יורק</a> ועבר מול <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>, המשיך לארץ הקודש שם עבר ביום שני דרך בית המדרש הגדול בקרית ויז'ניץ בבני ברק ונטמן בחלקת ויז'ניץ בבית העלמין בבני ברק.\n</p>\n<h2><span id=\".D7.9E.D7.9E.D7.A7.D7.95.D7.A8.D7.91.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ממקורביו\">ממקורביו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ממקורביו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ממקורביו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%A8%D7%99%D7%93%D7%9C%D7%A0%D7%93\" title=\"אברהם מענדל פרידלנד\">אברהם מענדל פרידלנד</a>.</li>\n<li>הפרופסור ר' <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%A0%D7%99%D7%A1%D7%99%D7%9D_%D7%90%D7%91%D7%95%D7%97%D7%A6%D7%99%D7%A8%D7%90\" title=\"מאיר ניסים אבוחצירא\">מאיר ניסים אבוחצירא</a>.</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בתו שפרה, רעיית הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%9C%D7%93%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"יצחק גולדשטיין\">יצחק גולדשטיין</a> - שלוחי הרבי במדריד, ספרד.</li>\n<li>בתו, חיה יעקובוביץ - צפת.</li>\n<li>בתו מלכה, רעיית הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%AA%D7%92%D7%A8\" title=\"אליהו תגר\">אליהו תגר</a> - ירושלים.</li>\n<li>בתו, טעמא שפירא - ירושלים.</li>\n<li>בנו, הת' ר' <a href=\"/index.php/%D7%A4%D7%99%D7%A0%D7%97%D7%A1_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"פינחס גרינברג\">פינחס גרינברג</a> - קראון הייטס.</li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אברהם אריה לייב גרינברג (הדף אינו קיים)\">אברהם אריה לייב גרינברג</a> - רב קהילת 'צמח צדק' קליבלנד.</li>\n<li>בתו ציפורה, רעיית ר' <a href=\"/index.php?title=%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%90%D7%92%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אהרון יוסף וואגל (הדף אינו קיים)\">אהרון יוסף וואגל</a> - קראון הייטס.</li>\n<li>בנו, ר' <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"ישראל גרינברג\">ישראל גרינברג</a> קראון הייטס.</li>\n<li>בתו, מרים קלמנסון - אובערוויליע, <a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>.</li>\n<li>בנו, ר' מנחם מענדל גרינברג - ניו הייבן.</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">Touro College. אוניברסיטה יהודית פרטית בניו יורק.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">נפטרה ב<a href=\"/index.php/%D7%98%22%D7%95_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"ט&quot;ו אייר\">ט\"ו א