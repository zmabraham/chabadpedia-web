\"כ&quot;ו באייר\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ז באייר\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ח באייר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ט באייר\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ב באייר</b> הוא היום השתיים עשרה ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">חודש אייר</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%97\" title=\"תרס&quot;ח\">תרס\"ח</a> – רבי מסעוד אבוחצירה, אביו של רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%95%D7%97%D7%A6%D7%99%D7%A8%D7%90\" class=\"mw-redirect\" title=\"ישראל אבוחצירא\">ישראל אבוחצירא</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%98\" title=\"תרס&quot;ט\">תרס\"ט</a> – רבי יהודה צבי מדלינא, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%98%22%D7%95\" title=\"תרט&quot;ו\">תרט\"ו</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%91%D7%96%D7%A4%D7%9C%D7%95%D7%91\" title=\"יעקב מרדכי בזפלוב\">יעקב מרדכי בזפלוב</a>, רב העיר <a href=\"/index.php/%D7%A4%D7%95%D7%9C%D7%98%D7%95%D7%91%D7%94\" title=\"פולטובה\">פולטובה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%A2%D7%A7%D7%91_%D7%95%D7%95%D7%99%D7%93%D7%A8%D7%91%D7%99%D7%A5\" title=\"חיים יעקב ווידרביץ\">חיים יעקב ווידרביץ</a> – רבה של <a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>, ולאחר מכן רב חסידי חב\"ד ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A8%D7%A1%D7%A7%D7%99%D7%9F\" title=\"יהודה לייב רסקין\">יהודה לייב רסקין</a>, שליח הרבי ב<a href=\"/index.php/%D7%9E%D7%A8%D7%95%D7%A7%D7%95\" title=\"מרוקו\">מרוקו</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ב באייר - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>כז לעומר'</i>\n<p>אומרים ב<a href=\"/index.php/%D7%AA%D7%A4%D7%9C%D7%94\" class=\"mw-redirect\" title=\"תפלה\">תפלה</a>: \"מנו מאמר\" - <a href=\"/index.php/%D7%9E%22%D7%9D\" class=\"mw-redirect\" title=\"מ&quot;ם\">מ\"ם</a> שלישית <a href=\"/index.php/%D7%A7%D7%9E%D7%A5\" title=\"קמץ\">קמוצה</a>. \"כיום\" כו'.\n</p><p>\"נאמר\" - מ\"ם <a href=\"/index.php/%D7%A4%D7%AA%D7%97\" class=\"mw-redirect\" title=\"פתח\">פתוחה</a>.\n</p><p>\"זכור\" - ב<a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%95%D7%A4%D7%9D\" class=\"mw-redirect\" title=\"מלאופם\">מלאופם</a> - \"כי עפר אנחנו\".\n</p><p>\"ונטלתני\" - <a href=\"/index.php/%D7%98%D7%99%22%D7%AA\" class=\"mw-redirect\" title=\"טי&quot;ת\">טי\"ת</a> פתוחה, <a href=\"/index.php/%D7%9C%D7%9E%22%D7%93\" class=\"mw-redirect\" title=\"למ&quot;ד\">למ\"ד</a> ב<a href=\"/index.php/%D7%A9%D7%91%D7%90\" title=\"שבא\">שבא</a>, <a href=\"/index.php/%D7%AA%D7%99%22%D7%95\" class=\"mw-redirect\" title=\"תי&quot;ו\">תי\"ו</a> דגושה פתוחה.\n</p><p>\"ואהבתך לא תסור\" - ולא ואל תסיר.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413233512\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.021 seconds\nReal time usage: 0.037 seconds\nPreprocessor visited node count: 78/1000000\nPost‐expand include size: 5689/2097152 bytes\nTemplate argument size: 697/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   17.928      1 -total\n 59.22%   10.617      1 תבנית:חודש_אייר\n 40.24%    7.215      1 תבנית:לוח_שנה_חסר\n 40.10%    7.189      1 תבנית:להיום_יום\n 18.95%    3.398      1 תבנית:כתב_קטן\n 18.85%    3.379      1 תבנית:היום_יום/י&quot;ב_אייר\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:22217-0!canonical and timestamp 20260413233512 and revision id 682419. Rendering was triggered because: page-view\n -->\n</div>"
