      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/48/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg/220px-%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg\" decoding=\"async\" width=\"220\" height=\"140\" class=\"mw-file-element\" srcset=\"/images/thumb/4/48/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg/330px-%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg 1.5x, /images/thumb/4/48/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg/440px-%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92.jpg 2x\" /></a><figcaption>הרב גרינברג מתוועד עם הבחורים ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%A7%D7%99%D7%A5_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%91%D7%99%D7%AA_%D7%93%D7%95%D7%93\" title=\"ישיבת קיץ חיילי בית דוד\">ישיבת קיץ חיילי בית דוד</a> שבארגון <a href=\"/index.php/%D7%90%D7%AA%22%D7%94_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" class=\"mw-redirect\" title=\"את&quot;ה העולמי\">את\"ה העולמי</a> (תשע\"ה)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/33/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99.jpeg/220px-%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99.jpeg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/3/33/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99.jpeg/330px-%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99.jpeg 1.5x, /images/thumb/3/33/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99.jpeg/440px-%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99.jpeg 2x\" /></a><figcaption>הרב גרינברג (משמאל) בפאנל לצד הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"מאיר וילשאנסקי\">מאיר וילשאנסקי</a></figcaption></figure>\n<p>הרב <b>ישראל (ישראל'יק) גרינברג</b> (נולד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a>, 1964) הוא חבר קהילת חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> המשמש כ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בקהילה, וכמלמד ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8_%D7%9E%D7%A0%D7%97%D7%9D_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"תלמוד תורה אור מנחם קראון הייטס\">תלמוד תורה אור מנחם</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%98_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"כ&quot;ט אייר\">כ\"ט אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> לרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"ברוך עקיבא גרינברג\">ברוך עקיבא גרינברג</a> ולהדסה.\n</p><p>לאחר חתונתו עם רעייתו מרת מאשא פערל בת ר' <a href=\"/index.php/%D7%94%D7%9C%D7%9C_%D7%9C%D7%95%D7%99%D7%A0%D7%96%D7%95%D7%9F\" title=\"הלל לוינזון\">הלל לוינזון</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ב<a href=\"/index.php/%D7%92%27_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"ג&#39; אדר\">ג' אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a>, התיישב ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.\n</p><p>עם סיום לימודיו ב<a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D_%D7%A9%D7%A2%D7%9C_%D7%99%D7%93_%D7%9E%D7%96%D7%9B%D7%99%D7%A8%D7%95%D7%AA_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"כולל אברכים שעל יד מזכירות הרבי\">כולל אברכים שעל יד מזכירות הרבי</a>, החליט להתפרנס מיגיע כפיו, ונכנס לניהול חנות צעצועים ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91_%D7%A7%D7%99%D7%A0%D7%92%D7%A1%D7%98%D7%95%D7%9F\" class=\"mw-redirect\" title=\"רחוב קינגסטון\">רחוב קינגסטון</a>, שבשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> החנות נסגרה.\n</p><p>במקביל, התוועדויותיו המתאפיינות בחיות ושמחה חסידית, גרמו לכך שהתחבב על נערים צעירים, והוא הוזמן להתוועד עמם רבות, בעיקר עם <a href=\"/index.php/%D7%A0%D7%A1%D7%99%D7%A2%D7%94_%D7%9C%D7%A8%D7%91%D7%99\" title=\"נסיעה לרבי\">האורחים שהגיעו לרבי לחודש תשרי</a>.\n</p><p>בהתוועדויות שלו נוהג להדגיש רבות את חשיבות ה<a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%94\" title=\"שמחה\">שמחה</a> החסידית, האמונה ב<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%9B%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"הרבי כמלך המשיח\">רבי כמלך המשיח</a>, וגאוות היחידה של חסידי ליובאוויטש.\n</p><p>עם הקמתה של המתיבתא שעל יד ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%95%D7%95%D7%99%D7%A0%D7%A1\" title=\"תומכי תמימים קווינס\">תומכי תמימים קווינס</a>, הצטרף לצוות החינוכי של הישיבה. במשך השנים עבר ללמד ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8_%D7%9E%D7%A0%D7%97%D7%9D_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"תלמוד תורה אור מנחם קראון הייטס\">תלמוד תורה אור מנחם</a> שם מלמד את התלמידים שלו בחיות מיוחדת.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, ר' <a href=\"/index.php/%D7%A4%D7%99%D7%A0%D7%97%D7%A1_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"פינחס גרינברג\">פינחס גרינברג</a> ע\"ה.</li>\n<li>בנו, ר' יוסף יצחק גרינברג.</li>\n<li>בנו, ר' יעקב גרינברג.</li>\n<li>בנו, ר' מנחם מענדל גרינברג.</li>\n<li>בנו, ר' הלל גרינברג.</li>\n<li>חתנו, ר' חיים שובוב.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://77012.blogspot.com/2023/09/blog-post_79.html\">מעורר: איך אפשר שלא להרגיש את החוויה שבניגוני חב\"ד? • הרב ישראל גרינברג</a></b>, באתר '<a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\">לחלוחית גאולתית</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/41px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 1.5x, /images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/54px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 2x\" /></a></span> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">בתי אונגרין, ירושלים.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414061939\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.061