%A8\" title=\"כ&quot;ח באדר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ט באדר\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ל&#39; באדר\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<dl><dd><dl><dd><small>הבהרה: ערך זה עוסק גם בי&#34;ח באדר א' וגם בי&#34;ח באדר ב'.</small></dd></dl></dd></dl>\n<p><b>י\"ח באדר</b> הוא היום השמונה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">חודש אדר</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> - פיגוע ירי בגשר ברוקלין לעבר שיירת הרכבים של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> שנסעה מ<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> ל<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%D7%A4%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"בית הרפואה\">בית הרפואה</a> בית ישראל. מהירי נהרג הת' <a href=\"/index.php/%D7%90%D7%A8%D7%99_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%9D\" title=\"ארי הלברשטם\">ארי הלברשטם</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%90\" title=\"תרמ&quot;א\">תרמ\"א</a> - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%91%D7%96%D7%A4%D7%9C%D7%95%D7%91\" title=\"שניאור זלמן בזפלוב\">שניאור זלמן בזפלוב</a>, מתלמידיה הראשונים של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a>, סגנו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a> בניהול הישיבה, ממייסדי <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%97%D7%A8%D7%A1%D7%95%D7%9F\" title=\"תומכי תמימים חרסון\">תומכי תמימים חרסון</a> ובית הכנסת חב\"ד בס. פרנציסקו, <a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%A4%D7%95%D7%A8%D7%A0%D7%99%D7%94\" title=\"קליפורניה\">קליפורניה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%92\" title=\"תרע&quot;ג\">תרע\"ג</a> (אדר שני) - הרב <a href=\"/index.php/%D7%A9%D7%A8%D7%92%D7%90_%D7%9E%D7%9C%D7%9A_%D7%A7%D7%A4%D7%9C%D7%9F\" title=\"שרגא מלך קפלן\">שרגא מלך קפלן</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בקהילת חב\"ד ובישיבת תומכי תמימים ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%91\" title=\"תשי&quot;ב\">תשי\"ב</a> - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%90%D7%99%D7%98%D7%A7%D7%99%D7%9F\" title=\"חיים שניאור זלמן איטקין\">חיים שניאור זלמן איטקין</a>, שליח הרבי בעיר המילטון שבקנדה.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A0\" title=\"תר&quot;נ\">תר\"נ</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%93%D7%95%D7%93_%D7%9C%D7%90%D7%95%D7%95%D7%90%D7%98\" class=\"mw-redirect\" title=\"אברהם דוד לאוואט\">אברהם דוד לאוואט</a>, סב סבו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a> - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%96%D7%95%D7%A1%D7%9E%D7%9F_%D7%93%D7%91%D7%95%D7%A8%D7%A5\" title=\"ישראל זוסמן דבורץ\">ישראל זוסמן דבורץ</a>, מאנשי <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%95%D7%A8%D7%A0%D7%91%D7%9C%D7%99%D7%98\" title=\"אברהם יצחק קורנבליט\">אברהם יצחק קורנבליט</a>, מנהל ישיבת <a href=\"/index.php?title=%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%97%D7%9E%D7%9C%D7%A0%D7%99%D7%A7&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אחי תמימים חמלניק (הדף אינו קיים)\">אחי תמימים חמלניק</a> ולימים מחסידי חב\"ד ב<a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%A7%D7%9C%D7%99%D7%9F\" title=\"ברוקלין\">ברוקלין</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> (אדר א') - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%95%D7%91%D7%A8\" title=\"משה ובר\">משה ובר</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בקהילת חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a> - הרב <a href=\"/index.php/%D7%9E%D7%A1%D7%A2%D7%95%D7%93_%D7%97%D7%99_%D7%97%D7%91%D7%99%D7%91\" title=\"מסעוד חי חביב\">מסעוד חי חביב</a>, מנהל בית הספר 'בית ליובאוויטש סיני' ב<a href=\"/index.php/%D7%A4%D7%A8%D7%99%D7%96\" title=\"פריז\">פריז</a>, ובית ספר 'יבנה' ב<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"מונטריאול\">מונטריאול</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> - הרב <a href=\"/index.php/%D7%96%D7%95%D7%A9%D7%90_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F\" title=\"זושא ריבקין\">זושא ריבקין</a>, ממקימי <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> '<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"בית מנחם (כפר חב&quot;ד)\">בית מנחם</a>' ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, והוגה הרעיון שזכה לאישור הרבי <a href=\"/index.php/%D7%90%D7%A8%D7%9E%D7%95%D7%9F_%D7%9C%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"ארמון למלך המשיח\">ארמון למלך המשיח</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ח באדר א' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>בברכה מעין שלש אם שתה יין ואכל פירות משבעת המינים, חותם: \"ועל פרי הגפן ועל הפירות\", בא\"י [ברוך אתה ה']  \"על פרי הגפן והפירות\" (ולא \"ועל\" הפירות).\n</td></tr></tbody></table>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ח באדר ב' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אבי אדוני זקני מורי ורבי</a> כותב באחד מ<a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמריו</a>: צריכים ללמוד בכל יום <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%A9%D7%91%D7%9B%D7%AA%D7%91\" class=\"mw-redirect\" title=\"תורה שבכתב\">תורה שבכתב</a> עם פירוש <a href=\"/index.php/%D7%A8%D7%A9%22%D7%99\" title=\"רש&quot;י\">רש\"י</a> שזהו תרומות מדרשי רז\"ל . . ולכל הפחות צריך כל אחד ואחד ללמוד מסכת <a href=\"/index.php/%D7%92%D7%9E%D7%A8%D7%90\" class=\"mw-redirect\" title=\"גמרא\">גמרא</a> בשנה.\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413173619\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.030 seconds\nReal time usage: 0.156 seconds\nPreprocessor visited node count: 105/1000000\nPost‐expand include size: 5777/2097152 bytes\nTemplate argument size: 469/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  101.250      1 -total\n 45.09%   45.657      2 תבנית:להיום_יום\n 37.99%   38.466      1 תבנית:חודש_אדר\n 20.55%   20.806      1 תבנית:לוח_שנה\n 16.54%   16.742      1 תבנית:אדרים\n 14.05%   14.230      1 תבנית:היום_יום/י&quot;ח_אדר_ב&#039;\n 13.48%   13.652      1 תבנית:היום_יום/י&quot;ח_אדר_א&#039;\n 10.56%   10.691      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:20830-0!canonical and timestamp 20260413173619 and revision id 821595. Rendering was triggered because: page-view\n -->\n</div>"
