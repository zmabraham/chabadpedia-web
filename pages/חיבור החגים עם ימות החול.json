5px;background:#E5E5FF; color: #000000;\"><span style=\"white-space: nowrap;\">ניגוני החג</span>\n</th>\n<td colspan=\"2\" width=\"100%\" align=\"right\"><a href=\"/index.php/%D7%90%D7%AA%D7%94_%D7%91%D7%97%D7%A8%D7%AA%D7%A0%D7%95_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" class=\"mw-redirect\" title=\"אתה בחרתנו (ניגון)\">אתה בחרתנו</a> • <a href=\"/index.php/%D7%9B%D7%93_%D7%99%D7%AA%D7%91%D7%99%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"כד יתבין ישראל (ניגון)\">כד יתבין ישראל</a>\n</td></tr>\n<tr>\n<th style=\"padding-left:15px;padding-right:15px;background:#E5E5FF; color: #000000;\"><span style=\"white-space: nowrap;\">שונות</span>\n</th>\n<td colspan=\"2\" width=\"100%\" align=\"right\"><a href=\"/index.php/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%AA%D7%95%D7%A8%D7%94_%D7%97%D7%93%D7%A9%D7%94_%D7%9E%D7%90%D7%AA%D7%99_%D7%AA%D7%A6%D7%90\" title=\"קונטרס תורה חדשה מאתי תצא\">קונטרס תורה חדשה מאתי תצא</a> • <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA_%D7%96%D7%9E%D7%9F_%D7%9E%D7%AA%D7%9F_%D7%AA%D7%95%D7%A8%D7%AA%D7%A0%D7%95_(%D7%97%D7%95%D7%91%D7%A8%D7%AA)\" title=\"שבועות זמן מתן תורתנו (חוברת)\">שבועות זמן מתן תורתנו (חוברת)</a>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap mw-references-columns\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%A9%D7%99%D7%97%D7%95%D7%AA\" class=\"mw-redirect mw-disambig\" title=\"ספר השיחות\">ספר השיחות</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%94\" title=\"תש&quot;ה\">תש\"ה</a>, עמ' 10.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%A9%D7%99%D7%97%D7%95%D7%AA\" class=\"mw-redirect mw-disambig\" title=\"ספר השיחות\">ספר השיחות</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a>, עמ' 11.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">ספר המנהגים עמוד 57, ממכתב <a href=\"/index.php/%D7%92%27_%D7%93%D7%A1%D7%9C%D7%99%D7%97%D7%95%D7%AA\" title=\"ג&#39; דסליחות\">ג' דסליחות</a> תשי\"א. אגרות קודש חלק ד' עמוד תצח אגרת א'ריד.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">על פי שיחת יום ב' דר\"ה <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%94\" title=\"תשמ&quot;ה\">תשמ\"ה</a>.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">בירושלמי שאצלנו הגירסא היא 'ללילה'.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">ירושלמי מסכת יומא פרק א' הלכה א', אודות לחם הפנים, שאף שנאמר בו 'לפני תמיד' אין גריעותא במה שנוטלים אותו מהשולחן בשעה שמחליפים אותו, כיון שאם 'מסר יום ללילה', נחשב הדבר כ'תמיד' ודי בכך, וכפי שפירש שם קרבן העדה שאפילו אם יהיה השולחן בלי לחם כ\"ג שעות - נחשב עדיין הדבר 'תמיד'.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">הובא גם בספר המנהגים עמוד 57, ושם מציין הרבי לספר השיחות תש\"ב עמוד 2. ספר השיחות תשי\"א עמוד ד' הערה 4.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">ראה באריכות את ביאור הרבי אודות טעם ההזכרה בפה דווקא: התוועדויות תשמ\"ו חלק א' עמוד 27, <a rel=\"nofollow\" class=\"external text\" href=\"https://hebrewbooks.org/pdfpager.aspx?req=15803&amp;st=&amp;pgnum=303\">שערי המועדים ראש השנה עמוד שכב</a>.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\">התוועדויות תשד\"מ חלק א' עמוד 25, <a rel=\"nofollow\" class=\"external text\" href=\"https://hebrewbooks.org/pdfpager.aspx?req=15803&amp;st=&amp;pgnum=307\">שערי המועדים ראש השנה עמוד שכו</a> (הוזכר גם במאמר של הרבי בהתוועדות זו).</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span class=\"reference-text\">ראו בשיחת יום ב' דראש השנה תשמ\"ה.</span>\n</li>\n<li id=\"cite_note-11\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-11\">^</a></span> <span class=\"reference-text\">לשמע אוזן עמוד 104.</span>\n</li>\n<li id=\"cite_note-12\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-12\">^</a></span> <span class=\"reference-text\">ראש השנה בימים חמישי-שישי (וכן בחו\"ל בשמחת תורה ופסח), ובארץ הקודש אם חל חג השבועות ביום שישי.</span>\n</li>\n<li id=\"cite_note-13\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-13\">^</a></span> <span class=\"reference-text\">ספר המנהגים עמוד 57. ושם, שהוא מפני טרחא דצבורא.</span>\n</li>\n<li id=\"cite_note-14\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-14\">^</a></span> <span class=\"reference-text\">קובץ ליובאוויטש 15 (תשי\"ז) עמוד 3.</span>\n</li>\n<li id=\"cite_note-15\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-15\">^</a></span> <span class=\"reference-text\">שיחת מוצאי ראש השנה תשי\"ג.</span>\n</li>\n<li id=\"cite_note-16\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-16\">^</a></span> <span class=\"reference-text\">כאשר ראש השנה חל בימים חמישי-שישי וההתוועדות נערכת במוצאי <a href=\"/index.php/%D7%A9%D7%91%D7%AA_%D7%A9%D7%95%D7%91%D7%94\" class=\"mw-redirect\" title=\"שבת שובה\">שבת שובה</a>, נוהגים לחזור את המאמר <a rel=\"nofollow\" class=\"external text\" href=\"https://he.chabad.org/library/article_cdo/aid/3140009\">'שיר המעלות ממעמקים' תשמ\"ח</a> (קונטרס ו' תשרי תשמ\"ח).</span>\n</li>\n<li id=\"cite_note-17\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-17\">^</a></span> <span class=\"reference-text\">ראו בהערה בסוף השיחה, וב<a rel=\"nofollow\" class=\"external text\" href=\"https://chabadlibrary.org/books/admur/tm/21/15/140.htm\">מקור הדברים בשיחת שבת פרשת בראשית תשי\"ח</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414102753\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.143 seconds\nReal time usage: 2.718 seconds\nPreprocessor visited node count: 508/1000000\nPost‐expand include size: 6291/2097152 bytes\nTemplate argument size: 120/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 7554/5000000 bytes\nLua time usage: 0.130/7 seconds\nLua virtual size: 5750784/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00% 2316.617      1 -total\n 87.31% 2022.688     17 תבנית:הערה\n  9.07%  210.012      1 תבנית:הערות_שוליים\n  2.16%   50.052      1 תבנית:תקנות_הרבי\n  1.35%   31.291      1 תבנית:שבועות\n  0.64%   14.928      5 תבנית:שורה_אחת\n  0.63%   14.571      1 תבנית:הערות_שוליים/מרחב_שם\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:58960-0!canonical and timestamp 20260414102753 and revision id 764908. Rendering was triggered because: page-view\n -->\n</div>"
