direct\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> השתחרר מ<a href=\"/index.php/%D7%9E%D7%90%D7%A1%D7%A8_%D7%95%D7%92%D7%90%D7%95%D7%9C%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"מאסר וגאולת אדמו&quot;ר הזקן\">מאסרו</a> ב<a href=\"/index.php/%D7%A4%D7%98%D7%A8%D7%91%D7%95%D7%A8%D7%92\" title=\"פטרבורג\">פטרבורג</a>. יום זה נקבע לדורות כחג הגאולה וכ<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94_%D7%9C%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ראש השנה לחסידות\">ראש השנה לחסידות</a></b>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%95\" title=\"תקע&quot;ו\">תקע\"ו</a> - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_(%D7%91%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" class=\"mw-redirect\" title=\"משה (בן אדמו&quot;ר הזקן)\">משה</a>, בנו של אדמו\"ר הזקן, ברח ונמלט מהכמרים שלקחוהו לאחר שניצח אותם בוויכוח שקיים איתם על ענייני הדת.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> - רכבת משא (\"עשאלון\") ועליה קבוצה של מאתיים חמישים חסידים יצאה מ<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> במסגרת הבריחה הגדולה <a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%96\" class=\"mw-redirect\" title=\"יציאת רוסיה תש&quot;ז\">יציאת רוסיה תש\"ז</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a> - החל <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%98_%D7%94%D7%A1%D7%A4%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"משפט הספרים\">משפט הספרים</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%98\" title=\"תקנ&quot;ט\">תקנ\"ט</a> - מרת <a href=\"/index.php/%D7%9E%D7%A0%D7%95%D7%97%D7%94_%D7%A8%D7%97%D7%9C_%D7%A1%D7%9C%D7%95%D7%A0%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מנוחה רחל סלונים\">מנוחה רחל סלונים</a>, בתו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> - הרב אוריאל מרטון, יועץ חינוכי משלוחי הרבי ב<a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8%D7%95%D7%A4%D7%98%D7%A8%D7%95%D7%91%D7%A1%D7%A7\" class=\"mw-redirect\" title=\"דנייפרופטרובסק\">דנייפרופטרובסק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%9C\" title=\"תש&quot;ל\">תש\"ל</a> - הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%90%D7%A9%D7%9B%D7%A0%D7%96%D7%99_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"מאיר אשכנזי (כפר חב&quot;ד)\">מאיר אשכנזי</a>, רבה של <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=5\" titl