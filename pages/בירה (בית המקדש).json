%D7%91%D7%9F_%D7%A4%D7%A1%D7%97\" class=\"mw-redirect\" title=\"קרבן פסח\">קרבן פסח</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A9%D7%AA%D7%99_%D7%9E%D7%AA%D7%A0%D7%95%D7%AA_%D7%A9%D7%94%D7%9F_%D7%90%D7%A8%D7%91%D7%A2\" title=\"שתי מתנות שהן ארבע\">שתי מתנות שהן ארבע</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A7%D7%A8%D7%91%D7%9F_%D7%9E%D7%A0%D7%97%D7%94\" title=\"קרבן מנחה\">קרבן מנחה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A7%D7%A8%D7%91%D7%9F_%D7%94%D7%A2%D7%95%D7%9E%D7%A8\" title=\"קרבן העומר\">קרבן העומר</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\"><a href=\"/index.php/%D7%A2%D7%95%D7%91%D7%93%D7%99_%D7%94%D7%9E%D7%A7%D7%93%D7%A9\" class=\"mw-redirect\" title=\"עובדי המקדש\">עובדי המקדש</a>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%9B%D7%94%D7%9F_%D7%92%D7%93%D7%95%D7%9C\" title=\"כהן גדול\">כהן גדול</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9B%D7%94%D7%A0%D7%99%D7%9D\" title=\"כהנים\">כהנים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A9%D7%91%D7%98_%D7%9C%D7%95%D7%99\" title=\"שבט לוי\">שבט לוי</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A9%D7%9E%D7%99%D7%A8%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9\" title=\"שמירת המקדש\">שמירת המקדש</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%99%D7%A9_%D7%94%D7%A8_%D7%94%D7%91%D7%99%D7%AA\" title=\"איש הר הבית\">איש הר הבית</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap mw-references-columns\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראה טור חו\"מ, מכירה יד: בירה שהוא בית גדול ובתים קטנים פתוחים לתוכו.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">מדרש רבה בראשית לט.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">דברי הימים א כט, א.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">דברי הימים א כט, יט.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">מגדל היה עומד בהר הבית והיה קרוי בירה רבי שמעון בן לקיש אמר כל הר הבית קרוי בירה (ירושלמי פסחים ז לה.). אמר רבה בר בר חנה מקום היה בהר הבית ובירה שמו ור\"ל אמר כל המקדש כולו קרוי בירה (יומא ב.).</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">תמיד א, א. וביארו הפרשנים שם, שהכוונה למחילה ההולכת תחת ההיכל (אך יש המפרשים שאין הכוונה רק להיכל אלא המחילה היתה הולכת תחת המקדש כולו כדלהלן בהערה הבאה.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">כפירוש הרמב\"ם על המשנה בתמיד שבהערה הקודמת, וכן בדברי 'המפרש' למשנה שם, שהמחילה יצאה מבית המוקד והלכה תחת הבירה שבהר הבית, ואילו הפתח שלה נפתח להר הבית. וראו להלן 'על פני הבירה', ש'בירה' ענינה חומת העזרה.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">דעת רבי יוחנן, ירושלמי פסחים ז, ח. ביומא ב, א. ובזבחים קד, ב.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\">דעת ריש לקיש ירושלמי פסחים ז, ח.</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span class=\"reference-text\">פסיקתא רבתי יד: מגדל היה עומד בהר הזיתים והיה שמו 'בירה'.</span>\n</li>\n<li id=\"cite_note-11\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-11\">^</a></span> <span class=\"reference-text\">פסיקתא רבתי יד 'ריש לקיש אמר: כל העיר נקראת בירה'.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413213031\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.161 seconds\nReal time usage: 0.678 seconds\nPreprocessor visited node count: 1559/1000000\nPost‐expand include size: 36926/2097152 bytes\nTemplate argument size: 34258/2097152 bytes\nHighest expansion depth: 13/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 4726/5000000 bytes\nLua time usage: 0.090/7 seconds\nLua virtual size: 6578176/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  631.080      1 -total\n 41.39%  261.221     11 תבנית:הערה\n 28.62%  180.610      2 תבנית:ניווט_קבוצות\n 27.40%  172.908      1 תבנית:פירוש_נוסף\n 26.08%  164.572      1 תבנית:בית_המקדש\n  9.43%   59.522      1 תבנית:תת_קבוצה\n  4.84%   30.572      1 תבנית:הערות_שוליים\n  4.34%   27.416      1 תבנית:פירושון\n  2.08%   13.126      1 תבנית:קישור_אם_קיים\n  1.44%    9.073     55 תבנית:*\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:70970-0!canonical and timestamp 20260413213031 and revision id 727186. Rendering was triggered because: page-view\n -->\n</div>"
