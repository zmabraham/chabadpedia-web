    "pageid": 71797,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%A6%D7%91%D7%AA%D7%95_%D7%A9%D7%9C_%D7%A8%27_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F.png\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/%D7%9E%D7%A6%D7%91%D7%AA%D7%95_%D7%A9%D7%9C_%D7%A8%27_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F.png/220px-%D7%9E%D7%A6%D7%91%D7%AA%D7%95_%D7%A9%D7%9C_%D7%A8%27_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F.png\" decoding=\"async\" width=\"220\" height=\"270\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/%D7%9E%D7%A6%D7%91%D7%AA%D7%95_%D7%A9%D7%9C_%D7%A8%27_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F.png/330px-%D7%9E%D7%A6%D7%91%D7%AA%D7%95_%D7%A9%D7%9C_%D7%A8%27_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F.png 1.5x, /images/1/1e/%D7%9E%D7%A6%D7%91%D7%AA%D7%95_%D7%A9%D7%9C_%D7%A8%27_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F.png 2x\" /></a><figcaption>מצבתו של ר' יהושע זליג ריבקין</figcaption></figure>\n<p>הרב <b>יהושע זעליג</b> הכהן <b>ריבקין</b> (? - <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כ כסלו</a> <a href=\"/index.php/%D7%AA%D7%A8%22%D7%A6\" title=\"תר&quot;צ\">תר\"צ</a>) היה חסיד חב\"ד, מאנשי העיירה <a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%9E%D7%95%D7%91%D7%99%D7%A5%27\" title=\"קלימוביץ&#39;\">קלימוביץ'</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד לרב <a href=\"/index.php?title=%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמעון ריבקין (הדף אינו קיים)\">שמעון ריבקין</a> מתלמידי ר' <a href=\"/index.php/%D7%94%D7%9C%D7%9C_%D7%9E%D7%A4%D7%90%D7%A8%D7%99%D7%98%D7%A9\" title=\"הלל מפאריטש\">הלל מפאריטש</a> ולאמו מרת גענעשא בכפר חוטימסק.\n</p><p>נישא לשיינא באשא בת ר' <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_(%D7%97%D7%99%D7%99%D7%9D)_%D7%A4%D7%91%D7%96%D7%A0%D7%A8\" class=\"mw-redirect\" title=\"מרדכי (חיים) פבזנר\">מרדכי פבזנר</a> מקלימוביץ' המיוחס בן אחר בן לרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A4%D7%95%D7%96%D7%A0%D7%A8\" title=\"מרדכי פוזנר\">מרדכי פוזנר</a> (אח <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a>). \n</p><p>לאחר חתונתו עבר להתגורר בקלימוביץ', לפרנסתו עבד ר' יהושע זעליג אצל הפריץ המקומי בתור יועץ מומחה לחוזק העצים.\n</p><p>נפטר ב<a href=\"/index.php/%D7%9B%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כ&#39; בכסלו\">כ' בכסלו</a> <a href=\"/index.php/%D7%AA%D7%A8%22%D7%A6\" title=\"תר&quot;צ\">תר\"צ</a> ונטמן בקלימוביץ'. רבים מיוצאי חלציו <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד\">חסידי חב\"ד</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ממשפחתו יצאו רבים מחסידי חב\"ד:\n</p>\n<ul><li>בנו ר' <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F\" title=\"שניאור זלמן ריבקין\">שניאור זלמן ריבקין</a> חתן ר' <a href=\"/index.php/%D7%A4%D7%A8%D7%A5_%D7%9C%D7%99%D7%99%D7%9F\" title=\"פרץ ליין\">פרץ ליין</a>.</li>\n<li>בנו ר' <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F\" title=\"מרדכי ריבקין\">מרדכי ריבקין</a> חתן ר' <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%93%D7%99%D7%99%D7%98%D7%A9\" title=\"מנחם מענדל דייטש\">מנחם מענדל דייטש</a>.</li>\n<li>בנו ר' אברהם ריבקין.</li>\n<li>בתו מרת רישא קמינצקי אשת ר' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"משה זלמן קמינצקי\">משה זלמן קמינצקי</a>.</li>\n<li>בתו מרת פרלה אשת ר' <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A4%D7%9C%D7%93%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"שניאור זלמן פלדמן\">שניאור זלמן פלדמן</a>.</li>\n<li>בתו מרת אסתר הדסה אשת ר' דוד אבא לוין<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> בן ר' <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A0%D7%A2%D7%95%D7%95%D7%9C%D7%A2%D7%A8\" class=\"mw-redirect\" title=\"ישראל נעוולער\">ישראל נעוולער</a>.</li>\n<li>בתו הנערה שימעה נפטרה ונטמנה במלחווקע, <a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>, <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a></li></ul>\n<p><b>מנכדיו הבולטים:</b>\n</p>\n<ul><li>משפחת הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F\" title=\"יוסף יצחק ריבקין\">יוסף יצחק ריבקין</a> - כרמיאל.</li>\n<li>משפחת הרב יהושע זעליג ריבקין - שליח ראשי, לואיזיאנה, ארה\"ב.</li>\n<li>משפחת הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%92%D7%95%D7%A4%D7%99%D7%9F\" title=\"ברוך גופין\">ברוך גופין</a>.</li>\n<li>משפחת הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%A2%D7%9E%D7%A2%D7%A1\" class=\"mw-redirect\" title=\"יצחק נעמעס\">יצחק נעמעס</a>.</li>\n<li>משפחת הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9E%D7%90%D7%99%D7%A8_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"שמואל מאיר זילברשטיין\">שמואל מאיר זילברשטיין</a>.</li>\n<li>משפחת הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8\" title=\"מרדכי אליהו שניאור\">מרדכי אליהו שניאור</a>.</li>\n<li>משפחת הרב <a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%96%D7%A7%D7%A1\" title=\"דניאל אליהו זקס\">דניאל אליהו זקס</a>.</li>\n<li>משפחת הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A4%D7%9C%D7%93%D7%9E%D7%9F\" title=\"יהושע זליג פלדמן\">יהושע זליג פלדמן</a>.</li>\n<li>משפחת הרב <a href=\"/index.php/%D7%A8%D7%90%D7%95%D7%91%D7%9F_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"ראובן קמינצקי\">ראובן קמינצקי</a></li></ul>\n<div class=\"stub\" style=\"background-color:#FFFCFC; border-color:#CCCCCC; border-style:double; border-width:3px; clear:both; padding-top:4px; padding-bottom:4px; padding-right:7px; margin:0.5em 0 0.5em 0;vertical-align:middle;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/50px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" decoding=\"async\" width=\"50\" height=\"50\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/75px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 1.5x, /images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/100px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 2x\" /></a></span> &#160; ערך זה הוא <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8\" title=\"חב&quot;דפדיה:קצרמר\">קצרמר</a>&#160;בנושא <a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8_%D7%90%D7%99%D7%A9%D7%99%D7%9D\" title=\"קטגוריה:קצרמר אישים\">אישים</a>. אתם מוזמנים <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%A8%D7%95%D7%9B%D7%99%D7%9D_%D7%94%D7%91%D7%90%D7%99%D7%9D#כתיבה_בחב&quot;דפדיה\" title=\"חב&quot;דפדיה:ברוכים הבאים\">לתרום</a> לחב\"דפדיה ו<b><span class=\"plainlinks\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php?title=%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%9C%D7%99%D7%92_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F&amp;action=edit&amp;editintro=%D7%AA%D7%91%D7%A0%D7%99%D7%AA%3A%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8%2F%D7%94%D7%A8%D7%97%D7%91%D7%94%2F%D7%90%D7%99%D7%A9%D7%99%D7%9D\">להרחיב אותו</a></span></b>.</div>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9