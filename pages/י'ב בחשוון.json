\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בחשוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בחשוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בחשוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בחשוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ל&#39; בחשוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ב בחשוון</b> הוא היום השנים עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חודש חשוון</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%9E%22%D7%97\" title=\"תקמ&quot;ח\">תקמ\"ח</a> (24/10/1787 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A7%D7%99%D7%A6%D7%A1\" title=\"זאב וולף קיצס\">זאב וולף קיצס</a>, תלמיד ה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a>, נפטר ומנוחתו כבוד ב<a href=\"/index.php/%D7%90%D7%95%D7%94%D7%9C_(%D7%A7%D7%91%D7%A8_%D7%94%D7%A6%D7%93%D7%99%D7%A7)\" title=\"אוהל (קבר הצדיק)\">אוהל</a> הבעל שם טוב ב<a href=\"/index.php/%D7%9E%D7%96%27%D7%99%D7%91%D7%95%D7%96%27\" title=\"מז&#39;יבוז&#39;\">מז'יבוז'</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%90\" title=\"תרצ&quot;א\">תרצ\"א</a> (/3/11/1930 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%9B%D7%94%D7%9F\" title=\"שלום כהן\">שלום כהן</a> מנהיגה הרוחני של הציבור הספרדי ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a> לאחר פטירת הרב <a href=\"/index.php/%D7%A2%D7%95%D7%91%D7%93%D7%99%D7%94_%D7%99%D7%95%D7%A1%D7%A3\" title=\"עובדיה יוסף\">עובדיה יוסף</a>, ונשיא מועצת \"חכמי התורה\" של מפלגת ש\"ס, נולד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> (20/10/1991 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A6%D7%93%D7%A7%D7%94\" class=\"mw-redirect\" title=\"יהודה צדקה\">יהודה צדקה</a>, ראש ישיבת פורת יוסף בירושלים, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%92\" title=\"תרפ&quot;ג\">תרפ\"ג</a> (3/11/1922 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F\" title=\"אברהם ליסון\">אברהם ליסון</a>, היה זקן תושבי כפר חב\"ד, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> 'נחום יצחק' ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>. בעבר כיהן בתפקידים חינוכיים שונים בהנהלת בית הספר של <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">רשת אהלי יוסף יצחק</a> בזרנוגה, ומוקדם יותר - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%90%D7%A7%D7%99%D7%A0%D7%92\" class=\"mw-redirect\" title=\"תומכי תמימים פאקינג\">תומכי תמימים פאקינג</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%97\" title=\"תשכ&quot;ח\">תשכ\"ח</a>- ר' <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%95%D7%95%D7%9C%D7%A3\" title=\"זלמן וולף\">זלמן וולף</a>- עסקן חב\"די שעוזר לשלוחי הרבי ברחבי העולם ואחד מעסקני חב\"ד בכנסת</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%94\" title=\"תרכ&quot;ה\">תרכ\"ה</a> (11/11/1864 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%99%D7%95%D7%A1%D7%A3_%D7%A8%D7%99%D7%91%D7%9C%D7%99%D7%9F\" title=\"אליהו יוסף ריבלין\">אליהו יוסף ריבלין</a> עלה ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a> בשנת <a href=\"/index.php/%D7%AA%D7%A8%22%D7%96\" title=\"תר&quot;ז\">תר\"ז</a> (1846 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>). מיסד <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" title=\"בית הכנסת צמח צדק (ירושלים)\">בית הכנסת צמח צדק</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> וראש הכולל שם.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a> (5/11/1995 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%A0%D7%90%D7%94\" title=\"ברוך נאה\">ברוך נאה</a>, בן הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%99%D7%99%D7%9D_%D7%A0%D7%90%D7%94\" title=\"אברהם חיים נאה\">אברהם חיים נאה</a>, ועורך <a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%9B%D7%95%D7%9C%D7%9C_%D7%97%D7%91%22%D7%93\" title=\"לוח כולל חב&quot;ד\">לוח כולל חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a> (27/10/2004 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב אברהם יצחק לסקר, <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> (5/11/2014 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_(%D7%9E%D7%95%D7%9C%D7%A2)_%D7%90%D7%96%D7%99%D7%9E%D7%95%D7%91\" class=\"mw-redirect\" title=\"שמואל (מולע) אזימוב\">שמואל (מולע) אזימוב</a>, משלוחי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ל<a href=\"/index.php/%D7%A4%D7%A8%D7%99%D7%96\" title=\"פריז\">פריז</a> ומגדולי מחזירי התשובה ב<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> - חכם <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%99%D7%9B%D7%90%D7%9C%D7%A9%D7%95%D7%99%D7%9C%D7%99\" title=\"יעקב מיכאלשוילי\">יעקב מיכאלשוילי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a> - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%95%D7%A2%D7%94_%D7%97%D7%93%D7%90%D7%93\" title=\"ישועה חדאד\">ישועה חדאד</a>, שליח הרבי ורב הקהילה הספרדית ב<a href=\"/index.php/%D7%9E%D7%99%D7%9C%D7%90%D7%A0%D7%95\" title=\"מילאנו\">מילאנו</a>, <a href=\"/index.php/%D7%90%D7%99%D7%98%D7%9C%D7%99%D7%94\" title=\"איטליה\">איטליה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%98%D7%99%D7%99%D7%98%D7%9C%D7%91%D7%95%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ישראל טייטלבוים\">ישראל טייטלבוים</a> - משלוחי הרבי וממייסדי קהילת חב\"ד במוריסטון.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ב בחשוון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>אחת מתורות הראשונות של <a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a> - ונקראו אז בשם \"ווערטער\": שמע ישראל - א <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%99\" class=\"mw-redirect\" title=\"יהודי\">איד</a> דערהערט - <a href=\"/index.php/%D7%94%D7%95%D7%99%27_(%D7%A9%D7%9D)\" class=\"mw-redirect\" title=\"הוי&#39; (שם)\">הוי\"ה</a> <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%9D\" class=\"mw-redirect\" title=\"אלוקים\">אלקינו</a> - אז כוחנו וחיותינו איז דאס למעלה מן ה<a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"טבע\">טבע</a>, און - הוי' <a href=\"/index.php/%D7%90%D7%97%D7%93%D7%95%D7%AA_%D7%94%27\" title=\"אחדות ה&#39;\">אחד</a>.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: אחת מתורות הראשונות של <a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a> - ונקראו אז בשם \"מילים\": <a href=\"/index.php/%D7%A9%D7%9E%D7%A2_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"שמע ישראל\">שמע ישראל</a> - <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%99\" class=\"mw-redirect\" title=\"יהודי\">יהודי</a> קולט - <a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94_(%D7%A9%D7%9D)\" title=\"הוי&quot;ה (שם)\">הוי'</a> <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%9D\" class=\"mw-redirect\" title=\"אלוקים\">אלוקינו</a> - שכוחנו וחיותינו זהו למעלה מן ה<a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"טבע\">טבע</a>, ו - הוי' אחד.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413180438\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.030 seconds\nReal time usage: 0.045 seconds\nPreprocessor visited node count: 98/1000000\nPost‐expand include size: 5851/2097152 bytes\nTemplate argument size: 565/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   19.257      1 -total\n 74.30%   14.308      1 תבנית:חודש_חשוון\n 51.49%    9.916      1 תבנית:לוח_שנה\n 24.66%    4.749      1 תבנית:להיום_יום\n 12.61%    2.428      1 תבנית:כתב_קטן\n 11.76%    2.264      1 תבנית:היום_יום/י&quot;ב_חשוון\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19536-0!canonical and timestamp 20260413180438 and revision id 727499. Rendering was triggered because: diff-page\n -->\n</div>"
