e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/moshiach/960609/\">הסרט החדש לג' תמוז</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">מתוך פרק קי\"ט בתהלים, <a href=\"/index.php/%D7%94%D7%A4%D7%A8%D7%A7_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הפרק של הרבי\">הפרק של הרבי</a> שנאמר בימי הקמת התכנית.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">לדוגמה בהתוועדות ה' טבת תשפ\"ב המרכזית באה\"ק שנערכה על ידי <a href=\"/index.php/%D7%94%D7%AA%D7%90%D7%97%D7%93%D7%95%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"התאחדות החסידים\">התאחדות החסידים</a>, בכינוס גאולה ומשיח שנערך ע\"י האגודה למען הגאולה האמיתית והשלימה בי' שבט תשפ\"ג, ועוד</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external free\" href=\"https://chabad.info/news/803875/\">https://chabad.info/news/803875/</a> הערב: מצטרפים לחסידים בג' תמוז תשנ\"ד</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">הוידאו מההודעה ההיסטורית בתוך <a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/drive/folders/1Ftow732FNJZ6ftSSJZS53YUdWPtx7T9X\">התכנית לחודש אדר תשפ\"ב</a>. <a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/seven-seventy/767062/\">דיווח על פרסום התיעוד ההיסטורי</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">בתוך <a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/drive/folders/1Ftow732FNJZ6ftSSJZS53YUdWPtx7T9X\">התכנית לחודש כסלו תשפ\"ב</a></span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">'מתחברים לסאטלייט' - <a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/12UqSl_nsOR1WUjcytEoUmTiz6p33uhn-/view?usp=sharing\">התכנית לחודש שבט תשפ\"א</a>, ו'מאחורי הסאטלייו' - התכנית לחודש שבט תשפ\"ג.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1369Nvgfq29rgb7LZII5pOHZ_bsPbIfaN/view?usp=sharing\">התכנית לחודש תמוז תשפ\"ב</a></span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/blogs/790252/\">הרהורי תמים בעקבות פרסום התיעוד</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/video/rebbe/moshiach-rebbe/664285\">מזכירו של הרבי: להמשיך בכל התוקף בפרסום זהות משיח</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414040900\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.136 seconds\nReal time usage: 0.929 seconds\nPreprocessor visited node count: 438/1000000\nPost‐expand include size: 2158/20971