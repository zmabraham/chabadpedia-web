D7%9E%D7%A8%D7%90_%D7%93%D7%90%D7%AA%D7%A8%D7%90\" class=\"mw-redirect\" title=\"מרא דאתרא\">רב העיר</a> <a href=\"/index.php?title=%D7%97%D7%95%D7%A8%D7%95%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חורול (הדף אינו קיים)\">חורול</a>, מנהל <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%97%D7%90%D7%A8%D7%90%D7%9C\" title=\"תומכי תמימים חאראל\">סניף ישיבת תומכי תמימים המקומית</a> ומראשי העסקנים שפעלו תחת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> לחיזוק וביצור חומות היהדות ברחבי רוסיה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%92\" title=\"תרע&quot;ג\">תרע\"ג</a> (30/10/1912 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%9E%D7%A2%D7%A0%D7%98%D7%9C%D7%99%D7%A7\" class=\"mw-redirect\" title=\"מרדכי מענטליק\">מרדכי מענטליק</a>, ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים ליובאוויטש המרכזית\">תומכי תמימים ליובאוויטש המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"תשכ&quot;ג\">תשכ\"ג</a> (16/11/1962 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php?title=%D7%92%D7%99%D7%9C_%D7%91%D7%9C%D7%99%D7%96%D7%95%D7%91%D7%A1%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"גיל בליזובסקי (הדף אינו קיים)\">גיל בליזובסקי</a>, שליח הרבי ורב אוניברסיטת בן-גוריון בבאר שבע.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> (02/11/1966 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A8%D7%9D_%D7%9E%D7%A2%D7%95%D7%93%D7%94\" title=\"יורם מעודה\">יורם מעודה</a>, מנהל כולל חב\"ד ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%98\" title=\"תרס&quot;ט\">תרס\"ט</a> (13/11/1908 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%90%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"ישעיה אורנשטיין\">ישעיה אורנשטיין</a>, ראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"כולל חב&quot;ד בארץ הקודש\">כולל חב\"ד בארץ הקודש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%96\" title=\"תרצ&quot;ז\">תרצ\"ז</a> (4/11/1936 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%A9%D7%95%D7%A8\" class=\"mw-redirect\" title=\"אהרן שור\">אהרן שור</a>, ממקימי בית כנסת חב\"ד ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%94\" title=\"תשמ&quot;ה\">תשמ\"ה</a> (14/11/1984 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%A4%D7%A2%D7%A8%D7%9C%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חיים ישראל שפערלין (הדף אינו קיים)\">חיים ישראל שפערלין</a>, גביר חסידי תושב <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a> (12/11/1995 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php?title=%D7%99%D7%95%D7%A0%D7%94_%D7%92%D7%A8%D7%99%D7%A0%D7%95%D7%95%D7%9C%D7%93&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יונה גרינוולד (הדף אינו קיים)\">יונה גרינוולד</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> שזכה להביא לרבי מספר <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%A0%D7%99%D7%9D_%D7%A9%D7%A0%D7%95%D7%92%D7%A0%D7%95_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"ניגונים שנוגנו לפני הרבי\">ניגונים מ'זמרת הארץ'</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a> - הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%9E%D7%9C%D7%9A_%D7%A6%D7%95%D7%95%D7%99%D7%91%D7%9C\" title=\"אלימלך צוויבל\">אלימלך צוויבל</a>, מנהל רוחני של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A8%D7%99%D7%A1%D7%98%D7%95%D7%9F\" title=\"תומכי תמימים מוריסטון\">תומכי תמימים מוריסטון</a>, חבר מערכת 'חסידות מבוארת', חבר מערכת 'וועד להפצת שיחות' וחבר וועד הפועל של <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%A8%D7%91%D7%A0%D7%99_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ועד רבני ליובאוויטש\">ועד רבני ליובאוויטש</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ט בחשוון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>מענה <a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a> ל<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a>: <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> איז (=היא) <a href=\"/index.php/%D7%A9%D7%9E%D7%A2_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"שמע ישראל\">שמע ישראל</a>, שמע איז (=הוא) ראשי תיבות <b>ש</b>או <b>מ</b>רום <a href=\"/index.php/%D7%A2%D7%99%D7%A0%D7%99%D7%99%D7%9D\" class=\"mw-redirect\" title=\"עיניים\"><b>ע</b>יניכם</a>, ואומר מרום ולא <a href=\"/index.php/%D7%A9%D7%9E%D7%99%D7%9D\" title=\"שמים\">שמים</a>, מרום איז העכער און העכער (= למעלה יותר ולמעלה יותר), להגיע למעלה מן ה<a href=\"/index.php/%D7%A9%D7%9B%D7%9C\" class=\"mw-redirect\" title=\"שכל\">שכל</a>. וזה גופא להבינו ב<a href=\"/index.php/%D7%A9%D7%9B%D7%9C\" class=\"mw-redirect\" title=\"שכל\">שכל</a>, וכמו שאומר וראו מי ברא אלה.\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414010243\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.023 seconds\nReal time usage: 0.054 seconds\nPreprocessor visited node count: 89/1000000\nPost‐expand include size: 5415/2097152 bytes\nTemplate argument size: 565/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   26.569      1 -total\n 63.23%   16.799      1 תבנית:חודש_חשוון\n 41.27%   10.964      1 תבנית:לוח_שנה\n 36.20%    9.617      1 תבנית:להיום_יום\n 18.08%    4.804      1 תבנית:היום_יום/י&quot;ט_חשוון\n 16.92%    4.494      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19545-0!canonical and timestamp 20260414010243 and revision id 703263. Rendering was triggered because: diff-page\n -->\n</div>"
