<a href=\"/index.php/%D7%98%D7%91%D7%A8%D7%99%D7%94\" title=\"טבריה\">טבריה</a> •  <a href=\"/index.php/%D7%99%D7%A7%D7%A0%D7%A2%D7%9D_%D7%A2%D7%99%D7%9C%D7%99%D7%AA\" title=\"יקנעם עילית\">יקנעם עילית</a> • <a href=\"/index.php/%D7%9B%D7%A8%D7%9E%D7%99%D7%90%D7%9C\" title=\"כרמיאל\">כרמיאל</a> • <a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a> • <a href=\"/index.php/%D7%A0%D7%94%D7%A8%D7%99%D7%94\" title=\"נהריה\">נהריה</a> • <a href=\"/index.php/%D7%A0%D7%95%D7%A3_%D7%94%D7%92%D7%9C%D7%99%D7%9C\" title=\"נוף הגליל\">נוף הגליל</a> • <a href=\"/index.php/%D7%A2%D7%A4%D7%95%D7%9C%D7%94\" title=\"עפולה\">עפולה</a> • <a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a> • <a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%A9%D7%9E%D7%95%D7%A0%D7%94\" title=\"קריית שמונה\">קריית שמונה</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\"><a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%9E%D7%A7%D7%95%D7%9E%D7%99%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה מקומית (הדף אינו קיים)\">מועצות מקומיות</a>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php?title=%D7%97%D7%A6%D7%95%D7%A8_%D7%94%D7%92%D7%9C%D7%99%D7%9C%D7%99%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חצור הגלילית (הדף אינו קיים)\">חצור הגלילית</a> • <a class=\"mw-selflink selflink\">יבנאל</a> • <a href=\"/index.php?title=%D7%99%D7%A1%D7%95%D7%93_%D7%94%D7%9E%D7%A2%D7%9C%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יסוד המעלה (הדף אינו קיים)\">יסוד המעלה</a> • <a href=\"/index.php?title=%D7%9B%D7%A4%D7%A8_%D7%95%D7%A8%D7%93%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כפר ורדים (הדף אינו קיים)\">כפר ורדים</a> • <a href=\"/index.php?title=%D7%9E%D7%92%D7%93%D7%9C_(%D7%99%D7%99%D7%A9%D7%95%D7%91)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מגדל (יישו