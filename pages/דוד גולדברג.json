    "pageid": 37576,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/81/%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg/250px-%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg\" decoding=\"async\" width=\"250\" height=\"249\" class=\"mw-file-element\" srcset=\"/images/thumb/8/81/%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg/375px-%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg 1.5x, /images/thumb/8/81/%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg/500px-%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92.jpg 2x\" /></a><figcaption>הרב גולדברג</figcaption></figure>\n<p>הרב <b>דוד גולדברג</b> (<a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> - <a href=\"/index.php/%D7%9B%22%D7%97_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"כ&quot;ח אדר\">כ\"ח אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%92\" title=\"תשל&quot;ג\">תשל\"ג</a>) היה ממשפיעי קהילת חב\"ד בירושלים, ממתפללי ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%90%D7%94%D7%9C_%D7%99%D7%A6%D7%97%D7%A7_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" title=\"בית הכנסת אהל יצחק (ירושלים)\">בית הכנסת אהל יצחק</a> בשכונת <a href=\"/index.php?title=%D7%9E%D7%90%D7%94_%D7%A9%D7%A2%D7%A8%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאה שערים (הדף אינו קיים)\">מאה שערים</a> בעיר, ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a> בהמלצת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> לאביו הרב <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%90%D7%99%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" title=\"יחיאל מאיר יהודה גולדברג (ירושלים)\">מאיר יחיאל יהודה גולדברג</a> ולאמו מרת צייטיל.\n</p><p>בין השנים <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%96\" title=\"תרפ&quot;ז\">תרפ\"ז</a> - <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%91\" title=\"תרצ&quot;ב\">תרצ\"ב</a> למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a> בשכונת גבעת שאול ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, אצל הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%96%D7%9C%D7%9E%D7%9F_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"שלמה זלמן הבלין\">שלמה זלמן הבלין</a> וה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> הרב <a href=\"/index.php/%D7%90%D7%9C%D7%AA%D7%A8_%D7%A9%D7%99%D7%9E%D7%97%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"אלתר שימחוביץ\">אלתר שימחוביץ</a>. ר' דוד נחשב כבחיר תלמידי ר' אלתר, ודאג לו עד לפטירתו, בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%98\" title=\"תרצ&quot;ט\">תרצ\"ט</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%98\" title=\"תרפ&quot;ט\">תרפ\"ט</a> בביקורו ההיסטורי של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> בארץ ישראל זכה ר' דוד עם עוד מעטים ללוותו.\n</p><p>לאחר חתונתו מונה בהמלצת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> כ<a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת תורת אמת. הנהלת ישיבת תורת אמת כתבה לאדמו\"ר הריי\"צ לקבל הסכמתו למינוי ר' דוד כמשגיח בישיבה, ואדמו\"ר הריי\"צ במענהו הוסיף גם את התואר \"משפיע\".\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> ייסד יחד עם הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A6%D7%91%D7%99_%D7%A1%D7%92%D7%9C\" title=\"משה צבי סגל\">משה צבי סגל</a> והרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"אהרן מרדכי זילברשטרום\">אהרן מרדכי זילברשטרום</a> את ארגון 'בני חב\"ד' להפצת מעיינות החסידות, וזכו למכתב עידוד מאדמו\"ר הריי\"צ.\n</p><p>נמנה על משפיעי קהילת חב\"ד בעיר, והתפלל בקביעות ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%90%D7%94%D7%9C_%D7%99%D7%A6%D7%97%D7%A7_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" title=\"בית הכנסת אהל יצחק (ירושלים)\">בית הכנסת אהל יצחק</a> בשכונת מאה שערים בירושלים. בכינוס שנערך בחודש אב תש\"י, היה מראשי קהילת חב\"ד בעיר שדחפו לכתיבת <a href=\"/index.php/%D7%9B%D7%AA%D7%91_%D7%94%D7%AA%D7%A7%D7%A9%D7%A8%D7%95%D7%AA\" title=\"כתב התקשרות\">כתב התקשרות</a> לרבי בבקשה שיקבל על עצמו את הנשיאות.\n</p><p>היה זורק ב<a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%AA_%D7%AA%D7%95%D7%A8%D7%94\" title=\"שמחת תורה\">שמחת תורה</a> שוקולדים לילדים על חשבונו וכששמע זאת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> מימן לו את סכום הדולרים לקנית השוקולדים.\n</p><p>נפטר בגיל 62 ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"כ&quot;ח אדר\">כ\"ח אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%92\" title=\"תשל&quot;ג\">תשל\"ג</a>, שבועיים לאחר חתונתו של <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%90%D7%99%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יחיאל מאיר יהודה גולדברג\">בנו הצעיר</a>, ונטמן ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A2%D7%9C%D7%9E%D7%99%D7%9F_%D7%94%D7%A8_%D7%94%D7%96%D7%99%D7%AA%D7%99%D7%9D\" class=\"mw-redirect\" title=\"בית העלמין הר הזיתים\">בית העלמין הר הזיתים</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> על פטירתו מסופר שנכנס פעם לרבי ליחדות וביקש ברכה להשתתף בכל חתונות ילדיו וכשיצא בכה שלא ביקש להיות אף בחתונות נכדיו.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>רעייתו צירל גולדברג - נפטרה ב' טבת תשס\"ג.\n</p>\n<ul><li>בנו, הרב <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%90%D7%99%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יחיאל מאיר יהודה גולדברג\">יחיאל מאיר יהודה גולדברג</a> - מחנך בתלמוד תורה חב\"ד בלוד שנהרג ב<a href=\"/index.php/%D7%97%27_%D7%A1%D7%99%D7%95%D7%95%D7%9F_%D7%AA%D7%A9%D7%9C%22%D7%93_(%D7%AA%D7%90%D7%95%D7%A0%D7%94)\" title=\"ח&#39; סיוון תשל&quot;ד (תאונה)\">תאונת דרכים מחרידה</a> שזיעזעה את כל חב\"ד ב<a href=\"/index.php/%D7%97%27_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ח&#39; סיוון\">ח' סיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a> יחד עם עוד שלושה <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"חסידים\">חסידים</a> (הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%A8%D7%9C%D7%99%D7%A7\" title=\"שניאור זלמן גרליק\">שניאור זלמן גרליק</a> - רבו של <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%95%D7%99%D7%99%D7%A1\" title=\"ישעיה וייס\">ישעיה וייס</a> מ<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a> וגיסתו גב' נחמה רוזנברג). - אחר פטירתו ילדה אשתו בן שנקרא על שמו, ר' יחיאל הוא ממנהלי חנות קה\"ת בקראון הייטס.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"מרדכי גולדברג\">מרדכי גולדברג</a> - בני ברק</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A9%D7%9C%D7%9E%D7%94_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יעקב שלמה גולדברג\">יעקב שלמה גולדברג</a> - קראון הייטס</li>\n<li>בתו מרת מלכה- נפטרה י\"ח אדר א' תשע\"ו, רעיית הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%A7%D7%A4%D7%9C%D7%9F\" title=\"נחום קפלן\">נחום קפלן</a> - לוד</li>\n<li>חתנו, הרב אלימלך בורנשטיין - בני ברק.</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>מנחם כהנא,&#160;‏<b>יומן שכתב בביקורו הראשון אצל הרבי</b>, שבועון בית משיח, גיליון 1361 עמוד 34-37 (תשפ\"ג) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://www.teshura.com/teshurapdf/Goldberg-Salavatizky%20-%2027%20Menachem%20Av%205776.pdf\">לדמותו של חסיד אמת</a></b> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <b><a rel=\"nofollow\" class=\"external text\" href=\"http://www.teshura.com/teshurapdf/Goldberg-Avtzon%20%232%20-%20Teves%2022%2C%205778.pdf\">מהדורה ב'</a></b>, תשורה מנישואי צאצאיו</li></ul>\n<!-- \nNewPP limit report\nCached time: 20260413142935\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.027 seconds\nReal time usage: 0.298 seconds\nPreprocessor visited node count: 90/1000000\nPost‐expand include size: 516/2097152 bytes\nTemplate argument size: 127/2097152 bytes\nHighest expansion depth: 4/100\nExpensive parser function count: 0/100\nUnstrip recursio