      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.webp\" class=\"mw-file-description\"><img alt=\"הרב יעקב מאזוז בהתוועדות חסידית בישיבת תות&quot;ל נתניה, מוצאי ש&quot;ק פ&#39; וישב.\" src=\"/images/thumb/a/a7/%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.webp/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.webp.png\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/a/a7/%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.webp/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.webp.png 1.5x, /images/thumb/a/a7/%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.webp/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.webp.png 2x\" /></a><figcaption>הרב יעקב מאזוז שי' ב<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA\" title=\"התוועדות חסידית\">התוועדות חסידית</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים נתניה (קטנה)\">ישיבת תות\"ל נתניה</a>, מוצאי ש\"ק פ' וישב תשפ\"ו.</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%95%D7%96_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/93/%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%95%D7%96_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F.jpeg/250px-%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%95%D7%96_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F.jpeg\" decoding=\"async\" width=\"250\" height=\"140\" class=\"mw-file-element\" srcset=\"/images/thumb/9/93/%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%95%D7%96_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F.jpeg/375px-%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%95%D7%96_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F.jpeg 1.5x, /images/thumb/9/93/%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%95%D7%96_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F.jpeg/500px-%D7%94%D7%A8%D7%91_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%95%D7%96_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%91%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F.jpeg 2x\" /></a><figcaption>הרב יעקב מזוז ב<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA\" title=\"התוועדות חסידית\">התוועדות חסידית</a> בישיבת תומכי תמימים הוד השרון, ה' טבת תשפ\"ה</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e9/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.jpeg/250px-%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.jpeg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e9/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.jpeg/375px-%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.jpeg 1.5x, /images/thumb/e/e9/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.jpeg/500px-%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96.jpeg 2x\" /></a><figcaption>הרב יעקב מאזוז</figcaption></figure>\n<p>הרב <b>יעקב מאזוז</b> הוא <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ורב קהילת <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> \"אור מנחם\" לדוברי צרפתית ב<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד לר' משה בן חי מאזוז ממשפחת רבנים נודעת בטוניס. משפחתו היגרה ל<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>, ובמשך השנים התקרב לחסידות על ידי השליח הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%90%D7%96%D7%99%D7%9E%D7%95%D7%91\" title=\"שמואל אזימוב\">שמואל אזימוב</a>.\n</p><p>את פעילותו עם הצעירים בצרפת החל בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a>. הוא החל לפעול בתוך בית הכנסת \"קוריאל\" ב<a href=\"/index.php/%D7%A4%D7%A8%D7%99%D7%96\" title=\"פריז\">פריז</a>, שם קיבל חדר קטן ושם החל לעבוד עם צעירים יהודים. הרב מאזוז זכה לנשיאת חן ורבים הגיעו לפעילויות שלו שהלכו וגדלו משנה לשנה.\n</p><p>החל משנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>, הביא הרב מאזוז בכל שנה קבוצות של צעירים לרבי בימי חג ה<a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"חנוכה\">חנוכה</a>. קבוצות אלו זכו לעידודים מיוחדים מהרבי וליחס לא רגיל. פעם אחת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> אף ערך חלוקת דולרים מיוחדת לכבודם. ר' <a href=\"/index.php/%D7%9E%D7%99%D7%9B%D7%90%D7%9C_%D7%98%D7%99%D7%99%D7%91\" title=\"מיכאל טייב\">מיכאל טייב</a>, מהמשפיעים הידועים היום ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, התחיל את צעדיו הראשונים בבית חב\"ד של הרב מאזוז בצרפת.\n</p><p>בסוף שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a> עלתה משפחת מאזוז ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a> ומיד עברה להתגורר ב<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a>. העיר נתניה מושכת אליה אלפי צרפתים ועולים מצרפת שהגיעו לארץ הקודש.\n</p>\n<h2><span id=\".D7.A4.D7.A2.D7.99.D7.9C.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"פעילות\">פעילות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;פעילות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: פעילות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>עם בואו לעיר פתח בפעילות עם הצעירים בכיכר העצמאות שבמרכז נתניה. הכיכר המרכזי בעיר שואב אליו מאות אלפי תיירים בשנה. הצרפתים מצאו בכיכר זו מקום מפגש מובהק. הוא פתח דוכן קטן להנחת תפילין, וקרא לעוברים ושבים, בעיקר לדוברי צרפתית שבהם, להניח תפילין. מנקודה זו הפעילות הלכה והתרחבה. בהמשך שכר חדר בקומה ראשונה של אחד הבניינים הנושקים לכיכר, וכיום הפעילות מתפרשת על פני קומה שלמה במלון \"טיילת\" הנמצא מול הים, שם פועל המרכז לדוברי צרפתית בנתניה.\n</p><p>הבית חב\"ד כולל <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA\" title=\"בית כנסת\">בית כנסת</a> מפואר, <a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94_%D7%98%D7%94%D7%A8%D7%94\" class=\"mw-redirect\" title=\"מקווה טהרה\">מקווה טהרה</a>, כולל שיעורי תורה (במקום סניף של כולל <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%A9%D7%9C%D7%9E%D7%94\" class=\"mw-redirect mw-disambig\" title=\"תורה שלמה\">תורה שלמה</a>), ומשרדים לניהול הפעילות.\n</p><p>המקום שוקק פעילות. בכל יום מתקיימים בו שיעורי תורה בחסידות, בגמרא ובהלכה. הלימודים במקום מתחילים ב'סדר חסידות' בשבע וחצי בבוקר ולאחר מכן תפילת שחרית. לאחר התפילה לומדים האברכים כשעה עם חברי הקהילה ורק לאחר מכן מתחילים ללמוד את הלימודים הרגילים, שנלמדים ברמה גבוהה.\n</p><p>הלימודים מסתיימים בארבע אחר הצהריים, וכבר אז מתחילות תפילות מנחה וסדרה של שיעורים עם שאר בני הקהילה עד שעות הלילה המאוחרות.\n</p><p>במשך השנים מסר הרב מאזוז את מגוון השיעורים, בגמרא, בהלכה ובחסידות ובהמשך הכניס את הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_%D7%90%D7%98%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלום אטל (הדף אינו קיים)\">שלום אטל</a> ואת בנו הרב משה מאזוז, שנרתמו אף הם למסירת שיעורים רצופים.\n</p><p>במסגרת פעילות הבית חב\"ד יוצא לאור קובץ שבועי '<a href=\"/index.php?title=%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%91%D7%A6%D7%A8%D7%A4%D7%AA%D7%99%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"דבר מלכות בצרפתית (הדף אינו קיים)\">דבר מלכות בצרפתית</a>', אותו מנהל הרב <a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%91%D7%95%D7%A7%D7%95%D7%91%D7%96%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמואל בוקובזה (הדף אינו קיים)\">שמואל בוקובזה</a>.\n</p><p>הבית חב\"ד פתוח ושוקק חיים גם בשבתות. בשבתות החורף מתפללים במקום כמאה ועשרים מתפללים, ובשבתות הקיץ מתקיימים שני מניינים עמוסים ביותר, והמקום מלא מקצה לקצה. במקום מתקיימת התוועדות חסידית פעילה בכל שבת מאחר תפילת מוסף ועד מנחה.\n</p><p>הפעילות עצמה מקבלת תנופה בזמני חגים. קריאת המגילה ברצף לאורך כל הפורים, ליל סדר ציבורי וחלוקת מאות ק\"ג מצות שמורה, בל\"ג בעומר בית חב\"ד הצרפתי הוא שותף פעיל בהצלחת התהלוכה המרכזית שמתקיימת בהשתתפות של כעשרים אלף מילדי נתניה. כך גם לקראת חנוכה, מתקיימות פעילויות מיוחדות בכיכר ושיירת האור של בית חב\"ד. פעילות הבית חב\"ד נושאת בגאון את המסר של משיח וכל הפעולות חדורות ב<a href=\"/index.php/%D7%94%D7%AA%D7%A7%D7%A9%D7%A8%D7%95%D7%AA\" title=\"התקשרות\">התקשרות</a> לרבי וציפיה להתגלותו כמלך המשיח.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב משה מאזוז - מנהל הבית חב\"ד לדוברי צרפתית נתניה.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%98%D7%90%D7%95%D7%91\" title=\"יוסף יצחק טאוב\">יוסף יצחק טאוב</a> - רב קהילת מרכז ממ\"ש בנתניה.</li>\n<li>בנו, הרב יוסף מאזוז- בית חב\"ד לדוברי צרפתית נתניה.</li>\n<li>בנו, הרב לוי מאזוז - שליח לדוברי צרפתית בשכונת עין התכלת בנתניה.</li>\n<li>בנו, הרב מענדי מאזוז - הקלידן החסידי<sup><span class=\"clarification-needed\" style=\"cursor: help; font-size: 90%;\" title=\"יש להסביר משפט זה במילים אחרות\">[דרושה הבהרה]</span></sup>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%96%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%96%D7%99%D7%92%D7%9C%D7%91%D7%95%D7%99%D7%9D\" title=\"מנחם זיגלבוים\">מנחם זיגלבוים</a>, <b><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/#!g=1&amp;url=article&amp;id=62290\">כואבים ומתחזקים</a></b> ראיון עם הרב מאזוז ב<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a></li></ul>\n<!-- \nNewPP limit report\nCached time: 20260413164832\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.047 seconds\nReal time usage: 0.099 seconds\nPreprocessor visited node count: 72/1000000\nPost‐expand include size: 513/2097152 bytes\nTemplate argument size: 128/2097152 bytes\nHighest expansion depth: 7/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\nLua time usage: 0.010/7 seconds\nLua virtual size: 5357568/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   69.470      1 תבנית:הבהרה\n100.00%   69.470      1 -total\n  9.21%    6.400      1 תבנית:קידוד\n  3.24%    2.248      1 תבנית:קטגוריה_בתבנית\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:56852-0!canonical and timestamp 20260413164832 and revision id 815424. Rendering was triggered because: page-view\n -->\n</div>"
