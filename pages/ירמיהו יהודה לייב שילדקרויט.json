    "pageid": 18118,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%97%D7%99%D7%A4%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/df/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%97%D7%99%D7%A4%D7%94.jpg/250px-%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%97%D7%99%D7%A4%D7%94.jpg\" decoding=\"async\" width=\"250\" height=\"166\" class=\"mw-file-element\" srcset=\"/images/thumb/d/df/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%97%D7%99%D7%A4%D7%94.jpg/375px-%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%97%D7%99%D7%A4%D7%94.jpg 1.5x, /images/thumb/d/df/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%97%D7%99%D7%A4%D7%94.jpg/500px-%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%97%D7%99%D7%A4%D7%94.jpg 2x\" /></a><figcaption>הרב שילדקרויט</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/46/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98.jpg/220px-%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98.jpg\" decoding=\"async\" width=\"220\" height=\"342\" class=\"mw-file-element\" srcset=\"/images/thumb/4/46/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98.jpg/330px-%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98.jpg 1.5x, /images/thumb/4/46/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98.jpg/440px-%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98.jpg 2x\" /></a><figcaption>הרב שילדקרויט (תשפ\"ו)</figcaption></figure>\n<p>הרב <b>ירמיהו יהודה (לייבל) שילדקרויט</b> (יליד <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a>), הוא שליח הרבי ל<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a> רב בית כנסת ומנכ\"ל מוסדות חינוך חב\"ד בחיפה והקריות.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9C%27_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"ל&#39; כסלו\">ל' כסלו</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a> ב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%94%D7%99%D7%99%D7%91%D7%9F\" title=\"ניו הייבן\">ניו הייבן</a> שב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a>, לאביו הרב <a href=\"/index.php/%D7%96%D7%90%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98\" title=\"זאב שילדקרויט\">זאב שילדקרויט</a>, שהיה חבר הנהלת <a href=\"/index.php/%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%99%D7%95_%D7%94%D7%99%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"אחי תמימים ניו הייוון\">אחי תמימים ניו הייוון</a> ומ<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שלוחי</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> במקום.\n</p><p>התחתן עם רבקה יענטא בתו של הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F\" title=\"אברהם ליסון\">אברהם ליסון</a> מ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>. \n</p><p>נשלח על ידי הרבי כחלק מקבוצות <a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">השלוחים לארץ הקודש</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a>.\n</p><p>ל<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a> הגיע בשליחות הרבי בימי הקיץ של שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a>. בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a> התחיל לנהל את בית חב\"ד חיפה ולפעול בכל חלקי העיר (מאוחר יותר הגיע הרב <a href=\"/index.php/%D7%93%D7%91_%D7%92%D7%99%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" class=\"mw-redirect\" title=\"דב גינזבורג\">דב גינזבורג</a> ופתח עוד ועוד בתי חב\"ד בחיפה).\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> נרתם הרב שילדקרויט לנהל את תלמוד תורה חב\"ד בקריות.\n</p><p>בשנים <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a> עד <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> גר ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> עקב סיבות שונות.\n</p><p>בצמוד לקהילת חב\"ד בעיר הקים את <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_(%D7%97%D7%99%D7%A4%D7%94)\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש (חיפה)\">ישיבת תומכי תמימים ליובאוויטש בחיפה</a>.\n</p><p>כיום גר ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>, ומנהל את מוסדות ופעילות חב\"ד בעיר.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98\" class=\"mw-redirect\" title=\"יוסף יצחק שילדקרויט\">יוסף יצחק שילדקרויט</a> - משלוחי הרבי, <a href=\"/index.php/%D7%A4%D7%90%D7%95%D7%9C%D7%95\" title=\"פאולו\">פאולו</a> <a href=\"/index.php/%D7%91%D7%A8%D7%96%D7%99%D7%9C\" title=\"ברזיל\">ברזיל</a>.</li>\n<li>בתו דבורה לאה, אשת הרב מנחם מענדל פיקרסקי, רעננה.</li>\n<li>בתו בלומה, אשת הרב זלמן רסקין - משלוחי הרבי בוינה.</li>\n<li>בתו חיה פריידא, אשת הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A0%D7%9C%D7%A1%D7%A7%D7%99_(%D7%A0%D7%99%D7%95_%D7%92%27%D7%A8%D7%96%D7%99)\" title=\"אברהם קנלסקי (ניו ג&#39;רזי)\">אברהם קנלסקי</a> - שליח ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%90%D7%91%D7%A8%D7%94%D7%9D\" title=\"ברית אברהם\">ברית אברהם</a> ב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%92%27%D7%A8%D7%96%D7%99\" title=\"ניו ג&#39;רזי\">ניו ג'רזי</a> וכן מנהל הבית חב\"ד בנמל התעופה ניוארק.</li>\n<li>בתו שטרנא שרה אשת הרב דוד מינסקי, משלוחי הרבי בחיפה ור\"מ בישיבת חב\"ד בעיר.</li>\n<li>בתו חנה, אשת הרב אברהם ברוך הבלין, ירושלים.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/video/rebbe/dailyvideo/135964/\">אצל הרבי בחלוקת הדולרים</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%9