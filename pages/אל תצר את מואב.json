php/%D7%91%D7%90%D7%AA%D7%99_%D7%9C%D7%92%D7%A0%D7%99\" title=\"באתי לגני\">באתי לגני</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8_%27%D7%95%D7%A9%D7%90%D7%91%D7%AA%D7%9D_%D7%9E%D7%99%D7%9D_%D7%91%D7%A9%D7%A9%D7%95%D7%9F%27\" title=\"מאמר &#39;ושאבתם מים בששון&#39;\">ושאבתם מים בששון</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%95%D7%99%D7%93%D7%A2%D7%AA_%D7%AA%D7%A8%D7%A0%22%D7%96_-_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"וידעת תרנ&quot;ז - מוסקבה\">וידעת תרנ\"ז - מוסקבה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%97%D7%9C%D7%A6%D7%95_%D7%AA%D7%A8%D7%A0%22%D7%98\" class=\"mw-redirect\" title=\"החלצו תרנ&quot;ט\">החלצו תרנ\"ט</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%97%D7%AA_%D7%A9%D7%90%D7%9C%D7%AA%D7%99_(%D7%9E%D7%90%D7%9E%D7%A8)\" title=\"אחת שאלתי (מאמר)\">אחת שאלתי</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%95%D7%A7%D7%91%D7%9C_%D7%94%D7%99%D7%94%D7%95%D7%93%D7%99%D7%9D\" title=\"וקבל היהודים\">וקבל היהודים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%99%D7%AA_%D7%92%D7%95%D7%99%D7%9D_%D7%A2%D7%9E%D7%9C%D7%A7_(%D7%9E%D7%90%D7%9E%D7%A8)\" title=\"ראשית גוים עמלק (מאמר)\">ראשית גוים עמלק</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #33cccc;\"><font size=\"2\"><a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמרי</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a></font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"אשרי תבחר תשט&quot;ז\">אשרי תבחר</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%99%D7%95%D7%9D_%D7%A2%D7%A9%D7%AA%D7%99_%D7%A2%D7%A9%D7%A8_%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"ביום עשתי עשר תשל&quot;א\">ביום עשתי עשר</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%92%D7%93%D7%95%D7%9C_%D7%99%D7%94%D7%99%D7%94_%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"גדול יהיה תשכ&quot;ב\">גדול יהיה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%95%D7%A9%D7%91%D7%AA%D7%99_%D7%91%D7%A9%D7%9C%D7%95%D7%9D_%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"ושבתי בשלום תשל&quot;ח\">ושבתי בשלום</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9B%D7%99_%D7%99%D7%A9%D7%90%D7%9C%D7%9A_%D7%91%D7%A0%D7%9A_%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"כי ישאלך בנך תשל&quot;ח\">כי ישאלך בנך</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9C%D7%90_%D7%AA%D7%94%D7%99%D7%94_%D7%9E%D7%A9%D7%9B%D7%9C%D7%94_%D7%AA%D7%A9%D7%99%22%D7%91\" title=\"לא תהיה משכלה תשי&quot;ב\">לא תהיה משכלה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%A4%D7%95%D7%A8%D7%99%D7%9D_%D7%A7%D7%98%D7%9F_-_%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"קונטרס פורים קטן - תשנ&quot;ב\">ואתה תצווה את בני ישראל</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A4%D7%95%D7%A8%D7%99%D7%9D_%D7%AA%D7%A9%D7%99%22%D7%92\" title=\"פורים תשי&quot;ג\">על כן קראו הימים האלה ימי הפורים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%A8%22%D7%97_%D7%9B%D7%A1%D7%9C%D7%95_-_%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"קונטרס ר&quot;ח כסלו - תשנ&quot;ג\">בורא ניב שפתיים תשמ\"ח</a>  <span style=\"white-space:nowrap; font-we