A_%D7%9E%D7%92%D7%99%D7%9C%D7%95%D7%AA_%D7%99%D7%9D_%D7%94%D7%9E%D7%9C%D7%97&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית מגילות ים המלח (הדף אינו קיים)\">מגילות</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%9E%D7%98%D7%94_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית מטה בנימין (הדף אינו קיים)\">מטה בנימין</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%A2%D7%A8%D7%91%D7%95%D7%AA_%D7%94%D7%99%D7%A8%D7%93%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית ערבות הירדן (הדף אינו קיים)\">ערבות הירדן</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%A9%D7%95%D7%9E%D7%A8%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית שומרון (הדף אינו קיים)\">שומרון</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413223738\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.067 seconds\nReal time usage: 0.874 seconds\nPreprocessor visited node count: 553/1000000\nPost‐expand include size: 7357/2097152 bytes\nTemplate argument size: 5404/2097152 bytes\nHighest expansion depth: 10/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5554176/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  672.823      1 תבנית:מחוז_יהודה_ושומרון\n100.00%  672.823      1 -total\n 96.22%  647.387      1 תבנית:ניווט_קבוצות\n  1.19%    8.017     20 תבנית:קיים\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:18131-0!cano