 href=\"/index.php/%D7%A9%D7%99%D7%A9%D7%95_%D7%95%D7%A9%D7%9E%D7%97%D7%95_(%D7%92)\" title=\"שישו ושמחו (ג)\">שישו ושמחו (ג)</a> • <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%99%D7%96_%D7%93%D7%99_%D7%91%D7%A2%D7%A1%D7%98%D7%A2_%D7%A1%D7%97%D7%95%D7%A8%D7%94\" title=\"ניגון תורה איז די בעסטע סחורה\">תורה איז די בעסטע סחורה</a> • <a href=\"/index.php/%D7%95%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D_%D7%95%D7%94%D7%A2%D7%95%D7%91%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"והחסידים והעובדים\">והחסידים והעובדים</a> • <a href=\"/index.php/%D7%A0%D7%98%D7%99%D7%9C%D7%AA_%D7%9C%D7%95%D7%9C%D7%91#ניגון_לנטילת_לולב\" title=\"נטילת לולב\">ניגון לנטילת לולב</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap mw-references-columns\"><ol class=\"references\">\n<li id=\"cite_note-אוצר-1\"><span class=\"mw-cite-backlink\">^ <sup><a href=\"#cite_ref-אוצר_1-0\">1</a></sup> <sup><a href=\"#cite_ref-אוצר_1-1\">2</a></sup></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.hebrewbooks.org/pdfpager.aspx?req=30510&amp;st=&amp;pgnum=396\">אוצר מנהגי חב\"ד שמחת תורה עמוד שפג</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">וכן ראה ביסוד ושורש העבודה שער י\"א פרק אחרון שישתדל לקנות חתן תורה ואם לא יצליח - שיקנה חתן בראשית, וכן בקהילות ליטא מקובל שמכבדים את הרב בעליית 'חתן תורה'.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">אברבנאל על פרשת וילך פרק לא סוף פסוק יח. צויין על ידי הרבי ברשימה שכתב אודות התוועדות שבת בראשית תשכ\"ז, נדפס בתורת מנחם חלק מח עמוד 197.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">אמרי פנחס אות רי.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">ראו לדוגמה בדרכי משה תרס\"ט, ב.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.hebrewbooks.org/pdfpager.aspx?req=59224&amp;pgnum=380\">התוועדויות תשד\"מ חלק א' עמוד 362</a>. וכן בשיחת שבת פרשת בראשית תשל\"ב בתחילתה.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">תורת מנחם חלק ט\"ו עמוד 135.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">לוח כולל חב\"ד. מדרכי משה תרס\"ט, ב.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\">התוועדויות תשנ\"ב חלק א' עמוד 169.</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span class=\"reference-text\">תורת מנחם חלק כא עמוד 133.</span>\n</li>\n<li id=\"cite_note-11\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-11\">^</a></span> <span class=\"reference-text\">ספר המנהגים עמוד 69.</span>\n</li>\n<li id=\"cite_note-12\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-12\">^</a></span> <span class=\"reference-text\">טור, שולחן ערוך, וכף החיים תרסט ס\"ק כד. על יסוד המסופר על דוד המלך שערך סעודה \"לגמרה של תורה\", ולפי זה עיקר המנהג להזמין את הציבור לסעודה הוא על החתן תורה דווקא.</span>\n</li>\n<li id=\"cite_note-13\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-13\">^</a></span> <span class=\"reference-text\">ערב חג השבועות תשכ\"ג בעת ביקור הרב <a href=\"/index.php/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%99%D7%90%D7%9C%D7%9C%D7%A2%D7%A1\" class=\"mw-redirect\" title=\"אפרים אליעזר יאללעס\">אפרים אליעזר יאללעס</a>, תורת מנחם חלק לז עמוד 4. מקדש מלך חלק ב' עמוד 364.</span>\n</li>\n<li id=\"cite_note-14\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-14\">^</a></span> <span class=\"reference-text\">דף קעג.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413190625\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.117 seconds\nReal time usage: 0.244 seconds\nPreprocessor visited node count: 1155/1000000\nPost‐expand include size: 14010/2097152 bytes\nTemplate argument size: 13965/2097152 bytes\nHighest expansion depth: 10/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 6043/5000000 bytes\nLua time usage: 0.080/7 seconds\nLua virtual size: 6230016/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  221.220      1 -total\n 69.30%  153.314     15 תבנית:הערה\n 21.98%   48.618      1 תבנית:סוכות\n 20.22%   44.734      1 תבנית:ניווט_קבוצות\n  7.99%   17.672      1 תבנית:הערות_שוליים\n  1.35%    2.983     20 תבנית:קיים\n  1.26%    2.781      1 תבנית:הערות_שוליים/מרחב_שם\n  0.89%    1.979      2 תבנית:שורה_אחת\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:59186-0!canonical and timestamp 20260413190625 and revision id 724205. Rendering was triggered because: page-view\n -->\n</div>"
