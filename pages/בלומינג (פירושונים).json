    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>ОћОљОЮ ОћОфОЏОЋОЋОаОфОЮ Ою...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%A5_%D7%91%D7%9C%D7%95%D7%9E%D7%99%D7%A0%D7%92\" title=\"ОЎОбОДОЉ ОцОеОЦ ОЉОюОЋОъОЎОаОњ\">ОЎОбОДОЉ ОцОеОЦ ОЉОюОЋОъОЎОаОњ</a> - <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"ОЌОАОЎОЊ ОЌОЉ&quot;ОЊ\">ОЌОАОЎОЊ ОЌОЉ\"ОЊ</a>, ОфОЋОЕОЉ <a href=\"/index.php/%D7%91%D7%95%D7%A8%D7%95_%D7%A4%D7%90%D7%A8%D7%A7\" title=\"ОЉОЋОеОЋ ОцОљОеОД\">ОЉОЋОеОЋ ОцОљОеОД</a>, ОћОбОЋОАОД ОЉОцОЎОеОЋОЕ Оћ<a href=\"/index.php/%D7%A8%D7%9E%D7%91%22%D7%9D\" title=\"ОеОъОЉ&quot;ОЮ\">ОеОъОЉ\"ОЮ</a> ОЋОъОЌОЉОе ОАОЊОеОф ОАОцОеОЎ 'ОеОъОЉ\"ОЮ ОћОбОеОЋОџ'.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%91%D7%9C%D7%95%D7%9E%D7%99%D7%A0%D7%92\" title=\"ОЕОюОъОћ ОЉОюОЋОъОЎОаОњ\">ОЎОЕОбОЎОћОЋ ОЕОюОъОћ ОЉОюОЋОъОЎОаОњ</a> - ОъОцОбОЎОюОЎ ОЌОЉ\"ОЊ ОЉОДОеОЋОюОЎОЎОаОћ. ОЉОбОЉОе ОЕОЎОъОЕ ОЏОЕОюОЎОЌ ОћОеОЉОЎ ОЉОљОўОюОаОўОћ, ОЏОъОЋОеОћ ОдОЊОД ОЉОДОћОЎОюОф ОЌОЉ\"ОЊ ОЉОъОЋОаОАОЎ, ОЋОЏОъОЕОцОЎОб ОЉ<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%97%D7%A0%D7%94\" title=\"ОъОЏОЋОЪ ОЌОаОћ\">ОъОЏОЋОЪ ОЌОаОћ</a> ОЉ<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"ОДОеОљОЋОЪ ОћОЎОЎОўОА\">ОДОеОљОЋОЪ ОћОЎОЎОўОА</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%92%D7%93%D7%9C%D7%99%D7%94_%D7%91%D7%9C%D7%95%D7%9E%D7%99%D7%A0%D7%92\" title=\"ОњОЊОюОЎОћ ОЉОюОЋОъОЎОаОњ\">ОњОЊОюОЎОћ ОЉОюОЋОъОЎОаОњ</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"ОъОЕОњОЎОЌ\">ОъОЕОњОЎОЌ</a> ОеОљОЕОЎ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_770\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф - 770\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф - 770</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%9D_%D7%91%D7%9C%D7%95%D7%9E%D7%99%D7%A0%D7%92\" title=\"ОЕОъОЋОљОю ОЌОЎОЎОЮ ОЉОюОЋОъОЎОаОњ\">ОЕОъОЋОљОю ОЌОЎОЎОЮ ОЉОюОЋОъОЎОаОњ</a> - <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"Ое&quot;Оъ\">Ое\"Оъ</a> ОЉ<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОћОюОЎ ОфОЋОеОћ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОћОюОЎ ОфОЋОеОћ</a> ОДОеОљОЋОЪ ОћОЎОЎОўОА ОЋ<a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"ОъОЋОеОћ ОдОЊОД\">ОъОЋОеОћ ОдОЊОД</a> ОЉОЕОЏОЋОаОф ОДОеОљОЋОЪ ОћОЎОЎОўОА.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%91%D7%9C%D7%95%D7%9E%D7%99%D7%A0%D7%92\" title=\"ОљОЉОеОћОЮ ОЉОюОЋОъОЎОаОњ\">ОљОЉОеОћОЮ ОЉОюОЋОъОЎОаОњ</a> - ОъОЎОЎОАОЊ ОЋОъОаОћОю <a href=\"/index.php/%D7%90%D7%99%D7%92%D7%95%D7%93_%D7%94%D7%9E%D7%9C%D7%9E%D7%93%D7%99%D7%9D_(%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1)\" title=\"ОљОЎОњОЋОЊ ОћОъОюОъОЊОЎОЮ (ОДОеОљОЋОЪ ОћОЎОЎОўОА)\">ОљОЎОњОЋОЊ ОћОъОюОъОЊОЎОЮ</a>, <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"ОДОеОљОЋОЪ ОћОЎОЎОўОА\">ОДОеОљОЋОЪ ОћОЎОЎОўОА</a>.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\"><img alt=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5