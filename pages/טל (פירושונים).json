    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>ОћОљОЮ ОћОфОЏОЋОЋОаОфОЮ Ою...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li><a href=\"/index.php/%D7%98%D7%9C\" title=\"ОўОю\">ОўОю</a></li></ul>\n<dl><dt>ОљОЎОЕОЎОЮ</dt></dl>\n<ul><li>Ое' ОЊ\"Ое <a href=\"/index.php/%D7%98%D7%9C_%D7%A0%D7%99%D7%A8\" title=\"ОўОю ОаОЎОе\">ОўОю ОаОЎОе</a> - ОеОЋОцОљ ОъОЕОцОЌОћ ОъОЋОбОеОџ, ОЎОЋ\"Ое ОЋОъОаОћОю ОљОеОњОЋОЪ ОљОЎОњОЋОЊ ОћОеОЋОцОљОЎОЮ ОћОЌОЉ\"ОЊОЎОЎОЮ. <a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОаОЌОюОф ОћОе ОЌОЉ&quot;ОЊ\">ОаОЌОюОф ОћОе ОЌОЉ\"ОЊ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%98%D7%9C\" title=\"ОъОаОЌОЮ ОўОю\">ОъОаОЌОЮ ОўОю</a> - ОЕОюОЎОЌ ОћОеОЉОЎ ОЋОеОЉ ОћОЎОЎОЕОЋОЉ ОбОЎОЪ ОљОЎОЎОюОћ ОЉОЌОЋОБ ОћОЏОеОъОю, ОЋОЌОЉОе ОћОаОћОюОф <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%93%D7%A8_%D7%90%D7%95%D7%A8_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"ОЌОЎОЎОЊОе ОљОЋОе ОюОЎОЋОЉОљОЋОЋОЎОўОЕ\">ОЌОЎОЎОЊОе ОљОЋОе ОюОЎОЋОЉОљОЋОЋОЎОўОЕ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%98%D7%9C\" title=\"ОЊОЋОЊ ОўОю\">ОЊОЋОЊ ОўОю</a> - ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЎОЎОЕОЋОЉ ОфОъОеОф, ОЕОЕОЎОъОЕ ОЉОбОЉОеОЋ ОЏОъОцОДОЊ ОЌОўОЎОЉОф ОћОъОю\"ОўОЎОЮ ОЉ<a href=\"/index.php/%D7%A6%D7%94%22%D7%9C\" title=\"ОдОћ&quot;Ою\">ОдОћ\"Ою</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%A9%D7%9E%D7%A9%D7%95%D7%9F_%D7%98%D7%9C\" title=\"ОЕОъОЕОЋОЪ ОўОю\">ОЕОъОЕОЋОЪ ОўОю</a> - ОЕОюОЎОЌ ОћОеОЉОЎ ОЋОъОаОћОю ОЉОЎОф ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%94%D7%95%D7%93_%D7%94%D7%A9%D7%A8%D7%95%D7%9F\" title=\"ОћОЋОЊ ОћОЕОеОЋОЪ\">ОћОЋОЊ ОћОЕОеОЋОЪ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%98%D7%9C\" title=\"ОЌОЎОЎОЮ ОўОю\">ОЌОЎОЎОЮ ОўОю</a> - ОъОЎОЎОАОЊ ОЋОъОаОћОю ОљОеОњОЋОЪ <a href=\"/index.php?title=%D7%9C%D7%9B%D7%A9%D7%99%D7%A4%D7%95%D7%A6%D7%95_%D7%9E%D7%A2%D7%99%D7%99%D7%A0%D7%95%D7%AA%D7%99%D7%9A&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОюОЏОЕОЎОцОЋОдОЋ ОъОбОЎОЎОаОЋОфОЎОџ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОюОЏОЕОЎОцОЋОдОЋ ОъОбОЎОЎОаОЋОфОЎОџ</a>, Ое\"Оъ ОюОбОЎОЋОаОљ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ</a> ОЋОъОЕОюОЋОЌОЎ ОћОеОЉОЎ ОЉОћОЋОЊ ОћОЕОеОЋОЪ.</li>\n<li>Ое' <a href=\"/index.php/%D7%9E%D7%9C%D7%9A_%D7%98%D7%9C\" title=\"ОъОюОџ ОўОю\">ОъОюОџ ОўОю</a> - ОЕОЌОДОЪ ОЌОАОЎОЊ ОЌОЉ\"ОЊ</li></ul>\n<dl><dt>ОаОЎОњОЋОаОЎОЮ ОЋОфОцОЎОюОЋОф</dt></dl>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%AA_%D7%98%D7%9C\" title=\"ОфОцОЎОюОф ОўОю\">ОфОцОЎОюОф ОўОю</a></li>\n<li><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%98%D7%9C_%D7%99%D7%A2%D7%A1%D7%99%D7%A1\" title=\"ОаОЎОњОЋОЪ ОўОю ОЎОбОАОЎОА\">ОаОЎОњОЋОЪ ОўОю ОЎОбОАОЎОА</a></li>\n<li><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%98%D7%9C_%D7%91%D7%95_%D7%AA%D7%91%D7%A8%D7%9A_%D7%9E%D7%96%D7%95%D7%9F\" title=\"ОаОЎОњОЋОЪ ОўОю ОЉОЋ ОфОЉОеОџ ОъОќОЋОЪ\">ОаОЎОњОЋОЪ ОўОю ОЉОЋ ОфОЉОеОџ ОъОќОЋОЪ</a></li></ul>\n<dl><dt>ОАОцОеОЎОЮ</dt></dl>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99_%D7%98%D7%9C\" class=\"mw-redirect\" title=\"ОъОЎ ОўОю\">ОъОЎ ОўОю</a></li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\"><img alt=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>ОцОЎОеОЋОЕОЋОаОЎОЮ</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> ОќОћОЋ ОЊОБ <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"ОЌОЉ&quot;ОЊОцОЊОЎОћ:ОцОЎОеОЋОЕОЋОаОЎОЮ\">ОцОЎОеОЋОЕОЋОаОЎОЮ</a>, ОЕОъОўОеОфОЋ ОюОћОЉОЌОЎОЪ ОЉОЎОЪ ОбОеОЏОЎОЮ ОЕОЋОаОЎОЮ ОЉОбОюОЎ ОЕОЮ ОЊОЋОъОћ.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/42px-Gnome-searchtool.svg.png 2x\" /></a></span> ОљОЮ ОюОљ ОъОдОљОфОЮ ОЉОеОЕОЎОъОф ОћОцОЎОеОЋОЕОЋОаОЎОЮ ОљОф ОћОбОеОџ ОЕОћОфОЏОЋОЋОаОфОЮ ОљОюОЎОЋ, ОаОАОЋ:\n</p>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%93%D7%A4%D7%99%D7%9D_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C%D7%99%D7%9D_%D7%91/%D7%98%D7%9C\" title=\"ОъОЎОЋОЌОЊ:ОЊОцОЎОЮ ОћОъОфОЌОЎОюОЎОЮ ОЉ/ОўОю\">ОЊОцОЎОЮ ОЕОЕОъОЮ ОъОфОЌОЎОю ОЉРђЮОўОюРђю</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/intitle:%D7%98%D7%9C%22\" title=\"ОъОЎОЋОЌОЊ:ОЌОЎОцОЋОЕ/intitle:ОўОю&quot;\">ОЊОцОЎОЮ ОЕОЕОъОЮ ОъОЏОЎОю РђЮОўОюРђю</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/~%22%D7%98%D7%9C%22\" title=\"ОъОЎОЋОЌОЊ:ОЌОЎОцОЋОЕ/~&quot;ОўОю&quot;\">ОЌОЎОцОЋОЕ РђЮОўОюРђю ОЉОЌОЉ\"ОЊОцОЊОЎОћ</a></li></ul>\n</div>\n</td>\n</tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413205102\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.051 seconds\nReal time usa