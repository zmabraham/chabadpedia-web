99%D7%99%D7%A9%D7%95%D7%91_%D7%A7%D7%94%D7%99%D7%9C%D7%AA%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יישוב קהילתי (הדף אינו קיים)\">יישובים&#160;קהילתיים</a>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%94%D7%92%D7%A0%D7%95%D7%96_(%D7%99%D7%99%D7%A9%D7%95%D7%91)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אור הגנוז (יישוב) (הדף אינו קיים)\">אור הגנוז</a> • <a class=\"mw-selflink selflink\">ביריה</a> • <a href=\"/index.php?title=%D7%91%D7%A8_%D7%99%D7%95%D7%97%D7%90%D7%99_(%D7%99%D7%99%D7%A9%D7%95%D7%91)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בר יוחאי (יישוב) (הדף אינו קיים)\">בר יוחאי</a> • <a href=\"/index.php?title=%D7%9B%D7%9C%D7%A0%D7%99%D7%AA_(%D7%99%D7%99%D7%A9%D7%95%D7%91)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כלנית (יישוב) (הדף אינו קיים)\">כלנית</a> • <a href=\"/index.php?title=%D7%9B%D7%A4%D7%A8_%D7%97%D7%A0%D7%A0%D7%99%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כפר חנניה (הדף אינו קיים)\">כפר חנניה</a> • <a href=\"/index.php?title=%D7%9C%D7%99%D7%91%D7%A0%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ליבנים (הדף אינו קיים)\">ליבנים</a> • <a href=\"/index.php?title=%D7%A2%D7%9E%D7%95%D7%A7%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עמוקה (הדף אינו קיים)\">עמוקה</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\">כפרים <a href=\"/index.php?title=%D7%93%D7%A8%D7%95%D7%96%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"דרוזים (הדף אינו קיים)\">דרוזים</a> ו<a href=\"/index.php?title=%D7%A6%27%D7%A8%D7%A7%D7%A1%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"צ&#39;רקסים (הדף אינו קיים)\">צ'רקסים</a>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php?title=%D7%A2%D7%99%D7%9F_%D7%90%D7%9C-%D7%90%D7%A1%D7%93&amp;action=edit&am