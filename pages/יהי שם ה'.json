/index.php/%D7%90%D7%AA%D7%94%D7%9C%D7%9A_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%27_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"ОљОфОћОюОџ ОюОцОаОЎ Оћ&#39; ОЉОљОеОдОЋОф ОћОЌОЎОЎОЮ (ОаОЎОњОЋОЪ)\">ОДОў\"Оќ (1)</a> ┬и <a href=\"/index.php/%D7%9B%D7%95%D7%A1_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA_%D7%90%D7%A9%D7%90_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"ОЏОЋОА ОЎОЕОЋОбОЋОф ОљОЕОљ (ОаОЎОњОЋОЪ)\">ОДОў\"Оќ (2)</a> ┬и <a href=\"/index.php/%D7%94%D7%9C%D7%9C%D7%95_%D7%90%D7%AA_%D7%94%27_%D7%9B%D7%9C_%D7%92%D7%95%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%99%22%D7%90_%D7%A0%D7%99%D7%A1%D7%9F_%D7%AA%D7%A9%D7%A2%22%D7%97)\" title=\"ОћОюОюОЋ ОљОф Оћ&#39; ОЏОю ОњОЋОЎОЎОЮ (ОаОЎОњОЋОЪ ОЎ&quot;Ољ ОаОЎОАОЪ ОфОЕОб&quot;ОЌ)\">ОДОЎ\"Оќ</a> ┬и <a href=\"/index.php/%D7%90%D7%95%D7%93%D7%9A_%D7%9B%D7%99_%D7%A2%D7%A0%D7%99%D7%AA%D7%A0%D7%99_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"ОљОЋОЊОџ ОЏОЎ ОбОаОЎОфОаОЎ (ОаОЎОњОЋОЪ)\">ОДОЎ\"ОЌ</a> ┬и <a href=\"/index.php/%D7%9B%D7%9C%D7%AA%D7%94_%D7%9C%D7%AA%D7%A9%D7%95%D7%A2%D7%AA%D7%9A_%D7%A0%D7%A4%D7%A9%D7%99_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"ОЏОюОфОћ ОюОфОЕОЋОбОфОџ ОаОцОЕОЎ (ОаОЎОњОЋОЪ)\">ОДОЎ\"Оў</a> ┬и <a href=\"/index.php/%D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%90%D7%9C_%D7%94%27\" title=\"ОЕОЎОе ОћОъОбОюОЋОф ОљОю Оћ&#39;\">ОД\"ОЏ</a> ┬и <a href=\"/index.php/%D7%90%D7%A9%D7%90_%D7%A2%D7%99%D7%A0%D7%99_%D7%90%D7%9C_%D7%94%D7%94%D7%A8%D7%99%D7%9D\" title=\"ОљОЕОљ ОбОЎОаОЎ ОљОю ОћОћОеОЎОЮ\">ОДОЏ\"Ољ</a> ┬и <a href=\"/index.php/%D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%9C%D7%93%D7%95%D7%93_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"ОЕОЎОе ОћОъОбОюОЋОф ОюОЊОЋОЊ (ОаОЎОњОЋОЪ)\">ОДОЏ\"ОЉ</a> ┬и <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%90%D7%9C%D7%99%D7%9A\" title=\"ОаОЎОњОЋОЪ ОЕОЎОе ОћОъОбОюОЋОф ОљОюОЎОџ\">ОДОЏ\"Оњ</a> ┬и <a href=\"/index.php/%D7%9C%D7%95%D7%9C%D7%99_%D7%94%27_%D7%A9%D7%94%D7%99%D7%94_%D7%9C%D7%A0%D7%95_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"ОюОЋОюОЎ Оћ&#39; ОЕОћОЎОћ ОюОаОЋ (ОаОЎОњОЋОЪ)\">ОДОЏ\"ОЊ</a> ┬и <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%94%D7%91%D7%95%D7%98%D7%97%D7%99%D7%9D_%D7%91%D7%94%27\" class=\"mw-redirect\" title=\"ОаОЎОњОЋОЪ ОЕОЎОе ОћОъОбОюОЋОф ОћОЉОЋОўОЌОЎОЮ ОЉОћ&#39;\">ОДОЏ\"Оћ</a>\n<p><small>ОаОЎОфОЪ ОюОеОљОЋОф ОљОф ОЕОЮ ОћОаОЎОњОЋОЪ ОЉОљОъОдОбОЋОф ОеОЎОЌОЋОБ ОбОЮ ОАОъОЪ ОћОбОЏОЉОе ОбОю ОъОАОцОе ОћОаОЎОњОЋОЪ</small>\n</p>\n</td></tr></tbody></table>\n<p>ОаОЎОњОЋОЪ <b>ОЎОћОЎ ОЕОЮ Оћ'</b> ОћОЋОљ <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ОаОЎОњОЋОЪ\">ОаОЎОњОЋОЪ</a> ОЕОћОЋОюОЌОЪ ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"ОфОЕОб&quot;ОЊ\">ОфОЕОб\"ОЊ</a> ОюОЏОЉОЋОЊ ОЎОЋОЮ ОћОЋОюОЊОфОЋ Оћ-112 ОЕОю <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a>, <a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"ОЎ&quot;Ољ ОЉОаОЎОАОЪ\">ОЎ\"Ољ ОЉОаОЎОАОЪ</a>.\n</p><p>ОъОфОЋОџ ОбОЕОеОЋОф ОаОЎОњОЋОаОЎОЮ, ОЉОЌОеОћ <a href=\"/index.php/%D7%95%D7%95%D7%A2%D7%93%D7%AA_%D7%94%D7%A0%D7%99%D7%92%D7%95%D7%A0%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"ОЋОЋОбОЊОф ОћОаОЎОњОЋОаОЎОЮ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ\">ОЋОЋОбОЊОф ОћОаОЎОњОЋОаОЎОЮ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ</a> ОљОф ОћОаОЎОњОЋОЪ ОЕОћОЋОюОЌОЪ ОбОю ОЎОЊОЎ Ое' <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%91%D7%9C%D7%A1%D7%95%D7%A4%D7%A1%D7%A7%D7%99\" title=\"ОљОћОеОЋОЪ ОЉОюОАОЋОцОАОДОЎ\">ОљОћОеОЋОЪ ОЉОюОАОЋОцОАОДОЎ</a>, ОбОю ОћОъОЎОюОЎОЮ ОЕОЉ<a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D\" title=\"ОфОћОюОЎОЮ\">ОфОћОюОЎОЮ</a> ОцОеОД ОДОЎ\"Оњ, ОћОцОеОД ОћОЌОЊОЕ ОЕОю ОћОеОЉОЎ ОЉОљОЋОфОћ ОЕОаОћ.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.9E.D7.99.D7.9C.D7.95.D7.AA_.D7.94.D7.A0.D7.99.D7.92.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"ОъОЎОюОЋОф_ОћОаОЎОњОЋОЪ\">ОъОЎОюОЋОф ОћОаОЎОњОЋОЪ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%99_%D7%A9%D7%9D_%D7%94%27&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОъОЎОюОЋОф ОћОаОЎОњОЋОЪ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%99_%D7%A9%D7%9D_%D7%94%27&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОъОЎОюОЋОф ОћОаОЎОњОЋОЪ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОћОаОЎОњОЋОЪ ОћОфОцОеОАОЮ ОфОЌОЎОюОћ ОЏОљОЕОе ОЉОъОДОЋОЮ ОћОцОАОЋОДОЎОЮ 'ОъОЎ ОЏОћ'.. ОЉОЕОъОЎОЮ ОЋОЉОљОеОЦ' ОћОЋОцОЎОб ОћОцОАОЋОД 'ОеОЮ ОбОю ОЏОю ОњОЋОЎОЮ Оћ' ОбОю ОћОЕОъОЎОЮ ОЏОЉОЋОЊОЋ', ОљОџ ОЉОћОЋОеОљОф ОъОЕОцОЎОбОЎ ОЌОЉ\"ОЊ ОћОцОАОЋОД ОћОЋОЌОюОБ, ОбОДОЉ ОъОЕОъОбОЋОф ОЕОљОЎОаОћ ОўОЋОЉОћ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<blockquote dir=\"rtl\"><div class=\"hebrewQuotation\">\n<p>ОЎо░Оћо┤ОЎ ОЕохОЂОЮ Оћ' Оъо░ОЉо╣ОеоИОџо░ ОъохОбоиОфоИо╝Оћ ОЋо░ОбоиОЊ ОбОЋо╣ОюоИОЮ.\n</p><p>Оъо┤ОЎ ОЏоио╝Оћ' Ољо▒Оюо╣ОћохОЎОаОЋо╝ ОћоиОъоио╝Оњо░ОЉо┤о╝ОЎОћо┤ОЎ ОюоИОЕоИОЂОЉоХОф:\n</p><p>ОћоиОъоио╝ОЕо░ОЂОцо┤о╝ОЎОюо┤ОЎ Оюо┤Оео░ОљОЋо╣Оф ОЉоио╝ОЕоИо╝ОЂОъоиОЎо┤ОЮ ОЋо╝ОЉоИОљоИОеоХОЦ:\n</p><p>Оъо░ОДо┤ОЎОъо┤ОЎ ОъохОбоИОцоИОе ОЊоИо╝Ою ОъохОљоиОЕо░ОЂОцо╣о╝Оф ОЎоИОео┤ОЎОЮ ОљоХОЉо░ОЎОЋо╣ОЪ:\n</p><p>Оюо░ОћОЋо╣ОЕо┤ОЂОЎОЉо┤ОЎ Обо┤ОЮ Оао░ОЊо┤ОЎОЉо┤ОЎОЮ Обо┤ОЮ Оао░ОЊо┤ОЎОЉохОЎ ОбоиОъо╝ОЋо╣:\n</p><p>ОЎо░ОЌо┤ОЎ Ољо▓ОЊОЋо╣ОаохОаОЋо╝ ОъОЋо╣ОеохОаОЋо╝ ОЋо░ОеоиОЉохо╝ОЎОаОЋо╝ ОъоХОюоХОџо░ ОћоиОъоИо╝ОЕо┤ОЂОЎОЌои Оюо░ОбОЋо╣ОюоИОЮ ОЋоИОбоХОЊ:\n</p><p>ОъоХОюоХОџо░ ОћоиОъоИо╝ОЕо┤ОЂОЎОЌои ОЌоиОЎ ОЋо░ОДоиОЎоИо╝ОЮ, ОЌоиОЎ ОЋо░ОДоиОЎоИо╝ОЮ Оюо░ОбОЋо╣ОюоИОЮ ОЋоИОбоХОЊ:\n</p>\n</div>\n<div style=\"text-align:left;border-top: 1px dotted #ccc;\">Рђћ <cite style=\"font-size:small; font-style: normal;\">ОфОћОюОЎОЮ ОДОЎОњ, ОЉ; Оћ; ОЋ; Оќ; ОЌ</cite></div>\n </blockquote> \n<h2><span id=\".D7.A8.D7.A7.D7.A2\"></span><span class=\"mw-headline\" id=\"ОеОДОб\">ОеОДОб</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%99_%D7%A9%D7%9D_%D7%94%27&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОеОДОб&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%99_%D7%A9%D7%9D_%D7%94%27&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОеОДОб\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОћОаОЎОњОЋОЪ ОЌОЋОЉОе ОЉОъОДОЋОеОЋ ОбОю ОЎОЊОЎ Ое' <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%91%D7%9C%D7%A1%D7%95%D7%A4%D7%A1%D7%A7%D7%99\" title=\"ОљОћОеОЋОЪ ОЉОюОАОЋОцОАОДОЎ\">ОљОћОеОЋОЪ ОЉОюОАОЋОцОАОДОЎ</a> ОюОДОеОљОф ОЎ\"Ољ ОаОЎОАОЪ ОфОаОЕ\"Ољ ОЋОћОЋОфОљОЮ ОюОъОЎОюОЎОЮ \"ОЋОЎОћОЎ ОаОЋОбОЮ ОћО│ ОљОюОЋОДОЎОаОЋ ОбОюОЎОаОЋ. (ОъОцОЎ ОъОЌОЉОе ОћОаОЎОњОЋОЪ ОеО│ ОљОћОеОЪ ОЉОюОАОЋОцОАОДОЎ)\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ОеОљОЋ_ОњОЮ\">ОеОљОЋ ОњОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%99_%D7%A9%D7%9D_%D7%94%27&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОеОљОЋ ОњОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%99_%D7%A9%D7%9D_%D7%94%27&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОеОљОЋ ОњОЮ\"><