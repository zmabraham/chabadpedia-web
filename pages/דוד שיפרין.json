    "pageid": 6579,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F2.jpg\" class=\"mw-file-description\"><img src=\"/images/e/e3/%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F2.jpg\" decoding=\"async\" width=\"144\" height=\"201\" class=\"mw-file-element\" /></a><figcaption>הרב שיפרין ב<a href=\"/index.php/%D7%99%22%D7%98_%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"י&quot;ט תמוז\">י\"ט תמוז</a> <a href=\"/index.php/%D7%AA%D7%A8%22%D7%A6\" title=\"תר&quot;צ\">תר\"צ</a></figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%27_%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F.png\" class=\"mw-file-description\"><img src=\"/images/thumb/a/a2/%D7%A8%27_%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F.png/220px-%D7%A8%27_%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F.png\" decoding=\"async\" width=\"220\" height=\"133\" class=\"mw-file-element\" srcset=\"/images/thumb/a/a2/%D7%A8%27_%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F.png/330px-%D7%A8%27_%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F.png 1.5x, /images/a/a2/%D7%A8%27_%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F.png 2x\" /></a><figcaption>ר' דוד שיפרין</figcaption></figure>\n<p>הרב <b>דוד שיפרין</b> (?– <a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ג באייר\">י\"ג אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a>) היה מגדולי החסידים ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a>, וזכה לראות בעיניו ארבעה מ<a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%A0%D7%A9%D7%99%D7%90%D7%99_%D7%97%D7%91%22%D7%93\" title=\"קטגוריה:נשיאי חב&quot;ד\">אדמו\"רי חב\"ד</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%96%D7%A2%D7%9E%D7%91%D7%99%D7%9F\" class=\"mw-redirect\" title=\"זעמבין\">זעמבין</a> לאביו ר' אליעזר, בצעירותו היה ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a> אצל <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a>, ובהגיעו לגיל עשרים התחתן עם אחת מבנות החסידים מ<a href=\"/index.php/%D7%A4%D7%9C%D7%A2%D7%A9%D7%A0%D7%99%D7%A5\" class=\"mw-redirect\" title=\"פלעשניץ\">פלעשניץ</a> ועבר להתגורר בקהילה החב\"דית המקומית.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A8%22%D7%A1\" title=\"תר&quot;ס\">תר\"ס</a> נסע ל<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a> וכיהן כיד ימינו של נשיא עדת החסידים בניו יורק, הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%99%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D\" title=\"אברהם חיים רוזנבוים\">אברהם חיים רוזנבוים</a>, ולאחר פטירתו בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%93\" title=\"תרע&quot;ד\">תרע\"ד</a> מונה לכהן כמזכיר <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"אגודת חסידי חב&quot;ד בארצות הברית\">אגודת חסידי חב\"ד בארצות הברית</a> וכגבאי <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"כולל חב&quot;ד\">כולל חב\"ד</a> ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a>. \n</p><p>הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%27%D7%99%D7%99%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F\" title=\"ישראל ג&#39;ייקובסון\">ישראל ג'ייקובסון</a> כותב עליו: ידידינו היקר החסיד ר' דוד שיפרין הוא היה נקודה המרכזית של אנ\"ש בארצות הברית, א הארציגער פנימיות'דיקער קלוגער חסיד'ישער איד, הוא עמד בקישור עם כל אנ\"ש בארצות הברית בלי פרסום בלי משרד ובלי משרת פקיד או איזה תואר שיהיה, רק הארציגע אמת'דיקע חסיד'ישע אהבת אחים\". \n</p><p>לפני שנסע לאמריקה בא ל<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> ואמר לו: רבי איך פאר אין אמריקה (בניו כבר היו אז באמריקה) לא באתי לשאול מרבינו אם לנסוע, יש לי כרטיס מסע, אך אינני חפץ להיות כתלמיד הבורח מהחדר ואינו מודיע לרבו להיכן ברח, וע\"כ באתי לאמר לרבי שנוסע הנני לאמריקה. \n</p><p>בשנותיו האחרונות הספיק לכהן כיו\"ר ועד לכתיבת <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%AA%D7%95%D7%A8%D7%94_%D7%9C%D7%A7%D7%91%D7%9C%D7%AA_%D7%A4%D7%A0%D7%99_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"ספר תורה לקבלת פני משיח\">ספר תורה לקבלת פני משיח</a>. \n</p><p>הרב שיפרין נפטר ב<a href=\"/index.php/%D7%99%22%D7%92_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"י&quot;ג אייר\">י\"ג אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> ומנ\"כ בסטטן איילנד, ניו יורק.\n</p>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ספריו\">ספריו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ספריו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ספריו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a href=\"/index.php/%D7%97%D7%9B%D7%9E%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%A2%D7%A9%22%D7%98_(%D7%A1%D7%A4%D7%A8)\" title=\"חכמי ישראל בעש&quot;ט (ספר)\">חכמי ישראל בעש\"ט</a></b> ספר המלקט בתוכו עשרות כתבי יד, מכתבים, וספרים נדירים ל<a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">בעל שם טוב</a> ונשיאי <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> מ<a href=\"/index.php/%D7%94%D7%92%D7%A0%D7%99%D7%96%D7%94_%D7%94%D7%97%D7%A8%D7%A1%D7%95%D7%A0%D7%99%D7%AA\" title=\"הגניזה החרסונית\">הגניזה החרסונית</a>. יצא לאור ב<a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%93\" title=\"תרפ&quot;ד\">תרפ\"ד</a>. דעת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> לא הייתה נוחה מספר זה. יש הטוענים כי הסיבה היא עקב פרסום קטעים \"רגישים\" מהגניזה בספר, אך הספר הודפס לפני שמכתבו של אדמו\"ר הריי\"צ בנוגע להתנגדותו הספיק להגיע לאמריקה.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://shturem.net/images/news/93817_news_03022017_81140.pdf\">ליובאוויטש וחייליה - ר' דוד שיפרין</a></b>, סקירה על דמותו בתוך גליון 'החייל', י' שבט תשע\"ז</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%A9%D7%99%D7%A4%D7%A8%D7%99%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>יוסף אשכנזי, <a href=\"/index.php/%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D_(%D7%A1%D7%A4%D7%A8)\" class=\"mw-redirect\" title=\"אוצר החסידים (ספר)\">אוצר החסידים</a> - אישיותם ומשנתם החסידית של משפיעי חב\"ד בניו-יורק, בהוצאת <a href=\"/index.php/%D7%97%D7%96%D7%A7_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)\" class=\"mw-redirect\" title=\"חזק (בית הוצאה לאור)\">חזק</a>, תשע\"ג</li></ul>\n<!-- \nNewPP limit report\nCached time: 20260413220151\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.015 seconds\nReal time usage: 0.045 seconds\nPreprocessor visited node count: 40/1000000\nPost‐expand include size: 0/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 2/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%    0.000      1 -total\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:6579-0!canonical and timestamp 20260413220151 and revision id 819516. Rendering was triggered because: diff-page\n -->\n</div>"
