      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/86/%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg/150px-%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg\" decoding=\"async\" width=\"150\" height=\"200\" class=\"mw-file-element\" srcset=\"/images/thumb/8/86/%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg/225px-%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg 1.5x, /images/thumb/8/86/%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg/300px-%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg 2x\" /></a><figcaption>הרב יצחק דוד גרונר</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91%D7%99_%D7%A9%D7%9C%D7%99%D7%98%D7%90_%D7%A2%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/%D7%94%D7%A8%D7%91%D7%99_%D7%A9%D7%9C%D7%99%D7%98%D7%90_%D7%A2%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg/150px-%D7%94%D7%A8%D7%91%D7%99_%D7%A9%D7%9C%D7%99%D7%98%D7%90_%D7%A2%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg\" decoding=\"async\" width=\"150\" height=\"113\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/%D7%94%D7%A8%D7%91%D7%99_%D7%A9%D7%9C%D7%99%D7%98%D7%90_%D7%A2%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg/225px-%D7%94%D7%A8%D7%91%D7%99_%D7%A9%D7%9C%D7%99%D7%98%D7%90_%D7%A2%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg 1.5x, /images/thumb/1/1e/%D7%94%D7%A8%D7%91%D7%99_%D7%A9%D7%9C%D7%99%D7%98%D7%90_%D7%A2%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg/300px-%D7%94%D7%A8%D7%91%D7%99_%D7%A9%D7%9C%D7%99%D7%98%D7%90_%D7%A2%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8.jpg 2x\" /></a><figcaption><a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> מעניק דולרים לשליחות מצוה בידי הרב יצחק דוד גרונר</figcaption></figure>\n<p>הרב <b>יצחק דוד גרונר</b> (<a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ד בניסן\">כ\"ד בניסן</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%94\" title=\"תרפ&quot;ה\">תרפ\"ה</a> - <a href=\"/index.php/%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ד&#39; בתמוז\">ד' בתמוז</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a>) היה <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"שלוחי הרבי\">שליח הרבי</a> ב<a href=\"/index.php/%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F\" title=\"מלבורן\">מלבורן</a> שב<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a> רב קהילת חב\"ד ומייסד מוסדות חב\"ד המקומיים. בנוסף, נודע כ<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9E%D7%95%D7%A2%D7%94\" title=\"בעל שמועה\">בעל שמועה</a> והעביר במסורה הרבה מסיפורי החסידים ומהנהגות רבותינו נשיאינו.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"כ&quot;ד בניסן\">כ\"ד בניסן</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%94\" title=\"תרפ&quot;ה\">תרפ\"ה</a> בברוקלין, <a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ניו יורק\">ניו יורק</a>, לאביו הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" class=\"mw-redirect\" title=\"אברהם ישעיה גרונר\">אברהם ישעיה גרונר</a> ולאימו הרבנית <a href=\"/index.php/%D7%9E%D7%A0%D7%95%D7%97%D7%94_%D7%A8%D7%97%D7%9C_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" title=\"מנוחה רחל גרונר\">מנוחה רחל</a> שהייתה מצאצאי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%9E%D7%A0%D7%95%D7%97%D7%94_%D7%A8%D7%97%D7%9C\" class=\"mw-redirect\" title=\"הרבנית מנוחה רחל\">הרבנית מנוחה רחל</a>. היה חבר ב<a href=\"/index.php/%D7%9E%D7%A9%D7%9C%D7%97%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%92%27%D7%95%D7%99%D7%A0%D7%98\" class=\"mw-redirect\" title=\"משלחת חב&quot;ד בג&#39;וינט\">משלחת חב\"ד בג'וינט</a>.\n</p><p>ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כ\"ח בסיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> נכנס ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" title=\"תומכי תמימים המרכזית 770\">תומכי תמימים המרכזית 770</a>.\n</p><p>ב<a href=\"/index.php/%D7%96%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ז&#39; באלול\">ז' באלול</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> נשא את דבורה בתו של הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%91%D7%99_%D7%A7%D7%95%D7%A0%D7%99%D7%A7%D7%95%D7%91\" title=\"חיים צבי קוניקוב\">חיים צבי קוניקוב</a>, וזכה שהרבי יהיה <a href=\"/index.php/%D7%9E%D7%A1%D7%93%D7%A8_%D7%A7%D7%99%D7%93%D7%95%D7%A9%D7%99%D7%9F\" title=\"מסדר קידושין\">מסדר קידושין</a> בחתונתו.\n</p><p>ב<a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> מונה לראש ישיבת <a href=\"/index.php/%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%95%D7%98%D7%A9%D7%A1%D7%98%D7%A8\" title=\"אחי תמימים רוטשסטר\">אחי תמימים רוטשסטר</a> וב<a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ג במנחם אב\">כ\"ג במנחם אב</a> שנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%94\" title=\"תש&quot;ה\">תש\"ה</a>, עם היווסדה של ישיבת <a href=\"/index.php/%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%A8%D7%90%D7%95%D7%95%D7%99%D7%93%D7%A0%D7%A1\" title=\"אחי תמימים פראווידנס\">אחי תמימים פראווידנס</a> הוא התמנה לראש הישיבה שם.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> נשלח כשד\"ר ל<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a>.\n</p><p>בהמשך, עד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%96\" title=\"תשי&quot;ז\">תשי\"ז</a> עמד בראש קהילה ב<a href=\"/index.php/%D7%A9%D7%99%D7%A7%D7%92%D7%95\" title=\"שיקגו\">שיקגו</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, ובשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%97\" title=\"תשי&quot;ח\">תשי\"ח</a> נשלח על ידי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ל<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a> והקים שם מעצמה של מוסדות ופעילות.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> חתם על פסק הקובע שהתקיימו אצל הרבי כל סימני ה<a href=\"/index.php/%D7%A8%D7%9E%D7%91%22%D7%9D\" title=\"רמב&quot;ם\">רמב\"ם</a> והוא \"בחזקת משיח\" ולכן מברכים אותו בברכת \"<a href=\"/index.php/%D7%99%D7%97%D7%99_%D7%94%D7%9E%D7%9C%D7%9A\" title=\"יחי המלך\">יחי המלך</a>\".\n</p><p>בשנותיו האחרונות סבל ממספר מחלות קשות ואת מקומו מילא חתנו הרב <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%98%D7%9C%D7%96%D7%A0%D7%A8\" title=\"צבי טלזנר\">צבי טלזנר</a>.\n</p><p>נפטר ב<a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%A9%D7%A0%D7%99\" class=\"mw-redirect\" title=\"יום שני\">יום שני</a> <a href=\"/index.php/%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ד&#39; בתמוז\">ד' בתמוז</a> שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> בבוקר, בהיותו בן שמונים ושתיים. מנוחתו כבוד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.\n</p><p>רעייתו האריכה ימים ונפטרה בגיל 92 בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> הוציא חיים מהלמן ספר על תולדות חייו בשם \"larger than life\".\n</p><p>חלק מבניו ובנותיו ממשיכים בשליחות בתפקידים חשובים במלבורן. \n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, מזכירו האישי של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" title=\"יהודה לייב גרונר\">יהודה לייב גרונר</a></li>\n<li>אחיו, הת' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" title=\"משה גרונר\">משה גרונר</a></li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלום דובער גרונר (הדף אינו קיים)\">שלום דובער גרונר</a>, רב ומשפיע קהילת חב\"ד ב<a href=\"/index.php/%D7%99%D7%95%D7%94%D7%A0%D7%A1%D7%91%D7%95%D7%A8%D7%92\" title=\"יוהנסבורג\">יוהנסבורג</a>, דרום אפריקה</li>\n<li>בנו, הרב יוסף גרונר, שליח בשכונת בנטלי, <a href=\"/index.php/%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F\" title=\"מלבורן\">מלבורן</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>בנו, הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%91%D7%99_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" title=\"חיים צבי גרונר\">חיים צבי גרונר</a>, ממלא מקומו בשליחות הרבי לאוסטרליה, רב מוסדות חב\"ד המרכזיים ורב בית הכנסת אוהל דבורה במלבורן</li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%A8%D7%95%D7%A0%D7%A8_(%D7%9E%D7%9C%D7%91%D7%95%D7%A8%D7%9F)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל גרונר (מלבורן) (הדף אינו קיים)\">מנחם מענדל גרונר</a>, שליח בשכונת גלן-איירה, מלבורן</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%98%D7%9C%D7%96%D7%A0%D7%A8\" class=\"mw-redirect\" title=\"צבי הירש טלזנר\">צבי הירש טלזנר</a>, ממלא מקומו ברבנות הקהילה במלבורן, דיין ומו\"צ</li>\n<li>חתנו, הרב דוד האלער, שליח ב<a href=\"/index.php/%D7%99%D7%95%D7%94%D7%A0%D7%A1%D7%91%D7%95%D7%A8%D7%92\" title=\"יוהנסבורג\">יוהנסבורג</a>, דרום אפריקה</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A6%D7%99%D7%A8%D7%A7%D7%99%D7%A0%D7%93\" title=\"יצחק צירקינד\">יצחק צירקינד</a> - רב, מו\"צ ומחנך ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a></li>\n<li>חתנו, הרב שמשון יורקוביץ' - שליח בשכונת מלוורן, מלבורן</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%91%D7%A8%D7%92%D7%A8\" title=\"שניאור זלמן ברגר\">שניאור זלמן ברגר</a>, <b>מחולל המהפכה בכח המשלח</b>, גליון 657 עמוד 26. <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span></li>\n<li>מנחם כהנא \"חסיד, שליח ומנהיג שחולל מהפכה\", גיליון 1466 עמ' 28. ובגיליון 1467 עמ' 34. <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://www.teshura.com/teshurapdf/Zirkind-Wolf%20-%20Menachem%20Av%2028%2C%205775.pdf\">לקט סיפורים שנכתבו מפיו</a></b>, בתוך תשורה מנישואיו צאצאיו, מנחם אב <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/images/4/4e/תשורה_צירקיינד_פריינד.pdf\">מכתבים ומענות שקיבל מהרבי</a></b>, בתוך תשורה מנישואי צירקינד-פריינד, <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://he.chabad.org/multimedia/media_cdo/aid/1161460\">הפאראד של אדמו\"ר הזקן</a></b> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D