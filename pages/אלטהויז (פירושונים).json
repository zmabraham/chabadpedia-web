    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<p><b>אישים</b>:\n</p>\n<ul><li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%91%D7%A6%D7%9C%D7%90%D7%9C_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96\" class=\"mw-redirect\" title=\"שמואל בצלאל אלטהויז\">שמואל בצלאל אלטהויז</a> - <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%9E%D7%A0%D7%92%D7%9F\" title=\"בעל מנגן\">בעל מנגן</a> חסידי, <a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a> (יליד <a href=\"/index.php/%D7%A0%D7%99%D7%A7%D7%95%D7%9C%D7%99%D7%99%D7%91\" title=\"ניקולייב\">ניקולייב</a>)</li>\n<li><a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%98%D7%95%D7%93%D7%A8%D7%95%D7%A1_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96\" title=\"פנחס טודרוס אלטהויז\">פנחס טודרוס אלטהויז</a> - עסקן חב\"די ומראשי <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"אגודת חסידי חב&quot;ד בארץ הקודש\">אגודת חסידי חב\"ד בארץ הקודש</a></li>\n<li>רבי <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96\" title=\"בנימין אלטהויז\">בנימין אלטהויז</a> מניקולייב - בעל מנגן</li>\n<li>רבי <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96\" title=\"אליהו חיים אלטהויז\">אליהו חיים אלטהויז</a> - בעל מנגן</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%96%D7%9C%D7%99%D7%92_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96\" class=\"mw-redirect mw-disambig\" title=\"חיים זליג אלטהויז\">חיים זליג אלטהויז</a> - מראשוני המתיישבים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a></li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%A9%D7%94_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96_(%D7%A0%D7%99%D7%A7%D7%95%D7%9C%D7%99%D7%99%D7%91)\" title=\"מנשה אלטהויז (ניקולייב)\">מנשה אלטהויז</a> - מחסידי חב\"ד ב<a href=\"/index.php/%D7%A0%D7%99%D7%A7%D7%95%D7%9C%D7%99%D7%99%D7%91\" title=\"ניקולייב\">ניקולייב</a></li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%A9%D7%94_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%98%D7%91%D7%A2%D7%95%D7%9F)\" title=\"מנשה אלטהויז (קריית טבעון)\">מנשה אלטהויז</a> - משלוחי הרבי ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%98%D7%91%D7%A2%D7%95%D7%9F\" title=\"קריית טבעון\">קריית טבעון</a></li>\n<li>הרב <a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96_(%D7%97%D7%95%D7%9C%D7%95%D7%9F)\" class=\"mw-redirect\" title=\"פנחס אלטהויז (חולון)\">פנחס טודרוס אלטהויז</a> - משלוחי הרבי ב<a href=\"/index.php/%D7%97%D7%95%D7%9C%D7%95%D7%9F\" title=\"חולון\">חולון</a> ורב שכונה בעיר</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%96%D7%9C%D7%99%D7%92_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96_(%D7%9C%D7%95%D7%93)\" class=\"mw-redirect\" title=\"חיים זליג אלטהויז (לוד)\">חיים זליג אלטהויז</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a></li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%96%D7%A2%D7%9C%D7%99%D7%92_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96_(%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8)\" title=\"חיים זעליג אלטהויז (דנייפר)\">חיים זעליג אלטהויז (דנייפר)</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת תומכי תמימים <a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8\" class=\"mw-redirect\" title=\"דנייפר\">דנייפר</a>.</li></ul>\n<p><b>ניגון:</b>\n</p>\n<ul><li><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%9C%D7%A8%27_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96_%D7%9E%D7%A0%D7%99%D7%A7%D7%95%D7%9C%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"ניגון לר&#39; אליהו חיים אלטהויז מניקולייב\">ניגון לר' אליהו חיים אלטהויז מניקולייב</a></li>\n<li><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%9C%D7%A8%27_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96_%D7%9E%D7%A0%D7%99%D7%A7%D7%95%D7%9C%D7%99%D7%99%D7%91\" title=\"ניגון לר&#39; בנימין אלטהויז מניקולייב\">ניגון לר' בנימין אלטהויז מניקולייב</a></li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/