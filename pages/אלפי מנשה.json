gn: right; font-weight: bold; padding-left: 5px;\"><a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית (הדף אינו קיים)\">מועצות אזוריות</a>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%92%D7%95%D7%A9_%D7%A2%D7%A6%D7%99%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית גוש עציון (הדף אינו קיים)\">גוש עציון</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%D7%A8%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית הר חברון (הדף אינו קיים)\">הר חברון</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%95%D7%AA_%D7%99%D7%9D_%D7%94%D7%9E%D7%9C%D7%97&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית מגילות ים המלח (הדף אינו קיים)\">מגילות</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%9E%D7%98%D7%94_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית מטה בנימין (הדף אינו קיים)\">מטה בנימין</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%A2%D7%A8%D7%91%D7%95%D7%AA_%D7%94%D7%99%D7%A8%D7%93%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית ערבות הירדן (הדף אינו קיים)\">ערבות הירדן</a> • <a href=\"/index.php?title=%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%A9%D7%95%D7%9E%D7%A8%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מועצה אזורית שומרון (הדף אינו קיים)\">שומרון</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</tbody></