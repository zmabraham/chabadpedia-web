bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ב בתשרי\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ג בתשרי\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ד בתשרי\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ה בתשרי\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ו בתשרי\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ז בתשרי\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ח בתשרי\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ט בתשרי\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ל&#39; בתשרי\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ג&#39; בתשרי</b> הוא היום השלישי\nבחודש הראשון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;והיום השלישי ב<a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%AA_%D7%99%D7%9E%D7%99_%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"עשרת ימי תשובה\">עשרת ימי תשובה</a>. יום זה הוא יום <a href=\"/index.php/%D7%AA%D7%A2%D7%A0%D7%99%D7%AA\" title=\"תענית\">תענית</a> הנקרא <a href=\"/index.php/%D7%A6%D7%95%D7%9D_%D7%92%D7%93%D7%9C%D7%99%D7%94\" title=\"צום גדליה\">צום גדליה</a>.\n</p><p>תאריך זה חל בתקופת תשרי&#160;והוא יכול לחול בימים&#160;שני, רביעי, חמישי ושבת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>א' (-3760 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%9E%D7%95%D7%A6%D7%90%D7%99_%D7%94%D7%A9%D7%91%D7%AA\" class=\"mw-redirect\" title=\"מוצאי השבת\">מוצאי השבת</a> הראשונה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. <a href=\"/index.php/%D7%90%D7%93%D7%9D_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" title=\"אדם הראשון\">אדם הראשון</a> לקח שני <a href=\"/index.php/%D7%90%D7%91%D7%9F\" title=\"אבן\">אבנים</a> והוציא מהם <a href=\"/index.php/%D7%90%D7%A9\" class=\"mw-redirect\" title=\"אש\">אש</a> ולזכר זה מברכים \"בורא מאורי האש\" ב<a href=\"/index.php/%D7%94%D7%91%D7%93%D7%9C%D7%94\" title=\"הבדלה\">הבדלה</a> בכל <a href=\"/index.php/%D7%9E%D7%95%D7%A6%D7%90%D7%99_%D7%A9%D7%91%D7%AA\" title=\"מוצאי שבת\">מוצאי שבת</a>.</li>\n<li>לפי חלק מהדעות<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup> בג'של\"ט (-422 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php?title=%D7%92%D7%93%D7%9C%D7%99%D7%94%D7%95_%D7%91%D7%9F_%D7%90%D7%97%D7%99%D7%A7%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"גדליהו בן אחיקם (הדף אינו קיים)\">גדליהו בן אחיקם</a>, מנהיג שארית הפליטה ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a>, נרצח.</li>\n<li>ה'<a href=\"/index.php?title=%D7%AA%D7%9E%22%D7%92&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"תמ&quot;ג (הדף אינו קיים)\">תמ\"ג</a> (05/10/1682 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%91%D7%9C%D7%99_%D7%92%D7%95%D7%9E%D7%91%D7%99%D7%A0%D7%A8\" title=\"אברהם אבלי גומבינר\">אברהם אבלי גומבינר</a>, ה'מגן אברהם' מקאליש, מחבר ספר 'מגן אברהם', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%96\" title=\"תקנ&quot;ז\">תקנ\"ז</a> (05/10/1796 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%A8%D7%95%D7%96%27%D7%99%D7%9F\" title=\"ישראל מרוז&#39;ין\">ישראל מרוז'ין</a>, מייסד <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A8%D7%95%D7%96%27%D7%99%D7%9F\" title=\"חסידות רוז&#39;ין\">חסידות רוז'ין</a> ו<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"רה</a> הראשון, נולד.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%96\" title=\"תרמ&quot;ז\">תרמ\"ז</a> (02/10/1886 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%91%D7%99%D7%93%D7%A8%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יצחק דוד בידרמן (הדף אינו קיים)\">יצחק דוד בידרמן</a> מ<a href=\"/index.php/%D7%9C%D7%A2%D7%9C%D7%95%D7%91\" class=\"mw-redirect\" title=\"לעלוב\">לעלוב</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%97\" title=\"תרפ&quot;ח\">תרפ\"ח</a> - הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99_%D7%9C%D7%93%D7%99%D7%95%D7%91\" title=\"יצחק חי לדיוב\">יצחק חי לדיוב</a> - מאנשי המחתרת היהודית בקהילת חב\"ד ב<a href=\"/index.php/%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"סמרקנד\">סמרקנד</a>, ולאחר עלייתו <a href=\"/index.php?title=%D7%90%D7%A8%D7%A6%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ארצה (הדף אינו קיים)\">ארצה</a> היה מעסקני הקהילה הבוכרית ותושב קהילת חב\"ד ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> (05/10/1940 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%A7%D7%A4%D7%9C%D7%9F\" title=\"נחום קפלן\">נחום קפלן</a>, משפיע בקהילת חב\"ד ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%92\" title=\"תקנ&quot;ג\">תקנ\"ג</a> (19/09/1792 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - מרת <a href=\"/index.php/%D7%93%D7%91%D7%95%D7%A8%D7%94_%D7%9C%D7%90%D7%94_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" title=\"דבורה לאה (בת אדמו&quot;ר הזקן)\">דבורה לאה</a> בת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> (24/09/1941 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%93%D7%91%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"אליעזר דבוסקין\">אליעזר דבוסקין</a>, כיהן כרב ו<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש ישיבה</a> בעיר <a href=\"/index.php/%D7%97%D7%A8%D7%A1%D7%95%D7%9F\" title=\"חרסון\">חרסון</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%93%22%D7%9E\" title=\"תשד&quot;מ\">תשד\"מ</a> (10/09/1983 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%98%D7%A8%D7%91%D7%A0%D7%99%D7%A7\" title=\"נחום טרבניק\">נחום טרבניק</a>, רבו של <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> במשך כעשר שנים.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> (20/09/2001 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%A0%D7%95%D7%98%D7%99%D7%A7\" class=\"mw-redirect\" title=\"שלום דובער נוטיק\">שלום דובער נוטיק</a>, <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9E%D7%95%D7%A2%D7%94\" title=\"בעל שמועה\">בעל שמועה</a> חסידי.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> (21/0912020 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%95%D7%9D\" title=\"אפרים רוזנבלום\">אפרים רוזנבלום</a>, משלוחי הרבי ב<a href=\"/index.php/%D7%A4%D7%99%D7%98%D7%A1%D7%91%D7%95%D7%A8%D7%92\" title=\"פיטסבורג\">פיטסבורג</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ג' בתשרי - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>מתחילין \"מזמור לדוד\" ולא \"לכו נרננה\", וכן בכל <a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבת</a> מוצאי <a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91\" title=\"יום טוב\">יום טוב</a>. הפטורה: שובה יכשלו בם. מי אל כמוך מימי קדם.</i>\n<p>ב<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a> אצל <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">רבינו הזקן</a> ב' תצא ב<a href=\"/index.php/%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ו&#39; באלול\">שישי באלול</a> <a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%93\" title=\"תקס&quot;ד\">תקס\"ד</a> סיפר לו רבינו: שבת <a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%AA%D7%91%D7%95%D7%90\" class=\"mw-redirect\" title=\"פרשת תבוא\">פרשת תבוא</a> <a href=\"/index.php/%D7%AA%D7%A7%D7%9B%22%D7%97\" title=\"תקכ&quot;ח\">תקכ\"ח</a> אמר <a href=\"/index.php/%D7%94%D7%9E%D7%92%D7%99%D7%93_%D7%9E%D7%9E%D7%A2%D7%96%D7%A8%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"המגיד ממעזריטש\">מורי ורבי</a> <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>, והתחלתה: \"ושבת עד <a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"הוי&quot;ה\">הוי\"ה</a> <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%9A\" class=\"mw-redirect\" title=\"אלוקיך\">אלוקיך</a>\", וביאר כי עבודת ה<a href=\"/index.php/%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"תשובה\">תשובה</a> צריכה להיות עד אשר '<a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"הוי&quot;ה\">הוי\"ה</a>', שהוא למעלה מהעולמות, יהיה 'אלוקיך', <a href=\"/index.php/%D7%90%D7%9C%D7%94%D7%99%22%D7%9D\" class=\"mw-redirect\" title=\"אלהי&quot;ם\">אלוקים</a> ב<a href=\"/index.php/%D7%92%D7%9E%D7%98%D7%A8%D7%99%D7%90\" class=\"mw-redirect\" title=\"גמטריא\">גמטריא</a> ה<a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"טבע\">טבע</a>, \"בראשית ברא אלקים\".\n</p><p>כל ה<a href=\"/index.php/%D7%97%D7%91%D7%A8%D7%99%D7%90_%D7%A7%D7%93%D7%99%D7%A9%D7%90\" class=\"mw-redirect\" title=\"חבריא קדישא\">חבריא קדישא</a> היו בהתעוררות גדולה מתורה ההיא. הרב הצדיק <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9E%D7%A9%D7%95%D7%9C%D7%9D_%D7%96%D7%95%D7%A1%D7%99%D7%90_%D7%9E%D7%90%D7%A0%D7%99%D7%A4%D7%95%D7%9C%D7%99\" class=\"mw-redirect\" title=\"רבי משולם זוסיא מאניפולי\">רבי משולם זוסיא מאניפולי</a> אמר, כי הוא אינו יכול להגיע למעלת <a href=\"/index.php/%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"תשובה\">תשובה</a> כזו, ועל כן יחלק את התשובה לחלקים, כי תשובה - ראשי תיבות:\n</p><p><b>ת</b>, \"תמים תהיה עם הוי\"ה אלוקיך\". <b>ש</b>, \"שויתי הוי\"ה לנגדי תמיד\". <b>ו</b>, \"<a href=\"/index.php/%D7%95%D7%90%D7%94%D7%91%D7%AA_%D7%9C%D7%A8%D7%A2%D7%9A_%D7%9B%D7%9E%D7%95%D7%9A\" class=\"mw-redirect\" title=\"ואהבת לרעך כמוך\">ואהבת לרעך כמוך</a>\". <b>ב</b>, \"<a href=\"/index.php/%D7%91%D7%9B%D7%9C_%D7%93%D7%A8%D7%9B%D7%99%D7%9A_%D7%93%D7%A2%D7%94%D7%95\" title=\"בכל דרכיך דעהו\">בכל דרכיך דעהו</a>\". <b>ה</b>, \"הצנע לכת עם אלוקיך\".\n</p><p>כשסיפר לי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> את הנזכר לעיל, סיים: תיבת <a href=\"/index.php/%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"תשובה\">תשובה</a> צרופה מחמש <a href=\"/index.php/%D7%90%D7%95%D7%AA%D7%99%D7%95%D7%AA_%D7%94%D7%90%D7%9C%22%D7%A3_%D7%91%D7%99%22%D7%AA\" title=\"אותיות האל&quot;ף בי&quot;ת\">אותיות</a>, אשר כל אות הוא דרך ואופן בעבודת התשובה, וביאר באריכות חמשה האופנים וכולם באים מכוח אל הפועל על ידי <a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%94\" title=\"עבודה\">עבודת</a> ה<a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%94\" title=\"תפילה\">תפילה</a>.\n</p>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השביעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">לדעת <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8\" class=\"mw-redirect\" title=\"רבי אליעזר\">רבי אליעזר</a></span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">הרמב\"ם, סדר עולם ועוד</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413082821\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.119 seconds\nReal time usage: 0.666 seconds\nPreprocessor visited node count: 483/1000000\nPost‐expand include size: 11927/2097152 bytes\nTemplate argument size: 1078/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 8/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 1096/5000000 bytes\nLua time usage: 0.080/7 seconds\nLua virtual size: 6180864/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  604.322      1 -total\n 53.16%  321.232      1 תבנית:פתיח_יום\n 32.89%  198.755      1 תבנית:פירוש_נוסף\n 20.72%  125.217      2 תבנית:הערה\n 15.15%   91.537      5 תבנית:מילה_אחרונה\n 10.80%   65.239      2 תבנית:מילה_ראשונה\n  5.10%   30