7%9E%D7%A1%D7%AA%D7%A8%D7%99%D7%9D.jpg/148px-%D7%90%D7%9C%D7%91%D7%95%D7%9D_%D7%91%D7%9E%D7%A1%D7%AA%D7%A8%D7%99%D7%9D.jpg 2x\" /></a></span></div>\n\t\t\t<div class=\"gallerytext\">'<b>במסתרים'</b><br />אלבום כרומו צבעוני המלקט פתגמים מהגותו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a></div>\n\t\t</li>\n</ul>\n</td></tr></tbody></table>\n<h3><span id=\".D7.91.D7.98.D7.90.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"בטאון\">בטאון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;בטאון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: בטאון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%91%D7%98%D7%90%D7%95%D7%9F_%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f0/%D7%91%D7%98%D7%90%D7%95%D7%9F_%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94.jpg/200px-%D7%91%D7%98%D7%90%D7%95%D7%9F_%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94.jpg\" decoding=\"async\" width=\"200\" height=\"206\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f0/%D7%91%D7%98%D7%90%D7%95%D7%9F_%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94.jpg/300px-%D7%91%D7%98%D7%90%D7%95%D7%9F_%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94.jpg 1.5x, /images/thumb/f/f0/%D7%91%D7%98%D7%90%D7%95%D7%9F_%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94.jpg/400px-%D7%91%D7%98%D7%90%D7%95%D7%9F_%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94.jpg 2x\" /></a><figcaption>הגליון הראשון - י\"א ניסן תשע\"ה</figcaption></figure>\n<p>לקראת <a href=\"/index.php/%D7%99%22%D7%90_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"י&quot;א ניסן\">י\"א ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> החל לצאת לאור מטעם 'אשכילה' כתב-עת מיוחד לחסידות, אשר מבוקשו: \"לשמש כלי להנחלת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a> החב\"דית, וליטול חלק במשימת דורנו - <a href=\"/index.php/%D7%94%D7%A4%D7%A6%D7%AA_%D7%94%D7%9E%D7%A2%D7%99%D7%99%D7%A0%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הפצת המעיינות\">הפצת המעיינות</a> חוצה - בין שדרות כל המפלגות\"<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. הגליון נושא את שמו של בית ההוצאה לאור, והוא מודפס על דף כרומו צבעוני.\n</p><p><b>מדורי הגליון</b>:\n</p>\n<ul><li><b>מחשבת החסידות</b> - ביאור מושגים בתורת החסידות, מאת הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%9C%D7%93%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"מנחם מענדל פלדמן\">מנחם מענדל פלדמן</a>.</li>\n<li><b>נפלאות ב'היום יום'</b> - מדור המתמקד בפתגמים מלוח '<a href=\"/index.php/%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" class=\"mw-redirect\" title=\"היום יום\">היום יום</a>' ומאיר בהם נקודות מיוחדות, מאת הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"משה אורנשטיין\">משה אורנשטיין</a>.</li>\n<li><b>לדמותם של אישים</b> - קווים לדמותם של גדולי החסידים מדורות עברו.</li>\n<li>'<b>היום יום' מאוייר</b> - אמנים ויוצרים מבטאים רעיונות מתוך לוח <a href=\"/index.php/%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" class=\"mw-redirect\" title=\"היום יום\">היום יום</a> באמצעות ציורים ואיורים על פי תפיסת עולמם.</li>\n<li><b>פרוזה</b> - קטעי ספרות מאת זאב גינוסר (הרב שמעיה הכט).</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.AA.D7.AA.D7.A4.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"משתתפים\">משתתפים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;משתתפים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: משתתפים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"משה אורנשטיין\">משה אורנשטיין</a> - ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים נתניה</a> (שם עט: ארי סמית).</li>\n<li>הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%95%D7%A4%D7%99%D7%9F\" title=\"זלמן גופין\">זלמן גופין</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.</li>\n<li>הרב מנחם מענדל פלדמן - משלוחי הרבי ב<a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8%D7%95%D7%A4%D7%98%D7%A8%D7%95%D7%91%D7%A1%D7%A7\" class=\"mw-redirect\" title=\"דנייפרופטרובסק\">דנייפרופטרובסק</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ישראל אלפנביין\">ישראל אלפנביין</a> - מלפנים <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים נתניה</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A1%D7%99%D7%A0%D7%92%D7%90%D7%95%D7%95%D7%99\" title=\"יעקב סינגאווי\">יעקב סינגאווי</a> - מרבני קהילת חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"קריית גת\">קריית גת</a> וחבר צוות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" class=\"mw-redirect mw-disambig\" title=\"תומכי תמימים קריית גת\">ישיבת תות\"ל המקומית</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F\" title=\"יהודה לייב נחמנסון\">יהודה לייב נחמנסון</a> - מרבני קהילת חב\"ד ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%94%D7%9B%D7%98\" class=\"mw-redirect\" title=\"שניאור זלמן הכט\">שניאור זלמן הכט</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a> ומשלוחי הרבי בעיר.</li>\n<li>הרב חיים לוריא - משלוחי הרבי באוקראינה.</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%99%D7%94_%D7%94%D7%9B%D7%98\" title=\"שמעיה הכט\">שמעיה הכט</a> - לשעבר <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים נתניה</a> וכיום מראשי מערכת הכשרות של הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%9C%D7%A0%D7%93%D7%90\" class=\"mw-redirect\" title=\"יצחק אייזיק לנדא\">לנדא</a> (שם עט: זאב גינוסר).</li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A9%D7%95%D7%95%D7%99%D7%9B%D7%94\" title=\"אליהו שוויכה\">אליהו שוויכה</a> - משלוחי הרבי ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A0%D7%97%D7%9E%D7%9F_%D7%9C%D7%A8%D7%A0%D7%A8\" title=\"ישראל נחמן לרנר\">ישראל נחמן לרנר</a> - ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" class=\"mw-redirect\" title=\"תומכי תמימים בית שמש (גדולה)\">תומכי תמימים בית שמש (גדולה)</a> (שם עט: ישראל אלתר).</li>\n<li>הרב מנחם שניאור מיודובניק - משיב ונו\"נ בישיבת <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד ליובאוויטש צפת (קטנה)\">חסידים חב\"ד ליובאוויטש צפת</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%90%D7%95%D7%9C%D7%99%D7%93%D7%95%D7%A8%D7%98\" class=\"mw-redirect\" title=\"דוד אולידורט\">דוד אולידורט</a> - חבר הנהלת <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a> המרכזי.</li>\n<li>ר' בנימין וילהלם - צפת.</li>\n<li>ר' מנחם מענדל וולף - נתניה (שם עט: מנחם זאבי).</li>\n<li>ר' שלום דב בער סינגאווי (שם עט: דב סיני).</li></ul>\n<h2><span id=\".D7.97.D7.96.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"חזון\">חזון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;חזון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: חזון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בכריכת הספר הראשון שיצא לאור על ידם, תמצתו ההוגים את משנתם הרעיונית בשתי פסקאות קצרות:\n</p>\n<blockquote dir=\"rtl\"><div class=\"hebrewQuotation HeQuotationMark\">\n<p>בית הוצאה לאור 'אשכילה', נוסד בשנת 2010 בידי סופרים ויוצרים בתל אביב אשר שמו רוחם ולבם לעסוק ביצירה מקורית ברוחה של <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חסידות חב\"ד</a> ובהשראת משנתו של הרבי מלובביץ', ולהוליד ספרות חדשה בתחום <a href=\"/index.php/%D7%94%D7%A7%D7%91%D7%9C%D7%94\" class=\"mw-redirect\" title=\"הקבלה\">הקבלה</a> והחסידות.\nהורתה ולידתה של במה ספרותית זו, באה לאור קריאתו של הרבי מלובביץ', כי העיון והעיסוק ב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a> מחיש פעמי משיח וממהר את בוא הגאולה.\n</p>\n</div>\n </blockquote>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94_(%D7%91%D7%99%D7%AA_%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8)&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%94%D7%A8%D7%A8%D7%99\" title=\"יחיאל הררי\">ד\"ר יחיאל הררי</a>, <a rel=\"nofollow\" class=\"external text\" href=\"http://hitbonenut.net/archives/5360\">מאמר השוואה בין ספר 'איש האמונה' בהוצאת 'אשכילה', לספרו של הרב סולובייצ'יק</a></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/index.php?url=article_he&amp;id=64678\">כתבה בחב\"ד אינפו - 'סודם של חסידים'</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://chabad.info/magazine/%D7%94%D7%A6%D7%A6%D7%94-%D7%A8%D7%90%D7%A9%D7%95%D7%A0%D7%99%D7%AA-%D7%9C%D7%9B%D7%AA%D7%91-%D7%94%D7%A2%D7%AA-%D7%90%D7%A9%D7%9B%D7%99%D7%9C%D7%94/\">הצצה ראשונית לכתב העת אשכילה</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span> י\"א ניסן תשע\"ה</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">יש לציין כי בשוק הספרים כבר קיים ספר בעל אותו שם, של הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%93%D7%95%D7%91_%D7%A1%D7%95%D7%9C%D7%95%D7%91%D7%99%D7%99%D7%A6%27%D7%99%D7%A7\" title=\"יוסף דוב סולובייצ&#39;יק\">יוסף דוב סולובייצ'יק</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ציטוט מתוך דבר העורך בגליון הראשון של כתב-העת.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413215004\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.137 seconds\nReal time usage: 0.885 seconds\nPreprocessor visited node count: 296/1000000\nPost‐expand include size: 3817/2097152 bytes\nTemplate argument size: 1076/2097152 bytes\nHighest expansion depth: 8/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 7255/5000000 bytes\nLua time usage: 0.050/7 seconds\nLua virtual size: 5746688/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  738.992      1 -total\n 48.53%  358.646      1 תבנית:פירוש_נוסף\n 24.28%  179.421      2 תבנית:הערה\n 14.