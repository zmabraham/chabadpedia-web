    "pageid": 62146,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%9C%D7%A3.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/d9/%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%9C%D7%A3.jpeg/250px-%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%9C%D7%A3.jpeg\" decoding=\"async\" width=\"250\" height=\"170\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d9/%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%9C%D7%A3.jpeg/375px-%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%9C%D7%A3.jpeg 1.5x, /images/thumb/d/d9/%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%9C%D7%A3.jpeg/500px-%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%95%D7%9C%D7%A3.jpeg 2x\" /></a><figcaption>הרב יוסף יצחק וולף עם נשיא אוקראינה היהודי מר וולדימיר זלנסקי</figcaption></figure>\n<p>הרב <b>יוסף יצחק וולף</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"תשל&quot;ב\">תשל\"ב</a>, 1972) הוא <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ורב העיר <a href=\"/index.php/%D7%97%D7%A8%D7%A1%D7%95%D7%9F\" title=\"חרסון\">חרסון</a> שב<a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%96_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"כ&quot;ז טבת\">כ\"ז טבת</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"תשל&quot;ב\">תשל\"ב</a> לר' <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%95%D7%95%D7%9C%D7%A3\" title=\"שלום דובער וולף\">שלום דובער וולף</a> ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a> שב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" title=\"קריית מלאכי\">קריית מלאכי</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> נסע לשנת ה<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a> אצל הרבי ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, ובשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a> יצא לשליחות לעיר <a href=\"/index.php/%D7%97%D7%A8%D7%A1%D7%95%D7%9F\" title=\"חרסון\">חרסון</a> שב<a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a> ו<a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9D\" class=\"mw-redirect\" title=\"נישואים\">נישא</a> לחיה בת ר' <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F_%D7%99%D7%95%D7%A1%D7%A4%D7%99%D7%9F\" title=\"ניסן יוספין\">ניסן יוספין</a>.\n</p><p>ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a> ייסד יחד עם השלוחים ר' <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%95%D7%95%D7%9C%D7%A3\" title=\"אברהם וולף\">אברהם וולף</a> (אחיו) ור' דוד מונדשיין את בית כנסת חב\"ד - אור אנבר ב<a href=\"/index.php/%D7%97%D7%A8%D7%A1%D7%95%D7%9F\" title=\"חרסון\">חרסון</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> החל בתהליכים לפדיית בית הכנסת חב\"ד ההיסטורי שבעיר חרסון<sup><span class=\"clarification-needed\" style=\"cursor: help; font-size: 90%;\" title=\"מדוע הוא היה צריך פדייה?\">[דרושה הבהרה]</span></sup> (שנבנה עוד באזור שנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%95\" title=\"תרנ&quot;ו\">תרנ\"ו</a>), אך הניסיון כשל ובית הכנסת נשאר שומם. בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> החל בתהליכי שיפוץ לבית הכנסת וב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> סיים השיפוץ וציין את המעמד ב<a href=\"/index.php/%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%A1%D7%A4%D7%A8_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"הכנסת ספר תורה\">הכנסת ספר תורה</a> מיוחד. בית כנסת נקרא אור אבנר - חב\"ד על-שם עמותת <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8\" title=\"אור אבנר\">אור אבנר</a> שעזרה בפדיית ובשיקום בית הכנסת<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> יצא אחד מחברי העירייה בחרסון במסע השמצה אנטישמי מכוון כנגד יהודי אוקראינה, בתגובה הרב יוסף יצחק וולף פעל בנושא אצל גורמים בממשלת אוקראינה וחיזק את הקהילה היהודית בחרסון<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">חודש שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> ניצל בנס מפיגוע שהתרחש בשדה התעופה במוסקבה אליו היה אמור להגיע בטיסה מאודסה, ובנס לא עלה בסוף על הטיסה<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> כאשר התרחשו הפגנות באוקראינה שגרמו להדחתו של הנשיא הפרו-רוסי ומינוי נשיא אחר תחתיו פלשה <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a> לחצי-האי קרים וסיפחה אותו, בעיר חרסון הקרובה לקרים המצב היה מתוח מאוד וחוץ מהאנרכיה ששררה ברחובות העיר היה חשש כבד שמא תפרוץ מלחמה, השליח הרב יוסף יצחק וולף חיזק את יהודי העיר והודיע שיישאר בעיר ויחזק את הפעילות היהודית במקום למרות המצב הקשה<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> הודיע הרב וולף על שיפוץ הציון של החסיד ר' <a href=\"/index.php/%D7%94%D7%9C%D7%9C_%D7%9E%D7%A4%D7%90%D7%A8%D7%99%D7%98%D7%A9\" title=\"הלל מפאריטש\">הלל מפאריטש</a> הטמון בעיר חרסון<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>, וב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D-%D7%90%D7%91\" class=\"mw-redirect mw-disambig\" title=\"חודש מנחם-אב\">חודש מנחם-אב</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a> נחנך מתחם הציון החדש במעמד גדול ומרשים<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> התרחש אירוע אנטישמי בסמוך לבית הכנסת חב\"ד בעיר חרסון, בתגובה הגיע נשיא אוקראינה היהודי מר וולדימיר זלנסקי לביקור בבית הכנסת והעריך את פעילות חב\"ד שבראשותו<sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\"><span class=\"cite-bracket\">&#91;</span>9<span class=\"cite-bracket\">&#93;</span></a></sup>, ובהמשך השנה אף קיבל מדליית כבוד ממשלתית על תרומתו למען תושבי העיר.\n</p><p>בחודש <a href=\"/index.php/%D7%90%D7%93%D7%A8_%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" class=\"mw-redirect\" title=\"אדר ראשון\">אדר ראשון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> פלשה <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a> ל<a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a> והמוני אנשים - ביניהם יהודים רבים - החלו להמילט מהמדינה, הרב וולף כמרבית השלוחים במדינה הודיע כי ישאר יחד עם בני קהילתו בסכנה, בהמשך נכבשה העיר חרסון בידי הרוסים והרב וולף עזר ליהודים הנצורים בעיר בכל המצטרך למרות הקושי הרב שבדבר וזכה לשבחים רבים מכל גווני הציבור בארץ ובעולם<sup id=\"cite_ref-10\" class=\"reference\"><a href=\"#cite_note-10\"><span class=\"cite-bracket\">&#91;</span>10<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב מנחם מענדל וולף שליח ב<a href=\"/index.php/%D7%A7%D7%A0%D7%93%D7%94\" title=\"קנדה\">קנדה</a></li>\n<li>בנו, הרב ארי' לייב וולף</li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%95%D7%95%D7%9C%D7%A3_(%D7%A1%D7%90%D7%A4%D7%99%D7%9C%D7%93)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אברהם וולף (סאפילד) (הדף אינו קיים)\">אברהם וולף</a></li>\n<li>בנו, הרב שלום דובער וולף</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li class=\"mw-empty-elt\"></li>\n<li>יצחק הורוויץ,&#160;‏<b><a rel=\"nofollow\" class=\"external text\" href=\"https://www.kcm.co.il/%d7%a0%d7%a1-%d7%9e%d7%a9%d7%9e%d7%99%d7%9d/\">נס משמיים</a></b>, שבועון כפר חב\"ד, גיליון 2120 עמוד 52 (תשפ\"ה) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\"><img src=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/45px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg\" decoding=\"async\" width=\"45\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/68px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 1.5x, /images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/90px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%9C%D7%A3&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/57070\">ב'דינר' חגיגי בחרסון ציינו 18 שנות פעילות חב\"ד ● גלריה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%