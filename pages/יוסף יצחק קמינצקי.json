      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99.png\" class=\"mw-file-description\"><img src=\"/images/thumb/b/bf/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99.png/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99.png\" decoding=\"async\" width=\"220\" height=\"137\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bf/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99.png/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99.png 1.5x, /images/thumb/b/bf/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99.png/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99.png 2x\" /></a><figcaption> הרב קמינצקי מנחה בוידיאו של <a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1_%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"כינוס השלוחים העולמי\">כינוס השלוחים העולמי</a></figcaption></figure>\n<p>הרב <b>יוסף יצחק קמינצקי</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a>, 1951) הוא יו\"ר המועצה הדתית שדות דן, סופר, וחוקר היסטוריה החב\"דית.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> ב<a href=\"/index.php/%D7%9B%22%D7%91_%D7%A1%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"כ&quot;ב סיון\">כ\"ב סיון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a> לאביו ר' <a href=\"/index.php/%D7%A8%D7%90%D7%95%D7%91%D7%9F_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"ראובן קמינצקי\">ראובן קמינצקי</a> ולאימו מרת דובא בת ר' <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%93%D7%A8%D7%99%D7%96%D7%99%D7%9F_(%D7%9E%D7%90%D7%99%D7%95%D7%A8)\" title=\"אברהם דריזין (מאיור)\">אברהם דריזין (מאיור)</a>.\n</p><p>בצעירותו למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> ובהמשך בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>. לקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%22%D7%9C\" title=\"תש&quot;ל\">תש\"ל</a> נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> בחצר הרבי ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a> נמנה על <a href=\"/index.php/%D7%94%D7%AA%D7%9C%D7%9E%D7%99%D7%93%D7%99%D7%9D_%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D\" title=\"התלמידים השלוחים\">התלמידים השלוחים</a> שנשלחו לישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.\n</p><p>בהגיעו לגיל ה<a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9F\" title=\"נישואין\">נישואין</a> התחתן עם מרת בתיה, בת הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%A8%D7%A1%D7%A7%D7%99%D7%9F\" title=\"שלום דובער רסקין\">שלום בער רסקין</a>, וקבע את מגוריו ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p><p>בתחילה עבד כמזכ\"ל <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">רשת אהלי יוסף יצחק</a>, ובמקביל החל לעסוק בחקר ההיסטוריה החב\"דית. מאוחר יותר מונה למנהל ההוצאה לאור של '<a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">הרשת'</a>. במסגרת עבודה זו הוציא לאור עשרות ספרים וחוברות וכן חומר לימודי רב.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> עזב את הרשת והקים הוצאת ספרים בשם \"המעיין החסידי\" במסגרתו כתב ספרים בהיסטוריה החב\"דית, חלק מספריו תורגמו למספר שפות. מחקריו מתמקדים בהיסטוריה הקשורה לערים, ישובים, אתרים ותאריכים בדברי ימי <a href=\"/index.php/%D7%A8%D7%91%D7%95%D7%AA%D7%99%D7%A0%D7%95_%D7%A0%D7%A9%D7%99%D7%90%D7%99%D7%A0%D7%95\" class=\"mw-redirect\" title=\"רבותינו נשיאינו\">רבותינו נשיאינו</a> והחסידים ב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>. פירסם ומפרסם ספרים, סרטים, מאמרים ותגליות בבימות חב\"דיות שונות.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> התמנה ליושב ראש המועצה הדתית שדות דן ובשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> נבחר שוב לתפקיד יושב ראש המועצה<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> וגם ב<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a>.\n</p>\n<h3><span id=\".D7.97.D7.A9.D7.99.D7.A4.D7.95.D7.AA_.D7.94.D7.99.D7.A1.D7.98.D7.95.D7.A8.D7.99.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"חשיפות_היסטוריות\">חשיפות היסטוריות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;חשיפות היסטוריות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: חשיפות היסטוריות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>הרב קמינצקי חשף מקומות היסטוריים-חב\"דיים רבים ברוסיה ואוקראינה.\n</p>\n<ul><li>מקום קבורתו של ר' <a href=\"/index.php/%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%97_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" title=\"דובער שניאורסון (אח אדמו&quot;ר שליט&quot;א)\">דובער שניאורסאהן</a> אחיו של הרבי, ליד דנייפרופטרובסק, פירסם לראשונה ב<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> גיליון 11.</li>\n<li>תיעוד ערים ועיירות בהם שהו אדמו\"רי חב\"ד</li></ul>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.95_.D7.95.D7.94.D7.95.D7.A6.D7.90.D7.95.D7.AA.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ספריו_והוצאותיו\">ספריו והוצאותיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ספריו והוצאותיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ספריו והוצאותיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A7%D7%99%D7%A6%D7%95%D7%A8_%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/d6/%D7%A7%D7%99%D7%A6%D7%95%D7%A8_%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA.jpg/100px-%D7%A7%D7%99%D7%A6%D7%95%D7%A8_%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA.jpg\" decoding=\"async\" width=\"100\" height=\"146\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A7%D7%99%D7%A6%D7%95%D7%A8_%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA.jpg/150px-%D7%A7%D7%99%D7%A6%D7%95%D7%A8_%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA.jpg 1.5x, /images/thumb/d/d6/%D7%A7%D7%99%D7%A6%D7%95%D7%A8_%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA.jpg/200px-%D7%A7%D7%99%D7%A6%D7%95%D7%A8_%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA.jpg 2x\" /></a><figcaption>הספר קיצור תולדות חב\"ד</figcaption></figure>\n<h3><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ספרים\">ספרים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;ספרים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: ספרים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><b><a href=\"/index.php/%D7%99%D7%9E%D7%99_%D7%97%D7%91%22%D7%93_(%D7%A1%D7%A4%D7%A8)\" title=\"ימי חב&quot;ד (ספר)\">ימי חב\"ד</a></b>, <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a>. מהדורה חדשה ומתוקנת יצאה לאור בשנת תשע\"ז.</li>\n<li><b>אנשים חסידים היו</b> - ביוגרפיה על זקניו החסידים ר' <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%9E%D7%A9%D7%94_%D7%94%D7%99%D7%A6%D7%97%D7%A7%D7%99\" title=\"זלמן משה היצחקי\">זלמן משה היצחקי</a> וחתנו ר' <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%93%D7%A8%D7%99%D7%96%D7%99%D7%9F_(%D7%9E%D7%90%D7%99%D7%95%D7%A8)\" title=\"אברהם דריזין (מאיור)\">אברהם דריזין (מאיור)</a>. יצא לאור בהוצאת <a href=\"/index.php?title=%D7%94%D7%9E%D7%A2%D7%99%D7%99%D7%9F_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"המעיין החסידי (הדף אינו קיים)\">המעיין החסידי</a> בערב <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94\" title=\"ראש השנה\">ראש השנה</a> תשס\"ד.</li>\n<li><b>קיצור תולדות חב\"ד</b> - סקירה תמציתית על תולדות <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חסידות חב\"ד</a> מתקופת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> ועד לתחילת נשיאות <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> (<a href=\"/index.php/%D7%99%27_%D7%91%D7%A9%D7%91%D7%98\" title=\"י&#39; בשבט\">י' בשבט</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a>) בליווי תמונות נדירות ומסמכים. יצא לאור בהוצאת המעיין החסידי בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a>.</li>\n<li><b>ערי ילדות</b> - אלבום על הערים <a href=\"/index.php/%D7%A0%D7%99%D7%A7%D7%95%D7%9C%D7%99%D7%99%D7%91\" title=\"ניקולייב\">ניקולייב</a> ו<a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%99%D7%A4%D7%A8%D7%A4%D7%98%D7%A8%D7%95%D7%91%D7%A1%D7%A7\" class=\"mw-redirect\" title=\"דנייפרפטרובסק\">דנייפרפטרובסק</a> בהם גדל הרבי בילדותו ועל פעילות שלוחי הרבי בדנייפרפטרובסק וניקולייב כיום. יצא לאור על ידי הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"שמואל קמינצקי\">שמואל קמינצקי</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a>.</li>\n<li><b>הרבי והמוסד</b> - יצא לאור בהוצאת המעיין החסידי <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a>.</li></ul>\n<h3><span id=\".D7.A1.D7.93.D7.A8.D7.95.D7.AA_.D7.A1.D7.A4.D7.A8.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"סדרות_ספרים\">סדרות ספרים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;סדרות ספרים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: סדרות ספרים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><b><a href=\"/index.php/%D7%A8%D7%91%D7%95%D7%AA%D7%99%D7%A0%D7%95_%D7%A0%D7%A9%D7%99%D7%90%D7%99%D7%A0%D7%95_(%D7%A1%D7%A4%D7%A8)\" title=\"רבותינו נשיאינו (ספר)\">רבותינו נשיאינו</a></b> - סיפורים לנוער על כל אדמו\"רי חב\"ד. שבעה כרכים.</li>\n<li><b><a href=\"/index.php/%D7%9E%D7%A2%D7%99%D7%99%D7%9F_%D7%97%D7%99_(%D7%A1%D7%A4%D7%A8)\" title=\"מעיין חי (ספר)\">מעיין חי</a></b> - שיחות של הרבי מעובדות לבני הנוער, יצא לאור בהוצאת <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7\" title=\"מכון לוי יצחק\">מכון לוי יצחק</a>. הספר בעזרת עריכתו של הרב קמינצקי. שמונה כרכים.</li></ul>\n<h3><span id=\".D7.94.D7.A4.D7.A7.D7.95.D7.AA_.D7.95.D7.99.D7.93.D7.90.D7.95\"></span><span class=\"mw-headline\" id=\"הפקות_וידאו\">הפקות וידאו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;הפקות וידאו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: הפקות וידאו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><b>\"מסע אל תולדות חב\"ד\"</b> - סקירה מצולמת בתחנות חייהם של נשיאי חב\"ד ברוסיה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב משה זלמן  קמינצקי - נחלת הר חב\"ד.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"לוי קמינצקי\">לוי קמינצקי</a> - שליח הרבי בעיר טומסק שב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"יהושע קמינצקי\">יהושע קמינצקי</a> - שליח הרבי הראשי ומנהל בית חב\"ד בסרביה.</li>\n<li>בנו הרב ראובן קמינצקי - קראון הייטס.</li>\n<li>בנו הת' אברהם קמינצקי - 770.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%A0%D7%A4%D7%AA%D7%9C%D7%99_%D7%93%D7%99%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"נפתלי דייטש\">נפתלי דייטש</a> - שליח הרבי הראשי ב<a href=\"/index.php/%D7%A8%D7%95%D7%9E%D7%A0%D7%99%D7%94\" title=\"רומניה\">רומניה</a>.</li>\n<li>חתנו הרב <a href=\"/index.php?title=%D7%93%D7%9F_%D7%A7%D7%A8%D7%99%D7%A6%27%D7%91%D7%A1%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"דן קריצ&#39;בסקי (הדף אינו קיים)\">דן קריצ'בסקי</a> - שליח הרבי בעיר אופה, ורב רפובליקת בשקיריה שב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>.</li>\n<li>חתנו, הרב <a href=\"/index.php?title=%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%95%D7%92%D7%A0%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"לוי יצחק ווגנר (הדף אינו קיים)\">לוי יצחק ווגנר</a> - מנהל <a href=\"/index.php/%D7%90%D7%92%D7%A3_%D7%A2%D7%9C%D7%99%D7%99%D7%94_%D7%91%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%97%D7%91%22%D7%93\" title=\"אגף עלייה בצעירי חב&quot;ד\">אגף עלייה וקליטה בצעירי חב\"ד</a>.</li>\n<li>חתנו, הרב שניאור גרינברג - מנהל אגף התקציבים בצעירי חב\"ד.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=8\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=8\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/images/8/82/קמינצקי_ברגר_בית_משיח.pdf\">עושים היסטוריה</a></b> - ראיון עם ר' <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%91%D7%A8%D7%92%D7%A8\" title=\"שניאור זלמן ברגר\">שניאור זלמן ברגר</a> לרגל <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A1%D7%95%D7%9B%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג הסוכות\">חג הסוכות</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span> <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> גליון 944</li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/old/pics/inbox/2386438_1557842.pdf\">הערט א'מעשה</a></b> לקט כתבות של הרב קמינצקי בתשורה גרינברג תשע\"ה</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/news/798415/\">הרב קמינצקי נבחר לראשות המועצה הדתית שדות דן <span typeof=\"mw:File\"></span></a><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D