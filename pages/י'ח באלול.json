      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">&gt;&gt;</a></span>\n<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"א&#39; באלול\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ב&#39; באלול\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ג&#39; באלול\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ד&#39; באלול\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ה&#39; באלול\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ו&#39; באלול\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ז&#39; באלול\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ח&#39; באלול\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ט&#39; באלול\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&#39; באלול\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;א באלול\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ב באלול\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ג באלול\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ד באלול\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ט&quot;ו באלול\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ט&quot;ז באלול\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ז באלול\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ט באלול\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&#39; באלול\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;א באלול\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ב באלול\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ג באלול\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ד באלול\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ה באלול\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ו באלול\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ז באלול\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ח באלול\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ט באלול\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ח באלול</b> הוא היום השמונה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a>. יום זה נקרא בפי <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד\">חסידי חב\"ד</a> \"ח\"י אלול\", על שם המאורעות החב\"דיים שהתרחשו בו, ישנם <a href=\"/index.php/%D7%9E%D7%A0%D7%94%D7%92%D7%99_%D7%97%22%D7%99_%D7%90%D7%9C%D7%95%D7%9C\" title=\"מנהגי ח&quot;י אלול\">מנהגים מיוחדים ליום זה</a>.\n</p><p>שנים עשר הימים מי\"ח ב<a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a> ועד ל<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94\" title=\"ראש השנה\">ראש השנה</a>, הם מקבילים לחודשי השנה החולפת והתשובה והתיקון בכל יום, מתקן את החודש אליו הוא שייך (י\"ח ב<a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a> – <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, <a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ט באלול\">י\"ט באלול</a> – <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חודש חשוון</a> וכן הלאה).\n</p>\n<dl><dd><span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d0/Postscript-viewer-blue.svg/25px-Postscript-viewer-blue.svg.png\" decoding=\"async\" width=\"25\" height=\"25\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d0/Postscript-viewer-blue.svg/38px-Postscript-viewer-blue.svg.png 1.5x, /images/thumb/d/d0/Postscript-viewer-blue.svg/50px-Postscript-viewer-blue.svg.png 2x\" /></span></span> ערך מורחב – <b><a href=\"/index.php/%D7%9E%D7%A0%D7%94%D7%92%D7%99_%D7%97%22%D7%99_%D7%90%D7%9C%D7%95%D7%9C\" title=\"מנהגי ח&quot;י אלול\">מנהגי ח\"י אלול</a></b><br /></dd></dl>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>שס\"ט – רבי יהודה ליוואי, <a href=\"/index.php/%D7%94%D7%9E%D7%94%D7%A8%22%D7%9C_%D7%9E%D7%A4%D7%A8%D7%90%D7%92\" class=\"mw-redirect\" title=\"המהר&quot;ל מפראג\">המהר\"ל מפראג</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A2%22%D7%93\" title=\"תע&quot;ד\">תע\"ד</a> - <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%94%D7%A0%D7%91%D7%99%D7%90\" title=\"אליהו הנביא\">אליהו הנביא</a> מתגלה לראשונה באופן פרטי אל <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A4%22%D7%93\" title=\"תפ&quot;ד\">תפ\"ד</a> – ה<a href=\"/index.php/%D7%A0%D7%91%D7%99%D7%90\" class=\"mw-redirect\" title=\"נביא\">נביא</a> <a href=\"/index.php/%D7%90%D7%97%D7%99%D7%94_%D7%94%D7%A9%D7%99%D7%9C%D7%95%D7%A0%D7%99\" title=\"אחיה השילוני\">אחיה השילוני</a> התגלה לראשונה אל <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a>, בהיותו בן עשרים ושש שנים, והחל ללמדו תורה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A6%22%D7%93\" title=\"תצ&quot;ד\">תצ\"ד</a> – <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a>, בהיותו בן שלושים ושש, הצטווה על ידי <a href=\"/index.php/%D7%90%D7%97%D7%99%D7%94_%D7%94%D7%A9%D7%99%D7%9C%D7%95%D7%A0%D7%99\" title=\"אחיה השילוני\">אחיה השילוני</a> להתגלות בעולם.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%97\" title=\"תק&quot;ח\">תק\"ח</a> - <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> נפגש עם <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a> בפעם היחידה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%92\" title=\"תקע&quot;ג\">תקע\"ג</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a> נסע מ<a href=\"/index.php/%D7%A7%D7%A8%D7%9E%D7%A0%D7%A6%27%D7%95%D7%92\" title=\"קרמנצ&#39;וג\">קרמנצ'וג</a> וקבע מקום מושבו ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%91\" title=\"תרנ&quot;ב\">תרנ\"ב</a> - <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> שומע שבע תורות מ<a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a> ב<a href=\"/index.php/%D7%92%D7%9F_%D7%A2%D7%93%D7%9F\" title=\"גן עדן\">גן עדן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"תרנ&quot;ז\">תרנ\"ז</a> – התחלת הלימודים בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> - <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A5\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;ץ\">אדמו\"ר הריי\"ץ</a> מגלה שביום <a href=\"/index.php/%D7%97%22%D7%99_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ח&quot;י אלול\">ח\"י אלול</a> מאחלים \"גוט יום טוב\".</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> – ראש העיר <a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"קריית גת\">קריית גת</a> היה ראש העיר הראשון שמסר לרבי כאות כבוד את <a href=\"/index.php/%D7%9E%D7%A4%D7%AA%D7%97_%D7%94%D7%A2%D7%99%D7%A8\" title=\"מפתח העיר\">מפתח העיר</a> באמצעות השליח הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%9C%D7%A1\" title=\"יעקב פלס\">יעקב פלס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a> - <a href=\"/index.php/%D7%9B%22%D7%A7_%D7%90%D7%93%22%D7%A9\" class=\"mw-redirect\" title=\"כ&quot;ק אד&quot;ש\">כ\"ק אד\"ש</a> מכריז שהגיע הזמן ש<a href=\"/index.php/%D7%97%22%D7%99_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ח&quot;י אלול\">ח\"י אלול</a> הוא היום טוב של כלל ישראל.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><b><a href=\"/index.php/%D7%AA%D7%A0%22%D7%97\" title=\"תנ&quot;ח\">תנ\"ח</a> – <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a> – רבי ישראל, נולד לר' <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_(%D7%90%D7%91_%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91)\" class=\"mw-redirect\" title=\"אליעזר (אב הבעל שם טוב)\">אליעזר</a> ושרה</b>.</li>\n<li><b><a href=\"/index.php/%D7%AA%D7%A7%22%D7%94\" title=\"תק&quot;ה\">תק\"ה</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> נולד לרבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%A8%D7%95%D7%9A_%D7%A4%D7%95%D7%96%D7%A0%D7%A8\" class=\"mw-redirect\" title=\"ישראל ברוך פוזנר\">ישראל ברוך</a> ו<a href=\"/index.php/%D7%A8%D7%91%D7%A7%D7%94_(%D7%90%D7%9D_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" title=\"רבקה (אם אדמו&quot;ר הזקן)\">רבקה</a> פוזנר</b>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%91\" title=\"תרפ&quot;ב\">תרפ\"ב</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A9%D7%A4%D7%A8%D7%99%D7%A0%D7%92%D7%A8\" title=\"יעקב שפרינגר\">יעקב שפרינגר</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%93\" title=\"תרצ&quot;ד\">תרצ\"ד</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%91%D7%A2%D7%A8_%D7%91%D7%95%D7%98%D7%9E%D7%9F\" title=\"שלום בער בוטמן\">שלום בער בוטמן</a>, משלוחי הרבי ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ הקודש</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a>, ומנהל בית חב\"ד ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%98\" title=\"תשי&quot;ט\">תשי\"ט</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%9E%D7%90%D7%99%D7%A8_%D7%99%D7%A9%D7%A9%D7%9B%D7%A8_%D7%9E%D7%90%D7%A8%D7%A7\" title=\"שלמה מאיר יששכר מארק\">שלמה מאיר יששכר מארק</a>, מתרגם סידרת ה<a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" class=\"mw-redirect\" title=\"אגרות קודש (אדמו&quot;ר שליט&quot;א)\">אגרות קודש</a> מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a> ל<a href=\"/index.php/%D7%9C%D7%A9%D7%95%D7%9F_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"לשון הקודש\">לשון הקודש</a>. וכן מגיה חסיד חב\"ד ולשעבר שליח ב<a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A7%D7%99%D7%9D\" title=\"אופקים\">אופקים</a> וב<a href=\"/index.php/%D7%9E%D7%95%D7%93%D7%99%D7%A2%D7%99%D7%9F-%D7%9E%D7%9B%D7%91%D7%99%D7%9D-%D7%A8%D7%A2%D7%95%D7%AA\" title=\"מודיעין-מכבים-רעות\">מודיעין מכבים רעות</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%94\" title=\"תשכ&quot;ה\">תשכ\"ה</a> - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A9%D7%90%D7%95%D7%9C_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%9E%D7%A5\" title=\"חיים שאול שטיינמץ\">חיים שאול שטיינמץ</a>, שליח הרבי בעיר סרסוטה שב<a href=\"/index.php/%D7%A4%D7%9C%D7%95%D7%A8%D7%99%D7%93%D7%94\" title=\"פלורידה\">פלורידה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A2%D7%9C%D7%99%D7%A7_%D7%90%D7%94%D7%A8%D7%95%D7%A0%D7%95%D7%91\" class=\"mw-redirect\" title=\"יהושע זעליק אהרונוב\">יהושע זעליק אהרונוב</a>, מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חסידי חב\"ד</a> שמסרו נפשם על הפצת יהדות ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">רוסיה הקומוניסטית</a>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadlive.org/jyoh\">סקירה בלעדית: ח\"י אלול – בתורת נשיאי חב\"ד</a></b>, באתר '<a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"חב&quot;ד לייב\">חב\"ד לייב</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/41px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 1.5x, /images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/54px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://www.mafteiach.app/likkutei_sichos/by_moad/18_elul\">לקוטי שיחות - ח\"י אלול</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9E%D7%A4%D7%AA%D7%97\" title=\"קישור לאתר מפתח\"><img alt=\"קישור לאתר מפתח\" src=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/30px-%D7%9E%D7%A4%D7%AA%D7%97.png\" decoding=\"async\" width=\"30\" height=\"30\" class=\"mw-file-element\" srcset=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/45px-%D7%9E%D7%A4%D7%AA%D7%97.png 1.5x, /images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/60px-%D7%9E%D7%A4%D7%AA%D7%97.png 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.chabad.co.il/?template=topic&amp;topic=151\">ח\"י באלול, הלכות ומנהגים, מאמרים וסיפורים</a> – <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C_(%D7%90%D7%AA%D7%A8)\" title=\"קישור חב&quot;ד בישראל\"><img alt=\"קישור חב&quot;ד בישראל\" src=\"/images/thumb/9/9e/%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg/60px-%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg\" decoding=\"async\" width=\"60\" height=\"12\" class=\"mw-file-element\" srcset=\"/images/thumb/9/9e/%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg/90px-%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg 1.5x, /images/thumb/9/9e/%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg/120px-%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg 2x\" /></a></span> <span class=\"grayText\"><small>(הקישור אינו פעיל)</small></span></li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%99%D7%A2%D7%A7%D7%91_%D7%97%D7%96%D7%9F\" title=\"שלום יעקב חזן\">שלום יעקב חזן</a>, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/magazine/711112/\">מה קרה בח\"י אלול בדור השביעי?</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D