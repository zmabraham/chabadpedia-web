D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://sinun770.org/התוועדות-י-שבט-תשעב-הרב-מיכל-וישצקי-עה/\">התוועדות י' שבט תשע\"ב – הרב מיכל וישצקי ע\"ה | מעייני ישראל ירושלים</a></b> באתר סינון חב\"ד לסרטוני יוטיוב <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span></li>\n<li><b> <a rel=\"nofollow\" class=\"external text\" href=\"https://sinun770.org/סיפורים-וזכרונות-מסירת-נפש-ברוסיא-הרב/\">סיפורים וזכרונות מסירת נפש ברוסיא, הרב מענדל פוטרפאס ע\"ה, ראיון עם הרב מיכל וישצקי, אידיש שנת תשפ\"ג</a></b>, ראיון לקו הטלפון אספקלריה, בערוץ היוטיוב חסידות Chassidus באתר סינון חב\"ד לסרטוני יוטיוב <span typeof=\"mw:File\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A6%D7%9C%D7%99%D7%9C\" title=\"קובץ שמע\"><img alt=\"קובץ שמע\" src=\"/images/thumb/4/42/%D7%A9%D7%9E%D7%A2.png/16px-%D7%A9%D7%9E%D7%A2.png\" decoding=\"async\" width=\"16\" height=\"16\" class=\"mw-file-element\" srcset=\"/images/thumb/4/42/%D7%A9%D7%9E%D7%A2.png/24px-%D7%A9%D7%9E%D7%A2.png 1.5x, /images/thumb/4/42/%D7%A9%D7%9E%D7%A2.png/32px-%D7%A9%D7%9E%D7%A2.png 2x\" /></a></span> (