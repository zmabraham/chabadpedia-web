      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"infobox\" style=\"width:20%; border: 1px solid #E4DB77; background-color: #F6F4D5; margin-bottom: 0.5em; margin-right: 1em; padding: 0.2em; color: black; float: left; text-align: center; font-size: 85%; clear:right;\">\n\n<tbody><tr style=\"background:lightblue;\">\n<th style=\"background-color: #E4DB77;\"><font size=\"4\"><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%AA_%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"שמות הוי&quot;ה\">שמותיו של הקב\"ה</a></font>\n</th></tr>\n\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">7 שמות שאינם נמחקים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94_(%D7%A9%D7%9D)\" title=\"הוי&quot;ה (שם)\">הוי\"ה</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A0%22%D7%99\" title=\"אדנ&quot;י\">אדנ\"י</a> · <a href=\"/index.php/%D7%90%22%D7%9C\" title=\"א&quot;ל\">א\"ל</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%99%D7%9D\" title=\"אלקים\">אלהי\"ם</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%22%D7%94\" class=\"mw-redirect\" title=\"אלו&quot;ה\">אלו\"ה</a> · <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%22%D7%AA\" class=\"mw-redirect\" title=\"צבאו&quot;ת\">צבאו\"ת</a> · <a href=\"/index.php/%D7%A9%D7%93%22%D7%99\" class=\"mw-redirect\" title=\"שד&quot;י\">שד\"י</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%AA_%D7%94%D7%95%D7%99%27_%D7%91%D7%9E%D7%99%D7%9C%D7%95%D7%90%D7%9D_(%D7%A2%22%D7%91_%D7%A1%22%D7%92_%D7%9E%22%D7%94_%D7%91%22%D7%9F)\" title=\"שמות הוי&#39; במילואם (ע&quot;ב ס&quot;ג מ&quot;ה ב&quot;ן)\">מילויים לשם הוי\"ה</a></font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A9%D7%9D_%D7%A2%22%D7%91\" title=\"שם ע&quot;ב\">שם ע\"ב</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%A1%22%D7%92\" title=\"שם ס&quot;ג\">שם ס\"ג</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%9E%22%D7%94\" title=\"שם מ&quot;ה\">שם מ\"ה</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%91%22%D7%9F\" title=\"שם ב&quot;ן\">שם ב\"ן</a>\n</td></tr>\n\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">שמות נוספים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%94%D7%99%22%D7%94\" title=\"אהי&quot;ה\">אהי\"ה</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%9E%22%D7%91\" title=\"שם מ&quot;ב\">שם מ\"ב</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%A2%22%D7%91_(%D7%A2%22%D7%91_%D7%AA%D7%99%D7%91%D7%95%D7%AA)\" title=\"שם ע&quot;ב (ע&quot;ב תיבות)\">שם ע\"ב (ע\"ב תיבות)</a> · <a href=\"/index.php/%D7%90%D7%9B%D7%93%D7%98%22%D7%9D\" class=\"mw-redirect\" title=\"אכדט&quot;ם\">אכדט\"ם</a> · <a href=\"/index.php/%D7%90%22%D7%9C_%D7%90%D7%93%D7%A0%22%D7%99\" title=\"א&quot;ל אדנ&quot;י\">א\"ל אדנ\"י</a> · <a href=\"/index.php/%D7%90%22%D7%9C_%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"א&quot;ל הוי&quot;ה\">א\"ל הוי\"ה</a> · <a href=\"/index.php/%D7%90%22%D7%9C_%D7%A9%D7%93%22%D7%99\" title=\"א&quot;ל שד&quot;י\">א\"ל שד\"י</a> · <a class=\"mw-selflink selflink\">אגל\"א</a> · <a href=\"/index.php/%D7%99%22%D7%94\" title=\"י&quot;ה\">י\"ה</a> · <a href=\"/index.php/%D7%9E%D7%A6%D7%A4%22%D7%A5\" title=\"מצפ&quot;ץ\">מצפ\"ץ</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">כינויים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A4%D7%95_%D7%A9%D7%9C_%D7%A2%D7%95%D7%9C%D7%9D\" title=\"אלופו של עולם\">אלופו של עולם</a> · <a href=\"/index.php/%D7%94%D7%A7%D7%93%D7%95%D7%A9_%D7%91%D7%A8%D7%95%D7%9A_%D7%94%D7%95%D7%90\" title=\"הקדוש ברוך הוא\">הקב\"ה</a> · <a href=\"/index.php/%D7%94%27_%D7%90%D7%97%D7%93\" class=\"mw-redirect\" title=\"ה&#39; אחד\">ה' אחד</a> · <a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_%D7%95%D7%9E%D7%94%D7%95%D7%AA\" title=\"עצמות ומהות\">עצמות ומהות</a> · <a href=\"/index.php/%D7%A7%D7%93%D7%9E%D7%95%D7%9F\" title=\"קדמון\">קדמון</a> · <a href=\"/index.php/%D7%90%D7%93%D7%95%D7%9F_(%D7%A9%D7%9D_%D7%94%27)\" title=\"אדון (שם ה&#39;)\">אדון</a> · <a href=\"/index.php/%D7%90%D7%93%D7%9D_%D7%94%D7%A2%D7%9C%D7%99%D7%95%D7%9F\" title=\"אדם העליון\">אדם העליון</a> · <a href=\"/index.php/%D7%9C%D7%90_%D7%90%D7%93%D7%9D\" title=\"לא אדם\">לא אדם</a> · <a href=\"/index.php/%D7%9E%D7%9C%D7%9A_%D7%9E%D7%9C%D7%9B%D7%99_%D7%94%D7%9E%D7%9C%D7%9B%D7%99%D7%9D\" title=\"מלך מלכי המלכים\">מלך מלכי המלכים</a> · <a href=\"/index.php/%D7%90%D7%95%D7%99%D7%91%D7%A2%D7%A8%D7%A9%D7%98%D7%A2%D7%A8\" title=\"אויבערשטער\">אויבערשטער</a> · <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_(%D7%A9%D7%9D)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלום (שם) (הדף אינו קיים)\">שלום</a> · <a href=\"/index.php?title=%D7%91%D7%95%D7%A8%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בורא (הדף אינו קיים)\">בורא</a>\n</td></tr></tbody></table><p><b>אגל\"א</b> הינו שם משמות הקודש היוצא מראשי תיבות; \"<b>א</b>תה <b>ג</b>יבור <b>ל</b>עולם <b>א</b>דני\", וענינו כהמשך הברכה; \"מחיה מתים אתה\".\n</p><h2><span id=\".D7.90.D7.95.D7.A4.D7.9F_.D7.90.27_.D7.91.D7.94.D7.A1.D7.91.D7.A8_-_.D7.AA.D7.99.D7.A7.D7.95.D7.9F_.D7.94.D7.A0.D7.A4.D7.99.D7.9C.D7.94\"></span><span class=\"mw-headline\" id=\"אופן_א'_בהסבר_-_תיקון_הנפילה\">אופן א' בהסבר - תיקון הנפילה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%92%D7%9C%22%D7%90&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אופן א&#039; בהסבר - תיקון הנפילה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%92%D7%9C%22%D7%90&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אופן א&#039; בהסבר - תיקון הנפילה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ב<a href=\"/index.php/%D7%A9%D7%91%D7%99%D7%A8%D7%AA_%D7%94%D7%9B%D7%9C%D7%99%D7%9D\" title=\"שבירת הכלים\">שבירת הכלים</a> נפלו <a href=\"/index.php/%D7%A8%D7%A4%22%D7%97_%D7%A0%D7%99%D7%A6%D7%95%D7%A6%D7%95%D7%AA\" class=\"mw-redirect\" title=\"רפ&quot;ח ניצוצות\">רפ\"ח ניצוצות</a> מ<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%AA%D7%95%D7%94%D7%95\" title=\"עולם התוהו\">עולם התוהו</a> לבריאה - ל<a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%A4%D7%AA_%D7%A0%D7%95%D7%92%D7%94\" title=\"קליפת נוגה\">קליפת נוגה</a> - בחינת \"מות\", ו<a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%A4%D7%94\" title=\"קליפה\">קליפה</a> זו נבראה על ידי אתה גיבור - <a href=\"/index.php/%D7%9E%D7%93%D7%AA_%D7%94%D7%92%D7%91%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"מדת הגבורה\">מדת הגבורה</a> וה<a href=\"/index.php/%D7%A6%D7%9E%D7%A6%D7%95%D7%9D\" class=\"mw-redirect\" title=\"צמצום\">צמצום</a>, ו<a href=\"/index.php/%D7%A0%D7%A9%D7%9E%D7%94\" class=\"mw-redirect\" title=\"נשמה\">נשמות</a> ישראל, מבררים ומעלים את הניצוצות אל הקדושה - על ידי שמשתמשים בעניני העולם לצורך עבודת ה', ומשתמשים במדת ה<a href=\"/index.php/%D7%A1%D7%A4%D7%99%D7%A8%D7%AA_%D7%94%D7%92%D7%91%D7%95%D7%A8%D7%94\" title=\"ספירת הגבורה\">גבורה</a> לבטל את הצמצום ולהגביר את הגילוי האלקי בעולם, על ידי זה שמחילים על העולם את אדנותו - שם א-דני (שם המורה על מדת הגבורה). ובזה הוא מחיה מתים.\n</p><p>על פי זה תתפרש התפילה:\n</p><p>אתה גיבור - שעל ידי זה נגרמת השבירה - מות,\n</p><p>לעולם א - דני - החלת אדנות ה' על העולם,\n</p><p>מחיה מתים אתה - תיקון השבירה והנפילה.\n</p>\n<h2><span id=\".D7.90.D7.95.D7.A4.D7.9F_.D7.91.27_.D7.91.D7.94.D7.A1.D7.91.D7.A8_-_.D7.92.D7.99.D7.9C.D7.95.D7.99_.D7.94.D7.9E.D7.A2.D7.9C.D7.94_.D7.95.D7.94.D7.A6.D7.95.D7.A8.D7.9A_.D7.91.D7.A6.D7.9E.D7.A6.D7.95.D7.9D_.D7.94.D7.90.D7.95.D7.A8_.D7.94.D7.90.D7.9C.D7.95.D7.A7.D7.99\"></span><span class=\"mw-headline\" id=\"אופן_ב'_בהסבר_-_גילוי_המעלה_והצורך_בצמצום_האור_האלוקי\">אופן ב' בהסבר - גילוי המעלה והצורך בצמצום האור האלוקי</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%92%D7%9C%22%D7%90&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;אופן ב&#039; בהסבר - גילוי המעלה והצורך בצמצום האור האלוקי&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%92%D7%9C%22%D7%90&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: אופן ב&#039; בהסבר - גילוי המעלה והצורך בצמצום האור האלוקי\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הסבר נוסף בהסברת פסוק זה הוא כך:\n</p><p>\"אתה\": בהתחלה אוא\"ס האיר בגלוי בכל העולם ולכן אמר הכתוב אתה - בלשון נוכח המורה על גילוי - איך שאוא\"ס האיר בגלוי בעולם שלכן אפרש להצביע ולומר 'אתה'. במצב זה אין אפשרות של עולמות משום שהעולמות הינם גבול וכשאוא\"ס שהינו בלי גבול מאיר וממלא את כל החלל אין אפשרות לעצם מוגבל. \n</p><p>\"גבור\": כדי שתהיה התהוות העולמות הקב\"ה צמצם את אוא\"ס, הצמצום נעשה על ידי מדת הגבורה שעניינה צמצום, \n</p><p>\"לעולם\": לאחר הצמצום יכול להיות מצב של התהוות העולמות, המילה לעולם מסבירה את המילה גיבור ואת מטרת פעולת הצמצום - התהוות העולמות. \n</p><p>\"אדנ-י\": מכיוון שהמטרה בהתהוות העולמות היא דירה לקב\"ה בעולמות ולא בעולמות כשלעצמם, המילה אדנ-י מבטאת את אדנותו ומלכותו של הקב\"ה בעולמות, מצב זה יתקיים במלואו ב<a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" class=\"mw-redirect\" title=\"גאולה האמיתית והשלימה\">גאולה האמיתית והשלימה</a> בה העולם הגשמי יגלה את מציאותו האמתית ואת <a href=\"/index.php/%D7%90%D7%97%D7%93%D7%95%D7%AA_%D7%94%27\" title=\"אחדות ה&#39;\">אחדות ה'</a>.\n</p>\n<dl><dd><small>(חלק מהחומר בערך נלקח מהספר <a href=\"/index.php/%D7%A2%D7%A8%D7%9B%D7%99%D7%9D_%D7%91%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_(%D7%A1%D7%A4%D7%A8)\" title=\"ערכים בחסידות (ספר)\">\"ערכים בחסידות\"</a>)</small></dd></dl>\n<div class=\"stub\" style=\"background-color:#FFFCFC; border-color:#CCCCCC; border-style:double; border-width:3px; clear:both; padding-top:4px; padding-bottom:4px; padding-right:7px; margin:0.5em 0 0.5em 0;vertical-align:middle;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/50px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" decoding=\"async\" width=\"50\" height=\"50\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/75px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 1.5x, /images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/100px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 2x\" /></a></span> &#160; ערך זה הוא <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8\" title=\"חב&quot;דפדיה:קצרמר\">קצרמר</a>&#160;בנושא <a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"קטגוריה:קצרמר חסידות\">חסידות</a>. אתם מוזמנים <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%A8%D7%95%D7%9B%D7%99%D7%9D_%D7%94%D7%91%D7%90%D7%99%D7%9D#כתיבה_בחב&quot;דפדיה\" title=\"חב&quot;דפדיה:ברוכים הבאים\">לתרום</a> לחב\"דפדיה ו<b><span class=\"plainlinks\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php?title=%D7%90%D7%92%D7%9C%22%D7%90&amp;action=edit&amp;editintro=%D7%AA%D7%91%D7%A0%D7%99%D7%AA%3A%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8%2F%D7%94%D7%A8%D7%97%D7%91%D7%94%2F%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\">להרחיב אותו</a></span></b>.</div>\n<!-- \nNewPP limit report\nCached time: 20260413212420\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 