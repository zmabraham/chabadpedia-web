      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"א&#39; בתשרי\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ב&#39; בתשרי\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ג&#39; בתשרי\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ד&#39; בתשרי\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ה&#39; בתשרי\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ו&#39; בתשרי\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ז&#39; בתשרי\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ח&#39; בתשרי\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&#39; בתשרי\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&#39; בתשרי\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;א בתשרי\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ב בתשרי\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ג בתשרי\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ד בתשרי\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&quot;ו בתשרי\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&quot;ז בתשרי\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ז בתשרי\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ח בתשרי\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&#39; בתשרי\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;א בתשרי\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ב בתשרי\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ג בתשרי\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ד בתשרי\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ה בתשרי\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ו בתשרי\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ז בתשרי\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ח בתשרי\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ט בתשרי\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ל&#39; בתשרי\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י&#34;ט בתשרי</b> הוא היום התשעה עשר\nבחודש הראשון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;והיום החמישי של <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A1%D7%95%D7%9B%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג הסוכות\">חג הסוכות</a> (ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a> הוא היום הרביעי של <a href=\"/index.php/%D7%97%D7%95%D7%9C_%D7%94%D7%9E%D7%95%D7%A2%D7%93\" title=\"חול המועד\">חול המועד</a> וב<a href=\"/index.php/%D7%97%D7%95%22%D7%9C\" class=\"mw-redirect\" title=\"חו&quot;ל\">חו\"ל</a> היום השלישי של חול המועד).\n</p><p>תאריך זה חל בתקופת תשרי&#160;והוא יכול לחול בימים&#160;שני, רביעי, שישי ושבת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%97\" title=\"תקנ&quot;ח\">תקנ\"ח</a> (09/10/1797 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%9E%D7%95%D7%99%D7%9C%D7%A0%D7%90\" class=\"mw-redirect\" title=\"אליהו מוילנא\">אליהו מוילנא</a> (הגאון), נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%93\" title=\"תקע&quot;ד\">תקע\"ד</a> (13/10/1813 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יעקב יצחק רבינוביץ', היהודי הקדוש מפשיסחא, נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%99%22%D7%92\" title=\"תרי&quot;ג\">תרי\"ג</a> (02/10/1852 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי נחמיה יחיאל רבינוביץ' מביחוב, מחבר ספר 'מעשה נחמיה', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%92\" title=\"תרכ&quot;ג\">תרכ\"ג</a> (13/10/1862 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יעקב בן שבת מ<a href=\"/index.php/%D7%9E%D7%A8%D7%95%D7%A7%D7%95\" title=\"מרוקו\">מרוקו</a>, מחבר ספר 'רוח יעקב', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%90\" title=\"תרמ&quot;א\">תרמ\"א</a> (24/09/1880 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי אברהם יהושע העשל ממז'יבוז', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%92\" title=\"תרע&quot;ג\">תרע\"ג</a> (30/09/1912 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי אהרן פרידמן מסדיגורא, מחבר ספר 'קדושת אהרן', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> (01/10/2007 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי בונים יואל טויסיג ממטרסדורף, מחבר ספר 'תפארת בנים', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> (29/09/1980 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרבי פתח והקים את ארגון <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"צבאות ה&#39;\">צבאות ה'</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%92\" title=\"תרפ&quot;ג\">תרפ\"ג</a> (11/10/1922 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%9C%D7%99%D7%99%D7%91%D7%95%D7%A9_%D7%94%D7%A8%D7%A6%D7%9C\" class=\"mw-redirect\" title=\"פנחס לייבוש הרצל\">פנחס לייבוש הרצל</a>, זקן חסידי חב\"ד ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> חב\"ד בשכונת מאה שערים ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> (03/10/1947 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A7%D7%A4%D7%9C%D7%9F\" class=\"mw-redirect\" title=\"אריה לייב קפלן\">אריה לייב קפלן</a>, שליח הרבי מייסד הקהילה ומנהל מוסדות חב\"ד בעיר <a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> (17/10/1981 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A0%D7%AA%D7%9F_%D7%91%D7%95%D7%A8%D7%95%D7%9B%D7%95%D7%91\" title=\"יונתן בורוכוב\">יונתן בורוכוב</a>, רב קהילת ה<a href=\"/index.php/%D7%91%D7%95%D7%9B%D7%A8%D7%94\" class=\"mw-redirect\" title=\"בוכרה\">בוכרים</a> ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a>, רב מכללת פסגות, וראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D\" class=\"mw-redirect\" title=\"כולל אברכים\">כולל</a> 'עטרת שלום'.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%90\" title=\"תשכ&quot;א\">תשכ\"א</a> (10/10/1960 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%91%D7%96%D7%A4%D7%9C%D7%95%D7%91\" title=\"שניאור זלמן בזפלוב\">שניאור זלמן בזפלוב</a>, סגנו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> בניהול ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a>, ממייסדי <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%97%D7%A8%D7%A1%D7%95%D7%9F\" title=\"תומכי תמימים חרסון\">תומכי תמימים חרסון</a>, ובית הכנסת החב\"די בס. פרנסיסקו שב<a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%A4%D7%95%D7%A8%D7%A0%D7%99%D7%94\" title=\"קליפורניה\">קליפורניה</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"תשל&quot;ה\">תשל\"ה</a> (05/10/1974 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ה<a href=\"/index.php/%D7%A4%D7%A8%D7%96%D7%99%D7%93%D7%A0%D7%98_(%D7%AA%D7%95%D7%90%D7%A8_%D7%9B%D7%91%D7%95%D7%93)\" title=\"פרזידנט (תואר כבוד)\">פרזידנט</a> השלישי של <a href=\"/index.php/%D7%9E%D7%93%D7%99%D7%A0%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"מדינת ישראל\">מדינת ישראל</a>, מר <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A8%D7%95%D7%91%D7%A9%D7%95%D7%91_(%D7%A9%D7%96%22%D7%A8)\" class=\"mw-redirect\" title=\"שניאור זלמן רובשוב (שז&quot;ר)\">שניאור זלמן רובשוב (שז\"ר)</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A4%D7%9C%D7%95%D7%98%D7%A7%D7%99%D7%9F\" title=\"שמואל פלוטקין\">שמואל פלוטקין</a> - מזקני חסידי חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>, שימש בעבר כשליח הרבי ב<a href=\"/index.php/%D7%96%27%D7%99%D7%98%D7%95%D7%9E%D7%99%D7%A8\" title=\"ז&#39;יטומיר\">ז'יטומיר</a> וב<a href=\"/index.php/%D7%91%D7%A8%D7%93%D7%99%D7%A6%27%D7%95%D7%91\" class=\"mw-redirect\" title=\"ברדיצ&#39;וב\">ברדיצ'וב</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ט בתשרי - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>איתא שכל השנה באומרו ב'<a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%A0%D7%94_%D7%A2%D7%A9%D7%A8%D7%94\" class=\"mw-redirect\" title=\"שמונה עשרה\">שמונה עשרה</a>' \"ואת כל מיני תבואתה לטובה\", צריך לכוון לחיטים ל<a href=\"/index.php/%D7%9E%D7%A6%D7%94\" title=\"מצה\">מצה</a> ו<a href=\"/index.php/%D7%90%D7%AA%D7%A8%D7%95%D7%92\" title=\"אתרוג\">אתרוג</a> - במקום אחד נזכר מלבד הנ\"ל גם <a href=\"/index.php/%D7%99%D7%99%D7%9F\" title=\"יין\">יין</a> ל<a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9\" title=\"קידוש\">קידוש</a> - ואז במילא תהיה כל התבואה לטובה.\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השביעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413214011\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.091 seconds\nReal time usage: 0.315 seconds\nPreprocessor visited node count: 431/1000000\nPost‐expand include size: 8412/2097152 bytes\nTemplate argument size: 1047/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 471/5000000 bytes\nLua time usage: 0.060/7 seconds\nLua virtual size: 6135808/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  269.885      1 -total\n 91.43%  246.748      1 תבנית:פתיח_יום\n 17.68%   47.728      5 תבנית:מילה_אחרונה\n 15.30%   41.301      1 תבנית:הערה\n 13.48%   36.377      2 תבנית:מילה_ראשונה\n 12.07%   32.571      1 תבנית:חודש_תשרי\n 10.57%   28.525      1 תבנית:לוח_שנה\n  6.16%   16.614      1 תבנית:הסר_מילה_ראשונה\n  5.65%   15.251      1 תבנית:הערות_שוליים\n  3.12%    8.424      3 תבנית:רווח\n-->\n\n<!-- Saved in parser cache with key chabadped_1