7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כ&quot;ז בכסלו\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כ&quot;ח בכסלו\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כ&quot;ט בכסלו\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"ל&#39; בכסלו\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י&#34;א בכסלו</b> הוא היום האחד עשר\nבחודש השלישי<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי.\n</p><p>תאריך זה חל בתקופת תשרי\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%9B%22%D7%92\" title=\"תקכ&quot;ג\">תקכ\"ג</a> - רבי יעקב יצחק הלוי לנדא, רבה של דוקלא ופרשבורג ומחבר ספר 'אמרי רברבי', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%9E%22%D7%95\" title=\"תקמ&quot;ו\">תקמ\"ו</a> - רבי שמחה מדעסוי, מחבר ההגהות על ה<a href=\"/index.php/%D7%A9%22%D7%A1\" class=\"mw-redirect\" title=\"ש&quot;ס\">ש\"ס</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A4%22%D7%95\" title=\"תקפ&quot;ו\">תקפ\"ו</a> - רבי אברהם אליעזר הלוי, מחשובי רבני איטליה, אב בית הדין של הקהילה היהודית טריאסטה, מורו של שד\"ל, ותלמיד <a href=\"/index.php/%D7%94%D7%97%D7%99%D7%93%22%D7%90\" class=\"mw-redirect\" title=\"החיד&quot;א\">החיד\"א</a>, תשובותיו והתכתבויות עמו התפרסמו בספרי ה<a href=\"/index.php/%D7%97%D7%AA%D7%9D_%D7%A1%D7%95%D7%A4%D7%A8\" class=\"mw-redirect\" title=\"חתם סופר\">חתם סופר</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%91\" title=\"תרכ&quot;ב\">תרכ\"ב</a> - רבי יחיאל הלר, מחבר ספר 'עמודי אור', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%98\" title=\"תרפ&quot;ט\">תרפ\"ט</a> - <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> <a href=\"/index.php/%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90\" class=\"mw-redirect\" title=\"חתונת אדמו&quot;ר שליט&quot;א\">עלה לתורה ב'שבת חתן' שלו</a> (\"<a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A8%D7%95%D7%A4%D7%A2%D7%A0%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אופרופעניש\">אופרופעניש</a>\"), במנין <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> בעיר <a href=\"/index.php/%D7%A8%D7%99%D7%92%D7%90\" class=\"mw-redirect\" title=\"ריגא\">ריגא</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%95\" title=\"תשכ&quot;ו\">תשכ\"ו</a> - הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%90%D7%95%D7%91%D7%A8%D7%9C%D7%A0%D7%93%D7%A8\" title=\"ברוך אוברלנדר\">ברוך אוברלנדר</a>, שליח הרבי לבודפסט, הונגריה, חוקר לתולדות תנועת החסידות.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A7%D7%A4%D7%9C%D7%9F\" title=\"שניאור זלמן קפלן\">שניאור זלמן קפלן</a> - ראש ישיבת <a href=\"/index.php/%D7%90%D7%94%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"אהל מנחם מענדל צפת\">אהל מנחם מענדל צפת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a> - הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%95%D7%94%D7%91%D7%94\" title=\"מנחם והבה\">מנחם והבה</a>, ראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D\" class=\"mw-redirect\" title=\"כולל אברכים\">כולל אברכים</a> ומכון הוראה ב<a href=\"/index.php/%D7%92%D7%91%D7%A2%D7%AA%D7%99%D7%99%D7%9D\" title=\"גבעתיים\">גבעתיים</a>, ראש כולל ערב ב<a href=\"/index.php?title=%D7%9E%D7%95%D7%A1%D7%93%D7%95%D7%AA_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C%27%D7%A1_%D7%A9%D7%95%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מוסדות מענדל&#39;ס שול (הדף אינו קיים)\">מענדל'ס שול</a> <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, ומחבר ועורך ספרים תורניים.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A2\" title=\"תר&quot;ע\">תר\"ע</a> - הרב <a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%A2%D7%A7%D7%91_%D7%A7%D7%A8%D7%99%D7%A9%D7%91%D7%A1%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חיים יעקב קרישבסקי (הדף אינו קיים)\">חיים יעקב קרישבסקי</a>, חסיד חב\"ד, בתקופת אדמו\"ר ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a>, מאיזור יקטרינוסלב.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> - הרב <a href=\"/index.php?title=%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%9C%D7%99%D7%A4%D7%90_%D7%93%D7%95%D7%91%D7%A8%D7%91%D7%A1%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אליעזר ליפא דוברבסקי (הדף אינו קיים)\">אליעזר ליפא דוברבסקי</a>, בן הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%93%D7%95%D7%91%D7%A8%D7%91%D7%A1%D7%A7%D7%99\" title=\"מנחם מענדל דוברבסקי\">מנחם מענדל דוברבסקי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> - הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%92%D7%95%D7%A4%D7%99%D7%9F\" title=\"אהרן גופין\">אהרן גופין</a>, למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a> והיה המייסד של התלמוד תורה וישיבה קטנה ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> והי' למנהלה משך עשרות בשנים.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a> - הרב <a href=\"/index.php/%D7%90%D7%9C%D7%97%D7%A0%D7%9F_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A8%D7%99%D7%99%D7%A6%D7%A1\" class=\"mw-redirect\" title=\"אלחנן יהודה לייב רייצס\">אלחנן יהודה לייב רייצס</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> - הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%97%D7%99_%D7%9C%D7%93%D7%99%D7%95%D7%91\" title=\"יצחק חי לדיוב\">יצחק חי לדיוב</a>, מאנשי המחתרת היהודית בקהילת חב\"ד ב<a href=\"/index.php/%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"סמרקנד\">סמרקנד</a>, ולאחר עלייתו <a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארצה</a> מעסקני הקהילה הבוכרית ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A6%D7%91%D7%99_%D7%A7%D7%95%D7%98%D7%9C%D7%A8%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"יוסף צבי קוטלרסקי\">יוסף צבי קוטלרסקי</a>, מהקבוצה המייסדת של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"תומכי תמימים מונטריאול\">תומכי תמימים מונטריאול</a>, ויו\"ר הנהלת ישיבת \"<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a>\" במשך שנים רבות.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"א בכסלו - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>מהגהות <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> על ה<a href=\"/index.php/%D7%A1%D7%99%D7%93%D7%95%D7%A8\" title=\"סידור\">סידור</a> \"סדר התפלה\" (עם ה<a href=\"/index.php/%D7%93%D7%90%22%D7%97\" class=\"mw-redirect\" title=\"דא&quot;ח\">דא\"ח</a>): חלק א' <a href=\"/index.php/%D7%93%22%D7%94\" class=\"mw-redirect\" title=\"ד&quot;ה\">ד\"ה</a> \"ברוך עושה בראשית\" (צ\"ט, א'): \"משא\"כ בחינת <a href=\"/index.php/%D7%A8%D7%93%D7%9C%22%D7%90\" class=\"mw-redirect\" title=\"רדל&quot;א\">רדל\"א</a>\", ניתקן \"ומעתה יובן פירוש וענין בחינת רדל\"א\". חלק ב' ד\"ה \"עד הגל\" (פ\"ח, ד'): \"לרבנן והלכה כר\"י שבירך\", ניתקן \"לרבנן אם בירך\".\n<p>שם: \"דעת ר\"י וכן האמת\" העביר קולמוס על \"וכן האמת\". שם (פ\"ט, א'): \"<a href=\"/index.php/%D7%AA%D7%94%D7%95\" class=\"mw-redirect\" title=\"תהו\">התהו דנקודים</a>\" ניתקן \"התהו ד<a href=\"/index.php/%D7%A2%D7%A7%D7%95%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"עקודים\">עקודים</a>\".\n</p>\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש התשיעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260414013641\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.087 seconds\nReal time usage: 0.675 seconds\nPreprocessor visited node count: 295/1000000\nPost‐expand include size: 8072/2097152 bytes\nTemplate argument size: 619/2097152 bytes\nHighest expansion depth: 8/100\nExpensive parser function count: 4/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 151/5000000 bytes\nLua time usage: 0.060/7 seconds\nLua virtual size: 5894144/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  637.801      1 -total\n 98.18%  626.215      1 תבנית:פתיח_יום\n 19.83%  126.498      4 תבנית:מילה_אחרונה\n 13.83%   88.221      1 תבנית:הערה\n  8.23%   52.503      1 תבנית:הסר_מילה_ראשונה\n  7.04%   44.919      1 תבנית:מילה_ראשונה\n  4.63%   29.530      1 תבנית:חודש_כסלו\n  3.56%   22.692      1 תבנית:לוח_שנה\n  1.79%   11.422      1 תבנית:להיום_יום\n  1.64%   10.452      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19821-0!canonical and timestamp 20260414013641 and revision id 822705. Rendering was triggered because: page-view\n -->\n</div>"
