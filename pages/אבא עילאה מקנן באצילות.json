      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"infobox\" style=\"width:25%; border: 1px solid #E4DB77; background-color: #F6F4D5; margin-bottom: 0.5em; margin-right: 1em; padding: 0.2em; color: black; float: left; text-align: center; font-size: 85%; clear:right;\">\n\n<tbody><tr style=\"background:lightblue;\">\n<th style=\"background-color: #E4DB77;\"><font size=\"4\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9E%D7%95%D7%AA_%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA_%D7%91%D7%A8%D7%99%D7%90%D7%94_%D7%99%D7%A6%D7%99%D7%A8%D7%94_%D7%A2%D7%A9%D7%99%D7%94\" title=\"עולמות אצילות בריאה יצירה עשיה\">עולמות אבי\"ע</a></font>\n</th></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"עולם האצילות\">עולם האצילות</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%9B%D7%AA%D7%A8_%D7%A2%D7%9C%D7%99%D7%95%D7%9F\" title=\"כתר עליון\">כתר עליון</a> · <a href=\"/index.php/%D7%A2%D7%AA%D7%99%D7%A7_%D7%99%D7%95%D7%9E%D7%99%D7%9F\" title=\"עתיק יומין\">עתיק יומין</a> · <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%9A_%D7%90%D7%A0%D7%A4%D7%99%D7%9F\" title=\"אריך אנפין\">אריך אנפין</a> · <a class=\"mw-selflink selflink\">אבא עילאה מקנן באצילות</a> · <a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94\" title=\"אבא עילאה\">אבא עילאה</a> · <a href=\"/index.php/%D7%90%D7%9E%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94\" title=\"אמא עילאה\">אמא עילאה</a> · <a href=\"/index.php/%D7%96%D7%A2%D7%99%D7%A8_%D7%90%D7%A0%D7%A4%D7%99%D7%9F\" title=\"זעיר אנפין\">זעיר אנפין</a> · <a href=\"/index.php/%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%93%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"מלכות דאצילות\">מלכות דאצילות</a> · <a href=\"/index.php/%D7%90%D7%93%D7%9D_%D7%94%D7%A2%D7%9C%D7%99%D7%95%D7%9F\" title=\"אדם העליון\">אדם העליון</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%9E%D7%9C_(%D7%91%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA)\" title=\"חשמל (בחסידות)\">חשמל</a> · <a href=\"/index.php/%D7%A4%D7%A8%D7%A1%D7%90\" title=\"פרסא\">פרסא</a>\n</td></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%91%D7%A8%D7%99%D7%90%D7%94\" title=\"עולם הבריאה\">עולם הבריאה</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php?title=%D7%90%D7%9E%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94_%D7%9E%D7%A7%D7%A0%D7%A0%D7%90_%D7%91%D7%91%D7%A8%D7%99%D7%90%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אמא עילאה מקננא בבריאה (הדף אינו קיים)\">אמא עילאה מקננא בבריאה</a> · <a href=\"/index.php/%D7%A9%D7%A8%D7%A4%D7%99%D7%9D\" title=\"שרפים\">שרפים</a> · <a href=\"/index.php/%D7%9E%D7%98%22%D7%98\" title=\"מט&quot;ט\">מט\"ט</a> · <a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%A7%D7%A8\" title=\"י&quot;ב בקר\">י\"ב בקר</a> · <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%91%D7%94\" title=\"מרכבה\">מרכבה</a>\n</td></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%99%D7%A6%D7%99%D7%A8%D7%94\" title=\"עולם היצירה\">עולם היצירה</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מלאכים\">מלאכים</a> · <a href=\"/index.php/%D7%97%D7%99%D7%95%D7%AA_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"חיות הקודש\">חיות הקודש</a> · <a href=\"/index.php/%D7%A1%D7%A0%D7%93%22%D7%9C\" class=\"mw-redirect\" title=\"סנד&quot;ל\">סנד\"ל</a>\n</td></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94\" title=\"עולם העשייה\">עולם העשייה</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94_%D7%94%D7%A8%D7%95%D7%97%D7%A0%D7%99\" class=\"mw-redirect\" title=\"עולם העשייה הרוחני\">עולם העשייה הרוחני</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A0%D7%99%D7%9D\" title=\"אופנים\">אופנים</a> · <a href=\"/index.php?title=%D7%92%D7%9C%D7%92%D7%9C%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"גלגלים (הדף אינו קיים)\">גלגלים</a> · <a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94_%D7%94%D7%92%D7%A9%D7%9E%D7%99\" title=\"עולם העשייה הגשמי\">עולם העשייה הגשמי</a>\n</td></tr>\n</tbody></table>\n<p><b>\"אבא עילאה מקנן באצילות\"</b>, הוא פתגם המופיע רבות ב<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> וב<a href=\"/index.php/%D7%A7%D7%91%D7%9C%D7%94\" class=\"mw-redirect\" title=\"קבלה\">קבלה</a>, ופירושו: \"<a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94\" title=\"אבא עילאה\">אבא עילאה</a>\" (כינוי ל<a href=\"/index.php/%D7%A1%D7%A4%D7%99%D7%A8%D7%AA_%D7%94%D7%97%D7%9B%D7%9E%D7%94\" title=\"ספירת החכמה\">ספירת החכמה</a>), מקנן ושוכן ב<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"עולם האצילות\">עולם האצילות</a>.\n</p><p>והיינו, שעיקר משכנה - התגלותה והשפעתה - של <a href=\"/index.php/%D7%A1%D7%A4%D7%99%D7%A8%D7%AA_%D7%94%D7%97%D7%9B%D7%9E%D7%94\" title=\"ספירת החכמה\">ספירת החכמה</a> היא בעולם האצילות, ולכן הספירה העיקריית באצילות, היא החכמה.\n</p><p>משמעות הדבר שכל <a href=\"/index.php/%D7%94%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הספירות\">הספירות</a> וההיכלות וכו' של עולם האצילות, מותאמים ופועלים לפי ענינה של ספירת החכמה.\n</p><p>ענינה של <a href=\"/index.php/%D7%A1%D7%A4%D7%99%D7%A8%D7%AA_%D7%94%D7%97%D7%9B%D7%9E%D7%94\" title=\"ספירת החכמה\">ספירת החכמה</a> הוא ה<a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C\" title=\"ביטול\">ביטול</a> הגדול ל<a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" title=\"אור אין סוף\">אור אין סוף</a> ברוך הוא, לכן נקראה <a href=\"/index.php/%D7%97%D7%9B%D7%9E%D7%94\" class=\"mw-redirect\" title=\"חכמה\">חכמה</a> - <a href=\"/index.php/%D7%90%D7%95%D7%AA%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אותיות\">אותיות</a> כח-מה, שמשמעותו ביטול, וענין זה של הביטול דחכמה - נרגש בכל עולם האצילות.\n</p>\n<div class=\"stub\" style=\"background-color:#FFFCFC; border-color:#CCCCCC; border-style:double; border-width:3px; clear:both; padding-top:4px; padding-bottom:4px; padding-right:7px; margin:0.5em 0 0.5em 0;vertical-align:middle;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/50px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" decoding=\"async\" width=\"50\" height=\"50\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/75px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 1.5x, /images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/100px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 2x\" /></a></span> &#160; ערך זה הוא <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8\" title=\"חב&quot;דפדיה:קצרמר\">קצרמר</a>&#160;בנושא <a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"קטגוריה:קצרמר חסידות\">חסידות</a>. אתם מוזמנים <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%A8%D7%95%D7%9B%D7%99%D7%9D_%D7%94%D7%91%D7%90%D7%99%D7%9D#כתיבה_בחב&quot;דפדיה\" title=\"חב&quot;דפדיה:ברוכים הבאים\">לתרום</a> לחב\"דפדיה ו<b><span class=\"plainlinks\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php?title=%D7%90%D7%91%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94_%D7%9E%D7%A7%D7%A0%D7%9F_%D7%91%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA&amp;action=edit&amp;editintro=%D7%AA%D7%91%D7%A0%D7%99%D7%AA%3A%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8%2F%D7%94%D7%A8%D7%97%D7%91%D7%94%2F%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\">להרחיב אותו</a></span></b>.</div>\n<dl><dd><small>(חלק מהחומר בערך נלקח מהספר <a href=\"/index.php/%D7%A2%D7%A8%D7%9B%D7%99%D7%9D_%D7%91%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_(%D7%A1%D7%A4%D7%A8)\" title=\"ערכים בחסידות (ספר)\">\"ערכים בחסידות\"</a>)</small></dd></dl>\n<!-- \nNewPP limit report\nCached time: 20260413075917\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.033 seconds\nReal time usage: 0.178 seconds\nPreprocessor visited node count: 106/1000000\nPost‐expand include size: 5278/2097152 bytes\nTemplate argument size: 187/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  138.070      1 -total\n 69.48%   95.924      1 תבנית:קצרמר\n 52.12%   71.964      1 תבנית:קצרמר/קוד\n 15.76%   21.760      1 תבנית:סגל\n 14.61%   20.176      1 תבנית:עולמות_אבי&quot;ע\n 11.49%   15.871      1 תבנית:רווח_קשיח\n  5.62%    7.760      1 תבנית:קצרמר/נושא_נוסף\n  5.41%    7.467      2 תבנית:קטגוריה_בתבנית\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:2443-0!canonical and timestamp 20260413075917 and revision id 826045. Rendering was triggered because: page-view\n -->\n</div>"
