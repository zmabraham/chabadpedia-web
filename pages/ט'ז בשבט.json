>כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A9%D7%91%D7%98\" title=\"כ&quot;ט בשבט\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A9%D7%91%D7%98\" title=\"ל&#39; בשבט\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ט\"ז בשבט</b> הוא היום השישה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">חודש שבט</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%9B\" title=\"תק&quot;כ\">תק\"כ</a> - רבי יונה נבון, רבו של החיד\"א מחבר 'גט מקושר' ו'נחפה בכסף', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%96\" title=\"תקע&quot;ז\">תקע\"ז</a> - רבי אשר צבי מאוסטראה, תלמיד <a href=\"/index.php/%D7%94%D7%9E%D7%92%D7%99%D7%93_%D7%9E%D7%9E%D7%96%D7%A8%D7%99%D7%98%D7%A9\" title=\"המגיד ממזריטש\">המגיד ממזריטש</a>, מחבר 'מעין החכמה', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> - רבי <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A9%D7%91%D7%93%D7%A8%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלום מרדכי שבדרון (הדף אינו קיים)\">שלום מרדכי שבדרון</a> מברז'אן, רב ופוסק מפורסם בגליציה, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> - רבי <a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A9%D7%9C%D7%9E%D7%94_%D7%91%D7%99%D7%93%D7%A8%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אברהם שלמה בידרמן (הדף אינו קיים)\">אברהם שלמה בידרמן</a> מ<a href=\"/index.php/%D7%9C%D7%A2%D7%9C%D7%95%D7%91\" class=\"mw-redirect\" title=\"לעלוב\">לעלוב</a> <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a> - על פי הוראת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, החסידים מתחילים לכתוב בעצמם את <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מאמר חסידות\">מאמרי החסידות</a> שהרבי אמר, <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%9E%D7%90%D7%9E%D7%A8%D7%99%D7%9D_%D7%9E%D7%9C%D7%95%D7%A7%D7%98#הדפסת_הסדרה\" class=\"mw-redirect\" title=\"ספר המאמרים מלוקט\">בשונה מהנהוג אצל שאר רבותינו נשיאינו</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%91\" title=\"תרע&quot;ב\">תער\"ב</a> - הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%97%D7%96%D7%9F\" title=\"אהרן חזן\">אהרן חזן</a>, מראשי העוסקים במחתרת היהודית ב<a href=\"/index.php/%D7%98%D7%A9%D7%A7%D7%A0%D7%98\" title=\"טשקנט\">טשקנט</a> וברחבי <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a>, ולאחר עלייתו <a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארצה</a> התיישב ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a> ועסק ב'<a href=\"/index.php/%D7%97%D7%93%D7%A8%D7%99_%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" title=\"חדרי תורה אור\">חדרי תורה אור</a>' ובחיזוק היהדות בין עולי <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%96\" title=\"תרע&quot;ז\">תרע\"ז</a> - הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8\" title=\"מרדכי אליהו שניאור\">מרדכי אליהו (מוניייע) שניאור</a>, מגיד שיעור בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A6\" title=\"תר&quot;צ\">תר\"צ</a> - הרב <a href=\"/index.php/%D7%99%D7%95%D7%90%D7%9C_%D7%9B%D7%94%D7%9F\" title=\"יואל כהן\">יואל כהן</a>, משפיע בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_770\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית - 770\">תומכי תמימים המרכזית - 770</a>, וראש צוות ה'<a href=\"/index.php/%D7%97%D7%95%D7%96%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"חוזרים\">חוזרים</a>' בחצר הרבי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%93\" title=\"תרצ&quot;ד\">תרצ\"ד</a> - הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A6%D7%91%D7%99_%D7%94%D7%95%D7%9C%D7%A6%D7%9E%D7%9F\" title=\"יעקב צבי הולצמן\">יעקב צבי הולצמן</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%91%22%D7%A7\" class=\"mw-redirect\" title=\"משב&quot;ק\">משב\"ק</a> <a href=\"/index.php/%D7%A4%D7%A8%D7%96%D7%99%D7%93%D7%A0%D7%98_1304\" title=\"פרזידנט 1304\">בבית של הרבי</a>, ו<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> הרבי ב<a href=\"/index.php/%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"אנטוורפן\">אנטוורפן</a> שבבלגיה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a> - הרב <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%A0%D7%94_%D7%A9%D7%9E%D7%95%D7%98%D7%A7%D7%99%D7%9F\" title=\"אלקנה שמוטקין\">אלקנה שמוטקין</a>, מנהל חברת המדיה החב\"דית <a href=\"/index.php/Jem\" class=\"mw-redirect\" title=\"Jem\">jem</a>, חוקר ומוציא לאור של ספרים ופרוייקטים בתולדות חייו ופועלו של הרבי.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%98\" title=\"תרכ&quot;ט\">תרכ\"ט</a> - הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%A9%D7%9C%D7%95%D7%9D_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%91%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7)\" title=\"ברוך שלום שניאורסון (בן אדמו&quot;ר הצמח צדק)\">ברוך שלום שניאורסון</a> בנו בכורו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a> וסב סבו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> - הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A0%D7%95%D7%91%D7%99%D7%A7%D7%95%D7%91\" title=\"מנחם מענדל נוביקוב\">מנחם מענדל נוביקוב</a>, <a href=\"/index.php/%D7%A9%D7%95%D7%97%D7%98_%D7%95%D7%91%D7%95%D7%93%D7%A7\" class=\"mw-redirect\" title=\"שוחט ובודק\">שוחט ובודק</a> ו<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9E%D7%95%D7%A2%D7%94\" title=\"בעל שמועה\">בעל שמועה</a> חסידי שפעל תחילה באנדריאפול, ובשנותיו האחרונות ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a> וב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a> - ר' <a href=\"/index.php?title=%D7%9E%D7%A9%D7%94_%D7%92%D7%95%D7%A8%D7%93%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"משה גורדון (הדף אינו קיים)\">משה גורדון</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> - הרב <a href=\"/index.php/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%A4%D7%9C%D7%A1\" title=\"טוביה פלס\">טוביה פלס</a>, עסקן חסידי שזכה לקירובים מהרבי ועומד מאחורי הדפסת <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_(%D7%A7%D7%95%D7%91%D7%A5)\" title=\"דבר מלכות (קובץ)\">דבר מלכות (קובץ)</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5\" title=\"אבא דוד גורביץ\">אבא דוד גורביץ</a>, שליח הרבי לאוזביקסטן ולאסיה התיכונה ומחנך בעל מסירות נפש.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%91%D7%99_%D7%A7%D7%A2%D7%A0%D7%99%D7%92\" title=\"חיים צבי קעניג\">חיים צבי קעניג</a>, שליח הרבי ליישוב הושעיה, סופר ואיש חסד.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ט\"ז בשבט - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> אמר: צווישען קעלט און <a href=\"/index.php/%D7%9B%D7%A4%D7%99%D7%A8%D7%94\" title=\"כפירה\">כפירה</a> איז נאר א דינע מחיצה. עס שטעהט \"כי <a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94_(%D7%A9%D7%9D)\" title=\"הוי&quot;ה (שם)\">ה'</a> <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%9D\" class=\"mw-redirect\" title=\"אלוקים\">אלקיך</a> אש אוכלה הוא\", <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אלקות\">אלקות</a> איז פלאם פייער, לערנען און <a href=\"/index.php/%D7%AA%D7%A4%D7%9C%D7%94\" class=\"mw-redirect\" title=\"תפלה\">דאווענען</a> דארף מען מיט <a href=\"/index.php?title=%D7%94%D7%AA%D7%9C%D7%94%D7%91%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"התלהבות (הדף אינו קיים)\">התלהבות</a> ה<a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a>, אז \"כל עצמותי תאמרנה\" די דברי ה' אין <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> ותפלה.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> אמר: בין קרירות ו<a href=\"/index.php/%D7%9B%D7%A4%D7%99%D7%A8%D7%94\" title=\"כפירה\">כפירה</a> ישנה רק מחיצה דקה. כתוב \"כי <a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94_(%D7%A9%D7%9D)\" title=\"הוי&quot;ה (שם)\">ה'</a> <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%9D\" class=\"mw-redirect\" title=\"אלוקים\">אלקיך</a> אש אוכלה הוא\", <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אלקות\">אלקות</a> היא להבת אש, ללמוד ו<a href=\"/index.php/%D7%AA%D7%A4%D7%9C%D7%94\" class=\"mw-redirect\" title=\"תפלה\">להתפלל</a> צריכים ב<a href=\"/index.php?title=%D7%94%D7%AA%D7%9C%D7%94%D7%91%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"התלהבות (הדף אינו קיים)\">התלהבות</a> ה<a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a>, ש\"כל עצמותי תאמרנה\" את דברי ה' ב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> ותפלה.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414122537\nC