    "pageid": 4873,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%93%D7%92%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/90/%D7%94%D7%93%D7%92%D7%9C.jpg/250px-%D7%94%D7%93%D7%92%D7%9C.jpg\" decoding=\"async\" width=\"250\" height=\"168\" class=\"mw-file-element\" srcset=\"/images/thumb/9/90/%D7%94%D7%93%D7%92%D7%9C.jpg/375px-%D7%94%D7%93%D7%92%D7%9C.jpg 1.5x, /images/thumb/9/90/%D7%94%D7%93%D7%92%D7%9C.jpg/500px-%D7%94%D7%93%D7%92%D7%9C.jpg 2x\" /></a><figcaption>דגל משיח</figcaption></figure>\n<p><b>דגל משיח</b> הינו דגל שבמרכזו כתר ותחתיו הכיתוב '<a href=\"/index.php/%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"משיח\">משיח</a>'. מטרתו היא לעורר את המודעות לביאת המשיח.\n</p>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F_%D7%A9%D7%9D_%D7%93%D7%92%D7%9C%D7%95%D7%9F_%D7%A2%D7%9C_%D7%94%D7%A9%D7%A8_%D7%90%D7%95%D7%A8%D7%99_%D7%90%D7%A8%D7%99%D7%90%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/3b/%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F_%D7%A9%D7%9D_%D7%93%D7%92%D7%9C%D7%95%D7%9F_%D7%A2%D7%9C_%D7%94%D7%A9%D7%A8_%D7%90%D7%95%D7%A8%D7%99_%D7%90%D7%A8%D7%99%D7%90%D7%9C.jpg/250px-%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F_%D7%A9%D7%9D_%D7%93%D7%92%D7%9C%D7%95%D7%9F_%D7%A2%D7%9C_%D7%94%D7%A9%D7%A8_%D7%90%D7%95%D7%A8%D7%99_%D7%90%D7%A8%D7%99%D7%90%D7%9C.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/3/3b/%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F_%D7%A9%D7%9D_%D7%93%D7%92%D7%9C%D7%95%D7%9F_%D7%A2%D7%9C_%D7%94%D7%A9%D7%A8_%D7%90%D7%95%D7%A8%D7%99_%D7%90%D7%A8%D7%99%D7%90%D7%9C.jpg/375px-%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F_%D7%A9%D7%9D_%D7%93%D7%92%D7%9C%D7%95%D7%9F_%D7%A2%D7%9C_%D7%94%D7%A9%D7%A8_%D7%90%D7%95%D7%A8%D7%99_%D7%90%D7%A8%D7%99%D7%90%D7%9C.jpg 1.5x, /images/thumb/3/3b/%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F_%D7%A9%D7%9D_%D7%93%D7%92%D7%9C%D7%95%D7%9F_%D7%A2%D7%9C_%D7%94%D7%A9%D7%A8_%D7%90%D7%95%D7%A8%D7%99_%D7%90%D7%A8%D7%99%D7%90%D7%9C.jpg/500px-%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F_%D7%A9%D7%9D_%D7%93%D7%92%D7%9C%D7%95%D7%9F_%D7%A2%D7%9C_%D7%94%D7%A9%D7%A8_%D7%90%D7%95%D7%A8%D7%99_%D7%90%D7%A8%D7%99%D7%90%D7%9C.jpg 2x\" /></a><figcaption>העסקן החבד\"י מ<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> ר' <a href=\"/index.php?title=%D7%90%D7%9C%D7%99_%D7%A1%D7%9C%D7%90%D7%95%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אלי סלאוין (הדף אינו קיים)\">אלי סלאוין</a> שם דגלון על השר אורי אריאל בעת ביקורו ב<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a></figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97_2.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/b/b5/%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97_2.jpg/250px-%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97_2.jpg\" decoding=\"async\" width=\"250\" height=\"179\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b5/%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97_2.jpg/375px-%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97_2.jpg 1.5x, /images/thumb/b/b5/%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97_2.jpg/500px-%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97_2.jpg 2x\" /></a><figcaption>איור של הדגל</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%92%D7%9C%D7%99_%D7%9E%D7%A9%D7%99%D7%97_-_%D7%91%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c4/%D7%93%D7%92%D7%9C%D7%99_%D7%9E%D7%A9%D7%99%D7%97_-_%D7%91%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8.jpg/250px-%D7%93%D7%92%D7%9C%D7%99_%D7%9E%D7%A9%D7%99%D7%97_-_%D7%91%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c4/%D7%93%D7%92%D7%9C%D7%99_%D7%9E%D7%A9%D7%99%D7%97_-_%D7%91%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8.jpg/375px-%D7%93%D7%92%D7%9C%D7%99_%D7%9E%D7%A9%D7%99%D7%97_-_%D7%91%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8.jpg 1.5x, /images/thumb/c/c4/%D7%93%D7%92%D7%9C%D7%99_%D7%9E%D7%A9%D7%99%D7%97_-_%D7%91%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8.jpg/500px-%D7%93%D7%92%D7%9C%D7%99_%D7%9E%D7%A9%D7%99%D7%97_-_%D7%91%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8.jpg 2x\" /></a><figcaption>חסידים עם הדגלים באחד מ<a href=\"/index.php/%D7%A2%D7%A6%D7%A8%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" title=\"עצרת גאולה ומשיח\">כינוסי חב\"ד</a></figcaption></figure>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.99.D7.A1.D7.98.D7.95.D7.A8.D7.99.D7.94\"></span><span class=\"mw-headline\" id=\"היסטוריה\">היסטוריה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;היסטוריה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: היסטוריה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הדגל המוכר כיום הודפס לראשונה בחודש אלול <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> על ידי השליח ב<a href=\"/index.php/%D7%95%D7%A4%D7%A8%D7%A6%D7%AA_%D7%A7%D7%99%D7%91%D7%95%D7%A6%D7%99%D7%9D\" title=\"ופרצת קיבוצים\">ופרצת קיבוצים</a> הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%91%D7%9F_%D7%90%D7%A8%D7%99\" class=\"mw-redirect\" title=\"יעקב בן ארי\">יעקב בן ארי</a> המתגורר ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" title=\"קריית מלאכי\">קריית מלאכי</a>. הצלחת הפעילות עם הדגל הביאה את הרב בן ארי לייצר פריטי פרסום רבים עליהם יש כתר ותחתיו הכיתוב משיח. אף רכבו וביתו של הרב בן ארי נצבעו בצבע הדגל ועליהם מופיע הכיתוב משיח.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a>, לקראת <a href=\"/index.php/%D7%A9%D7%9E%D7%99%D7%A0%D7%99_%D7%A2%D7%A6%D7%A8%D7%AA\" title=\"שמיני עצרת\">שמיני עצרת</a> ו<a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%AA_%D7%AA%D7%95%D7%A8%D7%94\" title=\"שמחת תורה\">שמחת תורה</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>, הודפסו דגלי משיח בהם הופיע הכיתוב \"<a href=\"/index.php/%D7%99%D7%97%D7%99_%D7%94%D7%9E%D7%9C%D7%9A\" title=\"יחי המלך\">יחי המלך</a> משיח צדקנו לעולם ועד\", הדגלים הודפסו ע\"י <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> יצר הרב בן ארי את דגל המשיח הגדול בעולם שהונף לראשונה ב<a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97_-_%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"כינוסי גאולה ומשיח - תשנ&quot;ה\">כינוס גאולה ומשיח</a> שנערך בנשר.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> יצאו תלמידי <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A0%D7%95%D7%A3_%D7%94%D7%92%D7%9C%D7%99%D7%9C_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש נוף הגליל (קטנה)\">ישיבת חח\"ל הקטנה בנוף הגליל</a> וב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"תומכי תמימים ראשון לציון\">ראשון לציון</a> במבצע מיוחד לתליית דגלים על בתים ברחבי <a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>. במהלך המבצע נתלו מאות דגלים המפיצים את הבשורה על בתים ובניינים בארץ. בעקבות הצלחת המבצע בארץ, יזמו התלמידים ב<a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" class=\"mw-redirect\" title=\"מרכז חב&quot;ד העולמי\">מרכז חב\"ד העולמי</a> ב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ניו יורק\">ניו יורק</a> מבצע דומה לתליית דגלים בבתים ועסקים ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%97%D7%A8%D7%91%D7%95%D7%AA_%D7%91%D7%A8%D7%96%D7%9C\" title=\"מלחמת חרבות ברזל\">מלחמת חרבות ברזל</a> חולק \"פאצ'\" רקום של דגל משיח בצבעי ירוק זית ואלפי חיילים ענדו למדיהם את הפאצ' שהפך ללהיט<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>, כמו כן מספר טנקים תועדו בפעילות כשדגלי משיח מתנוססים על גביהם<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.91.D7.A0.D7.94\"></span><span class=\"mw-headline\" id=\"מבנה\">מבנה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;מבנה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: מבנה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הדגל צבוע בצהוב, במרכזו איור של כתר בצבע כחול, ומתחתיו הכיתוב משיח בצבע אדום.\n</p><p>בתחילה היה זה הפוך - הכתר היה בצבע אדום והמילה משיח בכחול<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup> אך בהוצאה השניה של הדגל זה הוחלף למוצר המוכר כיום.\n</p><p>כיום ניתן לראות את הדגל בוריאציות רבות ומגוונות, ביניהם 'דגלון'<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup> לדש המעיל העליון, החליפה, ה<a href=\"/index.php/%D7%A1%D7%99%D7%A8%D7%98%D7%95%D7%A7\" title=\"סירטוק\">סירטוק</a> ול<a href=\"/index.php/%D7%9B%D7%95%D7%91%D7%A2_%D7%A7%D7%A0%D7%99%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"כובע קנייטש\">כובע</a>, שלייקס, דגל לתליה במקום גבוה<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>, דגל לגיהוץ, על עטיפות ספרים ועוד. כמו כן משמש הדגל לאמצעי פירסום פופלארי במשחקי הספורט הישראלים<sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\"><span class=\"cite-bracket\">&#91;</span>9<span class=\"cite-bracket\">&#93;</span></a></sup> ובכנסים של חסידי חב\"ד<sup id=\"cite_ref-10\" class=\"reference\"><a href=\"#cite_note-10\"><span class=\"cite-bracket\">&#91;</span>10<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%A4%D7%A8%D7%A1%D7%95%D7%9D_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" title=\"פרסום גאולה ומשיח\">פרסום גאולה ומשיח</a></li>\n<li><a href=\"/index.php/%D7%93%D7%92%D7%9C%D7%99_%D7%94%D7%A9%D7%91%D7%98%D7%99%D7%9D\" title=\"דגלי השבטים\">דגלי השבטים</a></li>\n<li><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%99_%D7%91%D7%9F_%D7%90%D7%A8%D7%99\" class=\"mw-redirect\" title=\"קובי בן ארי\">קובי בן ארי</a></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1t2L7QXOOZ6TQjIQVqwzIeOnfW2Epx9iC/view\"><b>בזכות הדגלים אני גואל אותכם</b></a> שיחת הגאולה גליון 67.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%92%D7%9C_%D7%9E%D7%A9%D7%99%D7%97&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1ZSBL59iRpfrOxIsop7q5fqx7za0_tFCp/view?usp=sharing\">העובדות שמאחורי הדגל</a></b> - תשורה מ<a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1_%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"כינוס השלוחים העולמי\">כינוס השלוחים העולמי</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6