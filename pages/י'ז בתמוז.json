gcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;א בתמוז\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ב בתמוז\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ג בתמוז\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ד בתמוז\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ה בתמוז\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ו בתמוז\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ז בתמוז\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ח בתמוז\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ט בתמוז\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ז בתמוז</b> הוא היום השבעה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>, והוא יום <a href=\"/index.php/%D7%A6%D7%95%D7%9D\" class=\"mw-redirect\" title=\"צום\">צום</a> בעקבות חמשה דברים שארעו בו. ביום זה מתחילים ימי <a href=\"/index.php/%D7%91%D7%99%D7%9F_%D7%94%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"בין המצרים\">בין המצרים</a>, הנמשכים עד <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91\" class=\"mw-redirect\" title=\"תשעה באב\">תשעה באב</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>א'תרנ\"ו – <a href=\"/index.php/%D7%A0%D7%97\" title=\"נח\">נח</a> משחרר את היונה כדי לבדוק אם נגמר <a href=\"/index.php/%D7%94%D7%9E%D7%91%D7%95%D7%9C\" title=\"המבול\">המבול</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>ב'תמ\"ח – <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%99%D7%A0%D7%95\" title=\"משה רבינו\">משה רבינו</a> משליך מידיו את <a href=\"/index.php/%D7%9C%D7%95%D7%97%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"לוחות הברית\">לוחות הברית</a> הראשונות, בירידתו מ<a href=\"/index.php/%D7%94%D7%A8_%D7%A1%D7%99%D7%A0%D7%99\" title=\"הר סיני\">הר סיני</a>, לאחר שראה את <a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">עם ישראל</a> עובדים ל<a href=\"/index.php/%D7%A2%D7%92%D7%9C_%D7%94%D7%96%D7%94%D7%91\" class=\"mw-redirect\" title=\"עגל הזהב\">עגל הזהב</a>.</li>\n<li>ג'שלח – הופסקה הקרבת קרבנות ה<a href=\"/index.php/%D7%AA%D7%9E%D7%99%D7%93\" class=\"mw-redirect\" title=\"תמיד\">תמיד</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9\" title=\"בית המקדש\">בית המקדש</a> הראשון.</li>\n<li>ג'תתכ\"ח – נפרצו חומות <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> בתקופת <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A9%D7%A0%D7%99\" class=\"mw-redirect\" title=\"בית שני\">בית שני</a> על ידי ה<a href=\"/index.php?title=%D7%A8%D7%95%D7%9E%D7%90%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רומאים (הדף אינו קיים)\">רומאים</a> ונתבטל <a href=\"/index.php/%D7%A7%D7%A8%D7%91%D7%9F_%D7%94%D7%AA%D7%9E%D7%99%D7%93\" class=\"mw-redirect\" title=\"קרבן התמיד\">קרבן התמיד</a> ואפוסטמוס, קצין רומאי, שרף את התורה והציב צלם בבית המקדש.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%22%D7%A6\" title=\"ת&quot;צ\">ת\"צ</a> – רבי <a href=\"/index.php/%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%A8%D7%94%27%D7%A1\" title=\"לייב שרה&#39;ס\">לייב שרה'ס</a>, מתלמידי <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a> ו<a href=\"/index.php/%D7%94%D7%9E%D7%92%D7%99%D7%93_%D7%9E%D7%9E%D7%96%D7%A8%D7%99%D7%98%D7%A9\" title=\"המגיד ממזריטש\">המגיד ממזריטש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> – הרב <a href=\"/index.php/%D7%90%D7%A9%D7%A8_%D7%9C%D7%A2%D7%9E%D7%99%D7%9C_%D7%9B%D7%94%D7%9F\" title=\"אשר לעמיל כהן\">אשר לעמיל כהן</a>, רב קהילת חב\"ד ב<a href=\"/index.php/%D7%91%D7%99%D7%AA%D7%A8_%D7%A2%D7%99%D7%9C%D7%99%D7%AA\" title=\"ביתר עילית\">ביתר עילית</a>.</li>\n<li>? - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%A0%D7%98%D7%99%D7%96%D7%93%D7%94\" title=\"משה אנטיזדה\">משה אנטיזדה</a>, רב ושליח לקהילה הפרסית בנתניה.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> – הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"אהרן מרדכי זילברשטרום\">אהרן מרדכי זילברשטרום</a>, ממקימי <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">רשת אהלי יוסף יצחק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> – הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%90%D7%99%D7%99%D7%96%D7%A0%D7%91%D7%A8%D7%92\" title=\"ברוך אייזנברג\">ברוך אייזנברג</a> מותיקי אנ\"ש ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%91%D7%95%D7%98%D7%9E%D7%9F\" title=\"שמואל מנחם מענדל בוטמן\">שמואל מנחם מענדל בוטמן</a> מנהל <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"צעירי אגודת חב&quot;ד ארצות הברית\">צעירי אגודת חב\"ד ארצות הברית</a>, יו\"ר <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%9D_%D7%94%D7%A8%D7%9E%D7%91%22%D7%9D\" title=\"סיום הרמב&quot;ם\">סיום הרמב\"ם</a> העולמי, יו\"ר <a href=\"/index.php/%D7%90%D7%99%D7%92%D7%95%D7%93_%D7%A6%D7%90%D7%A6%D7%90%D7%99_%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"איגוד צאצאי רבינו הזקן\">איגוד צאצאי רבינו הזקן</a> ב<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ארצות הברית\">ארצות הברית</a> ויו\"ר <a href=\"/index.php/%D7%94%D7%9E%D7%98%D7%94_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99_%D7%9C%D7%94%D7%91%D7%90%D7%AA_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"המטה העולמי להבאת המשיח\">המטה העולמי להבאת המשיח</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%94%D7%A8%D7%9F_%D7%A0%D7%A4%D7%A8%D7%A1%D7%98%D7%A7\" title=\"ישראל אהרן נפרסטק\">ישראל אהרן נפרסטק</a> מ<a href=\"/index.php/%D7%96%D7%A7%D7%A0%D7%99_%D7%90%D7%A0%22%D7%A9\" title=\"זקני אנ&quot;ש\">זקני</a> חסידי חב\"ד בארץ הקודש וחבר <a href=\"/index.php/%D7%95%D7%95%D7%A2%D7%93_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"וועד כפר חב&quot;ד\">וועד כפר חב\"ד</a>.</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><sp