7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span> כ\"ד אב תשע\"ז</span>\n</li>\n<li id=\"cite_note-כפר-2\"><span class=\"mw-cite-backlink\">^ <sup><a href=\"#cite_ref-כפר_2-0\">1</a></sup> <sup><a href=\"#cite_ref-כפר_2-1\">2</a></sup> <sup><a href=\"#cite_ref-כפר_2-2\">3</a></sup></span> <span class=\"reference-text\">ש. מגידמן, <b>הדרכות שקיבלתי מהרבי</b>, מוסף נשימה של <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a> גליון מס' 2066 עמ' 29-30.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://www.chabad.org.il/Magazines/Article.asp?ArticleID=1803&amp;CategoryID=641\">גליון התקשרות מס' 555</a></span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">בית משיח גליון 174 ע' 36-38</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">בראיון שהעניקה רעייתו בת שבע למגזין נשימה של שבועון כפר חב\"ד היא מסופקת אם הרבי חזר על המשפט שלושה או ארבעה פעמים.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://www.chabad.org/therebbe/article_cdo/aid/142535/jewish/The-Rebbe-and-President-Reagan.htm\">\"הרבי והנשיא רונלד רייגן\" באתר chabad.org</a></span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\"><b><a rel=\"nofollow\" class=\"external text\" href=\"http://col.org.il/news/142803\">\"ממך ציפיתי ליותר\": בקשתו החריגה של נשיא ארצות הברית</a></b> - באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span> כ\"ו כסלו תשפ\"ג</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://www.col.org.il/show_news.rtx?artID=24627\">פיענוח כתי\"ק</a>.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\">ראשי תיבות <b>ז</b>ה <b>ב</b>ורר <b>ל</b>ו <b>א</b>חד <b>וז</b>ה <b>ב</b>ורר <b>ל</b>ו <b>א</b> - מצב בו שני בעלי הדין בוחרים דיין, ושני הדיינים הנבחרים בוררים דיין שלישי</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span class=\"reference-text\">בהסתמך על פסיקה של רבני <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%A8%D7%91%D7%A0%D7%99_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" class=\"mw-redirect\" title=\"ועד רבני ליובאוויטש העולמי\">ועד רבני ליובאוויטש העולמי</a>, שטענו כי הדיון בענייני הצוואה צריך להיערך לפניהם ולא לפני <a href=\"/index.php/%D7%91%D7%93%22%D7%A5_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" class=\"mw-redirect\" title=\"בד&quot;ץ קראון הייטס\">הבד\"צ בקראון הייטס</a> - בניגוד לטענת הבד\"ץ</span>\n</li>\n<li id=\"cite_note-11\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-11\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:1_210.jpg\" title=\"קובץ:1 210.jpg\">צילום המכתב</a></span>\n</li>\n<li id=\"cite_note-12\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-12\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://col.org.il/show_news.rtx?artID=54204\">לאחר 15 שנה: הוסר כתב ה\"לא צייתי לדינא\" ● כל הפרטים</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-13\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-13\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/index.php?url=article_he&amp;id=54190\">פסק דין ברור: להחלטות צד אחד אין כל תוקף</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D