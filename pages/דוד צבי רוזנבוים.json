      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><div class=\"nomobile\">\n<table class=\"ambox\" cellspacing=\"0\" style=\"border: 1px solid #9ACD32;background-color:#fcfcfc; -moz-border-radius: 1em 1em 1em 0; -webkit-border-radius: 1em 1em 1em 0; border-radius: 1em 1em 1em 0;;border-right:10px solid #9ACD32; width:80%; margin: auto;\">\n<tbody><tr>\n<td rowspan=\"2\" style=\"-moz-border-radius: 0 0.9em 0.9em 0; -webkit-border-radius: 0 0.9em 0.9em 0; border-radius: 0 0.9em 0.9em 0;;width:46px;vertical-align:middle;padding:0 7px;\" class=\"mbox-image\"><div class=\"mbox-image\" style=\"padding:3px;\"><span typeof=\"mw:File\"><span><img src=\"/images/thumb/1/19/Gnome-colors-emblem-development.svg/30px-Gnome-colors-emblem-development.svg.png\" decoding=\"async\" width=\"30\" height=\"30\" class=\"mw-file-element\" srcset=\"/images/thumb/1/19/Gnome-colors-emblem-development.svg/45px-Gnome-colors-emblem-development.svg.png 1.5x, /images/thumb/1/19/Gnome-colors-emblem-development.svg/60px-Gnome-colors-emblem-development.svg.png 2x\" /></span></span></div>\n</td>\n<td colspan=\"2\" class=\"mbox-text\" style=\"border-bottom:1px solid #9ACD32;\"><div class=\"mbox-text-span\"><b>ОбОеОџ ОќОћ ОаОъОдОљ ОЉОфОћОюОЎОџ ОбОЉОЋОЊОћ ОъОфОъОЕОџ.</b><br />ОћОбОеОџ <span style=\"color: green;\"><b>ОцОфОЋОЌ ОюОбОеОЎОЏОћ</b></span>.</div>\n</td></tr>\n<tr>\n<td style=\"vertical-align:center;font-size:90%;padding:2px 10px;\" class=\"hide-when-compact\">ОљОфОЮ ОъОЋОќОъОаОЎОЮ ОюОЉОдОб ОбОеОЎОЏОћ ОюОЕОЋОаОЎОф, ОЌОЉ\"ОЊОќОдОЎОћ ОЋОАОњОаОЋОЪ ОюОцОАОДОљОЋОф ОЕОаОЏОфОЉОЋ, ОЋОЏОъОЋ ОЏОЪ ОюОбОќОЋОе ОюОћОеОЌОЎОЉ ОЋОюОћОЕОюОЎОЮ ОљОф ОћОбОеОџ.\n</td>\n<td style=\"vertical-align:center;white-space:nowrap;width:60px;border-color:#9ACD32;border-width:0px 3px 0px 0px;border-style:solid;border-top-right-radius: 30px 30px;border-bottom-right-radius: 1px 1px;\" class=\"hide-when-compact\"><div class=\"plainlinks\" style=\"text-align:center;font-size:90%;padding:2px 10px;white-space:no-wrap;\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php?title=%D7%93%D7%95%D7%93_%D7%A6%D7%91%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D&amp;action=edit\">ОбОеОЎОЏОћ</a> - <a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%94:%D7%93%D7%95%D7%93_%D7%A6%D7%91%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D\" title=\"ОЕОЎОЌОћ:ОЊОЋОЊ ОдОЉОЎ ОеОЋОќОаОЉОЋОЎОЮ\">ОЕОЎОЌОћ</a></div>\n</td></tr></tbody></table></div>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A6%D7%91%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A4%D7%A8%D7%A7%D7%A9_%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%97%D7%AA%D7%95%D7%9B%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/0/0a/%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A6%D7%91%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A4%D7%A8%D7%A7%D7%A9_%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%97%D7%AA%D7%95%D7%9B%D7%94.jpg/250px-%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A6%D7%91%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A4%D7%A8%D7%A7%D7%A9_%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%97%D7%AA%D7%95%D7%9B%D7%94.jpg\" decoding=\"async\" width=\"250\" height=\"203\" class=\"mw-file-element\" srcset=\"/images/thumb/0/0a/%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A6%D7%91%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A4%D7%A8%D7%A7%D7%A9_%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%97%D7%AA%D7%95%D7%9B%D7%94.jpg/375px-%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A6%D7%91%D7%99_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%A4%D7%A8%D7%A7%D7%A9_%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%97%D7%AA%D7%95%D7%9B%D7%94.jpg 1.5x,