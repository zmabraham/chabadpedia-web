D7%94%D7%A7%D7%91%D7%A8%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"הליכה לבית הקברות (הדף אינו קיים)\">הליכה לבית הקברות</a> · <a href=\"/index.php/%D7%94%D7%A9%D7%AA%D7%98%D7%97%D7%95%D7%AA_%D7%A2%D7%9C_%D7%A7%D7%91%D7%A8%D7%99_%D7%A6%D7%93%D7%99%D7%A7%D7%99%D7%9D\" class=\"mw-redirect\" title=\"השתטחות על קברי צדיקים\">השתטחות על קברי צדיקים</a> · <a href=\"/index.php/%D7%97%D7%91%D7%A8%D7%90_%D7%A7%D7%93%D7%99%D7%A9%D7%90\" title=\"חברא קדישא\">חברא קדישא</a> · <a href=\"/index.php/%D7%AA%D7%97%D7%99%D7%99%D7%AA_%D7%94%D7%9E%D7%AA%D7%99%D7%9D\" title=\"תחיית המתים\">תחיית המתים</a> · <a href=\"/index.php/%D7%94%D7%99%22%D7%93\" class=\"mw-redirect\" title=\"הי&quot;ד\">הי\"ד</a>\n</td></tr>\n<tr>\n<th style=\"padding-left:15px;padding-right:15px;background:#cedff2; color: #000000;\"><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D\" title=\"בית החיים\">בתי עלמין</a></span>\n</th>\n<td colspan=\"2\" width=\"100%\" align=\"right\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A2%D7%9C%D7%9E%D7%99%D7%9F_%D7%A6%D7%A4%D7%AA\" title=\"בית העלמין צפת\">בית העלמין צפת</a> · <a href=\"/index.php/%D7%94%D7%A8_%D7%94%D7%9E%D7%A0%D7%95%D7%97%D7%95%D7%AA\" title=\"הר המנוחות\">הר המנוחות</a> · <a href=\"/index.php/%D7%97%D7%9C%D7%A7%D7%AA_%D7%97%D7%91%22%D7%93_%D7%94%D7%A8_%D7%94%D7%96%D7%99%D7%AA%D7%99%D7%9D\" title=\"חלקת חב&quot;ד הר הזיתים\">חלקת חב\"ד הר הזיתים</a> · <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A2%D7%9C%D7%9E%D7%99%D7%9F_%D7%9E%D7%95%D7%A0%D7%98%D7%99%D7%A4%D7%99%D7%95%D7%A8%D7%99\" title=\"בית העלמין מונטיפיורי\">בית העלמין מונטיפיורי</a> · <a href=\"/index.php/%D7%97%D7%9C%D7%A7%D7%AA_%D7%90%D7%A0%D7%A9%D7%99_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_(%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7)\" title=\"חלקת אנשי ליובאוויטש (ניו יורק)\">חלקת אנשי ליובאוויטש (ניו יורק)</a>\n</td></tr>\n<tr>\n<th style=\"padding-left:15px;padding-right:15px;bac