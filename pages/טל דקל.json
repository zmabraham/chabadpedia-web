    "pageid": 88122,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%98%D7%9C_%D7%93%D7%A7%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/6a/%D7%94%D7%A8%D7%91_%D7%98%D7%9C_%D7%93%D7%A7%D7%9C.jpg/220px-%D7%94%D7%A8%D7%91_%D7%98%D7%9C_%D7%93%D7%A7%D7%9C.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6a/%D7%94%D7%A8%D7%91_%D7%98%D7%9C_%D7%93%D7%A7%D7%9C.jpg/330px-%D7%94%D7%A8%D7%91_%D7%98%D7%9C_%D7%93%D7%A7%D7%9C.jpg 1.5x, /images/thumb/6/6a/%D7%94%D7%A8%D7%91_%D7%98%D7%9C_%D7%93%D7%A7%D7%9C.jpg/440px-%D7%94%D7%A8%D7%91_%D7%98%D7%9C_%D7%93%D7%A7%D7%9C.jpg 2x\" /></a><figcaption>הרב טל דקל</figcaption></figure>\n<p>הרב <b>טל דקל</b> (<a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a>, 1955 - <a href=\"/index.php/%D7%99%22%D7%90_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"י&quot;א סיוון\">י\"א סיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a>, 8 ביוני 2025) היה פעיל ב<a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%AA_%D7%94%D7%9E%D7%91%D7%A6%D7%A2%D7%99%D7%9D\" title=\"עשרת המבצעים\">מבצעי הרבי</a> ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>, <a href=\"/index.php/%D7%99%D7%95%D7%A7%D7%A0%D7%A2%D7%9D_%D7%A2%D7%99%D7%9C%D7%99%D7%AA\" class=\"mw-redirect\" title=\"יוקנעם עילית\">יוקנעם עילית</a>, ו<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a>, ובערוב ימיו שליח הרבי בבית הרפואה השיקומי גריאטרי גולדנקייר דושי שב<a href=\"/index.php/%D7%A0%D7%95%D7%A3_%D7%94%D7%92%D7%9C%D7%99%D7%9C\" title=\"נוף הגליל\">נצרת</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%9C_%D7%93%D7%A7%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%D7%9C_%D7%93%D7%A7%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד לר' יעקב ולשולמית שירה במשפחה שאינה שומרת תורה ומצוות במנהלה המקומית נווה שאנן שב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>.\n</p><p>לאחר שירות ב<a href=\"/index.php/%D7%A6%D7%94%22%D7%9C\" title=\"צה&quot;ל\">צה\"ל</a> למד באוניברסיטת בן גוריון ב<a href=\"/index.php/%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2\" title=\"באר שבע\">באר שבע</a>, שם <a href=\"/index.php/%D7%97%D7%96%D7%A8%D7%94_%D7%91%D7%AA%D7%A9%D7%95%D7%91%D7%94\" class=\"mw-redirect\" title=\"חזרה בתשובה\">חזר בתשובה</a> והתקרב ל<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חסידות חב\"ד</a> באמצעות שליח הרבי ורב האוניברסיטה הרב <a href=\"/index.php/%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C_%D7%A1%D7%95%D7%A4%D7%A8\" title=\"יחזקאל סופר\">יחזקאל סופר</a>.\n</p><p>נשא את עליזה וקבע את מקום מגוריו בחיפה. \n</p><p>לפרנסתו עבד בבית דפוס, בתקופת <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%9C%D7%91%D7%A0%D7%95%D7%9F_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%A0%D7%94\" title=\"מלחמת לבנון הראשונה\">מלחמת לבנון הראשונה</a>, בעת שהורה הרבי <a href=\"/index.php/%D7%94%D7%93%D7%A4%D7%A1%D7%AA_%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"הדפסת ספר התניא\">להדפיס את ספר התניא</a> בביירות, נמנה הרב דקל על המדפיסים כשההדפסה נעשית באמצעות מכונות הדפוס של העסק בו עבד.\n</p><p>שימש כפעיל <a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%9B%D7%A9%D7%A8%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מבצע כשרות\">מבצע כשרות</a>, הוא סבב בבתים שונים בחיפה כשמלבד הכשרת המטבחים דאג להשאיר מדריכות שילמדו עם בעלות המטבחים הלכות כשרות. \n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a> עבר לגור ב<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a> בשל הצורך להעניק לילדיו <a href=\"/index.php/%D7%97%D7%99%D7%A0%D7%95%D7%9A_%D7%A2%D7%9C_%D7%98%D7%94%D7%A8%D7%AA_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"חינוך על טהרת הקודש\">חינוך על טהרת הקודש</a>, לפרנסתו החל לעבוד כמנהל רכש במפעל אביבית - הדר בנוף הגליל.\n</p><p>מדי יום שישי סייע לפעילות אחיו הרב <a href=\"/index.php/%D7%A0%D7%95%D7%A2%D7%9D_%D7%93%D7%A7%D7%9C\" title=\"נועם דקל\">נועם דקל</a> בשליחותו ב<a href=\"/index.php/%D7%99%D7%95%D7%A7%D7%A0%D7%A2%D7%9D_%D7%A2%D7%99%D7%9C%D7%99%D7%AA\" class=\"mw-redirect\" title=\"יוקנעם עילית\">יוקנעם עילית</a>, סייע בחלוקת מזון למשפחות נזקקות ולמד <a href=\"/index.php/%D7%97%D7%91%D7%A8%D7%95%D7%AA%D7%90\" title=\"חברותא\">חברותא</a> קבועה ב<a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%A0%D7%99%D7%90\" title=\"ספר התניא\">ספר התניא</a> עם אחד מיהודי המקום.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a> החל לעסוק בפעילות <a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%91%D7%95%D7%AA_%D7%A9%D7%91%D7%AA\" title=\"מסיבות שבת\">מסיבות שבת</a> לילדי מגדל העמק בשל הוראת הרבי אליו ב<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> \"שיזכה להשפיע על הנוער בארץ ישראל\" ובשל הסברו של <a href=\"/index.php/%D7%9E%D7%96%D7%9B%D7%99%D7%A8\" class=\"mw-redirect\" title=\"מזכיר\">מזכיר</a> הרבי הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" title=\"יהודה לייב גרונר\">יהודה לייב גרונר</a> במענה לשאלת הרב דקל אליו כעבור שנים ממועד היחידות שכוונת הרבי היא לעריכת מסיבות שבת.\n</p><p>עם פרישתו ל<a href=\"/index.php/%D7%92%D7%9E%D7%9C%D7%90%D7%95%D7%AA\" class=\"mw-redirect\" title=\"גמלאות\">גמלאות</a> ממפעל אביבית - הדר החל לפעול ב<a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" title=\"מבצע תפילין\">מבצע תפילין</a> בבית הרפואה השיקומי גריאטרי גולדנקייר דושי שבנצרת כשכעבור תקופה קיבל משרת שליחות רשמית במקום תחת שליח הרבי הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A9%D7%95%D7%9F_%D7%94%D7%9C%D7%A4%D7%A8%D7%99%D7%9F\" title=\"שמשון הלפרין\">שמשון הלפרין</a>, מלבד הנחות תפילין סיפק ארוחות כשרות למהדרין וייעוץ למטופלים כשאלו מהם שהתגוררו במגדל העמק המשיכו לקבל ארוחות כשרות לביתם באמצעות בנו הרב לוי יצחק דקל.\n</p><p>נפטר בבוקר שבת <a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%A0%D7%A9%D7%90\" title=\"פרשת נשא\">פרשת נשא</a>, י\"א סיוון תשפ\"ה בהיותו בן שבעים ונטמן במוצאי שבת בבית הקברות במגדל העמק<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%9C_%D7%93%D7%A7%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%D7%9C_%D7%93%D7%A7%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, הרב <a href=\"/index.php/%D7%A0%D7%95%D7%A2%D7%9D_%D7%93%D7%A7%D7%9C\" title=\"נועם דקל\">נועם דקל</a> - שליח הרבי ב<a href=\"/index.php?title=%D7%99%D7%95%D7%A7%D7%A0%D7%A2%D7%9D_%D7%A2%D7%9C%D7%99%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יוקנעם עלית (הדף אינו קיים)\">יוקנעם עלית</a></li></ul>\n<p>לרב דקל ולרעייתו, שנים עשר בנים ובנות\n</p>\n<div align=\"right\" style=\"border: 1px solid #ddd;font-size:smaller; text-align: right; padding:5px 1em 5px 1em; width: auto;\">פרק זה לוקה בחסר. אנא <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%94:%D7%9B%D7%AA%D7%99%D7%91%D7%94_%D7%91%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94\" title=\"עזרה:כתיבה בחב&quot;דפדיה\">תרמו</a> לחב\"דפדיה והשלימו אותו. יתכן שיש על כך פירוט ב<a href=\"/index.php?title=%D7%A9%D7%99%D7%97%D7%94:%D7%98%D7%9C_%D7%93%D7%A7%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שיחה:טל דקל (הדף אינו קיים)\">דף השיחה</a>. \n</div>\n<ul><li>בנו ר' לוי יצחק דקל</li>\n<li>בנו ר' מנחם מענדל דקל</li>\n<li>בתו, גב' חנה, אשת ר' דוד יוסף אליאס - <a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%9C_%D7%93%D7%A7%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%D7%9C_%D7%93%D7%A7%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>טל יעסיס</b>, שבועון כפר חב\"ד, גיליון 2119 עמוד 58 (תשפ\"ה) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\"><img src=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/45px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg\" decoding=\"async\" width=\"45\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/68px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 1.5x, /images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/90px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/bdh/1217605/\">מוותיקי אנ\"ש במגדל העמק: הרב טל דקל ע\"ה</a> י\"א סיוון תשפ\"ה <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413173514\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.069 seconds\nReal time usage: 0.959 seconds\nPreprocessor visited node count: 164/1000000\nPost‐expand include size: 1535/2097152 bytes\nTemplate argument size: 113/2097152 bytes\nHighest expansion depth: 7/100\nExpensive parser function count: 1/100\nUnstrip recursion de