%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ו בתמוז\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ז בתמוז\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ח בתמוז\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ט בתמוז\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ד' בתמוז</b> הוא היום הרביעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ד'תתקל\"א – רבינו יעקב ב\"ר מאיר מרומרוג (<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%AA%D7%9D\" title=\"רבינו תם\">רבינו תם</a>), נפטר.</li>\n<li>ה'מ\"ו – רבי <a href=\"/index.php?title=%D7%9E%D7%90%D7%99%D7%A8_%D7%91%D7%9F_%D7%91%D7%A8%D7%95%D7%9A&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאיר בן ברוך (הדף אינו קיים)\">מאיר בן ברוך</a> מרוטנברג הושלך לכלא.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%94\" title=\"תקס&quot;ה\">תקס\"ה</a> – רבי <a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%94%D7%95%D7%A8%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"פנחס הורביץ\">פנחס הורביץ</a> מפרנקפורט דמיין, מחבר ספר 'הפלאה', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%97\" title=\"תרמ&quot;ח\">תרמ\"ח</a> – הפרופסור והסופר ר' <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%A4%D7%99%D7%A9%D7%9C_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F\" title=\"יהושע פישל שניאורסון\">יהושע פישל שניאורסון</a>, ממשפחת <a href=\"/index.php/%D7%A4%D7%95%D7%A8%D7%98%D7%9C:%D7%91%D7%99%D7%AA_%D7%A8%D7%91%D7%99\" title=\"פורטל:בית רבי\">בית הרב</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%98\" title=\"תקע&quot;ט\">תקע\"ט</a> – מרת <a href=\"/index.php/%D7%90%D7%A1%D7%AA%D7%A8_%D7%9E%D7%A8%D7%99%D7%9D_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99)\" title=\"אסתר מרים (בת אדמו&quot;ר האמצעי)\">אסתר מרים</a> בתו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%90%D7%9C%D7%99%D7%9E%D7%9C%D7%9A_%D7%9E%D7%A0%D7%92%D7%9C\" title=\"אליעזר אלימלך מנגל\">אליעזר אלימלך מנגל</a>, משלוחי הרבי ב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%92%27%D7%A8%D7%96%D7%99\" title=\"ניו ג&#39;רזי\">ניו ג'רזי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> – ה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> החסידי הרב <a href=\"/index.php/%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%95%D7%98%D7%A8%D7%A4%D7%A1\" class=\"mw-redirect\" title=\"מענדל פוטרפס\">מענדל פוטרפס</a>, מראשי הפעילים ב<a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%95\" title=\"יציאת רוסיה תש&quot;ו\">יציאת רוסיה תש\"ו</a>, ממקימי מוסדות חב\"ד ב<a href=\"/index.php/%D7%9C%D7%95%D7%A0%D7%93%D7%95%D7%9F\" title=\"לונדון\">לונדון</a>, ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> – הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%A0%D7%97%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"אהרון נחמן פרידמן\">אהרון נחמן פרידמן</a>, מזכיר המועצה האזורית עמק לוד שעשה רבות למען פיתוח <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> במסגרת תפקידו.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> – הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%93_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" title=\"יצחק דוד גרונר\">יצחק דוד גרונר</a>, שליח הרבי ב<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a> רב קהילת חב\"ד ומייסד מוסדות חב\"ד המקומיים.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ד' בתמוז - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסיד</a> אחד או תלמיד אחד כאשר נותן לבו <a href=\"/index.php/%D7%93%D7%A2%D7%AA\" class=\"mw-redirect\" title=\"דעת\">דעתו</a> ו<a href=\"/index.php/%D7%A0%D7%A4%D7%A9\" title=\"נפש\">נפשו</a> על ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> וחיזוקה, פועל ישועות בעיר גדולה בכל עניני העיר, והוא בדרך מלמעלה מדרך הטבע בזכות אבות העולם.\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">על פי מצבה שמצאו ר' <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%A0%D7%97%D7%A9%D7%95%D7%9F\" title=\"דוד נחשון\">דוד נחשון</a> ור' <a href=\"/index.php/%D7%90%D7%91%D7%99_%D7%98%D7%90%D7%95%D7%91\" class=\"mw-redirect\" title=\"אבי טאוב\">אבי טאוב</a> בבית החיים ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>, בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414043726\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.060 seconds\nReal time usage: 0.421 seconds\nPreprocessor visited node count: 140/1000000\nPost‐expand include size: 5771/2097152 bytes\nTemplate argument size: 698/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 492/5000000 bytes\nLua time usage: 0.010/7 seconds\nLua virtual size: 5206016/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  331.212      1 -total\n 66.37%  219.822      1 תבנית:הערה\n 20.43%   67.668      1 תבנית:הערות_שוליים\n  7.46%   24.709      1 תבנית:חודש_תמוז\n  5.63%   18.657      1 תבנית:להיום_יום\n  5.57%   18.465      1 תבנית:לוח_שנה_חסר\n  3.26%   10.811      1 תבנית:היום_יום/ד&#039;_תמוז\n  2.93%    9.711      1 תבנית:הערות_שוליים/מרחב_שם\n  2.36%    7.832      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:17039-0!canonical and timesta