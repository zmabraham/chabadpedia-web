D7%93%D7%A8\" title=\"כ&quot;ח באדר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ט באדר\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ל&#39; באדר\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<dl><dd><dl><dd><small>הבהרה: ערך זה עוסק גם בב&#39; באדר א' וגם בב&#39; באדר ב'.</small></dd></dl></dd></dl>\n<p><b>ב' באדר</b> הוא היום השני ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">חודש אדר</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%91\" title=\"תקס&quot;ב\">תקס\"ב</a> (אדר ראשון) - רבי <a href=\"/index.php?title=%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91_%D7%90%D7%9C%D7%92%D7%90%D7%96%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יום טוב אלגאזי (הדף אינו קיים)\">יום טוב (מהרי\"ט) אלגאזי</a>, הראשון לציון וראש ישיבת המקובלים בית אל ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> - רבי יעקב יחזקיה גרינוואלד (הראשון) מ<a href=\"/index.php/%D7%A4%D7%90%D7%A4%D7%90\" class=\"mw-redirect\" title=\"פאפא\">פאפא</a>, מחבר הספר \"ויגד יעקב\", שכיהן כרב וכראש הישיבה בפאפא שבהונגריה, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a> - רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%9C%D7%AA%D7%A8\" title=\"ישראל אלתר\">ישראל אלתר</a>, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php/%D7%92%D7%95%D7%A8\" class=\"mw-redirect\" title=\"גור\">גור</a> ומחבר ספר 'בית ישראל', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%97%22%D7%A6\" title=\"תרח&quot;צ\">תרח\"צ</a> (אדר ראשון) - החל <a href=\"/index.php/%D7%9E%D7%90%D7%A1%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D_%D7%AA%D7%A8%D7%A6%22%D7%97\" class=\"mw-redirect\" title=\"מאסר חסידים תרצ&quot;ח\">גל מעצרים</a> ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a>, בו נעצרו עשרות חסידים.</li></ul>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a> - הרבי אמר שיחה שמכונה בשם ' חשבונו של עולם ', בעיינים עצומות ולאח\"כ חילק דולרים<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> (אדר ראשון) - נרצחה הגברת <a href=\"/index.php/%D7%A4%D7%A2%D7%A9%D7%90_%D7%9C%D7%90%D7%94_%D7%9C%D7%90%D7%A4%D7%99%D7%99%D7%9F\" title=\"פעשא לאה לאפיין\">פעשא לאה לאפיין</a>, מנשות חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li></ul>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> (אדר שני) - התקיים ב<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a> ערב ההשקה בו החל לפעול מיזם <a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A0%D7%95%D7%A2%D7%99_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"אופנועי הגאולה\">אופנועי הגאולה</a> ל<a href=\"/index.php/%D7%A4%D7%A8%D7%A1%D7%95%D7%9D_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" title=\"פרסום גאולה ומשיח\">פרסום בשורת הגאולה</a>, ביוזמת <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> הרב מאיר צמח.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%98\" title=\"תרצ&quot;ט\">תרצ\"ט</a> - הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%92%D7%95%D7%9C%D7%93%D7%A9%D7%9E%D7%99%D7%93\" title=\"מרדכי יוסף אלעזר גולדשמיד\">מרדכי יוסף אלעזר גולדשמיד</a> ר\"מ בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"תומכי תמימים בני ברק\">תומכי תמימים בני ברק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> (אדר ראשון) - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%91%D7%A7%D7%A8%D7%9E%D7%9F\" title=\"ישראל שמעון בקרמן\">ישראל שמעון בקרמן</a>, חסיד חב\"ד מ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> ומחברי <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"צעירי אגודת חב&quot;ד ארץ הקודש\">צעירי אגודת חב\"ד ארץ הקודש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%92\" title=\"תשי&quot;ג\">תשי\"ג</a> - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%95%D7%93%D7%9E%D7%9F\" title=\"שניאור זלמן גודמן\">שניאור זלמן גודמן</a>, מ<a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"שלוחי הרבי לארץ הקודש\">שלוחי הרבי לארץ הקודש</a> ושליח ב<a href=\"/index.php/%D7%90%D7%A9%D7%93%D7%95%D7%93\" title=\"אשדוד\">אשדוד</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> (אדר שני) - ר' <a href=\"/index.php/%D7%93%D7%A0%D7%99%D7%90%D7%9C_%D7%99%D7%A6%D7%97%D7%A7_%D7%9E%D7%95%D7%A1%D7%A7%D7%95%D7%91%D7%99%D7%A5\" title=\"דניאל יצחק מוסקוביץ\">דניאל יצחק מוסקוביץ</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בשיקגו, אילנוי, וחבר ה'<a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9C%D7%A2%D7%A0%D7%99%D7%A0%D7%99_%D7%97%D7%99%D7%A0%D7%95%D7%9A\" title=\"מרכז לעניני חינוך\">מרכז לעניני חינוך</a>'.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> (אדר שני) - ר' <a href=\"/index.php/%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%99%D7%A0%D7%A8\" class=\"mw-redirect\" title=\"לייב שיינר\">לייב שיינר</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בבוסטון.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> (אדר ראשון) - הרב <a href=\"/index.php/%D7%99%D7%A7%D7%95%D7%AA%D7%99%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%9F\" title=\"יקותיאל גרין\">יקותיאל גרין</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> אנ\"ש ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, וסופר חב\"די.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ב' באדר א' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%92%D7%93%D7%95%D7%9C\" class=\"mw-redirect\" title=\"רבינו הגדול\">רבינו הגדול</a> - הזקן - סידר לפני אנשי-שלומינו העבודה ב<a href=\"/index.php/%D7%9E%D7%95%D7%97\" title=\"מוח\">מוח</a> ולחפש את ה<a href=\"/index.php/%D7%90%D7%9E%D7%AA\" title=\"אמת\">אמת</a>, לבקר כל תנועה, שתהיה רק כפי האמת ובאה על ידי <a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"עבודת ה&#39;\">עבודה</a>. ועבודה זו אינה כמו שטועים בזה טעות גמור לחשוב שצריך לפרק הרים ולשבר סלעים, איבערקערען די וועלט (= להפוך את העולם). האמת הגמור הוא, אשר כל עבודה ופועל, איזה שיהיו, בכוונה אמיתית די ומספיק: א ברכה בכוונה, דעם ווארט אין דאווענען כדבעי בהכנת ה<a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a> ובידיעה לפני מי אתה עומד, א פסוק <a href=\"/index.php/%D7%97%D7%95%D7%9E%D7%A9_(%D7%A1%D7%A4%D7%A8)\" title=\"חומש (ספר)\">חומש</a> בידיעה שהוא דבר ה', א פסוק <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D\" title=\"תהלים\">תהלים</a>, ו<a href=\"/index.php?title=%D7%9E%D7%99%D7%93%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מידה (הדף אינו קיים)\">מידה</a> <a href=\"/index.php/%D7%98%D7%95%D7%91\" title=\"טוב\">טובה</a> לקרב ליבו של <a href=\"/index.php?title=%D7%97%D7%91%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חבר (הדף אינו קיים)\">חברו</a> ב<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94\" title=\"אהבה\">אהבה</a> וחבה (= ברכה בכוונה, מילה זו בתפילה כדבעי בהכנת ה<a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a> ובידיעה לפני מי אתה עומד, פסוק <a href=\"/index.php/%D7%97%D7%95%D7%9E%D7%A9_(%D7%A1%D7%A4%D7%A8)\" title=\"חומש (ספר)\">חומש</a> בידיעה שהוא דבר ה', פסוק <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D\" title=\"תהלים\">תהלים</a> ו<a href=\"/index.php/%D7%9E%D7%99%D7%93%D7%95%D7%AA_(%D7%91%D7%90%D7%93%D7%9D)\" title=\"מידות (באדם)\">מידה</a> <a href=\"/index.php/%D7%98%D7%95%D7%91\" title=\"טוב\">טובה</a> לקרב לבו של <a href=\"/index.php?title=%D7%97%D7%91%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חבר (הדף אינו קיים)\">חברו</a> ב<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94\" title=\"אהבה\">אהבה</a> וחיבה).\n<p>אמת הדבר, אשר בכדי להגיע לזה צריכים יגיעת רבה ועצומה, פשוט לערנען א רבוי און פארשטיין (= ללמוד בריבוי ולהבין) - כל אחד לפי ערכו - ואז ה' בעזרו שיהיה כפי האמת.\n</p>\n</td></tr></tbody></table>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ב' באדר ב' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ה<a href=\"/index.php/%D7%91%D7%A8%D7%9B%D7%94\" title=\"ברכה\">ברכה</a> צריכה לאיזה דבר שתאחז בו, וכמו המטר על שדה חרושה וזרועה, או היורה ומלקוש על תבואת השדה והכרם. אבל בשדה בור לא חרושה ולא זרועה, אין המטר יורה ומלקוש מביאים תועלת.\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1ZizAuXqA0armQhBw-GD4j_3y73gvhDJF/view?usp=drivesdk\">שיחת ב אדר מ\"ח</a></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413043221\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU 