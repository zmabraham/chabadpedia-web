      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table border=\"0\" cellpadding=\"4\" cellspacing=\"0\" style=\"margin: 0 1.5em 0 0; float:left; clear:left; border:1px solid #aaa; background-color:#f9f9f9; width:200px; direction:rtl;\">\n\n<tbody><tr>\n<th colspan=\"12\" style=\"background:#98FB98; text-align:center\"><a href=\"/index.php/%D7%9E%D7%A1%D7%A4%D7%A8%D7%99%D7%9D_(%D7%A1%D7%A4%D7%A8%D7%95%D7%AA)\" title=\"ОъОАОцОеОЎОЮ (ОАОцОеОЋОф)\">ОъОАОцОе</a> ОљОеОЉОбОЎОЮ\n</th></tr>\n<tr>\n<td colspan=\"12\" style=\"background:white; text-align:center; padding:0;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%A1%D7%A4%D7%A8_40.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/70/%D7%9E%D7%A1%D7%A4%D7%A8_40.jpg/150px-%D7%9E%D7%A1%D7%A4%D7%A8_40.jpg\" decoding=\"async\" width=\"150\" height=\"106\" class=\"mw-file-element\" srcset=\"/images/thumb/7/70/%D7%9E%D7%A1%D7%A4%D7%A8_40.jpg/225px-%D7%9E%D7%A1%D7%A4%D7%A8_40.jpg 1.5x, /images/thumb/7/70/%D7%9E%D7%A1%D7%A4%D7%A8_40.jpg/300px-%D7%9E%D7%A1%D7%A4%D7%A8_40.jpg 2x\" /></a></span>\n</td></tr>\n<tr>\n<th colspan=\"12\" style=\"background:#BFD7FF; text-align:center\">ОљОЌОЊОЋОф ОЋОбОЕОеОЋОф\n</th></tr>\n<tr style=\"text-align:center;\">\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%90%D7%A4%D7%A1&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОљОцОА (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">0</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/1_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"1 (ОъОАОцОе)\">1</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%AA%D7%99%D7%99%D7%9D\" title=\"ОЕОфОЎОЎОЮ\">2</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%A9\" title=\"ОЕОюОЋОЕ\">3</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2\" title=\"ОљОеОЉОб\">4</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%97%D7%9E%D7%A9\" title=\"ОЌОъОЕ\">5</a>\n</td>\n<td st