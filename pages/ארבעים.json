e=\"ОъОљОћ\">100</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%9E%D7%90%D7%94_%D7%95%D7%90%D7%97%D7%93\" title=\"ОъОљОћ ОЋОљОЌОЊ\">101</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php?title=%D7%9E%D7%90%D7%AA%D7%99%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОъОљОфОЎОЎОЮ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">200</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%A8%D7%99%22%D7%95\" title=\"ОеОЎ&quot;ОЋ\">216</a>\n</td>\n<td style=\"width:15%\"><a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%A9_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОюОЋОЕ ОъОљОЋОф (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">300</a>\n</td>\n<td style=\"width:15%\"><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2_%D7%9E%D7%90%D7%95%D7%AA\" title=\"ОљОеОЉОб ОъОљОЋОф\">400</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%97%D7%9E%D7%A9_%D7%9E%D7%90%D7%95%D7%AA\" title=\"ОЌОъОЕ ОъОљОЋОф\">500</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php?title=%D7%A9%D7%A9_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОЕ ОъОљОЋОф (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">600</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td colspan=\"12\">\n<table style=\"width:100%;\">\n<tbody><tr>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%A9%D7%91%D7%A2_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОЉОб ОъОљОЋОф (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">700</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/770_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"770 (ОъОАОцОе)\">770</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%A0%D7%94_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОъОЋОаОћ ОъОљОЋОф (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">800</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%AA%D7%A9%D7%A2_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОфОЕОб ОъОљОЋОф (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">900</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"ОљОюОБ (ОъОАОцОе)\">1000</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%A9%D7%99%D7%A9%D7%99%D7%9D_%D7%A8%D7%99%D7%91%D7%95%D7%90\" title=\"ОЕОЎОЕОЎОЮ ОеОЎОЉОЋОљ\">600,000</a>\n</td></tr>\n</tbody></table>\n</td></tr>\n</tbody></table>\n</td></tr>\n</tbody></table>\n<p>ОћОъОАОцОе <b>ОљОеОЉОбОЎОЮ</b> ОъОЋОеОћ ОбОю ОбОаОЎОЪ ОЕОю ОЉОЎОўОЋОю ОЋОћОЉОЊОюОћ, ОЋОњОЎОюОЋОЎ ОаОДОЋОЊОф ОћОЌОЏОъОћ.\n</p><p>ОъОАОцОе ОќОћ ОДОЕОЋОе ОњОЮ ОбОЮ ОћОЉОЊОюОћ ОЉОЎОЪ ОЕОаОЎ ОъОдОЉОЎОЮ ОЕОЋОаОЎОЮ, ОЉОЊОЋОњОъОф ОћОЉОЊОюОћ ОЉОЎОЪ ОъОдОЉ ОЕОю ОўОЋОъОљОћ ОЋОўОћОеОћ, ОЋОЏОЊОЋОъОћ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ОбОю ОцОЎ ОцОаОЎОъОЎОЋОф, ОћОеОЉОћ ОъОћОбОаОЎОаОЎОЮ ОћОДОЕОЋОеОЎОЮ ОЉОъОАОцОе ОљОеОЉОбОЎОЮ ОДОЕОЋОеОЎОЮ ОбОЮ ОљОеОЉОбОф ОљОЋОфОЎОЋОф ОЕОЮ ОћОЕОЮ ОЏОцОЎ ОЕОЏОю ОљОЌОф ОЏОюОЋОюОћ ОъОбОЕОе - ОЕОћОбОЕОе ОДОЕОЋОе ОбОЮ ОъОАОцОе ОЎОЋ\"ОЊ ОЕОбОаОЎОаОЋ ОћОЋОљ ОЉОЎОўОЋОю ОЋОћОфОњОюОЋОф ОаОДОЋОЊОф ОћОЌОЏОъОћ ОћОъОфОцОЕОўОф ОЉОЏОю ОћОбОЋОюОъОЋОф<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.9E.D7.A1.D7.A4.D7.A8_.D7.91.D7.AA.D7.95.D7.A8.D7.94\"></span><span class=\"mw-headline\" id=\"ОћОъОАОцОе_ОЉОфОЋОеОћ\">ОћОъОАОцОе ОЉОфОЋОеОћ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОћОъОАОцОе ОЉОфОЋОеОћ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОћОъОАОцОе ОЉОфОЋОеОћ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОЉОфОЋОеОћ ОъОЋОцОЎОб ОћОъОАОцОе ОљОеОЉОбОЎОЮ ОЉОеОЎОЉОЋОЎ ОбОаОЎОаОЎОЮ:\n</p>\n<ul><li>ОљОеОЉОбОЎОЮ ОЎОЋОЮ ОЕОъОЕОћ ОеОЉОЎОаОЋ ОћОЎОћ ОбОю ОћОе ОАОЎОаОЎ (ОЕОюОЋОЕ ОцОбОъОЎОЮ, ОЏОю ОцОбОЮ ОљОеОЉОбОЎОЮ ОЎОЋОЮ).</li>\n<li>ОљОеОЉОбОЎОЮ ОАОљОћ ОЉ<a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94\" title=\"ОъОДОЋОЋОћ\">ОъОДОЋОЋОћ</a>.</li>\n<li>ОљОеОЉОбОЎОЮ ОЎОЋОЮ ОаОЎОфОџ ОћОъОЉОЋОю ОбОю ОћОљОеОЦ.</li>\n<li>ОљОеОЉОбОЎОЮ ОЎОЋОЮ ОфОеОЋ ОћОъОеОњОюОЎОЮ ОљОф ОћОљОеОЦ</li>\n<li>ОљОеОЉОбОЎОЮ ОЕОаОћ ОЕОЉОаОЎ ОЎОЕОеОљОю ОћОфОћОюОЏОЋ ОЉОъОЊОЉОе.</li>\n<li>ОљОеОЉОбОЎОЮ ОЎОЋОЮ ОљОдОю ОЊОЋОЊ ОЋОњОюОЎОф<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>\"ОЋОфОЕОДОЋОў ОћОљОеОЦ ОљОеОЉОбОЎОЮ ОЕОаОћ\"</li>\n<li>ОљОеОЉОбОЎОЮ ОЎОАОЋОЊОЋОф Ою<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9\" title=\"ОЉОЎОф ОћОъОДОЊОЕ\">ОЉОЎОф ОћОъОДОЊОЕ</a><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>ОцОфОЌОЋ ОЕОю ОљОЋОюОЮ ОћОЎОћ ОљОеОЉОбОЎОЮ ОљОъОћ.</li>\n<li>ОъОЕОћ ОеОЉОЎОаОЋ, ОеОЉОЎ ОбОДОЎОЉОљ, ОћОюОю ОћОќОДОЪ, ОеОЉОЎ ОЎОЋОЌОаОЪ ОЉОЪ ОќОЏОљОЎ, ОЌОЎОЎОћОЮ ОъОЌОЋОюОДОЎОЮ ОюОЕОюОЋОЕ ОфОДОЋОцОЋОф ОЕОю 40 ОЕОаОћ.</li>\n<li>ОљОеОЉОбОЎОЮ ОЎОЋОЮ ОљОЌОеОЎ ОЎОдОЎОеОф ОћОЋОюОЊ ОЏОЉОе ОаОбОЕОћ ОќОЏОЋОе ОљОЋ ОаОДОЉОћ<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>ОЉОЪ ОљОеОЉОбОЎОЮ ОюОЉОЎОаОћ.</li>\n<li>ОюОљОЌОе ОљОеОЉОбОЎОЮ ОЕОаОћ ОбОЋОъОЊ ОљОЊОЮ ОбОю ОбОЋОъОД ОЊОбОф ОеОЉОЋ, \"ОљОеОЉОбОЎОЪ ОЕОаОЎОЪ ОДОљОЎ ОљОЎОаОЎОЕ ОљОЊОбОфОЎ' ОЊОеОЉОЎ\".</li>\n<li>ОљОеОЉОбОЎОЮ ОЎОЋОЮ ОДОЋОЊОЮ ОЎОдОЎОеОф ОћОЋОюОЊ ОъОЏОеОЎОќОЎОЮ ОЉОф ОцОюОЋОаОЎ ОюОцОюОЋОаОЎ<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>ОљОеОЉОбОЎОЮ ОЕОаОћ ОЉОЎОЪ ОДОЎОЉОЋОЦ ОњОюОЋОЎОЋОф ОюОфОЌОЎОЎОф ОћОъОфОЎОЮ<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>ОфОбОаОЎОф ОфОЕОЋОЉОћ - ОљОеОЉОбОЎОЮ ОЎОЋОЮ<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>ОъОюОљОЏОф ОЉОЕОЉОф \"ОљОеОЉОбОЎОЮ ОЌОАОе ОљОЌОф\"</li>\n<li>ОљОеОЉОбОЎОЮ ОъОюОДОЋОф.</li>\n<li>ОљОеОЉОбОЎОЮ ОЌОюОЋОф ОфОЋОЊОћ (ОЕОюОЋОЕОЎОЮ ОЕОю ОъОдОћ ОЋОбОЕОе ОЕОю ОЌОъОЦ).</li></ul>\n<h2><span id=\".D7.94.D7.95.D7.A8.D7.90.D7.AA_.D7.90.D7.93.D7.9E.D7.95.22.D7.A8_.D7.94.D7.9E.D7.94.D7.A8.22.D7.A9\"></span><span class=\"mw-headline\" id=\"ОћОЋОеОљОф_ОљОЊОъОЋ&quot;Ое_ОћОъОћОе&quot;ОЕ\">ОћОЋОеОљОф ОљОЊОъОЋ\"Ое ОћОъОћОе\"ОЕ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОћОЋОеОљОф ОљОЊОъОЋ&quot;Ое ОћОъОћОе&quot;ОЕ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОћОЋОеОљОф ОљОЊОъОЋ&quot;Ое ОћОъОћОе&quot;ОЕ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"ОљОЊОъОЋ&quot;Ое ОћОъОћОе&quot;ОЕ\">ОљОЊОъОЋ\"Ое ОћОъОћОе\"ОЕ</a> ОдОЎОЋОЋОћ ОљОф ОљОЌОЊ ОћОЌОАОЎОЊОЎОЮ ОюОюОъОЋОЊ ОЏОю <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ОъОљОъОе ОЌОАОЎОЊОЋОф\">ОъОљОъОе ОЌОАОЎОЊОЋОф</a> ОљОеОЉОбОЎОЮ ОцОбОъОЎОЮ, ОЋОЉОљОЮ ОЎОбОЕОћ ОЏОЪ, ОЉОЏОю ОъОДОЋОЮ ОЕОЎОћОЎОћ - ОЎОЎОцОюОЋ ОюОЋ ОъОЌОЕОЉОЋОф ОъОфОЋОџ ОћОъОљОъОе.\n</p><p>ОбОдОћ ОќОЋ ОфОњОеОЋОЮ ОюОЏОџ ОЕОЎОЌОЕОЋОЉ ОЌОАОЎОЊОЋОф ОфОъОЎОЊ, ОЋОљОБ ОЎОЌОюОЋОЮ ОЌОАОЎОЊОЋОф, ОЕОћОеОЎ ОъОћ ОЕОЌОЋОЕОЉОЎОЮ ОЉОЎОЋОЮ ОЌОЋОюОъОЎОЮ ОЉОюОЎОюОћ. ОЋОъОЏОЎОЋОЋОЪ ОЕОљОЊОЮ 'ОњОЊОю ОЋОдОЋОъОЌ' ОЉОбОф ОћОЕОЎОаОћ, ОћОеОЎ ОЕОћОЋОљ ОЎОњОЊОю ОЋОЎОдОъОЌ ОЉОЌОАОЎОЊОЋОф.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ОеОљОЋ_ОњОЮ\">ОеОљОЋ ОњОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОеОљОЋ ОњОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОеОљОЋ ОњОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p><a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D_%D7%9C%27\" title=\"ОфОћОюОЎОЮ Ою&#39;\">ОфОћОюОЎОЮ Ою'</a>\n</p><p><br />\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОДОЎОЕОЋОеОЎОЮ_ОЌОЎОдОЋОаОЎОЎОЮ\">ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;veaction=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D&amp;action=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ОЕОаОЎОљОЋОе ОљОЕОЏОаОќОЎ, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/images/7/75/ОцОеОЕОћ_ОеОљОћ_ОфОЕОцОЊ.pdf\">ОљОеОЉОбОЎОЮ ОЎОЋОЮ ОЋОаОЋОЕОбОфОЎ</a></b>, ОњОюОЎОЋОЪ ОцОеОЕОћ ОеОљОћ ОфОЕОц\"ОЊ <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"ОДОЋОЉОЦ PDF\" rel=\"nofollow\"><img alt=\"ОДОЋОЉОЦ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОћОбОеОЋОф_ОЕОЋОюОЎОЎОЮ\">ОћОбОеОЋОф ОЕОЋОюОЎОЎОЮ</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://chabadlibrary.org/books/admur/tm/14/29/index.htm\">ОЕОЎОЌОф ОЏ\"ОБ ОъОаОЌОЮ ОљОЉ 