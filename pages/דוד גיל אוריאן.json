4_%D7%95%D7%9E%D7%A9%D7%99%D7%97_.jpg/440px-%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%93_%D7%92%D7%99%D7%9C_%D7%90%D7%95%D7%A8%D7%99%D7%90%D7%9F_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%91%D7%A2%D7%A0%D7%99%D7%99%D7%A0%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97_.jpg 2x\" /></a><figcaption>הרב דוד גיל אוריאן במסירת שיעור בענייני <a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"גאולה ומשיח\">גאולה ומשיח</a> ב<a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99_770\" class=\"mw-redirect\" title=\"מרכז חב&quot;ד העולמי 770\">מרכז חב\"ד העולמי 770</a>. <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a></figcaption></figure>\n<p>הרב <b>דוד גיל הכהן אוריאן</b> (נולד ב<a href=\"/index.php/%D7%92%27_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"ג&#39; תשרי\">ג' תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a>) הוא ראש ישיבת 'אור מנחם' <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חב\"ד</a> ב<a href=\"/index.php/%D7%90%D7%A9%D7%A7%D7%9C%D7%95%D7%9F\" title=\"אשקלון\">אשקלון</a> ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ו<a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%94%D7%95%D7%A8%D7%90%D7%94\" title=\"מורה הוראה\">מו\"צ</a> ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%99%D7%9C_%D7%90%D7%95%D7%A8%D7%99%D7%90%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%99%D7%9C_%D7%90%D7%95%D7%A8%D7%99%D7%90%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php?title=%D7%A8%D7%9E%D7%AA_%D7%99%D7%A9%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רמת ישי (הדף אינו קיים)\">רמת ישי</a> ב<a href=\"/index.php/%D7%92%27_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"ג&#39; תשרי\">ג' תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a> לרב <a href=\"/index.php?title=%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%9E%D7%A9%D7%94_%D7%90%D7%95%D7%A8%D7%99%D7%90%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מרדכי משה אוריאן (הדף אינו קיים)\">מרדכי משה אוריאן</a>.\n</p><p>למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> ובישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%AA%22%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" class=\"mw-redirect\" title=\"תות&quot;ל מגדל העמק\">תות\"ל מגדל העמק</a>.\n</p><p>לקראת שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a>, נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" title=\"תומכי תמימים המרכזית 770\">תומכי תמימים המרכזית 770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'. לאחר מכן שימש כשליח בבית חב\"ד ב<a href=\"/index.php/%D7%A1%D7%99%D7%93%D7%A0%D7%99\" title=\"סידני\">סידני</a> שב<a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%9C%D7%99%D7%94\" title=\"אוסטרליה\">אוסטרליה</a>. \n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> נשא את שרה בת הרב אליהו דהאן מ<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a> והתיישב שם. לאחר תקופת לימודים בכולל <a href=\"/index.php?title=%D7%90%D7%95%D7%94%D7%9C_%D7%97%D7%A0%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אוהל חנה (הדף אינו קיים)\">אוהל חנה</a> בנחלת הר חב\"ד נתמנה להיות ר\"מ בישיבת <a href=\"/index.php?title=%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ישיבת אור אבנר (הדף אינו קיים)\">אור אבנר</a> ב<a href=\"/index.php/%D7%A8%D7%9E%D7%9C%D7%94\" title=\"רמלה\">רמלה</a>. עם הקמת ישיבת אור מנחם חב\"ד <a href=\"/index.php/%D7%90%D7%A9%D7%A7%D7%9C%D7%95%D7%9F\" title=\"אשקלון\">אשקלון</a>, החל לשמש כראש הישיבה.\n</p><p>במקביל לעבודה בישיבה, משמש כמשפיע בבית הכנסת אהל לוי יצחק בשכונת המחנה ומוסר שיעורי <a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"תניא\">תניא</a> ו<a href=\"/index.php/%D7%94%D7%9C%D7%9B%D7%94\" title=\"הלכה\">הלכה</a>, כמו כן עוסק בייעוץ זוגי ובהשכנת שלום בית.\n</p>\n<div class=\"stub\" style=\"background-color:#FFFCFC; border-color:#CCCCCC; border-style:double; border-width:3px; clear:both; padding-top:4px; padding-bottom:4px; padding-right:7px; margin:0.5em 0 0.5em 0;vertical-align:middle;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/50px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" decoding=\"async\" width=\"50\" height=\"50\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/75px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 1.5x, /images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/100px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 2x\" /></a></span> &#160; ערך זה הוא <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8\" title=\"חב&quot;דפדיה:קצרמר\">קצרמר</a>&#160;בנושא <a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8_%D7%90%D7%99%D7%A9%D7%99%D7%9D\" title=\"קטגוריה:קצרמר אישים\">אישים</a>. אתם מוזמנים <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%A8%D7%95%D7%9B%D7%99%D7%9D_%D7%94%D7%91%D7%90%D7%99%D7%9D#כתיבה_בחב&quot;דפדיה\" title=\"חב&quot;דפדיה:ברוכים הבאים\">לתרום</a> לחב\"דפדיה ו<b><span class=\"plainlinks\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php?title=%D7%93%D7%95%D7%93_%D7%92%D7%99%D7%9C_%D7%90%D7%95%D7%A8%D7%99%D7%90%D7%9F&amp;action=edit&amp;editintro=%D7%AA%D7%91%D7%A0%D7%99%D7%AA%3A%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8%2F%D7%94%D7%A8%D7%97%D7%91%D7%94%2F%D7%90%D7%99%D7%A9%D7%99%D7%9D\">להרחיב אותו</a></span></b>.</div>\n<!-- \nNewPP limit report\nCached time: 20260414045850\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.028 seconds\nReal time usage: 0.059 seconds\nPreprocessor visited node count: 100/1000000\nPost‐expand include size: 3525/2097152 bytes\nTemplate argument size: 169/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   28.554      1 תבנית:קצרמר\n100.00%   28.554      1 -total\n 84.95%   24.257      1 תבנית:קצרמר/קוד\n 39.26%   11.209      1 תבנית:רווח_קשיח\n 14.15%    4.041      1 תבנית:קצ