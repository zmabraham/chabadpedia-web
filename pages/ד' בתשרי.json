      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"א&#39; בתשרי\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ב&#39; בתשרי\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ג&#39; בתשרי\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ה&#39; בתשרי\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ו&#39; בתשרי\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ז&#39; בתשרי\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ח&#39; בתשרי\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&#39; בתשרי\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&#39; בתשרי\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;א בתשרי\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ב בתשרי\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ג בתשרי\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ד בתשרי\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&quot;ו בתשרי\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ט&quot;ז בתשרי\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ז בתשרי\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ח בתשרי\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"י&quot;ט בתשרי\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&#39; בתשרי\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;א בתשרי\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ב בתשרי\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ג בתשרי\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ד בתשרי\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ה בתשרי\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ו בתשרי\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ז בתשרי\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ח בתשרי\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ט בתשרי\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ל&#39; בתשרי\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ד&#39; בתשרי</b> הוא היום הרביעי\nבחודש הראשון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;והיום הרביעי ב<a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%AA_%D7%99%D7%9E%D7%99_%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"עשרת ימי תשובה\">עשרת ימי תשובה</a>.\n</p><p>תאריך זה חל בתקופת תשרי&#160;והוא יכול לחול בימים&#160;ראשון, שלישי, חמישי ושישי.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A7%22%D7%97\" title=\"תק&quot;ח\">תק\"ח</a> (08/09/1747 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי צבי הירש אשכנזי מהלברשטאט, מחבר ספר 'כוס הישועות', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A4%22%D7%90\" title=\"תקפ&quot;א\">תקפ\"א</a> (12/09/1820 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי אברהם דנציג, מחבר ספר 'חיי אדם', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%96\" title=\"תקנ&quot;ז\">תקנ\"ז</a> (06/10/1796 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי ישראל יעקב בורלא, מחבר ספר 'מקור ישראל נחלת יהודה', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%22%D7%97\" title=\"תר&quot;ח\">תר\"ח</a> (14/09/1847 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יצחק אריה וורמסר, 'בעל שם' ממיכלשטאט, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%95\" title=\"תרצ&quot;ו\">תרצ\"ו</a> - הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"מרדכי גולדברג\">מרדכי גולדברג</a>, משפיע בקהילת חב\"ד <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>. שימש בעבר כמזכיר <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"צעירי אגודת חב&quot;ד בארץ הקודש\">צעירי אגודת חב\"ד בארץ הקודש</a>, מנהל ישיבות <a href=\"/index.php/%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" title=\"אחי תמימים ראשון לציון\">אחי תמימים ראשון לציון</a> ו<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%94%D7%91%D7%95%D7%9B%D7%A8%D7%99%D7%9D\" title=\"ישיבת הבוכרים\">ישיבת הבוכרים</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%22%D7%94\" title=\"תש&quot;ה\">תש\"ה</a> - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%9E%D7%95%D7%98%D7%A7%D7%99%D7%9F\" title=\"ישראל שמוטקין\">ישראל שמוטקין</a>,<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> במילוואקי שבוויסקונסין, וחבר <a href=\"/index.php/%D7%90%D7%92%D7%95%22%D7%97_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99%D7%AA\" class=\"mw-redirect\" title=\"אגו&quot;ח העולמית\">אגו\"ח העולמית</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> - הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%91%D7%A8%D7%92%D7%9E%D7%9F\" title=\"יעקב ברגמן\">יעקב ברגמן</a> - מזקני ומחשובי אנ\"ש ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%22%D7%9B\" title=\"תש&quot;כ\">תש\"כ</a> (06/10/1959 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%97%D7%99%D7%99%D7%9D_%D7%93%D7%99%D7%A1%D7%A7%D7%99%D7%9F\" class=\"mw-redirect\" title=\"שלמה חיים דיסקין\">שלמה חיים דיסקין</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח הרבי</a> ורב העיר <a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%90%D7%AA%D7%90\" title=\"קריית אתא\">קריית אתא</a></li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><b>ה'תע\"ד (24/09/1713 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%99%D7%95%D7%90%D7%9C_%D7%94%D7%9C%D7%A4%D7%A8%D7%99%D7%9F\" class=\"mw-redirect\" title=\"יואל הלפרין\">יואל בעל שם</a> מאוסטראה, ממנהיגי חבורת הנסתרים שממנה יצאה <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">תנועת החסידות</a>.</b></li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> (03/10/2008 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%94%D7%9C%D7%9C_%D7%A4%D7%91%D7%96%D7%A0%D7%A8\" title=\"הלל פבזנר\">הלל פבזנר</a>, אב בית הדין של <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%A8%D7%91%D7%A0%D7%99_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"ועד רבני ליובאוויטש צרפת\">ועד רבני ליובאוויטש צרפת</a> וחבר <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%A8%D7%91%D7%A0%D7%99_%D7%90%D7%99%D7%A8%D7%95%D7%A4%D7%94\" title=\"מרכז רבני אירופה\">מרכז רבני אירופה</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> (28/09/2014 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%9C%D7%99%D7%99%D7%91%D7%95%D7%A9_%D7%94%D7%A8%D7%A6%D7%9C\" class=\"mw-redirect\" title=\"פנחס לייבוש הרצל\">פנחס לייבוש הרצל</a>, זקן חסידי חב\"ד ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> חב\"ד בשכונת מאה שערים ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%9E%D7%9C%D7%9E%D7%93\" title=\"משה מלמד\">משה מלמד</a>, פעיל חב\"ד בעיר <a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ד' בתשרי - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i><a href=\"/index.php/%D7%A6%D7%95%D7%9D_%D7%92%D7%93%D7%9C%D7%99%D7%94\" title=\"צום גדליה\">צום גדליה</a> נדחה. אבינו מלכנו. <a href=\"/index.php/%D7%A1%D7%9C%D7%99%D7%97%D7%95%D7%AA\" title=\"סליחות\">סליחות</a></i>.\n<p>קיצור ביאור <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> באופן הא':\n</p><p><b>ת</b>, \"תמים תהיה עם ה' אלוקיך\" - עבודת ה<a href=\"/index.php/%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"תשובה\">תשובה</a> הבאה על ידי ה<a href=\"/index.php/%D7%AA%D7%9E%D7%99%D7%9E%D7%95%D7%AA\" title=\"תמימות\">תמימות</a>, כמה בחינות ומדריגות בענין התמימות, וביחס אל התשובה העולה על כולנה היא תמימות ה<a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a> - הנקראת ערנסטקייט (= רצינות) - כאמור ב<a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D\" class=\"mw-redirect\" title=\"אברהם\">אברהם</a> \"ומצאת את לבבו נאמן לפניך\".\n</p>\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השביעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260414032308\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.094 seconds\nReal time usage: 0.209 seconds\nPreprocessor visited node count: 353/1000000\nPost‐expand include size: 8422/2097152 bytes\nTemplate argument size: 753/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 4/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 151/5000000 bytes\nLua time usage: 0.060/7 seconds\nLua virtual size: 6160384/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,templat