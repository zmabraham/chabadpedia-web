%95%D7%9F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ד&#39; בסיוון</b> הוא היום הרביעי\nבחודש התשיעי<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי.\n</p><p>תאריך זה חל בתקופת ניסן&#160;והוא יכול לחול בימים&#160;שני, רביעי, שישי ושבת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח – ה' ציווה ל<a href=\"/index.php/%D7%9E%D7%A9%D7%94\" class=\"mw-redirect\" title=\"משה\">משה</a> מי האנשים שיעלו להר סיני במעמד מתן תורה.</li>\n<li>ב'תמ\"ח – משה את ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> מ<a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%91%D7%A8%D7%90%D7%A9%D7%99%D7%AA\" title=\"פרשת בראשית\">פרשת בראשית</a> עד פרשת מתן תורה.</li>\n<li>ד'תתנ\"ו – מסע הצלב בערים שפירא וורמייזא ומגנצא.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%9B%22%D7%96\" title=\"תקכ&quot;ז\">תקכ\"ז</a> – רבי מנשה יהושע פאדווא ממודינא, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%94\" title=\"תרמ&quot;ה\">תרמ\"ה</a> – רבי ישעיה נפתלי הרץ מדינוב, מחבר ספר 'הנותן אמרי שפר', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%90\" title=\"תשס&quot;א\">תשס\"א</a> – רבי צבי הכהן טורנהיים מלאקווא-וולברוז', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> – יצא ה'עשאלון' הראשון במסגרת התארגנות החסידים לבריחה ההמונית מרוסיה, שנודעה בשם יציאת רוסיה תש\"ו</li>\n<li>בשנת תשל\"ד – הרבי יצא בהכרזה על <a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%91%D7%99%D7%AA_%D7%9E%D7%9C%D7%90_%D7%A1%D7%A4%D7%A8%D7%99%D7%9D\" title=\"מבצע בית מלא ספרים\">מבצע בית מלא ספרים</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%91\" title=\"תרפ&quot;ב\">תרפ\"ב</a> – הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%97%D7%95%D7%A1%D7%99%D7%93%D7%95%D7%91\" title=\"שניאור זלמן חוסידוב\">שניאור זלמן חוסידוב</a>, מנכבדי הקהילה החסידית ב<a href=\"/index.php/%D7%A4%D7%95%D7%9C%D7%98%D7%91%D7%94\" class=\"mw-redirect\" title=\"פולטבה\">פולטבה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> – הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D_%D7%A7%D7%9C%D7%99%D7%99%D7%9F\" title=\"שמואל מנחם קליין\">שמואל מנחם קליין</a>, מהדמויות המרכזיות בקהילות חב\"ד ב<a href=\"/index.php/%D7%A4%D7%95%D7%9C%D7%98%D7%91%D7%94\" class=\"mw-redirect\" title=\"פולטבה\">פולטבה</a> וב<a href=\"/index.php/%D7%98%D7%A9%D7%A7%D7%A0%D7%98\" title=\"טשקנט\">טשקנט</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%97%D7%9F\" class=\"mw-redirect\" title=\"דובער חן\">דובער חן</a>, מזקני אנ\"ש ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%AA%D7%A8_%D7%9E%D7%A9%D7%94_%D7%91%D7%9C%D7%95%D7%99\" class=\"mw-redirect\" title=\"אלתר משה בלוי\">אלתר משה בלוי</a>, מחנך ומנהל ארגוני חסד ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%91%D7%99%D7%A1%D7%98%D7%A8%D7%99%D7%A6%D7%A7%D7%99\" title=\"יהודה לייב ביסטריצקי\">יהודה לייב ביסטריצקי</a>, מייסד ארגון <a href=\"/index.php/%D7%94%D7%A6%D7%9C%D7%94_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"הצלה קראון הייטס\">הצלה קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"שלום דובער אלפרוביץ&#39;\">שלום דובער אלפרוביץ'</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%94%D7%99%D7%99%D7%91%D7%9F\" title=\"ניו הייבן\">ניו הייבן</a>-<a href=\"/index.php?title=%D7%A7%D7%95%D7%A0%D7%98%D7%99%D7%A7%D7%98&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"קונטיקט (הדף אינו קיים)\">קונטיקט</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ד' בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>מח לעומר</i>\n<p><a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a> הוא זמן המוכשר לעשות הכל לטובת <a href=\"/index.php/%D7%9C%D7%99%D7%9E%D7%95%D7%93_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" title=\"לימוד התורה\">לימוד התורה</a> וה<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודה</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%90%D7%AA_%D7%A9%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"יראת שמים\">יראת שמים</a>, וכן להתעסק ב<a href=\"/index.php/%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"תשובה\">תשובה</a> בהנוגע ל<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> באין מפריע משטן המקטרג, כדוגמת זמן התקיעות בר\"ה ויום הקדוש דצום הכפורים.\n</p>\n<div style=\"clear: right; float: right;\"><b><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D/%D7%92%27_%D7%A1%D7%99%D7%95%D7%9F\" title=\"תבנית:היום יום/ג&#39; סיון\">ליום הקודם</a></b></div>\n<div style=\"clear: left; float: left;\"><b><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D/%D7%94%27_%D7%A1%D7%99%D7%95%D7%9F\" title=\"תבנית:היום יום/ה&#39; סיון\">ליום הבא</a></b></div>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השלישי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414045335\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.094 seconds\nReal time usage: 0.306 seconds\nPrepro