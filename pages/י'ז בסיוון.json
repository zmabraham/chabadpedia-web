F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י&#34;ז בסיוון</b> הוא היום השבעה עשר\nבחודש התשיעי<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי.\n</p><p>תאריך זה חל בתקופת ניסן&#160;והוא יכול לחול בימים&#160;ראשון, שלישי, חמישי ושישי.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>א'תרנ\"ו - <a href=\"/index.php/%D7%AA%D7%99%D7%91%D7%AA_%D7%A0%D7%97\" title=\"תיבת נח\">תיבת נח</a> נחה על הרי אררט לאחר ה<a href=\"/index.php/%D7%9E%D7%91%D7%95%D7%9C\" class=\"mw-redirect\" title=\"מבול\">מבול</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A4%22%D7%95\" title=\"תקפ&quot;ו\">תקפ\"ו</a> – רבי אלעזר פלקלס, בעל שו\"ת 'תשובה מאהבה', נפטר</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%91\" title=\"תרל&quot;ב\">תרל\"ב</a> – רבי אהרן פרלוב, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php/%D7%A7%D7%A8%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"קרלין\">קרלין</a> ומחבר הספר 'בית אהרן', נפטר</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%92\" title=\"תרע&quot;ג\">תרע\"ג</a> – רבי צבי הירש ברוידא מקלם, נפטר</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> – רבי משה מרדכי שטגר, מחבר ספר 'מגד שמים', נפטר</li>\n<li>תש\"ד – רבי משה פרהנד ממקווא, מחבר הספר 'אהל משה', נפטר</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> – <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%97%D7%99%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%90\" class=\"mw-redirect\" title=\"הרבנית חיה מושקא\">הרבנית חיה מושקא</a> עלו על ספינת \"סורפא פינטא\" שיצאה מפורטוגל לכיון <a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ניו יורק\">ניו יורק</a>, אליה הגיעו ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כ\"ח בסיוון</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a> – הושק אתר <a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C_(%D7%90%D7%AA%D7%A8)\" title=\"חב&quot;ד בישראל (אתר)\">חב\"ד בישראל</a></li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%98\" title=\"תרע&quot;ט\">תרע\"ט</a> – הרב <a href=\"/index.php/%D7%93%D7%91_%D7%91%D7%A2%D7%A8%D7%99%D7%A9_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%A8%D7%92\" title=\"דב בעריש רוזנברג\">דב בעריש רוזנברג</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> שיכון חב\"ד ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%93\" title=\"תרצ&quot;ד\">תרצ\"ד</a> - הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%9E%D7%A9%D7%94_%D7%99%D7%95%D7%A0%D7%99%D7%A7\" title=\"דוד אליהו משה יוניק\">דוד אליהו משה יוניק</a> שו\"ב ומוהל חב\"די מנכבדי אנ\"ש באנטוורפן.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%96\" title=\"תשי&quot;ז\">תשי\"ז</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A8%D7%9D_%D7%90%D7%91%D7%A8%D7%92%27%D7%9C\" title=\"יורם אברג&#39;ל\">יורם אברג'ל</a>, ראש מוסדות רב פעלים על שם <a href=\"/index.php/%D7%94%D7%91%D7%9F_%D7%90%D7%99%D7%A9_%D7%97%D7%99\" class=\"mw-redirect\" title=\"הבן איש חי\">הבן איש חי</a> ב<a href=\"/index.php/%D7%A0%D7%AA%D7%99%D7%91%D7%95%D7%AA\" title=\"נתיבות\">נתיבות</a> ומגדולי המחזירים בתשובה</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a> – הרב <a href=\"/index.php/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%9E%D7%9C%D7%95%D7%91\" title=\"אפרים מלוב\">אפרים מלוב</a>, מנכל מוסדות חב\"ד ב<a href=\"/index.php/%D7%A2%D7%9E%D7%A0%D7%95%D7%90%D7%9C\" title=\"עמנואל\">עמנואל</a> וסגן ראש העיר</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"תשל&quot;ה\">תשל\"ה</a> – ה<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסיד</a> רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%27%D7%99%D7%99%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F\" title=\"ישראל ג&#39;ייקובסון\">ישראל ג'ייקובסון</a>, מחשובי עסקני חב\"ד בארצות הברית.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a> - מרת <a href=\"/index.php/%D7%9E%D7%99%D7%A0%D7%90_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" class=\"mw-redirect\" title=\"מינא גוראריה\">מינא גוראריה</a> רעייתו של <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"שלום דובער גוראריה\">גנב הספרים</a> ובתו של החסיד <a href=\"/index.php/%D7%90%D7%9C%D7%AA%D7%A8_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%97%D7%A1%D7%A7%D7%99%D7%A0%D7%93\" title=\"אלתר דובער חסקינד\">אלתר דובער חסקינד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> – הרב <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%9F_%D7%A1%D7%95%D7%93%D7%A7\" title=\"נחמן סודק\">נחמן סודק</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> וראש מוסדות חב\"ד ב<a href=\"/index.php/%D7%90%D7%A0%D7%92%D7%9C%D7%99%D7%94\" class=\"mw-redirect\" title=\"אנגליה\">אנגליה</a></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ז בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ניט הנאה האבען פון עולם הזה אין פולען זין, הוא רק הכנה טובה ל<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודה</a>. ענין העבודה הוא לעשות ה<a href=\"/index.php/%D7%92%D7%A9%D7%9E%D7%99\" class=\"mw-redirect\" title=\"גשמי\">גשמי</a> כלי ל<a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אלקות\">אלקות</a>.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: לא להנות מעולם הזה במלוא המובן, הוא רק הכנה טובה ל<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודה</a>. ענין העבודה הוא לעשות ה<a href=\"/index.php/%D7%92%D7%A9%D7%9E%D7%99\" class=\"mw-redirect\" title=\"גשמי\">גשמי</a> כלי ל<a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אלקות\">אלקות</a>.\n</p>\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השלישי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260413132318\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.096 seconds\nReal time usage: 0.722 seconds\nPreprocessor visited node count: 386/1000000\nPost‐expand include size: 8340/2097152 bytes\nTemplate argument size: 737/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 4/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 151/5000000 bytes\nLua time usage: 0.060/7 seconds\nLua virtual size: 6123520/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  627.808      1 -total\n 96.17%  603.779      1 תבנית:פתיח_יום\n 24.16%  151.647      5 תבנית:מילה_אחרונה\n 18.33%  115.099      1 תבנית:הערה\n  7.75%   48.629      2 תבנית:מילה_ראשונה\n  6.81%   42.745      1 תבנית:הסר_מילה_ראשונה\n  4.54%   28.471      2 תבנית:רווח\n  4.10%   25.745      1 תבנית:חודש_סיוון\n  3.80%   23.865      1 תבנית:להיום_יום\n  2.91%   18.238      1 תבנית:לוח_שנה\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:22613-0!canonical and timestamp 20260413132318 and revision id 831569. Rendering was triggered because: unknown\n -->\n</div>"
