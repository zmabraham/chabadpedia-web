F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ג בסיוון</b> הוא היום השלושה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">חודש סיוון</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>תל\"ח – רבי אפרים הכהן, אב\"ד ווילנא, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%99\" title=\"תר&quot;י\">תר\"י</a> – רבי זאב וולף גולדברג, אב\"ד ראצאפרט, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%91\" title=\"תרע&quot;ב\">תרע\"ב</a> – רבי שרגא יאיר רבינוביץ', ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php/%D7%91%D7%99%D7%90%D7%9C%D7%94\" class=\"mw-redirect\" title=\"ביאלה\">ביאלה</a> ומחבר הספר 'ארון עדות', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> – רבי יעקב מאיר בידרמן, מרבני יהדות פולין, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> – רבי יצחק אייזיק ווייס, האדמו\"ר מ<a href=\"/index.php?title=%D7%A1%D7%A4%D7%99%D7%A0%D7%A7%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ספינקא (הדף אינו קיים)\">ספינקא</a> ומחבר הספר 'חקל יצחק', נרצח על קידוש ה'.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a> – רבי יעקב מוצפי, חכם וראב\"ד <a href=\"/index.php/%D7%94%D7%A2%D7%93%D7%94_%D7%94%D7%97%D7%A8%D7%93%D7%99%D7%AA\" title=\"העדה החרדית\">העדה החרדית</a> הספרדית ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%98\" title=\"תשמ&quot;ט\">תשמ\"ט</a> – רבי רפאל יונה טיקוצ'ינסקי, ראש ישיבת ירוחם, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A1%22%D7%96\" title=\"תקס&quot;ז\">תקס\"ז</a> – יום חתונת מרת <a href=\"/index.php/%D7%A9%D7%A8%D7%94_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99)\" class=\"mw-redirect\" title=\"שרה (בת אדמו&quot;ר האמצעי)\">שרה</a> בת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a> עם הרב <a href=\"/index.php?title=%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%93%D7%A8%D7%91%D7%A8%D7%9E%D7%93%D7%99%D7%A7%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אליעזר דרברמדיקר (הדף אינו קיים)\">אליעזר דרברמדיקר</a>, נכד <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%9E%D7%91%D7%A8%D7%93%D7%99%D7%A6%27%D7%91\" class=\"mw-redirect\" title=\"רבי לוי יצחק מברדיצ&#39;ב\">רבי לוי יצחק מברדיצ'ב</a>, ב<a href=\"/index.php/%D7%94%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%94%D7%92%D7%93%D7%95%D7%9C%D7%94_%D7%91%D7%96%27%D7%9C%D7%95%D7%91%D7%99%D7%9F\" title=\"החתונה הגדולה בז&#39;לובין\">החתונה הגדולה בז'לובין</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A1\" title=\"תר&quot;ס\">תר\"ס</a> – (כפי בשולשלת היחס) התחתנו <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%91_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" class=\"mw-redirect\" title=\"רבי לוי יצחק שניאורסון (אב אדמו&quot;ר שליט&quot;א)\">רבי לוי יצחק</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%97%D7%A0%D7%94\" class=\"mw-redirect\" title=\"הרבנית חנה\">הרבנית חנה</a>, הורי <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%9B%22%D7%A7_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" title=\"רבי מנחם מענדל שניאורסון (כ&quot;ק אדמו&quot;ר שליט&quot;א)\">הרבי</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"תרנ&quot;ז\">תרנ\"ז</a> – הרב <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%99%D7%90%D7%9C_%D7%96%D7%9C%D7%99%D7%92_%D7%A1%D7%9C%D7%95%D7%A0%D7%99%D7%9D\" title=\"עזריאל זליג סלונים\">עזריאל זליג סלונים</a>, מראשי עסקני חב\"ד בארץ הקודש וממנהלי <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"כולל חב&quot;ד\">כולל חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a> – הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%92%D7%93%D7%A1%D7%99\" title=\"שמעון גדסי\">שמעון גדסי</a>, חבר הצוות הרוחני של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%9E%D7%AA_%D7%90%D7%91%D7%99%D7%91\" title=\"תומכי תמימים רמת אביב\">תומכי תמימים רמת אביב</a>, משלוחי הרבי ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a> ומחבר ספרי הלכה.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%93%D7%9C%D7%9E%D7%9F\" title=\"יוסף יצחק איידלמן\">יוסף יצחק איידלמן</a>, חבר <a href=\"/index.php/%D7%9E%D7%A2%D7%A8%D7%9B%D7%AA_%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מערכת אוצר החסידים\">מערכת אוצר החסידים</a> <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%90%D7%94%D7%9C%D7%99_%D7%A9%D7%9D\" class=\"mw-redirect\" title=\"מכון אהלי שם\">מכון אהלי שם</a> ועורך <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%94%D7%AA%D7%A7%D7%A9%D7%A8%D7%95%D7%AA\" class=\"mw-redirect\" title=\"שבועון התקשרות\">שבועון התקשרות</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ג בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a> חיבר כמה <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ניגון\">נגונים</a>, למודו היה בקול ונגון, ולפעמים היה מפסיק באמצע למודו, או כתיבתו <a href=\"/index.php/%D7%93%D7%90%22%D7%97\" class=\"mw-redirect\" title=\"דא&quot;ח\">דא\"ח</a> או שו\"ת, ומנגן איזה ניגון.\n<p><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אבי אדוני זקני מורי ורבי</a> סיפר, אשר מקול ניגונו של הצמח צדק היה יודע במה הוא עסוק באותה שעה.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413124604\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.025 seconds\nReal time usage: 0.080 seconds\nPreprocessor visited node count: 104/1000000\nPost‐expand include size: 5299/2097152 bytes\nTemplate argument size: 561/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   44.193      1 -total\n 55.83%   24.671      1 תבנית:חודש_סיוון\n 43.82%   19.365      1 תבנית:להיום_יום\n 36.05%   15.930      1 תבנית:לוח_שנה\n 19.86%    8.778      1 תבנית:היום_יום/י&quot;ג_סיון\n 17.12%    7.566      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:22552-0!canonical and timestamp 20260413124604 and revision id 774425. Rendering was triggered because: diff-page\n -->\n</div>"
