0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ד במנחם אב\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ה במנחם אב\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ו במנחם אב\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ז במנחם אב\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ח במנחם אב\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ט במנחם אב\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"ל&#39; במנחם אב\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ה' באב</b> הוא היום החמישי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">חודש מנחם אב</a> והיום השמונה עשר מ<a href=\"/index.php/%D7%99%D7%9E%D7%99_%D7%91%D7%99%D7%9F_%D7%94%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ימי בין המצרים\">ימי בין המצרים</a> (החמישי ב\"תשעת הימים\").\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>של\"ב – ה<a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%91%D7%9C\" class=\"mw-redirect\" title=\"מקובל\">מקובל</a> האלוקי רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%95%D7%A8%D7%99%D7%90\" class=\"mw-redirect\" title=\"יצחק לוריא\">יצחק לוריא</a> אשכנזי, רבינו <a href=\"/index.php/%D7%94%D7%90%D7%A8%22%D7%99\" title=\"האר&quot;י\">האר\"י</a> הקדוש, נפטר ועלה לגנזי מרומים.</li>\n<li><a href=\"/index.php/%D7%AA%22%D7%A9\" title=\"ת&quot;ש\">ת\"ש</a> – רבי <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A2%D7%95%D7%96%D7%A8_%D7%92%D7%A8%D7%95%D7%93%D7%96%27%D7%99%D7%A0%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"חיים עוזר גרודז&#39;ינסקי\">חיים עוזר גרודז'ינסקי</a>, רבה של <a href=\"/index.php/%D7%95%D7%99%D7%9C%D7%A0%D7%90\" class=\"mw-redirect\" title=\"וילנא\">וילנא</a>, מחבר ספר 'שו\"ת אחיעזר', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a> – המקובל רבי <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%91%D7%9F_%D7%98%D7%95%D7%91\" title=\"משה בן טוב\">משה בן טוב</a> בן מסעוד ואיטו, מבאר שבע, מנהל \"מוסדות דור ודור\" בירושלים, מקים מקוואות ומחזק <a href=\"/index.php/%D7%98%D7%94%D7%A8%D7%AA_%D7%94%D7%9E%D7%A9%D7%A4%D7%97%D7%94\" title=\"טהרת המשפחה\">טהרת המשפחה</a> בארץ ישראל, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a> – הגיעה לארץ הקודש <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%98%22%D7%96\" class=\"mw-redirect\" title=\"שלוחים לארץ הקודש תשט&quot;ז\">קבוצת השלוחים המיוחדת</a> שנשלחה על ידי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, לאחר <a href=\"/index.php/%D7%A8%D7%A6%D7%97_%D7%99%D7%93_%D7%94%D7%97%D7%9E%D7%A9%D7%94\" class=\"mw-redirect\" title=\"רצח יד החמשה\">הפיגוע בכפר חב\"ד</a> ב<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"ראש חודש אייר\">ראש חודש אייר</a> תשט\"ז.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%94\" title=\"תשכ&quot;ה\">תשכ\"ה</a> – הרבי ערך <a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"התוועדות\">התוועדות</a> לציון <a href=\"/index.php?title=%D7%A1%D7%99%D7%95%D7%9D_%D7%90%D7%9E%D7%99%D7%A8%D7%AA_%D7%94%D7%A7%D7%93%D7%99%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"סיום אמירת הקדיש (הדף אינו קיים)\">סיום אמירת הקדיש</a> ומלאות אחד עשר חודשים מ<a href=\"/index.php/%D7%94%D7%A1%D7%AA%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הסתלקות\">הסתלקות</a> אמו הרבנית <a href=\"/index.php/%D7%97%D7%A0%D7%94_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חנה שניאורסון\">חנה שניאורסון</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> – הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A4%D7%99%D7%96%D7%9D\" title=\"שמעון יהודה פיזם\">שמעון יהודה פיזם</a>, מזכ\"ל ארגון <a href=\"/index.php/%D7%94%D7%AA%D7%90%D7%97%D7%93%D7%95%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D_%D7%9C%D7%A7%D7%91%D7%9C%D7%AA_%D7%A4%D7%A0%D7%99_%D7%9E%D7%A9%D7%99%D7%97\" title=\"התאחדות החסידים לקבלת פני משיח\">התאחדות החסידים לקבלת פני משיח</a>, ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד ליובאוויטש צפת\">חסידי חב\"ד ליובאוויטש צפת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%9E%D7%9C%D7%9A_%D7%A9%D7%97%D7%A8\" title=\"אלימלך שחר\">אלימלך שחר</a> מנכ\"ל מוסדות חב\"ד ברחובות.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> – הרב <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%92%D7%95%D7%A8%D7%95%D7%93%D7%A6%D7%A7%D7%99\" title=\"בנימין אליהו גורודצקי\">בנימין אליהו גורודצקי</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">בא-כוחם</a> של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ב<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>, ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a> ובצפון אפריקה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a> – הרב <a href=\"/index.php/%D7%A0%D7%AA%D7%9F_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94_(%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1)\" title=\"נתן גוראריה (קראון הייטס)\">נתן גוראריה</a>, מחשובי חסידי חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> וחבר הנהלת מוסד <a href=\"/index.php/%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94_(%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1)\" class=\"mw-redirect\" title=\"אהלי תורה (קראון הייטס)\">אהלי תורה</a>.</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%99%D7%9E%D7%99_%D7%91%D7%99%D7%9F_%D7%94%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ימי בין המצרים\">ימי בין המצרים</a></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ה' במנחם אב - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>\"<a href=\"/index.php/%D7%A1%D7%95%D7%A8_%D7%9E%D7%A8%D7%A2\" class=\"mw-redirect\" title=\"סור מרע\">סור מרע</a> ו<a href=\"/index.php/%D7%A2%D7%A9%D7%94_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"עשה טוב\">עשה טוב</a> בקש שלום ורדפהו\", האט דער <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a> געזאגט: אין יעדער דבר <a href=\"/index.php/%D7%92%D7%A9%D7%9E%D7%99\" class=\"mw-redirect\" title=\"גשמי\">גשמי</a> פון דברים המותרים זיינען פאראן <a href=\"/index.php/%D7%98%D7%95%D7%91\" title=\"טוב\">טוב</a> ו<a href=\"/index.php/%D7%A8%D7%A2\" title=\"רע\">רע</a>: דער גשמי איז רע און דער חיות <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%99\" class=\"mw-redirect\" title=\"אלקי\">אלקי</a> וואס איז מחיה דעם גשמי איז טוב. באדארף דער מענש וואס באנוצט דעם גשמי זיין א סור מרע, ניט וועלען דעם תענוג וואס איז פאראן אין דעם גשמי, און זיין ועשה טוב וועלען געשפייזט און געהאלפען ווערען פון דעם חיות אלקי וואס איז אין דעם דבר הגשמי. בקש שלום ורדפהו דער מענש וואס איז א סור מרע און א ועשה טוב, באדארף זוכען און נאכלויפען צו מאכען שלום צווישען דעם גשמי און חיות אלקי וואס איז איהם מחיה.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: \"<a href=\"/index.php/%D7%A1%D7%95%D7%A8_%D7%9E%D7%A8%D7%A2\" class=\"mw-redirect\" title=\"סור מרע\">סור מרע</a> ו<a href=\"/index.php/%D7%A2%D7%A9%D7%94_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"עשה טוב\">עשה טוב</a> בקש שלום ורדפהו\", אמר ה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a>: בכל דבר <a href=\"/index.php/%D7%92%D7%A9%D7%9E%D7%99\" class=\"mw-redirect\" title=\"גשמי\">גשמי</a> מהדברים המותרים ישנו <a href=\"/index.php/%D7%98%D7%95%D7%91\" title=\"טוב\">טוב</a> ו<a href=\"/index.php/%D7%A8%D7%A2\" title=\"רע\">רע</a>: הגשמי הוא רע והחיות ה<a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A7%D7%99\" class=\"mw-redirect\" title=\"אלוקי\">אלוקי</a> שמחיהו את הגשמי הוא טוב. צריך האדם המשתמש עם הגשמי להיות סור מרע, לא לרצות ה<a href=\"/index.php/%D7%AA%D7%A2%D7%A0%D7%95%D7%92\" title=\"תענוג\">תענוג</a> הקיים בגשמי, ולהיות \"ועשה טוב\", לרצות ניזון מהחיות אלוקי שבדבר הגשמי. \"בקש שלום ורדפהו\" האדם שהוא \"סור מרע ועשה טוב\" צריך לחפש ולרדוף לעשות שלום בין הגשמי והחיות אלקי שמחיהו.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413222106\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.028 seconds\nReal time usage: 0.048 seconds\nPreprocessor visited node count: 117/1000000\nPost‐expand include size: 8108/2097152 bytes\nTemplate argument size: 660/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parse