      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%AA%D7%A8_%27%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94%27.png\" class=\"mw-file-description\"><img src=\"/images/thumb/6/68/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%AA%D7%A8_%27%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94%27.png/220px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%AA%D7%A8_%27%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94%27.png\" decoding=\"async\" width=\"220\" height=\"92\" class=\"mw-file-element\" srcset=\"/images/thumb/6/68/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%AA%D7%A8_%27%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94%27.png/330px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%AA%D7%A8_%27%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94%27.png 1.5x, /images/thumb/6/68/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%AA%D7%A8_%27%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94%27.png/440px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%AA%D7%A8_%27%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94%27.png 2x\" /></a><figcaption>לוגו האתר החדש (תשפ\"ד)</figcaption></figure>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94.JPG\" class=\"mw-file-description\"><img src=\"/images/thumb/8/85/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94.JPG/220px-%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94.JPG\" decoding=\"async\" width=\"220\" height=\"35\" class=\"mw-file-element\" srcset=\"/images/thumb/8/85/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94.JPG/330px-%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94.JPG 1.5x, /images/thumb/8/85/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94.JPG/440px-%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94.JPG 2x\" /></a><figcaption>לוגו האתר הישן</figcaption></figure>\n<p><b>אתר 'הגאולה'</b> הוא אתר אינטרנט עם חדשות ומאמרי תוכן בנושאי <a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"גאולה ומשיח\">גאולה ומשיח</a> ו<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%9E%D7%95%D7%AA_%D7%94%D7%90%D7%A8%D7%A5\" class=\"mw-redirect\" title=\"שלימות הארץ\">שלימות הארץ</a>, <a href=\"/index.php/%D7%A9%D7%99%D7%A2%D7%95%D7%A8%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"שיעורי תורה\">שיעורי תורה</a> ועוד. האתר הוקם בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> על ידי הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%99%D7%A7\" title=\"חיים ציק\">חיים ציק</a>, והוא מתופעל על ידי <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה האמיתית והשלימה</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.99.D7.99.D7.A1.D7.95.D7.93_.D7.94.D7.90.D7.AA.D7.A8\"></span><span class=\"mw-headline\" id=\"ייסוד_האתר\">ייסוד האתר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;ייסוד האתר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: ייסוד האתר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>האתר נוסד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> על ידי הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%99%D7%A7\" title=\"חיים ציק\">חיים ציק</a> ופעילי <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה האמיתית והשלימה</a>, ושימש בעיקר לחדשות חב\"ד בנושא גאולה ומשיח ושלימות הארץ וכפרסום לפעולות הארגון וחומרים היוצאים לאור על ידו, ולתת בימה לדעות ולעמדות אותם מייצג הארגון.\n</p><p>ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשון\">חודש חשון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a>, השתדרג האתר ומאז הוא עובד בעיקר על פרסום סיפורי ניסים דרך ה<a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"אגרות קודש\">אגרות קודש</a>, דעתו של הרבי בנוגע ל<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%9E%D7%95%D7%AA_%D7%94%D7%90%D7%A8%D7%A5\" class=\"mw-redirect\" title=\"שלימות הארץ\">שלימות הארץ</a>, תאריכים מיוחדים בימי חב\"ד, עלון <a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%AA_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"שיחת הגאולה\">שיחת הגאולה</a> היוצא על ידי הארגון ושאר חדשות חב\"ד.\n</p><p>בחצי שנה שלאחר מכן התפתחה פעילותו, וצוות האתר החל להעלות בתדירות גבוהה קטעי וידאו בנושאי <a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"גאולה ומשיח\">גאולה ומשיח</a> ודיווחים שוטפים מהמתרחש בחצר הרבי ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> הושק באתר מדור מיוחד לילדים בו מתפרסמים <a href=\"/index.php/%D7%A1%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" title=\"סיפורי חסידים\">סיפורי חסידים</a> מנוקדים ומעובדים, סרטוני וידאו בעלי מסרים חינוכיים, חידות וציורים לצביעה.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> נמחק כל המידע באתר, וכל הכתבות והמדיה אבדו. כיום בחיפוש באתר ניתן להגיע לכתבות רק החל משנה זו.\n</p><p>תחת האתר פעל בעבר גם אתר המדיה 'זמן הגאולה' בו היו מרוכזים קרוב לאלפיים סרטי וידאו הקשורים למשנתו של הרבי ולפרסום בשורת הגאולה והעיסוק בענייני גאולה ומשיח. הסרטים היו מקוטלגים על פי מדורים ולא היו ניתנים להורדה ישירה.\n</p><p>החל משנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a> החל האתר לעבוד בשיתוף פעולה עם '<a href=\"/index.php/%D7%A2%D7%A8%D7%95%D7%A5_%D7%96%D7%9E%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" class=\"mw-redirect\" title=\"ערוץ זמן הגאולה\">ערוץ זמן הגאולה</a>' ביוטיוב, שמשדר במשך היממה כולה שיעורי תורה וכינוסים בענייני גאולה ומשיח.\n</p>\n<h2><span id=\".D7.94.D7.90.D7.AA.D7.A8_.D7.9B.D7.99.D7.95.D7.9D\"></span><span class=\"mw-headline\" id=\"האתר_כיום\">האתר כיום</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;האתר כיום&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: האתר כיום\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>לקראת <a href=\"/index.php/%D7%99%27_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"י&#39; שבט\">י' שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> החליטה האגודה לשדרג את האתר, וב<a href=\"/index.php/%D7%97%27_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"ח&#39; שבט\">ח' שבט</a> התפרסם האתר החדש, עם עיצוב חדשני וצוות כתבים מורחב.\n</p><p>לאתר התווסף מדור קבוע של יומן מ<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_770\" class=\"mw-redirect\" title=\"בית משיח 770\">בית משיח 770</a>, וכן גלריית תמונות שבועית.\n</p><p>בנוסף החלה מערכת האתר להעלות כתבות מתוך עלון <a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%AA_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"שיחת הגאולה\">שיחת הגאולה</a> ו<a href=\"/index.php/%D7%A2%D7%99%D7%AA%D7%95%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" class=\"mw-redirect\" title=\"עיתון הגאולה\">עיתון הגאולה</a>.\n</p><p>הניסוח בחלק מהכתבות החל להיות מותאם לציבור הכללי בכדי לתת מענה לגולשים שאינם מהציבור החב\"די. לשם כך גם מעלה מערכת האתר נושאים ב<a href=\"/index.php/%D7%9C%D7%99%D7%9E%D7%95%D7%93_%D7%A2%D7%A0%D7%99%D7%A0%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" title=\"לימוד עניני גאולה ומשיח\">גאולה ומשיח</a> וכתבות נושאים ב<a href=\"/index.php/%D7%99%D7%94%D7%93%D7%95%D7%AA\" title=\"יהדות\">יהדות</a> בשפה פשוטה וקלה, וכן הלכות ומנהגים המתפרסמים בערבי חגים בהתאם לימי השנה.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> נוסף כפתור לייק בסיום כל כתבה המאפשר לגולשים להביע את הנאתם מהתכנים באתר.\n</p><p>נכון ל<a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> צבר האתר מעל 12,000,000 צפיות בכתבות (החל משנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a>)<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A6.D7.95.D7.95.D7.AA_.D7.94.D7.90.D7.AA.D7.A8\"></span><span class=\"mw-headline\" id=\"צוות_האתר\">צוות האתר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;צוות האתר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: צוות האתר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב <a href=\"/index.php/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F\" title=\"טוביה דורון\">טוביה דורון</a></li>\n<li>הרב <a href=\"/index.php/%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%A4%D7%A8%D7%99%D7%A9%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"בן ציון פרישמן\">בן ציון פרישמן</a></li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%97%D7%99%D7%9E%D7%99\" title=\"יצחק רחימי\">יצחק רחימי</a></li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%99%D7%A7\" title=\"חיים ציק\">חיים ציק</a></li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%91%D7%99%D7%A9%D7%99_%D7%90%D7%A4%D7%A8%D7%92%D7%95%D7%9F\" title=\"אבישי אפרגון\">אבישי אפרגון</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A1%D7%92%D7%9C_(%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שניאור זלמן סגל (באר שבע) (הדף אינו קיים)\">שניאור זלמן סגל</a></li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94_(%D7%A2%D7%99%D7%AA%D7%95%D7%9F)\" title=\"הגאולה האמיתית והשלימה (עיתון)\">הגאולה האמיתית והשלימה (עיתון)</a></li>\n<li><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\">חב\"ד אינפו</a></li>\n<li><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%A3_%D7%90%D7%9D\" title=\"חב&quot;ד אף אם\">חב\"ד אף אם</a></li>\n<li><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\">חב\"ד און ליין</a></li>\n<li><a href=\"/index.php/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D_(%D7%90%D7%AA%D7%A8)\" title=\"שטורעם (אתר)\">שטורעם</a></li>\n<li><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C_(%D7%90%D7%AA%D7%A8)\" title=\"חב&quot;ד בישראל (אתר)\">חב\"ד בישראל</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.hageula.com/\">דף הבית של האתר</a></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שולי