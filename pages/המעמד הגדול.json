    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/89/%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C.jpeg/250px-%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C.jpeg\" decoding=\"async\" width=\"250\" height=\"200\" class=\"mw-file-element\" srcset=\"/images/thumb/8/89/%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C.jpeg/375px-%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C.jpeg 1.5x, /images/thumb/8/89/%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C.jpeg/500px-%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C.jpeg 2x\" /></a><figcaption>„Ф„Ю„Ґ„Ю„У „Ф„Т„У„Х„Ь (<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"„™„©„§&quot;„У\">„™„©„§\"„У</a>)</figcaption></figure>\n<p><b>„Ф„Ю„Ґ„Ю„У „Ф„Т„У„Х„Ь</b> „Ф„Х„Р „Ы„Щ„†„Х„° „Р„®„¶„Щ „©„Ь <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"„Р„Т„Х„У„™ „Ч„°„Щ„У„Щ „Ч„С&quot;„У „С„Щ„©„®„Р„Ь\">„Р„Т„Х„У„™ „Ч„°„Щ„У„Щ „Ч„С\"„У „С„Щ„©„®„Р„Ь</a> „Ф„Ю„Щ„Х„Ґ„У „Ь„Ы„Ь„Ь <a href=\"/index.php/%D7%90%D7%A0%22%D7%A9\" class=\"mw-redirect\" title=\"„Р„†&quot;„©\">„Р„†\"„©</a> <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"„Ч„°„Щ„У„Щ „Ч„С&quot;„У\">„Ч„°„Щ„У„Щ „Ч„С\"„У</a> „С<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"„Р„®„• „Щ„©„®„Р„Ь\">„Р„®„• „Щ„©„®„Р„Ь</a> „Ы„Ф„Ы„†„Ф „Ь„Щ„Х„Э „Ф„Х„Ь„У„™„Х „©„Ь <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"„Ф„®„С„Щ\">„Ф„®„С„Щ</a> „С<a href=\"/index.php/%D7%99%22%D7%90_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"„Щ&quot;„Р „†„Щ„°„Я\">„Щ\"„Р „†„Щ„°„Я</a> „Х„Ю„™„І„Щ„Щ„Э „С„Щ„Ю„Щ„Э „Ф„°„Ю„Х„Ы„Щ„Э „Р„Ь„Щ„Х. „Ф„Ы„Щ„†„Х„° „Ю„Р„Х„®„Т„Я „Ґ„Ь-„Щ„У„Щ „Р„®„Т„Х„Я <a href=\"/index.php/%D7%9E%D7%98%D7%94_%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"„Ю„Ш„Ф „Ю„©„Щ„Ч „С„Р„®„• „Ф„І„Х„У„©\">„Ю„Ш„Ф „Ю„©„Щ„Ч „С„Р„®„• „Ф„І„Х„У„©</a> „©„Ґ„Ь-„Щ„У„Щ „Р„Т„Х\"„Ч „Ф„Ч„Ь „Ю„©„†„™ <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"„™„©„°&quot;„С\">„™„©„°\"„С</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.99.D7.A1.D7.98.D7.95.D7.A8.D7.99.D7.94\"></span><span class=\"mw-headline\" id=\"„Ф„Щ„°„Ш„Х„®„Щ„Ф\">„Ф„Щ„°„Ш„Х„®„Щ„Ф</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C&amp;veaction=edit&amp;section=1\" title=\"„Ґ„®„Щ„Ы„™ „§„°„І„Ф: &quot;„Ф„Щ„°„Ш„Х„®„Щ„Ф&quot;\" class=\"mw-editsection-visualeditor\"><span>„Ґ„®„Щ„Ы„Ф</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C&amp;action=edit&amp;section=1\" title=\"„Ґ„®„Щ„Ы„™ „І„Х„У „Ф„Ю„І„Х„® „©„Ь „Ф„§„®„І: „Ф„Щ„°„Ш„Х„®„Щ„Ф\"><span>„Ґ„®„Щ„Ы„™ „І„Х„У „Ю„І„Х„®</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>„С„©„†„™ <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"„™„©„°&quot;„С\">„™„©„°\"„С</a>, „Ф„®„С <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%94%D7%A2%D7%A0%D7%93%D7%9C\" class=\"mw-redirect\" title=\"„©„Ю„Х„Р„Ь „Ф„Ґ„†„У„Ь\">„©„Ю„Х„Р„Ь „Ф„Ґ„†„У„Ь</a> „®„¶„Ф „Ь„Р„®„Т„Я „Ю„§„Т„Я „Ь„®„Т„Ь „Щ\"„Р „†„Щ„°„Я, „Х„Ф„Х„Р „§„†„Ф „Ь„®„С„Щ „С<a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"„Р„Т„®„Х„™ „І„Х„У„©\">„Р„Т„®„Х„™ „І„Х„У„©</a> „Х„Ф„Ю„Ы„™„С „©„Щ„¶„Р „™„Р„Э „С„У„Щ„Х„І „Ь„©„Р„Ь„Ф. „Ф„Х„Р „Ф„Ч„Ь „С„Ы„Щ„†„Х„° „С„Р„¶„Ш„У„Щ„Х„Я „Щ„У „Р„Ь„Щ„Ф„Х.\n</p><p>„С„©„†„™ <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"„™„©„°&quot;„Ц\">„™„©„°\"„Ц</a>, „С„Ґ„І„С„Х„™ „С„Щ„І„Х„© „®„С „Х„С„Ґ„І„С„Х„™ „™„©„Х„С„™ „Ф„®„С„Щ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> „Ф„™„І„Щ„Щ„Э „Ф„Ы„Щ„†„Х„° „С„Р„¶„Ш„У„Щ„Х„Я „С„Ь„Х„Ю„§„Щ„Ь„У, „С„Ф„©„™„™„§„Х„™ 30,000 „Р„Щ„©.\n</p><p>„Ю„©„†„™ <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"„™„©„Ґ&quot;„Ф\">„™„©„Ґ\"„Ф</a>, „Ф„Ч„Ь „Ф„Р„®„Т„Х„Я „Ь„Ґ„®„Х„Ъ „Р„™ „Ф„Ы„†„° „С„Ю„™„Ы„Х„†„™ „Ю„Щ„Х„Ч„У„™ „Ф„Ю„Щ„Х„Ґ„У„™ „С„Ґ„Щ„І„® „Ґ„С„Х„® „Ч„°„Щ„У„Щ „Ч„С\"„У „С„Р„Ф\"„І „Ы„©„Ф„Х„Р „Ю„Ы„Х„†„Ф '„Ф„Ю„Ґ„Ю„У „Ф„Т„У„Х„Ь'. „Ы„†„°„Щ„Э „Р„Ь„Х „†„Ґ„®„Ы„Х „С„Ф„Щ„Ы„Ь '„Р„®„†„Ф' „С„Ч„Х„Ь„Х„Я, „С„Ф„Щ„Ы„Ь „Ф„°„§„Х„®„Ш '„Щ„У „Р„Ь„Щ„Ф„Х' „Х„С„Р„Щ„¶„Ш„У„Щ„Х„Я „С„Ь„Х„Ю„§„Щ„Ь„У „С„Ф„©„™„™„§„Х„™ „Ю„®„С„Щ„™ „Ю„Р„†\"„©.\n„Ь„І„®„Р„™ „Ф„Ы„†„° „С„©„†„™ <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"„™„©„§&quot;„С\">„™„©„§\"„С</a>, „С„Щ„І„©„Х „С„Ґ„Щ„™„Х„Я '„Щ„©„®„Р„Ь „Ф„Щ„Х„Э' „Ь„Ф„Ґ„†„Щ„І „Ю„Ч„Х„Х„Ф „Ь„®„Т„Ь „Ю„Р„Ф „Х„Ґ„©„®„Щ„Э „©„†„Ф „Ь„®„С„Щ, „Х„С„Ч„®„Х „Ь„Ф„§„Щ„І „Ю„Х„°„£ „Ю„®„©„Щ„Э „С„Ф„Х„¶„Р„™ „Ф„Ґ„Щ„™„Х„Я, „©„Ю„Х„І„У„© „Ы„Х„Ь„Х „Ь„®„С„Щ.\n</p><p>„С„Ґ„Щ„™„Х„Я „Ф„Х„§„Щ„Ґ„Х „Ф„§„®„Ц„Щ„У„†„Ш „Ю„® <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%A8%D7%A6%D7%95%D7%92\" title=\"„Щ„¶„Ч„І „Ф„®„¶„Х„Т\">„Щ„¶„Ч„І „Ф„®„¶„Х„Т</a>, „Ф„®„С„†„Щ„Э „Ф„®„Р„©„Щ„Щ„Э „Ь„Щ„©„®„Р„Ь, „Х„Р„Щ„©„Щ „¶„Щ„С„Х„® „Ю„Ы„Ь „Т„Х„Х„†„Щ „Ф„І„©„™ „Ф„Щ„©„®„Р„Ь„Щ„™.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9B.D7.A0.D7.99.D7.AA_.D7.94.D7.9B.D7.99.D7.A0.D7.95.D7.A1\"></span><span class=\"mw-headline\" id=\"„™„Х„Ы„†„Щ„™_„Ф„Ы„Щ„†„Х„°\">„™„Х„Ы„†„Щ„™ „Ф„Ы„Щ„†„Х„°</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C&amp;veaction=edit&amp;section=2\" title=\"„Ґ„®„Щ„Ы„™ „§„°„І„Ф: &quot;„™„Х„Ы„†„Щ„™ „Ф„Ы„Щ„†„Х„°&quot;\" class=\"mw-editsection-visualeditor\"><span>„Ґ„®„Щ„Ы„Ф</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%92%D7%93%D7%95%D7%9C&amp;action=edit&amp;section=2\" title=\"„Ґ„®„Щ„Ы„™ „І„Х„У „Ф„Ю„І„Х„® „©„Ь „Ф„§„®„І: „™„Х„Ы„†„Щ„™ „Ф„Ы„Щ„†„Х„°\"><span>„Ґ„®„Щ„Ы„™ „І„Х„У „Ю„І„Х„®</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>„Ч„Х„У„©„Щ„Э „Ь„§„†„Щ „Ф„Ы„Щ„†„Х„°, „Ю„Х„Т„©„™ „™„Х„Ы„†„Щ„Ф „Ю„Ь„Р„Ф „Х„Т„У„Х„©„Ф „Ґ„Ь „Ю„Ф „©„Ф„Х„Ь„Ъ „Ь„Ф„Щ„Х„™.\n</p><p>„Ф„Ы„†„° „Ґ„¶„Ю„Х, „Ю„™„І„Щ„Щ„Э „Ь„Р„Ч„® „Ы„†„° '„Щ„Х„Э „¶„С„Р„Х„™ „Ф<i>, „Ы„©„С„™„Ч„Щ„Ь„™ „Ф„Ю„Ґ„Ю„У „Ю„У„С„® „Ф„Ю„†„Ч„Ф, „Х„Ь„Р„Ч„® „Ю„Ы„Я „Ф„І„®„Р„™ „§„®„І„Х „©„Ь „Ф„®„С„Щ „С„Ю„Ґ„Ю„У „Ф„Р„Ь„§„Щ„Э „Ґ„Ь „Щ„У„Щ „Р„Ч„У „Ф„Ю„©„§„Щ„Ґ„Щ„Э „Ы„©„С„°„Щ„Х„Э „Ю„Ы„®„Щ„Ц „Р„™ „Ф„Ы„®„Ц„™ '<a href=\"/index.php/%D7%99%D7%97%D7%99\" class=\"mw-redirect\" title=\"„Щ„Ч„Щ\">„Щ„Ч„Щ</a>'.</i>\n„†„Х„©„Р „Ф„™„Х„Ы„†„Щ„™ „Ю„©„™„†„Ф „Ю„©„†„Ф „Ь„©„†„Ф.\n</p><p>„С„Ы„†„° „†„Х„Р„Ю„Щ„Э „Р„Щ„©„Щ„Э „Ч„©„Х„С„Щ„Э, „Ч„С„®„Щ „Ы„†„°„™, <a href=\"/index.php/%D7%A8%D7%91%D7%A0%D7%99%D7%9D\" class=\"mw-redirect\" title=\"„®„С„†„Щ„Э\">„®„С„†„Щ„Э</a>, „Ь„¶„У „Ц„Ю„®„Щ„Э, „Х„С„Ю„Ф„Ь„Ъ „Ф„Ы„†„° „Ю„Х„І„®„†„Щ„Э „І„Ш„Ґ„Щ „Х„Щ„У„Р„Х „Ю„Ф„®„С„Щ, „Ґ„Ь „Р„†„©„Щ„Э „©„Ю„°„§„®„Щ„Э „Ґ„Ь „Ф„І„©„® „©„Ь„Ф„Э „Ґ„Э „Ф„®„С„Щ.\n</p><p>„Ь„Ы„Щ„†„Х„° „Ю„Т„Щ„Ґ„Щ„Э „Ю„©„Ь„Ч„™ „Ч„С„®„Щ <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%22%D7%93\" title=\"„Ю„Ы„Х„Я „Ф„Ь„Ы„Ф „Ч„С&quot;„У\">„Ю„Ы„Х„Я „Ф„Ь„Ы„Ф „Ч„С\"„У</a> „Ф„®„С <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%91%D7%95%D7%A2%D7%96_%D7%99%D7%95%D7%A8%D7%A7%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"„С„®„Х„Ъ „С„Х„Ґ„Ц „Щ„Х„®„І„Х„С„Щ„•\">„С„®„Х„Ъ „С„Х„Ґ„Ц „Щ„Х„®„І„Х„С„Щ„•</a>, „Ф„®„С <a href=\"/index.php/%D7%92%D7%93%D7%9C%D7%99%D7%94_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"„Т„У„Ь„Щ„Ф „Р„І„°„Ь„®„Х„У\">„Т„У„Ь„Щ„Ф „Р„І„°„Ь„®„Х„У</a>, „Ф„®„С <a href=\"/index.php/%D7%99%D7%A9%D7%A2%D7%99%D7%94%D7%