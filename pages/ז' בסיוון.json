%95%D7%9F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ז' בסיוון</b> הוא היום השביעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">חודש סיוון</a>. בחוץ לארץ חוגגים ביום זה את יומו השני של <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח – <a href=\"/index.php/%D7%9E%D7%AA%D7%9F_%D7%AA%D7%95%D7%A8%D7%94\" title=\"מתן תורה\">מתן תורה</a> לשיטת <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%99%D7%95%D7%A1%D7%99\" title=\"רבי יוסי\">רבי יוסי</a>.</li>\n<li>ב'תמ\"ח – <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%99%D7%A0%D7%95\" title=\"משה רבינו\">משה רבינו</a> עלה להר סיני לקבל את <a href=\"/index.php/%D7%9C%D7%95%D7%97%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"לוחות הברית\">לוחות הברית</a> הראשונות.</li>\n<li>ב'תתנ\"ה – <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%94%D7%9E%D7%9C%D7%9A\" title=\"דוד המלך\">דוד המלך</a>, ראשון מלכי ישראל ומחבר <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%94%D7%9C%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ספר התהלים\">ספר התהלים</a>, נולד<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>ב'תתקכ\"ה – <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%94%D7%9E%D7%9C%D7%9A\" title=\"דוד המלך\">דוד המלך</a> נפטר<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%98\" title=\"תק&quot;ט\">תק\"ט</a> – אברהם בן אברהם, הגרף פוטוצקי שהתגייר, הועלה על המוקד ונקבר בסמוך לציון ה<a href=\"/index.php/%D7%92%D7%A8%22%D7%90\" class=\"mw-redirect\" title=\"גר&quot;א\">גר\"א</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%98\" title=\"תק&quot;ט\">תק\"ט</a> – רבי <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%95%D7%95%D7%9C%D7%95%D7%96%27%D7%99%D7%9F\" title=\"חיים מוולוז&#39;ין\">חיים מוולוז'ין</a>, נולד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%91\" title=\"תקצ&quot;ב\">תקצ\"ב</a> – רבי יששכר בעריש מ<a href=\"/index.php?title=%D7%96%D7%99%D7%93%D7%99%D7%98%D7%A9%D7%95%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"זידיטשוב (הדף אינו קיים)\">זידיטשוב</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%92\" title=\"תשי&quot;ג\">תשי\"ג</a> – רבי זליג ראובן בנגיס, ראב\"ד <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> מחבר ספר 'לפלגות ראובן', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a> – רבי שמואל הרנפלד, אב\"ד מטרסדורף ומחבר ספר 'מענה שמחה', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%9B%22%D7%90\" title=\"תקכ&quot;א\">תקכ\"א</a> – <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%A6%D7%91%D7%99\" class=\"mw-redirect\" title=\"רבי צבי\">רבי צבי</a>, בנו וממלא מקומו של <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%A9%22%D7%98\" class=\"mw-redirect\" title=\"הבעש&quot;ט\">הבעש\"ט</a> אמר, כי אביו הודיעו ב<a href=\"/index.php/%D7%97%D7%9C%D7%95%D7%9D\" title=\"חלום\">חלום</a> להעביר את הנהגת הנשיאות ל<a href=\"/index.php/%D7%94%D7%9E%D7%92%D7%99%D7%93_%D7%9E%D7%9E%D7%A2%D7%96%D7%A8%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"המגיד ממעזריטש\">המגיד ממעזריטש</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%98\" title=\"תרע&quot;ט\">תרע\"ט</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%A9%D7%9C%D7%9E%D7%94_%D7%92%D7%A8%D7%A9%D7%95%D7%91%D7%99%D7%A5\" title=\"דוד שלמה גרשוביץ\">דוד שלמה גרשוביץ</a>, פרטיזן ב<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%99%D7%94\" title=\"מלחמת העולם השנייה\">מלחמת העולם השנייה</a> ומראשוני המתיישבים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%92\" title=\"תרצ&quot;ג\">תרצ\"ג</a> – הרב <a href=\"/index.php/%D7%A7%D7%94%D7%AA_%D7%95%D7%99%D7%99%D7%A1\" title=\"קהת וייס\">קהת וייס</a>, שליח הרבי בפיטסבורג ומנהל סניף ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%99%D7%98%D7%A1%D7%91%D7%95%D7%A8%D7%92\" title=\"תומכי תמימים פיטסבורג\">אחי תמימים</a> בעיר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a> – הרב <a href=\"/index.php/%D7%91%D7%95%D7%A2%D7%96_%D7%A7%D7%9C%D7%99\" title=\"בועז קלי\">בועז קלי</a>, יו\"ר מטה <a href=\"/index.php/%D7%A9%D7%91%D7%A2_%D7%9E%D7%A6%D7%95%D7%95%D7%AA_%D7%91%D7%A0%D7%99_%D7%A0%D7%97\" title=\"שבע מצוות בני נח\">שבע מצוות בני נח</a> וחבר הנהלת מוסדות חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C\" title=\"קריית שמואל\">קריית שמואל</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> – הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A1%D7%A0%D7%93%D7%A8_%D7%A0%D7%9E%D7%A6%D7%95%D7%91\" title=\"אברהם סנדר נמצוב\">אברהם סנדר נמצוב</a>, מראשוני חסידי חב\"ד ב<a href=\"/index.php/%D7%90%D7%A0%D7%92%D7%9C%D7%99%D7%94\" class=\"mw-redirect\" title=\"אנגליה\">אנגליה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%91%D7%A8%D7%96%D7%99%D7%9F\" class=\"mw-redirect\" title=\"יהודה אריה לייב ברזין\">יהודה אריה לייב ברזין</a>, ממייסדי קהילת חב\"ד ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%A8%D7%A1%D7%A7%D7%99%D7%9F\" title=\"שלום דובער רסקין\">שלום דובער רסקין</a>, מזקני החסידים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> – ר' <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A6%D7%91%D7%99_%D7%90%D7%99%D7%99%D7%96%D7%A0%D7%91%D7%9A\" title=\"יצחק צבי אייזנבך\">יצחק צבי אייזנבך</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> שהביא את הניגון '<a href=\"/index.php/%D7%90%D7%99%D7%9E%D7%AA%D7%99_%D7%A7%D7%90%D7%AA%D7%99_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" class=\"mw-redirect\" title=\"אימתי קאתי (ניגון)\">אימתי קאתי מר</a>'.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%93%D7%99%D7%9C\" title=\"מרדכי דיל\">מרדכי דיל</a> מחסידי חב\"ד ב<a href=\"/index.php/%D7%91%D7%99%D7%AA%D7%A8_%D7%A2%D7%99%D7%9C%D7%99%D7%AA\" title=\"ביתר עילית\">ביתר</a>, תלמיד חכם.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ז' בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>ב' ד<a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a></i>.\n<p>נשיאת כפים: כשאומרים תיבת \"יברכך\" - המתברך ראשו באמצע. \"ה'\" - מיסב ראשו לימינו, שהיא שמאל המברך. \"וישמרך\" - באמצע. \"יאר\" - לשמאלו שהיא ימין המברך וכו'. \"שלום\" - ראשו באמצע. אמירת \"רבונו של עולם\" - בשעה שהכהנים מנגנים דוקא, אבל כשאומרים התיבות צריך לשמוע. כשמנגנים ל\"וישם\" אומרים רבונו של עולם . . הצדיק. כשמנגנים לתיבת \"לך\" ואם . . אלישע. ל\"שלום\" וכשם . . לטובה. כשאומרים \"שלום\" - אומרים \"ותשמרני ותחנני ותרצני\". אדיר במרום אומרים אחר ענית אמן כשעדיין הטלית על פניו.\n</p>\n<div style=\"clear: right; float: right;\"><b><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D/%D7%95%27_%D7%A1%D7%99%D7%95%D7%9F\" title=\"תבנית:היום יום/ו&#39; סיון\">ליום הקודם</a></b></div>\n<div style=\"clear: left; float: left;\"><b><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D/%D7%97%27_%D7%A1%D7%99%D7%95%D7%9F\" title=\"תבנית:היום יום/ח&#39; סיון\">ליום הבא</a></b></div>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">שיחת <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a> תשד\"מ.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">לקוטי שיחות ח\"ח שיחה לחג השבועות.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414035607\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.059 seconds\nReal time usage: 0.109 seconds\nPreprocessor visited node count: 197/1000000\nPost‐expand include size: 7130/2097152 bytes\nTemplate argument size: 557/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 725/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5472256/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   85.911      1 -total\n 65.42%   56.201      2 תבנית:הערה\n 19.26%   16.549      1 תבנית:הערות_שוליים\n  9.24%    7.942      1 תבנית:חודש_סיוון\n  5.95%    5.108      1 תבנית:לוח_שנה\n  5.59%    4.801      1 תבנית:להיום_יום\n  3.40%    2.920      1 תבנית:הערות_שוליים/מרחב_שם\n  2.43%    2.090      1 תבנית:כתב_ק