9%D7%9E%D7%97_%D7%AA%D7%A9%D7%9E%D7%97_%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"המשך שמח תשמח תרנ&quot;ז\">המשך שמח תשמח תרנ\"ז</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%A8%D7%A0%22%D7%98\" class=\"mw-redirect\" title=\"המשך רנ&quot;ט\">המשך רנ\"ט</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91_%D7%A9%D7%9C_%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94_%D7%AA%D7%A8%D7%A1%22%D7%95\" title=\"המשך יום טוב של ראש השנה תרס&quot;ו\">המשך תרס\"ו</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%A9%D7%A2%D7%94_%D7%A9%D7%94%D7%A7%D7%93%D7%99%D7%9E%D7%95_%D7%AA%D7%A2%D7%A8%22%D7%91\" title=\"בשעה שהקדימו תער&quot;ב\">המשך תער\"ב</a> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%AA%D7%A9%D7%A8%D7%99_%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"המשך תשרי תשכ&quot;ג\">המשך תשרי תשכ\"ג</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #33cccc;\"><font size=\"2\">מושגים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%94%D7%9B%D7%A0%D7%94_%D7%9C%D7%9E%D7%90%D7%9E%D7%A8\" class=\"mw-redirect\" title=\"ניגון הכנה למאמר\">ניגון הכנה למאמר</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C\" title=\"דיבור המתחיל\">דיבור המתחיל</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%99%D7%90%D7%99%D7%A8_%D7%A0%D7%AA%D7%99%D7%91_(%D7%9E%D7%95%D7%A9%D7%92)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יאיר נתיב (מושג) (הדף אינו קיים)\">יאיר נתיב</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%99%D7%9B%D7%9C%D7%90%D7%9A\" title=\"ביכלאך\">ביכלאך</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%9C%D7%AA%D7%99_%D7%9E%D7%95%D7%92%D7%94\" title=\"בלתי מוגה\">בלתי מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9E%D7%95%D7%92%D7%94\" title=\"מוגה\">מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשך</a>\n</td></tr>\n</tbody></table>\n<p><b>המאמר 'החודש הזה לכם' <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a></b> -   נאמר בש\"פ ויקהל פקודי <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a>, והוגה כשנה לאחר מכן לקראת <a href=\"/index.php/%D7%91%27_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ב&#39; ניסן\">ב' ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.A8.D7.A7.D7.A2\"></span><span class=\"mw-headline\" id=\"רקע\">רקע</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%97%D7%95%D7%93%D7%A9_%D7%94%D7%96%D7%94_%D7%AA%D7%A9%D7%9E%22%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;רקע&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%97%D7%95%D7%93%D7%A9_%D7%94%D7%96%D7%94_%D7%AA%D7%A9%D7%9E%22%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: רקע\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>המאמר החודש הזה לכם' <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a> ב<a href=\"/index.php/%D7%91%27_%D7%A0%D7%99%D7%A1%D7%9F_%D7%AA%D7%A9%D7%9E%22%D7%97\" class=\"mw-redirect\" title=\"ב&#39; ניסן תשמ&quot;ח\">ב' ניסן תשמ\"ח</a> <a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91%D7%99\" title=\"התוועדות עם הרבי\">התוועדות</a> שבת פרשת ויקהל פקודי, ופרשת החודש מברכים חודש <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a>, והוא מיוסד על <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמר</a> שאמר <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a>, שנאמר בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> (אעת\"ר), ושגם בה הייתה אותה קביעות כמו ב<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a>.\n</p><p>שנה לאחר אמירת המאמר, הוא הוגה ויצא לאור לקראת <a href=\"/index.php/%D7%91%27_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ב&#39; ניסן\">ב' ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>. הנקודות העיקריות ב<a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמר</a> הן: <b>א.</b> מעלת גילוי האלוקי המתלבש בעולמות להחיותם, <b>ב.</b> מעלתת הגילויים שבתורה הנעלים הרבה יותר מן הראשונים.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9B.D7.9F_.D7.94.D7.9E.D7.90.D7.9E.D7.A8\"></span><span class=\"mw-headline\" id=\"תוכן_המאמר\">תוכן המאמר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%97%D7%95%D7%93%D7%A9_%D7%94%D7%96%D7%94_%D7%AA%D7%A9%D7%9E%22%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;תוכן המאמר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%97%D7%95%D7%93%D7%A9_%D7%94%D7%96%D7%94_%D7%AA%D7%A9%D7%9E%22%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: תוכן המאמר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ה<a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמר</a> מבאר את הפסוק <b>\"החודש הזה לכם ראשי חדשים, ראשון הוא לכם לחדשי השנה\"</b>, על פי דברי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> במאמר משנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> הנ\"ל, שבחומש בראשית ובפרשיות של חומש שמות לפני פרשת החודש, \n</p><p>מדובר בגילויים האלוקים שבעולמות, כולל'<a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%94%D7%A7%D7%95\" class=\"mw-redirect\" title=\"אור הקו\">אור הקו</a>', שאמנם הוא עצמו בבחינת בלי גבול, וגם לאחר שמתלבש בכלים אינו נתפס בהם, אבל מכל מקום הוא בגדר גבול, כיון שנמשך על ידי ה<a href=\"/index.php/%D7%A6%D7%9E%D7%A6%D7%95%D7%9D\" class=\"mw-redirect\" title=\"צמצום\">צמצום</a>. ומפרשת החודש ואילך, מדבר אודות הגילוים האלוקיים של ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>, שהוא גילוי <a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA\" class=\"mw-redirect\" title=\"עצמות\">עצמות</a> <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" title=\"אור אין סוף\">אור אין סוף</a> שלפני ה<a href=\"/index.php/%D7%A6%D7%9E%D7%A6%D7%95%D7%9D\" class=\"mw-redirect\" title=\"צמצום\">צמצום</a>.\n</p><p>ומוסיף, שב<a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a> השייך לעולמות, נכלל גם שורש המדידה שב'<a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%94%D7%A7%D7%95\" class=\"mw-redirect\" title=\"אור הקו\">אור הקו</a>' שהוא ב<a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" title=\"אור אין סוף\">אור אין סוף</a> שלפני הצמצום, ואפילו עליית רצון, כי גם הם בבחינת <a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a> שבבחינת 'המשכה וגילוי', ולכן גם המשכתם היא על ידי ה<a href=\"/index.php/%D7%A6%D7%9E%D7%A6%D7%95%D7%9D\" class=\"mw-redirect\" title=\"צמצום\">צמצום</a>. ואילו הכוונה בנתינת ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> היא - להמשיך גם את האור שלפני כל הצמצומים.\n</p><p>במאמר מובא ביאור נרחב אודות ה<a href=\"/index.php/%D7%A6%D7%9E%D7%A6%D7%95%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"צמצומים\">צמצומים</a> שלפני ה'<a href=\"/index.php/%D7%A6%D7%9E%D7%A6%D7%95%D7%9D_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" title=\"צמצום הראשון\">צמצום הראשון</a>', ומסיק שהגילויים שב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> מתחילים בעיקר ב<a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%94%D7%97%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"פרשת החודש\">פרשת החודש</a>, הם לפני כל צמצומים אלו, והם מ<a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_%D7%90%D7%95%D7%A8_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" class=\"mw-redirect\" title=\"עצמות אור אין סוף\">עצמות אור אין סוף</a> ממש.\n</p><p>ולכן נאמר \"החודש הזה לכם <b>ראש</b> חדשים\" כי בחודש <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> נמשך גילוי <a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_%D7%90%D7%95%D7%A8_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" class=\"mw-redirect\" title=\"עצמות אור אין סוף\">עצמות אור אין סוף</a>, ולכן \"בניסן נגאלו ובניסן עתידין ליגאל\" <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, כי עניין ה<a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"גאולה\">גאולה</a> הוא, שאז תתגלה ה<a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" class=\"mw-redirect\" title=\"עצמות אין סוף\">עצמות אין סוף</a> בלי לבוש ממש.\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצונים\">קישורים חיצונים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%97%D7%95%D7%93%D7%A9_%D7%94%D7%96%D7%94_%D7%AA%D7%A9%D7%9E%22%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצונים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%97%D7%95%D7%93%D7%A9_%D7%94%D7%96%D7%94_%D7%AA%D7%A9%D7%9E%22%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצונים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://he.chabad.org/library/article_cdo/aid/3140123\">מאמר החודש הזה לכם תשמ\"ז</a> - טקסט</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראש השנה י\"א א'</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414084441\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.071 seconds\nReal time usage: 1.163 seconds\nPreprocessor visited node count: 192/1000000\nPost‐expand include size: 8290/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 373/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5201920/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  847.423      1 -total\n 79.45%  673.257      1 תבנית:הערה\n 10.92%   92.574      1 תבנית:הערות_