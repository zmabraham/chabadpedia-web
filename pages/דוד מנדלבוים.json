      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D_%D7%AA%D7%A9%D7%A4%27%27%D7%95.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/74/%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D_%D7%AA%D7%A9%D7%A4%27%27%D7%95.jpg/220px-%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D_%D7%AA%D7%A9%D7%A4%27%27%D7%95.jpg\" decoding=\"async\" width=\"220\" height=\"293\" class=\"mw-file-element\" srcset=\"/images/thumb/7/74/%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D_%D7%AA%D7%A9%D7%A4%27%27%D7%95.jpg/330px-%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D_%D7%AA%D7%A9%D7%A4%27%27%D7%95.jpg 1.5x, /images/thumb/7/74/%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D_%D7%AA%D7%A9%D7%A4%27%27%D7%95.jpg/440px-%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D_%D7%AA%D7%A9%D7%A4%27%27%D7%95.jpg 2x\" /></a><figcaption>הרב דוד מנדלבוים (<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a>)</figcaption></figure><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/ea/%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D.jpg/200px-%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D.jpg\" decoding=\"async\" width=\"200\" height=\"300\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ea/%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D.jpg/300px-%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D.jpg 1.5x, /images/thumb/e/ea/%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D.jpg/400px-%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D.jpg 2x\" /></a><figcaption>הרב דוד מנדלבוים (<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a>)</figcaption></figure>\n<p>הרב <b>דוד מנדלבוים</b> (<b>מנדלבאום</b>), (נולד ב<a href=\"/index.php/%D7%92%27_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"ג&#39; טבת\">ג' טבת</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a>)  הוא מהדמויות המפורסמות מאנשי <a href=\"/index.php/770_-_%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"770 - מרכז חב&quot;ד העולמי\">בית חיינו - 770</a>, ממשפיעי אנ\"ש בשכונת <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>, <a href=\"/index.php/%D7%A1%D7%95%D7%A4%D7%A8_%D7%A1%D7%AA%22%D7%9D\" title=\"סופר סת&quot;ם\">סופר סת\"ם</a>, <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A7%D7%95%D7%A8%D7%90\" title=\"בעל קורא\">בעל קורא</a> ו<a href=\"/index.php/%D7%A9%D7%95%22%D7%91\" class=\"mw-redirect\" title=\"שו&quot;ב\">שו\"ב</a>.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%92%27_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"ג&#39; טבת\">ג' טבת</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a>. משפחתו<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> משכונת וושינגטון הייטס ב<a href=\"/index.php/%D7%9E%D7%A0%D7%94%D7%98%D7%9F\" title=\"מנהטן\">מנהטן</a>.\n</p><p>התחיל את הקשר שלו עם ליובאוויטש בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%90\" title=\"תשכ&quot;א\">תשכ\"א</a> שנסע בחודשי הקיץ למחנה <a href=\"/index.php/%D7%A7%D7%A2%D7%9E%D7%A4_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"קעמפ גן ישראל\">גן ישראל</a> שם ראה את <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בפעם הראשונה.\n</p><p>בין השנים <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%95\" title=\"תשכ&quot;ו\">תשכ\"ו</a> למד בתומכי תמימים בדפורד ודין, ב<a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%98\" title=\"תשכ&quot;ט\">תשכ\"ט</a> למד בתות\"ל נוארק, <a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%92%27%D7%A8%D7%96%D7%99\" title=\"ניו ג&#39;רזי\">ניו ג'רזי</a> ובשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%9C\" title=\"תש&quot;ל\">תש\"ל</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_770\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית - 770\">תומכי תמימים המרכזית - 770</a>.\n</p><p>זכה להיכנס ל<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> אצל הרבי עשר פעמים.\n</p><p>בתקופה שבין <a href=\"/index.php/%D7%94%D7%90%D7%99%D7%A8%D7%95%D7%A2_%D7%94%D7%91%D7%A8%D7%99%D7%90%D7%95%D7%AA%D7%99_(%D7%AA%D7%A9%D7%A0%22%D7%91_-_%D7%AA%D7%A9%D7%A0%22%D7%93)\" title=\"האירוע הבריאותי (תשנ&quot;ב - תשנ&quot;ד)\">כ\"ז אדר (השני)</a> לג' תמוז תשנ\"ד (בו שהה הרבי ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A8%D7%A4%D7%95%D7%90%D7%94\" title=\"בית רפואה\">בית הרפואה</a> <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_(%D7%9E%D7%A8%D7%9B%D7%96_%D7%A8%D7%A4%D7%95%D7%90%D7%99)\" title=\"בית ישראל (מרכז רפואי)\">בית ישראל</a>) היה הראשון להשתדך. והתחתן ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" title=\"תומכי תמימים ברינואה\">תומכי תמימים ברינואה</a> ב<a href=\"/index.php/%D7%9B%22%D7%93_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"כ&quot;ד אלול\">כ\"ד אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> עם מרת עיישא.\n</p><p>משמש כ<a href=\"/index.php/%D7%A1%D7%95%D7%A4%D7%A8_%D7%A1%D7%AA%22%D7%9D\" title=\"סופר סת&quot;ם\">סופר סת\"ם</a> ומגיה סת\"ם מומחה. את התמחותו למד אצל הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%96%D7%99%D7%A8%D7%A7%D7%99%D7%A0%D7%93\" class=\"mw-redirect\" title=\"אליעזר זירקינד\">אליעזר זירקינד</a>, הסופר סת\"ם של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.\n</p><p>משמש כ<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A7%D7%95%D7%A8%D7%90\" title=\"בעל קורא\">בעל קורא</a> דייקן. היה קורא בתורה בשני וחמישי ב<a href=\"/index.php/%D7%96%D7%90%D7%9C\" title=\"זאל\">זאל</a> בנוכחות <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, בזמנים שר' <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%A8%D7%A1%D7%A7%D7%99%D7%9F\" title=\"דוד רסקין\">דוד רסקין</a> לא קרא. כיום קורא בתורה במניינים המתקיימים בבית הכנסת הגדול ב-770.\n</p><p>מזמן לזמן מעורר בבימות שונות כמו <a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5_%D7%94%D7%A2%D7%A8%D7%95%D7%AA_%D7%95%D7%91%D7%99%D7%90%D7%95%D7%A8%D7%99%D7%9D_%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"קובץ הערות וביאורים אהלי תורה\">קובץ הערות וביאורים אהלי תורה</a> על עניינים שונים בתחום הסת\"ם בו עוסק ובענייני הלכה ומנהג<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. כמו כן היה שותף לפרסום אופן עשיית הקשר המיוחד בתפילין של ראש כפי שהוא בתפילין של הרבי<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ידוע כאחד מהדמויות הבולטות ב-770<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>. וגם כבעל שמועה וזכרון נפלא בהתרחשויות שבהן היה נוכח.\n</p><p>במשך תקופה היה קושר לרבי את הטלית קטן. את התפקיד קיבל לאחר חתונתו של ר' <a href=\"/index.php/%D7%97%D7%A1%22%D7%93_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" class=\"mw-redirect\" title=\"חס&quot;ד הלברשטאם\">חס\"ד הלברשטאם</a>, כפי שהורה הרבי לחס\"ד כמה הנהגות בקשירת הציצית: א. ללכת קודם למקווה. ב. שזה ייעשה על ידי תמים בישיבה דווקא ולא על ידי אברך. ג. לעשות זאת בין הסדרים. ד. לעשות זאת דווקא ביום ולא בלילה<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%9E%D7%A0%D7%93%D7%9C%D7%91%D7%95%D7%99%D7%9D&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://old2.ih.chabad.info/#!g=1&amp;url=article&amp;id=53219\">שיעור בהלכות ציצית ותפילין</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">מצאצאי הרמ\"א והנודע ביהודה</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">לדוגמא: <a rel=\"nofollow\" class=\"external text\" href=\"https://old2.ih.chabad.info/#!g=1&amp;url=article&amp;id=68940\">ר' דוד מנדלבאום טוען: חובה לקנות תפילין \"דקות\"</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://anash.org/r-dovid-mendelbaum-explains-the-rebbes-tefillin-kesher/\">דוד מנדלבאום מסביר על קשר התפילין של הרבי</a> • <a rel=\"nofollow\" class=\"external text\" href=\"https://anash.org/first-time-photos-of-rebbes-tefillin-knots-show-unique-details/\">תמונות מקשרי התפילין של הרבי</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%90%D7%A0%22%D7%A9_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר אנ&quot;ש\"><img alt=\"קישור לאתר אנ&quot;ש\" src=\"/images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/22px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg\" decoding=\"async\" width=\"22\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/33px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg 1.5x, /images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/44px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">ר' דוד מופיע רבות ביומני ר' <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%99%D7%A4%D7%94\" title=\"זלמן יפה\">זלמן יפה</a><span class=\"source-needed-all\"><sup>[</sup><sup><a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%99%D7%91%D7%9C%D7%99%D7%95%D7%92%D7%A8%D7%A4%D7%99%D7%94\" title=\"חב&quot;דפדיה:ביבליוגרפיה\">דרוש מקור: לדוגמה?</a>]</sup></span></span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">בית משיח גיליון 470 עמ' 23.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414045956\nCache expiry: 86400