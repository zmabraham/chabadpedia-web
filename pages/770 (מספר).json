      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><div class=\"noexcerpt noprint\" style=\"font-size: 90%; color: #555577; margin-right: 22px;\"><span typeof=\"mw:File\"><span><img src=\"/images/thumb/b/bc/Disambig_RTL.svg/25px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"25\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/38px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/50px-Disambig_RTL.svg.png 2x\" /></span></span> <span class=\"nodisambig\">המונח \"770\" מפנה לכאן. אם הכוונה למשמעות אחרת, ראו <a href=\"/index.php/770_(%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D)\" class=\"mw-disambig\" title=\"770 (פירושונים)\">770 (פירושונים)</a></span>.</div>\n<table border=\"0\" cellpadding=\"4\" cellspacing=\"0\" style=\"margin: 0 1.5em 0 0; float:left; clear:left; border:1px solid #aaa; background-color:#f9f9f9; width:200px; direction:rtl;\">\n\n<tbody><tr>\n<th colspan=\"12\" style=\"background:#98FB98; text-align:center\">מספר שבע מאות ושבעים\n</th></tr>\n<tr>\n<td colspan=\"12\" style=\"background:white; text-align:center; padding:0;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%A1%D7%A4%D7%A8_770.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/b/b8/%D7%9E%D7%A1%D7%A4%D7%A8_770.jpg/150px-%D7%9E%D7%A1%D7%A4%D7%A8_770.jpg\" decoding=\"async\" width=\"150\" height=\"106\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b8/%D7%9E%D7%A1%D7%A4%D7%A8_770.jpg/225px-%D7%9E%D7%A1%D7%A4%D7%A8_770.jpg 1.5x, /images/thumb/b/b8/%D7%9E%D7%A1%D7%A4%D7%A8_770.jpg/300px-%D7%9E%D7%A1%D7%A4%D7%A8_770.jpg 2x\" /></a></span>\n</td></tr>\n<tr>\n<th colspan=\"12\" style=\"background:#BFD7FF; text-align:center\">אחדות ועשרות\n</th></tr>\n<tr style=\"text-align:center;\">\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%90%D7%A4%D7%A1&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אפס (הדף אינו קיים)\">0</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/1_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"1 (מספר)\">1</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%AA%D7%99%D7%99%D7%9D\" title=\"שתיים\">2</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%A9\" title=\"שלוש\">3</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2\" title=\"ארבע\">4</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%97%D7%9E%D7%A9\" title=\"חמש\">5</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%A9\" title=\"שש\">6</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%91%D7%A2\" title=\"שבע\">7</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%A0%D7%94\" title=\"שמונה\">8</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%AA%D7%A9%D7%A2\" title=\"תשע\">9</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A2%D7%A9%D7%A8\" title=\"עשר\">10</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%90%D7%97%D7%93_%D7%A2%D7%A9%D7%A8\" title=\"אחד עשר\">11</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%AA%D7%99%D7%99%D7%9D_%D7%A2%D7%A9%D7%A8%D7%94\" title=\"שתיים עשרה\">12</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%A9_%D7%A2%D7%A9%D7%A8%D7%94\" title=\"שלוש עשרה\">13</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2_%D7%A2%D7%A9%D7%A8%D7%94\" title=\"ארבע עשרה\">14</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%97%D7%9E%D7%A9_%D7%A2%D7%A9%D7%A8%D7%94\" title=\"חמש עשרה\">15</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%A9_%D7%A2%D7%A9%D7%A8%D7%94\" title=\"שש עשרה\">16</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%91%D7%A2_%D7%A2%D7%A9%D7%A8%D7%94\" title=\"שבע עשרה\">17</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/18_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"18 (מספר)\">18</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%AA%D7%A9%D7%A2_%D7%A2%D7%A9%D7%A8%D7%94\" title=\"תשע עשרה\">19</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%99%D7%9D\" title=\"עשרים\">20</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%90%D7%97%D7%93&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ואחד (הדף אינו קיים)\">21</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%AA%D7%99%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושתיים (הדף אינו קיים)\">22</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%9C%D7%95%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושלוש (הדף אינו קיים)\">23</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%90%D7%A8%D7%91%D7%A2\" title=\"עשרים וארבע\">24</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%97%D7%9E%D7%A9\" title=\"עשרים וחמש\">25</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושש (הדף אינו קיים)\">26</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%91%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושבע (הדף אינו קיים)\">27</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%9E%D7%95%D7%A0%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושמונה (הדף אינו קיים)\">28</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%AA%D7%A9%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ותשע (הדף אינו קיים)\">29</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%A9%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלושים (הדף אינו קיים)\">30</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D\" title=\"ארבעים\">40</a>\n</td>\n<td><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D_%D7%95%D7%AA%D7%A9%D7%A2\" title=\"ארבעים ותשע\">49</a>\n</td>\n<td><a href=\"/index.php/%D7%97%D7%9E%D7%99%D7%A9%D7%99%D7%9D\" title=\"חמישים\">50</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%99%D7%A9%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שישים (הדף אינו קיים)\">60</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%99%D7%A9%D7%99%D7%9D_%D7%95%D7%A9%D7%9E%D7%95%D7%A0%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שישים ושמונה (הדף אינו קיים)\">68</a>\n</td>\n<td><a href=\"/index.php/%D7%A9%D7%91%D7%A2%D7%99%D7%9D\" title=\"שבעים\">70</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%91%D7%A2%D7%99%D7%9D_%D7%95%D7%A9%D7%AA%D7%99%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שבעים ושתיים (הדף אינו קיים)\">72</a>\n</td>\n<td><a href=\"/index.php/%D7%A9%D7%91%D7%A2%D7%99%D7%9D_%D7%95%D7%97%D7%9E%D7%A9\" title=\"שבעים וחמש\">75</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%A0%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמונים (הדף אינו קיים)\">80</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%A0%D7%99%D7%9D_%D7%95%D7%90%D7%A8%D7%91%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמונים וארבע (הדף אינו קיים)\">84</a>\n</td>\n<td><a href=\"/index.php?title=%D7%AA%D7%A9%D7%A2%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"תשעים (הדף אינו קיים)\">90</a>\n</td></tr>\n<tr>\n<th colspan=\"12\" style=\"background:#BFD7FF; text-align:center\">מאות ואלפים\n</th></tr>\n<tr style=\"text-align:center;\">\n<td colspan=\"12\">\n<table style=\"width:100%;\">\n<tbody><tr>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%9E%D7%90%D7%94\" title=\"מאה\">100</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%9E%D7%90%D7%94_%D7%95%D7%90%D7%97%D7%93\" title=\"מאה ואחד\">101</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php?title=%D7%9E%D7%90%D7%AA%D7%99%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאתיים (הדף אינו קיים)\">200</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%A8%D7%99%22%D7%95\" title=\"רי&quot;ו\">216</a>\n</td>\n<td style=\"width:15%\"><a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%A9_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלוש מאות (הדף אינו קיים)\">300</a>\n</td>\n<td style=\"width:15%\"><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2_%D7%9E%D7%90%D7%95%D7%AA\" title=\"ארבע מאות\">400</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%97%D7%9E%D7%A9_%D7%9E%D7%90%D7%95%D7%AA\" title=\"חמש מאות\">500</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php?title=%D7%A9%D7%A9_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שש מאות (הדף אינו קיים)\">600</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td colspan=\"12\">\n<table style=\"width:100%;\">\n<tbody><tr>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%A9%D7%91%D7%A2_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שבע מאות (הדף אינו קיים)\">700</a>\n</td>\n<td style=\"width:17%\"><a class=\"mw-selflink selflink\">770</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%A0%D7%94_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמונה מאות (הדף אינו קיים)\">800</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%AA%D7%A9%D7%A2_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"תשע מאות (הדף אינו קיים)\">900</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"אלף (מספר)\">1000</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%A9%D7%99%D7%A9%D7%99%D7%9D_%D7%A8%D7%99%D7%91%D7%95%D7%90\" title=\"שישים ריבוא\">600,000</a>\n</td></tr>\n</tbody></table>\n</td></tr>\n</tbody></table>\n</td></tr>\n</tbody></table>\n<p><b>770</b> הוא מספר הקשור ביותר עם <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חסידות חב\"ד</a>, כיוון שהוא כתובת <a href=\"/index.php/770_-_%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"770 - מרכז חב&quot;ד העולמי\">מרכז חב\"ד העולמי</a> השוכן ברחוב <a href=\"/index.php/%D7%90%D7%99%D7%A1%D7%98%D7%A8%D7%9F_%D7%A4%D7%90%D7%A8%D7%A7%D7%95%D7%95%D7%99\" title=\"איסטרן פארקווי\">איסטרן פארקווי</a> 770. הרבי התייחס מספר פעמים לקשר התוכני בין המספר למבנה.\n</p>\n<h2><span id=\".D7.9E.D7.94.D7.95.D7.AA_.D7.94.D7.9E.D7.A1.D7.A4.D7.A8\"></span><span class=\"mw-headline\" id=\"מהות_המספר\">מהות המספר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=770_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;מהות המספר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=770_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: מהות המספר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9B%D7%AA%D7%95%D7%91%D7%AA_770.png\" class=\"mw-file-description\"><img src=\"/images/4/4e/%D7%9B%D7%AA%D7%95%D7%91%D7%AA_770.png\" decoding=\"async\" width=\"84\" height=\"75\" class=\"mw-file-element\" /></a><figcaption>מספר הבית שעל בנין <a href=\"/index.php/770_-_%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"770 - מרכז חב&quot;ד העולמי\">770 - מרכז חב\"ד העולמי</a></figcaption></figure>\n<p>המספר 770 מורה על שלימות, כי הוא שילוב של המספר <a href=\"/index.php/%D7%A9%D7%91%D7%A2\" title=\"שבע\">שבע</a> כפי שהוא כלול מ<a href=\"/index.php/%D7%A2%D7%A9%D7%A8\" title=\"עשר\">עשר</a> - מספר השלם, ושבע כפי שהוא כלול מ<a href=\"/index.php/%D7%9E%D7%90%D7%94\" title=\"מאה\">מאה</a> - מספר בתכלית השלימות, ועד שכולל את שני מעלות השלימות יחד.\n</p><p>וענינו ב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a>: המספר שבע קשור עם מציאות ה<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%96%D7%94\" class=\"mw-redirect\" title=\"עולם הזה\">עולם</a> ש<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%90%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"בריאת העולם\">נברא</a> בשבעה ימים, וב<a href=\"/index.php/%D7%96%27_%D7%9E%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ז&#39; מדות\">שבע מדות</a>. והשלימות של המספר שבע מורה על שלימות עבודת <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"בני ישראל\">בני ישראל</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%A8%D7%95%D7%A8_%D7%94%D7%AA%D7%97%D7%AA%D7%95%D7%9F\" class=\"mw-redirect\" title=\"בירור התחתון\">בירור העולם</a> שאז היא <a href=\"/index.php/%D7%91%D7%99%D7%90%D7%AA_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"ביאת המשיח\">ביאת המשיח</a><sup id=\"cite_ref-בית_רבינו_1-0\" class=\"reference\"><a href=\"#cite_note-בית_רבינו-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.92.D7.9E.D7.98.D7.A8.D7.99.D7.90.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"גמטריאות\"><a href=\"/index.php/%D7%92%D7%99%D7%9E%D7%98%D7%A8%D7%99%D7%94\" title=\"גימטריה\">גמטריאות</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=770_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;גמטריאות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=770_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: גמטריאות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>לכבוד <a href=\"/index.php/%D7%99%27_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"י&#39; שבט\">י' שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> שהיה שנת השבעים לנשיאות <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, הוציא הרב קומר מ<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a> קובץ המכיל 70 גימטריאות חסידיות של המספר 770. כמה גימטריאות אף מופיעים בשיחות הרבי, ומהם:\n</p>\n<ul><li>770 בגימטריה פרצת שקשור עם ה<a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"גאולה\">גאולה</a> כנאמר \"עלה הפורץ לפניהם<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>\" שמתייחס על <a href=\"/index.php/%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"משיח\">משיח</a>, וכן מורה שמ<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> יוצאת אורה לכל העולם<sup id=\"cite_ref-בית_רבינו_1-1\" class=\"reference\"><a href=\"#cite_note-בית_רבינו-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>770 בגימטריה <a href=\"/index.php/770_-_%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"770 - מרכז חב&quot;ד העולמי\">בית משיח</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>770 בגימטריה <a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<p>יש עוד כמה גימטריאות שקשורות למספר הזה, ומהם:\n</p>\n<ul><li>770 בגימטריה \"מאסף לכל המחנות\"<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>770 בגימטריה \"המלוכה והממשלה לחי עלמים\".</li>\n<li>770 בגימטריה \"לגאולה שלימה בקרוב\".</li>\n<li>770 בגימטריה \"ברוקל (י)ן ניו יורק\".</li>\n<li>770 בגימטריה \"אות המשיח\".</li>\n<li>770 בגימטריה \"בן דוד משיח צדקנו גואלנו\".</li>\n<li>בנוסף ידוע, שמספר הפעמים בהם נזכר '<a href=\"/index.php/%D7%9E%D7%A9%D7%94\" class=\"mw-redirect\" title=\"משה\">משה</a>' בתנ\"ך עולה 770.</li></ul>\n<h2><span id=\".D7.A9.D7.99.D7.9E.D7.95.D7.A9_.D7.91.D7.9E.D7.A1.D7.A4.D7.A8\"></span><span class=\"mw-headline\" id=\"שימוש_במספר\">שימוש במספר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=770_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;שימוש במספר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=770_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: שימוש במספר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>כאשר פורסמה מודעה ב<a href=\"/index.php/%D7%A2%D7%99%D7%AA%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"עיתון כפר חב&quot;ד\">עיתון כפר חב\"ד</a> כשהסכום שצוין בה היה מספר 770, ציווה הרבי לגנוז את כל עותקי העיתון ולהדפיסו מחדש ללא המודעה המדוברת<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>קיימות פרשנויות שונות לפיהם קיים חילוק בין המקרה עליו נסוב מענה הרבי לבין מקרים אחרים. כיום בקרב חלק מחסידי חב\"ד נהוג לעשות שימוש במספר כמו שילובו במספר הטלפון שלהם, שימוש במחזיק מפתחות בו מופיע המספר, ועוד.\n</p>\n<table class=\"navbox nowraplinks mw-collapsible autocollapse\" style=\"width: 75%; clear: both; margin: 0.5em auto; margin-top: 0.5em; margin-bottom: 0.5em; padding: 0.2em; text-align: right;\">\n\n<tbody><tr>\n<th colspan=\"3\" style=\"text-align: center; padding-top: 0.1em; padding-bottom: 0.1em; color: black; background:#d1eeee; font-weight: bold;\"><a href=\"/index.php/770_-_%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" title=\"770 - מרכז חב&quot;ד העולמי\">בניין שבע מאות ושבעים</a>\n</th></tr>\n\n\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\"><b>בנין המשולשים</b>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><div style=\"display:none;\"></div>\n<table class=\"nowraplinks\" style=\"width: 100%; text-align: right;\">\n\n\n\n\n\n<tbody><tr>\n<td style=\"background-color: #deeeee; text-align: right; font-weight: bold; padding-left: 5px;\">כללי\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%A8%D7%9B%D7%99%D7%A9%D7%94_%D7%95%D7%97%D7%A0%D7%95%D7%9B%D7%AA_%D7%94%D7%91%D7%99%D7%AA_%D7%A9%D7%9C_770\" title=\"רכישה וחנוכת הבית של 770\">רכישה וחנוכת הבית</a> · <a href=\"/index.php/%D7%91%D7%93%D7%A7_%D7%94%D7%91%D7%99%D7%AA_(770)\" title=\"בדק הבית (770)\">בדק הבית</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #deeeee; text-align: right; font-weight: bold; padding-left: 5px;\"><b>קומה ראשונה</b>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%A7%D7%95%D7%9E%D7%AA_%D7%94%D7%9B%D7%A0%D7%99%D7%A1%D7%94_%D7%A9%D7%9C_770\" title=\"קומת הכניסה של 770\">קומת הכניסה</a> · <a href=\"/index.php/%D7%9E%D7%96%D7%9B%D7%99%D7%A8%D7%95%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90\" class=\"mw-redirect\" title=\"מזכירות אדמו&quot;ר שליט&quot;א\">חדר המזכירות</a> · <a href=\"/index.php/%D7%97%D7%93%D7%A8_%D7%94%D7%A8%D7%91%D7%99\" title=\"חדר הרבי\">חדר הרבי</a> · <a href=\"/index.php/%D7%94%D7%96%D7%90%D7%9C_%D7%94%D7%A7%D7%98%D7%9F\" title=\"הזאל הקטן\">הזאל הקטן</a> · <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%A9%D7%99%D7%93%D7%95%D7%A8%D7%99_%D7%97%D7%91%22%D7%93\" title=\"מרכז שידורי חב&quot;ד\">מרכז שידורי חב\"ד</a> · <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%9C%D7%A2%D7%A0%D7%99%D7%A0%D7%99_%D7%97%D7%99%D7%A0%D7%95%D7%9A\" title=\"מרכז לעניני חינוך\">מרכז לעניני חינוך</a> .\n</td></tr>\n\n<tr>\n<td style=\"background-color: #deeeee; text-align: right; font-weight: bold; padding-left: 5px;\"><b>קומה שניה</b>\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%93%D7%99%D7%A8%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6_%D7%91-770\" title=\"דירת אדמו&quot;ר הריי&quot;צ ב-770\">דירת אדמו\"ר הריי\"צ ב-770</a> · <a href=\"/index.php/%D7%A1%D7%A2%D7%95%D7%93%D7%95%D7%AA_%D7%91%D7%91%D7%99%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" title=\"סעודות בבית אדמו&quot;ר הריי&quot;צ\">סעודות בבית אדמו\"ר הריי\"צ</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #deeeee; text-align: right; font-weight: bold; padding-left: 5px;\">קומה שלישית\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%A1%D7%A4%D7%A8%D7%99%D7%99%D7%AA_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93\" title=\"ספריית אגודת חסידי חב&quot;ד\">ספריית ליובאוויטש</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" title=\"אוצר החסידים\">אוצר החסידים</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\