    "pageid": 33002,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9C%D7%95%D7%92%D7%95_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/ef/%D7%9C%D7%95%D7%92%D7%95_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7.jpg/150px-%D7%9C%D7%95%D7%92%D7%95_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7.jpg\" decoding=\"async\" width=\"150\" height=\"138\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ef/%D7%9C%D7%95%D7%92%D7%95_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7.jpg/225px-%D7%9C%D7%95%D7%92%D7%95_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7.jpg 1.5x, /images/e/ef/%D7%9C%D7%95%D7%92%D7%95_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7.jpg 2x\" /></a><figcaption>סמל מחנה הקיץ</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%9E%D7%A9%D7%95%D7%AA%D7%A4%D7%AA.png\" class=\"mw-file-description\"><img src=\"/images/thumb/6/6d/%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%9E%D7%A9%D7%95%D7%AA%D7%A4%D7%AA.png/300px-%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%9E%D7%A9%D7%95%D7%AA%D7%A4%D7%AA.png\" decoding=\"async\" width=\"300\" height=\"158\" class=\"mw-file-element\" srcset=\"/images/6/6d/%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%9E%D7%A9%D7%95%D7%AA%D7%A4%D7%AA.png 1.5x\" /></a><figcaption>חניכי מחנה הקיץ בתמונה משותפת (תשע\"ג)</figcaption></figure>\n<p><b>גן ישראל <a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a></b> הינו מחנה קיץ לחיילי <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"צבאות השם\">צבאות השם</a> במתכונת יומית ('דיי קעמפ') ב<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a>, והוקם בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a>.\nמחנה הקיץ פועל במתכונת של חצי יום ותוכניות ערב על ידי סניף צבאות השם מגדל העמק ותחת \"<a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%9E%D7%97%D7%A0%D7%95%D7%AA_%D7%94%D7%A7%D7%99%D7%A5_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"רשת מחנות הקיץ גן ישראל בארץ הקודש\">רשת מחנות הקיץ גן ישראל בארץ הקודש</a>\".\n</p><p>כמו כן, מתקיים מחנה קיץ לחיילות <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"צבאות השם\">צבאות השם</a> במתכונת יומית ('דיי קעמפ') ב<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a>.\n</p><p>נכון לשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> מתחנכים בכל המסגרות כמאתיים ושישים חניכים וחניכות.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.AA.D7.A4.D7.AA.D7.97.D7.95.D7.AA_.D7.9E.D7.97.D7.A0.D7.94_.D7.94.D7.A7.D7.99.D7.A5\"></span><span class=\"mw-headline\" id=\"התפתחות_מחנה_הקיץ\">התפתחות מחנה הקיץ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;התפתחות מחנה הקיץ&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: התפתחות מחנה הקיץ\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>מחנה הקיץ נוסד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a> על ידי הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91\" class=\"mw-redirect\" title=\"מנחם מענדל זלמנוב\">מנחם מענדל זלמנוב</a>, בנו של הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91\" title=\"משה זלמנוב\">משה זלמנוב</a> משלוחי הרבי ב<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a>, כחלק מפעילות צבאות השם בעיר שמתקיימת למעלה מ-35 שנה, הפעילות מוקדשת לזכות נשמת הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%99%D7%A6%D7%97%D7%A7_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91\" title=\"ישראל יצחק זלמנוב\">ישראל יצחק זלמנוב</a> (ב\"ר שמואל).\n</p><p>עם השנים התמסדה והתרחבה פעילות מחנה הקיץ, עד שבשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> מנה מחנה הקיץ של הבנים למעלה מ־80 חיליים, ומאז פועלת במתכונת מורחבת עם מספר שעות מוגדל, עם צוות מפקדים מורחב ומסור שיוצר לדיי קעמפ אווירה חסידית ומאתגרת ממש כמו בקעמפים הגדולים.\n</p><p>החל משנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> מתקיים הדיי קעמפ ע\"ש הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%90%D7%91%D7%9C%D7%A1%D7%A7%D7%99\" title=\"זלמן טוביה אבלסקי\">זלמן טוביה אבלסקי</a> הרב הראשי למולדובה ובירתה <a href=\"/index.php/%D7%A7%D7%99%D7%A9%D7%99%D7%A0%D7%91\" title=\"קישינב\">קישינב</a> מייסד ומנהל חב\"ד ליובאוויטש <a href=\"/index.php/%D7%9E%D7%95%D7%9C%D7%93%D7%95%D7%91%D7%94\" title=\"מולדובה\">מולדובה</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> החל לצאת עלון על ידי צוות הדיי קעמפ הנקרא בשם \"חיילים נאמנים\" היוצא לאור מידי פעם, בשלב מסויים הוחלף שם העיתון ל\"הקרב האחרון\".\nבמהלך השנה מתקיים כנס ומפגש בין מפקדי הדיי קעמפ והחיילים.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> נפתחה מסגרת מיוחדת עבור החיילים שעולים לכיתות ח' וישיבה, באותה שנה גם הוקם דיי קעמפ לבנות העיר, בהשתתפות כשבעים חניכות<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> התקיימה לראשונה שבת בדיי קעמפ (כולל לינה וארוחות)<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> נרשמו למעלה מ־260 חיילים וחיילות למחנות הקיץ.\n</p><p>בזמנים נוספים בשנה, מפעיל הסניף יחד עם צוות הדיי קעמפ, מחנה בימי בין הזמנים של חג ה<a href=\"/index.php/%D7%A4%D7%A1%D7%97\" title=\"פסח\">פסח</a> וחג ה<a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"חנוכה\">חנוכה</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A0.D7.94.D7.9C.D7.99_.D7.9E.D7.97.D7.A0.D7.94_.D7.94.D7.A7.D7.99.D7.A5_.D7.9C.D7.90.D7.95.D7.A8.D7.9A_.D7.94.D7.A9.D7.A0.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"מנהלי_מחנה_הקיץ_לאורך_השנים\">מנהלי מחנה הקיץ לאורך השנים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;מנהלי מחנה הקיץ לאורך השנים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: מנהלי מחנה הקיץ לאורך השנים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a>: <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91\" class=\"mw-redirect\" title=\"מנחם מענדל זלמנוב\">מנחם מענדל זלמנוב</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a>: <a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91_(%D7%9E%D7%95%D7%9C%D7%93%D7%95%D7%91%D7%94)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמואל זלמנוב (מולדובה) (הדף אינו קיים)\">שמואל זלמנוב</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a>: <a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%90%D7%99%D7%A8_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חיים מאיר זלמנוב (הדף אינו קיים)\">חיים מאיר זלמנוב</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a> - <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a>: לוי זלמנוב</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a>: ברוך שניאור זלמנוב</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.9