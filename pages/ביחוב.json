\"background-color: #F2F3F4; font-size: 95%;\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"תבנית:עיירות ברוסיה\">עיירות ברוסיה</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" class=\"mw-redirect\" title=\"תבנית:עיירות באוקראינה\">עיירות באוקראינה</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%9C%D7%99%D7%98%D7%90\" title=\"תבנית:עיירות בליטא\">עיירות בליטא</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%9C%D7%98%D7%91%D7%99%D7%94\" title=\"תבנית:עיירות בלטביה\">עיירות בלטביה</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%A8%D7%99%D7%9D_%D7%91%D7%A4%D7%95%D7%9C%D7%99%D7%9F\" title=\"תבנית:ערים בפולין\">ערים בפולין</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"תבנית:עיירות בצרפת\">עיירות בצרפת</a>\n</td></tr></tbody></table><p>‏\n</p><h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap mw-references-columns\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראה אגרות קודש כ\"ק אדמו\"ר הזקן עמודים: 28. 32. עה-ז. שיח. שכז. תז.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">שיחת שבת חול המועד פסח <a href=\"/index.php/%D7%AA%22%D7%A9\" title=\"ת&quot;ש\">ת\"ש</a>.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">נדפס בספר המאמרים תקס\"ז ע' רי. ובשינוים ב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" class=\"mw-redirect\" title=\"תורה אור\">תורה אור</a> ז, ד.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">נדפס בספר המאמרים תק\"ע ע' פא.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">ראה אג\"ק שלו, מבוא ע' 20.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">ראה מאמרי אדמו\"ר האמצעי: דברים חלק ב, במפתח המאמרים, ע' תשכח הערה 15. ושם ובהערות שלאחרי זה על עוד ביקור. נ\"ך ע' פז</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">ראה מאמרי אדמו\"ר האמצעי ויקרא חלק ב ע' תרצט בהערה.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">ראה מאמרי אדמו\"ר האמצעי במדבר חלק א ע' קכ.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\">ראה אג\"ק אדמו\"ר האמצעי נספח 10 ע' רחצ</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span class=\"reference-text\">ראה לקוטי תורה, רשימת הכתבי יד ע' קסח.</span>\n</li>\n<li id=\"cite_note-11\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-11\">^</a></span> <span class=\"reference-text\">בשנת <a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%91\" title=\"תקצ&quot;ב\">תקצ\"ב</a> התקבל ל<a href=\"/index.php/%D7%9E%D7%95%22%D7%A6\" class=\"mw-redirect\" title=\"מו&quot;צ\">מו\"צ</a> בליובאוויטש. ראה אודותיו \"מבית הגנזים\" פרק לג. אג\"ק כ\"ק אדמו\"ר הצמח צדק ע' כז בהערה</span>\n</li>\n<li id=\"cite_note-12\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-12\">^</a></span> <span class=\"reference-text\">ראה <a href=\"/index.php/%D7%A9%D7%95%22%D7%AA_%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"שו&quot;ת צמח צדק\">שו\"ת צמח צדק</a> <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a> הוצאה חדשה סימנים עב. עח. וראה שם יו\"ד ע' שמג אודות בוחאב חדש. אהע\"ז ח\"ב ש, ו. אודות בוחאב ישן. אג\"ק שלו לפי הנסמן במפתח שמות מקומות.</span>\n</li>\n<li id=\"cite_note-13\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-13\">^</a></span> <span class=\"reference-text\">אג\"ק שלו ע' עה.</span>\n</li>\n<li id=\"cite_note-14\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-14\">^</a></span> <span class=\"reference-text\">ראה עתון <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\">כפר חב\"ד</a> גליון 453 עמ' 18. בס' <a href=\"/index.php/%D7%A4%D7%A8%D7%A7%D7%99_%D7%93%D7%A8%D7%91%D7%99_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8\" title=\"פרקי דרבי אליעזר\">פרקי דרבי אליעזר</a> עם פירוש הרד\"ל (<a href=\"/index.php/%D7%95%D7%95%D7%90%D7%A8%D7%A9%D7%90\" class=\"mw-redirect\" title=\"ווארשא\">ווארשא</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%99%22%D7%91\" title=\"תרי&quot;ב\">תרי\"ב</a>) אחר ההסכמות מודיע: \"גם זכיתי ונתכבדתי ביקר שהדותא ח\"י קודש מכ' קדושת אדמו\"ר כש\"ת מנחם מענדיל שליט\"א דק\"ק ליובאוויטש\".</span>\n</li>\n<li id=\"cite_note-15\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-15\">^</a></span> <span class=\"reference-text\">מכתב ברכה לקבלת הרבנות מכ\"ק אדמו\"ר מוהריי\"צ - אג\"ק שלו חלק טז ע' קצג. וראם שם ע' שלג.</span>\n</li>\n<li id=\"cite_note-16\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-16\">^</a></span> <span class=\"reference-text\">לקוטי רשימות ומעשיות אות מג.</span>\n</li>\n<li id=\"cite_note-17\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-17\">^</a></span> <span class=\"reference-text\">זכרון לבני ישראל ע' ק הערה קעז. כנראה הוא ר' ישראל איסור גוטין תלמיד ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a> - ספר התמימים בערכו.</span>\n</li>\n<li id=\"cite_note-18\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-18\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" title=\"ספר התמימים\">ספר התמימים</a> בערכו.</span>\n</li>\n<li id=\"cite_note-19\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-19\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%AA%D7%95%D7%9C%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%A8%D7%95%D7%A1%D7%99%D7%90_%D7%94%D7%A1%D7%95%D7%91%D7%99%D7%99%D7%98%D7%99%D7%AA\" title=\"תולדות חב&quot;ד ברוסיא הסובייטית\">תולדות חב\"ד ברוסיא הסובייטית</a> ע' מח.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413061332\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.133 seconds\nReal time usage: 0.614 seconds\nPreprocessor visited node count: 601/1000000\nPost‐expand include size: 7494/2097152 bytes\nTemplate argument size: 2243/2097152 bytes\nHighest expansion depth: 6/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 7604/5000000 bytes\nLua time usage: 0.130/7 seconds\nLua virtual size: 5746688/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  560.818      1 -total\n 88.23%  494.788     19 תבנית:הערה\n  6.64%   37.214      1 תבנית:עיירות_ברוסיה_הלבנה\n  5.37%   30.133      1 תבנית:ניווט\n  4.65%   26.092      1 תבנית:הערות_שוליים\n  0.97%    5.429      1 תבנית:הערות_שוליים/מרחב_שם\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:45135-0!can