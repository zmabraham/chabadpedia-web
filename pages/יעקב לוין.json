      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%9C%D7%95%D7%99%D7%9F_%D7%9E%D7%A7%D7%A8%D7%99%D7%90_%D7%90%D7%AA_%D7%A4%D7%A8%D7%A7%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99._%D7%9C%27%27%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/7f/%D7%94%D7%A8%D7%91_%D7%9C%D7%95%D7%99%D7%9F_%D7%9E%D7%A7%D7%A8%D7%99%D7%90_%D7%90%D7%AA_%D7%A4%D7%A8%D7%A7%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99._%D7%9C%27%27%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg/220px-%D7%94%D7%A8%D7%91_%D7%9C%D7%95%D7%99%D7%9F_%D7%9E%D7%A7%D7%A8%D7%99%D7%90_%D7%90%D7%AA_%D7%A4%D7%A8%D7%A7%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99._%D7%9C%27%27%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/7/7f/%D7%94%D7%A8%D7%91_%D7%9C%D7%95%D7%99%D7%9F_%D7%9E%D7%A7%D7%A8%D7%99%D7%90_%D7%90%D7%AA_%D7%A4%D7%A8%D7%A7%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99._%D7%9C%27%27%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg/330px-%D7%94%D7%A8%D7%91_%D7%9C%D7%95%D7%99%D7%9F_%D7%9E%D7%A7%D7%A8%D7%99%D7%90_%D7%90%D7%AA_%D7%A4%D7%A8%D7%A7%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99._%D7%9C%27%27%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg 1.5x, /images/thumb/7/7f/%D7%94%D7%A8%D7%91_%D7%9C%D7%95%D7%99%D7%9F_%D7%9E%D7%A7%D7%A8%D7%99%D7%90_%D7%90%D7%AA_%D7%A4%D7%A8%D7%A7%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99._%D7%9C%27%27%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg/440px-%D7%94%D7%A8%D7%91_%D7%9C%D7%95%D7%99%D7%9F_%D7%9E%D7%A7%D7%A8%D7%99%D7%90_%D7%90%D7%AA_%D7%A4%D7%A8%D7%A7%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99._%D7%9C%27%27%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpg 2x\" /></a><figcaption>הרב לוין מקריא את פרקו של הרבי בפאראד ל\"ג בעומר תשפ\"ה בכפר חב\"ד</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A2%D7%A0%D7%A7%D7%9C%D7%94_%D7%9C%D7%95%D7%99%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f4/%D7%99%D7%A2%D7%A0%D7%A7%D7%9C%D7%94_%D7%9C%D7%95%D7%99%D7%9F.jpg/220px-%D7%99%D7%A2%D7%A0%D7%A7%D7%9C%D7%94_%D7%9C%D7%95%D7%99%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"142\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f4/%D7%99%D7%A2%D7%A0%D7%A7%D7%9C%D7%94_%D7%9C%D7%95%D7%99%D7%9F.jpg/330px-%D7%99%D7%A2%D7%A0%D7%A7%D7%9C%D7%94_%D7%9C%D7%95%D7%99%D7%9F.jpg 1.5x, /images/thumb/f/f4/%D7%99%D7%A2%D7%A0%D7%A7%D7%9C%D7%94_%D7%9C%D7%95%D7%99%D7%9F.jpg/440px-%D7%99%D7%A2%D7%A0%D7%A7%D7%9C%D7%94_%D7%9C%D7%95%D7%99%D7%9F.jpg 2x\" /></a><figcaption>הרב לוין עומד צמוד ל<a href=\"/index.php/%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"רבי\">רבי</a> (מימין) במעמד <a href=\"/index.php/%D7%97%D7%9C%D7%95%D7%A7%D7%AA_%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"חלוקת ספר התניא\">חלוקת ספר התניא</a></figcaption></figure>\n<p>הרב <b>יעקב (יענקל'ה) הלוי לוין</b> (נולד ב<a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ה בתמוז\">כ\"ה בתמוז</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a>) הוא מנהל ארגון <a href=\"/index.php?title=Israelhelp.org&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Israelhelp.org (הדף אינו קיים)\">Israelhelp.org</a> המסייע לנזקקים, ומשפיע ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%95%D7%99%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%95%D7%99%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%94_%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"כ&quot;ה תמוז\">כ\"ה תמוז</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a> ב<a href=\"/index.php/%D7%A4%D7%AA%D7%97_%D7%AA%D7%A7%D7%95%D7%95%D7%94\" title=\"פתח תקווה\">פתח תקווה</a> לרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%9C%D7%95%D7%99%D7%9F\" class=\"mw-redirect\" title=\"זלמן לוין\">זלמן לוין</a> ולרחל בתו של ר' <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%A8%D7%99%D7%96\" title=\"אברהם פריז\">אברהם פריז</a>, בשנות ילדותו התגורר ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p><p>לאחר שלמד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> ו<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"קריית גת\">קריית גת</a> - באלול <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"תשל&quot;ב\">תשל\"ב</a> נסע לשהות במחיצת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%9E%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"הרבי מליובאוויטש\">הרבי מליובאוויטש</a> עד סוף שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a>.\n</p><p>ב<a href=\"/index.php/%D7%97%22%D7%99_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"ח&quot;י אדר\">ח\"י אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a> <a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9F\" title=\"נישואין\">התחתן</a> עם חיה צירא בתו של החסיד הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A9%D7%A8_%D7%9B%D7%94%D7%A0%D7%95%D7%91\" title=\"שלום חיים אשר כהנוב\">שלום חיים אשר כהנוב</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ר' יענקל'ה הינו <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9E%D7%95%D7%A2%D7%94\" title=\"בעל שמועה\">בעל שמועה</a> מפורסם שזכה לשהות ארבע עשרה שנה אצל <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> זכה לקירובים מיוחדים, וזכה להסתופף בצילם של גדולי החסידים.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%95%D7%99%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%95%D7%99%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב אליהו שמואל לוין - <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a></li>\n<li>בנו, הרב מנחם מענדל לוין - קראון הייטס</li>\n<li>בנו, הרב יוסף יצחק לוין - טבריה</li>\n<li>חתנו, הרב שמואל נובאק - שליח הרבי ל<a href=\"/index.php?title=%D7%92%27%D7%A7%D7%A1%D7%95%D7%A0%D7%95%D7%95%D7%99%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ג&#39;קסונוויל (הדף אינו קיים)\">ג'קסונוויל</a> פלורידה</li>\n<li>חתנו, ר' ישראל זלמנוב - קראון הייטס</li>\n<li>חתנו, ר' דודי גלבשטיין - פלורידה</li>\n<li>חתנו, ר' מענדי הנאו - כפר חב\"ד</li>\n<li>חתנו, ר' יצחק צ'רנאוחוב - קראון הייטס</li>\n<li>חתנו, ר' הלל הראל - קראון הייטס</li>\n<li>חתנו, הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%90%D7%93%D7%A8%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל אדרי (הדף אינו קיים)\">מנחם מענדל אדרי</a> - משפיע בישיבת <a href=\"/index.php/%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"אהלי תמימים כפר חב&quot;ד\">אהלי תמימים כפר חב\"ד</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%95%D7%99%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%95%D7%99%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/129797\">העלו זכרונות: \"כשחשבתי שחטפו את הרב אליהו לנדא\"</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/115415\">לראות את הזריחה עם הרבי: תיאור של רגע ● בדידי הווה עובדא</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/84173\">כיפת הברזל של עם ישראל ● מרגש</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/168270\">זיכרונות פורים תשמ\"א – התקשרות שאין לה גבולות</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">היה בנו של הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9B%D7%94%D7%A0%D7%95%D7%91\" title=\"אליהו שמואל כהנוב\">אליהו שמואל כהנוב</a> (גיסו של הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9C%D7%95%D7%99%D7%98%D7%99%D7%9F\" title=\"שמואל לויטין\">שמואל לויטין</a>),ונכדו של הרב <a href=\"/index.php/%D7%90%D7%A9%D7%A8_%D7%9E%D7%A8%D7%92%D7%9C%D7%99%D7%95%D7%AA\" title=\"אשר מרגליות\">אשר מרגליות</a> רבה של העיירה <a href=\"/index.php/%D7%A8%D7%90%D7%A7%D7%A9%D7%99%D7%A7\" title=\"ראקשיק\">ראקשיק</a> וחתנו של הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%90%D7%91%D7%A2%D7%9C%D7%A2%D7%A8\" title=\"אליהו אבעלער\">אליהו אבעלער</a> שהיה מחסידי ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a>, <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a>, ו<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a></span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">בשנת תרכ\"ח שהגיע רבי אליהו ליחידות אצל אדמו\"ר המהר\"ש, הוא אמר לו \"אליהו, הריני מקנא בך, אתה נוסע לשוק, רואה הרבה אנשים, הרי כשבאמצע העסק מתדברים עם זולת באימרה יהודית, אימרה מ\"עין יעקב\", ומעוררים על לימוד נגלה וחסידות - נעשה מכך שמחה למעלה, ואת דמי הסרסרות משלם ה' יתברך בבני חיי ומזוניי, וככל שהשוק גדול יותר, יותר עבודה, הפרנסה גדולה יותר\" - <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D/%D7%98%22%D7%96_%D7%90%D7%99%D7%99%D7%A8\" title=\"תבנית:היום יום/ט&quot;ז אייר\">היום יום ט\"ז אייר</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413142024\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.092 seconds\nReal time