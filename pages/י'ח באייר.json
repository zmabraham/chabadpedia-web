      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">&gt;&gt;</a></span>\n<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">חודש אייר</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"א&#39; באייר\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ב&#39; באייר\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ג&#39; באייר\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ד&#39; באייר\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ה&#39; באייר\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ו&#39; באייר\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ז&#39; באייר\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ח&#39; באייר\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ט&#39; באייר\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&#39; באייר\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;א באייר\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ב באייר\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ג באייר\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ד באייר\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ט&quot;ו באייר\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ט&quot;ז באייר\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ז באייר\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ט באייר\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&#39; באייר\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;א באייר\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ב באייר\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ג באייר\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ד באייר\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ה באייר\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ו באייר\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ז באייר\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ח באייר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ט באייר\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ח באייר</b> הוא היום השמונה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">חודש אייר</a>, ביום זה מציינים את <a href=\"/index.php/%D7%99%D7%90%D7%A8%D7%A6%D7%99%D7%99%D7%98\" title=\"יארצייט\">יום ההילולא</a> של <a href=\"/index.php/%D7%A8%D7%A9%D7%91%22%D7%99\" class=\"mw-redirect\" title=\"רשב&quot;י\">רשב\"י</a>, <a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמ\"ח – ה<a href=\"/index.php/%D7%9E%D7%9F\" title=\"מן\">מן</a> החל לרדת בבוקר מן השמים ל<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"בני ישראל\">בני ישראל</a> ב<a href=\"/index.php?title=%D7%9E%D7%93%D7%91%D7%A8_%D7%A1%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מדבר סין (הדף אינו קיים)\">מדבר סין</a> (לדעת אחד המדרשים).</li>\n<li><b>ג'תתק\"כ – רבי <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%91%D7%9F_%D7%99%D7%95%D7%97%D7%90%D7%99\" class=\"mw-redirect\" title=\"שמעון בן יוחאי\">שמעון בן יוחאי</a>, <a href=\"/index.php/%D7%AA%D7%A0%D7%90%D7%99%D7%9D\" title=\"תנאים\">תנא</a> <a href=\"/index.php/%D7%A7%D7%91%D7%9C%D7%94\" class=\"mw-redirect\" title=\"קבלה\">מקובל</a> ומחבר <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%96%D7%94%D7%A8\" class=\"mw-redirect\" title=\"ספר הזהר\">ספר הזהר</a>, נפטר.</b></li>\n<li>של\"ב – רבי <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%99%D7%A1%D7%A8%D7%9C%D7%99%D7%A9\" class=\"mw-redirect\" title=\"משה איסרליש\">משה איסרליש</a> (הרמ\"א), רבה של העיר קראקא, מחבר ה'מפה' על השולחן ערוך וספר 'דרכי משה' על ארבעה הטורים, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A4%22%D7%97\" title=\"תקפ&quot;ח\">תקפ\"ח</a> – רבי שלמה חריף-מכנר מקשאנוב, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a> – רבי מרדכי יפה – שלזינגר, אב\"ד אייזנשטט ו<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>-יפו ומחבר הספרים 'שפת המעיל', 'משברי ים' ועוד, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a> – רבי אלטר אליהו הלוי רובינשטיין, גאב\"ד אנטוורפן ומחבר הספר 'מגדנות אליהו', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%91\" title=\"תרצ&quot;ב\">תרצ\"ב</a> – רבי <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%94%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F_(%D7%97%D7%AA%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6)\" class=\"mw-redirect\" title=\"מנחם מענדל הורנשטיין (חתן אדמו&quot;ר הריי&quot;צ)\">מנחם מענדל הורנשטיין</a>, חתן <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a>, בא בקשרי התנאים עם מרת <a href=\"/index.php/%D7%A9%D7%99%D7%99%D7%A0%D7%90_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6)\" class=\"mw-redirect\" title=\"שיינא (בת אדמו&quot;ר הריי&quot;צ)\">שיינא</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> – נערכה <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%95%D7%9B%D7%AA_%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"תהלוכת ל&quot;ג בעומר\">תהלוכת ל\"ג בעומר</a> הראשונה ליד <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> – הסתיימו חגיגות <a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9B%D7%AA_%D7%94%D7%91%D7%99%D7%AA\" title=\"חנוכת הבית\">חנוכת הבית</a> של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> – במהלך תקופת החרדה לפני פרוץ <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%A9%D7%A9%D7%AA_%D7%94%D7%99%D7%9E%D7%99%D7%9D\" title=\"מלחמת ששת הימים\">מלחמת ששת הימים</a>, מודיע <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ב<a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%94\" title=\"שיחה\">שיחתו</a> ב<a href=\"/index.php/%D7%A4%D7%90%D7%A8%D7%90%D7%93\" class=\"mw-redirect\" title=\"פאראד\">פאראד</a> כי המלחמה תסתיים בישועה גדולה מהקב\"ה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"תשל&quot;ו\">תשל\"ו</a> – <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> מסיים לקבוע את צורתם הסופית של <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%9D_%D7%A2%D7%A9%D7%A8_%D7%94%D7%A4%D7%A1%D7%95%D7%A7%D7%99%D7%9D\" class=\"mw-redirect\" title=\"שנים עשר הפסוקים\">שנים עשר הפסוקים</a> אותם צריך כל ילד יהודי לשנן בעל פה, וביקש ש<a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%97%D7%91%D7%A8_%D7%A2%D7%98_(%D7%AA%D7%A9%D7%9C%22%D7%95)\" title=\"מבצע חבר עט (תשל&quot;ו)\">ילדי חו\"ל יתכתבו עם ילדי ארץ ישראל</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%97\" title=\"תרנ&quot;ח\">תרנ\"ח</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%9E%D7%99%D7%A9%D7%95%D7%9C%D7%95%D7%91%D7%99%D7%9F\" title=\"אליעזר מישולובין\">אליעזר מישולובין</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"סמרקנד\">סמרקנד</a> ולאחר מכן ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%97\" title=\"תשי&quot;ח\">תשי\"ח</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%99%D7%A2%D7%A7%D7%91_%D7%97%D7%96%D7%9F\" title=\"שלום יעקב חזן\">שלום יעקב חזן</a>, חבר מערכת <a href=\"/index.php/%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" title=\"אוצר החסידים\">אוצר החסידים</a> ו<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> וחוקר חב\"די.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%99%22%D7%96\" title=\"תרי&quot;ז\">תרי\"ז</a> – ר' <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%91%D7%90%D7%A9%D7%A2%D7%A1\" title=\"שלמה באשעס\">שלמה באשעס</a>, מעמודי התווך של עדת החסידים בדענעבורג, נפטר בגיל 112.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> – הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%99%D7%A0%D7%99%D7%9F\" title=\"אריה לייב שיינין\">אריה לייב שיינין</a>, רבה של דוקשיץ ומבחירי בוגרי ישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a>, נרצח על <a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9_%D7%94%27\" class=\"mw-redirect\" title=\"קידוש ה&#39;\">קידוש ה'</a> ב<a href=\"/index.php/%D7%A9%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"שואה\">שואה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a> – הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A8%D7%99%D7%94%D7%95_%D7%A4%D7%9C%D7%93%D7%9E%D7%9F\" title=\"שמריהו פלדמן\">שמריהו פלדמן</a>, <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%9E%D7%A0%D7%92%D7%9F\" title=\"בעל מנגן\">בעל מנגן</a> חסידי תושב <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A0%D7%94_%D7%96%D7%90%D7%91_%D7%9E%D7%A0%D7%93%D7%9C%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"יונה זאב מנדלסון\">יונה זאב מנדלסון</a>, \"שר המשקים ד<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a>\".</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> - הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%90%D7%9C_%D7%A6%D7%93%D7%99%D7%A7\" title=\"אריאל צדיק\">אריאל צדיק</a>, חסיד חב\"ד שעסק במבצעי הקודש של הרבי, ופעיל להפצת המעיינות. היה אחד ממ\"ה <a href=\"/index.php/%D7%A0%D7%A9%D7%9E%D7%95%D7%AA\" class=\"mw-redirect\" title=\"נשמות\">נשמות</a> קדושות באסון <a href=\"/index.php/%D7%9E%D7%99%D7%A8%D7%95%D7%9F\" title=\"מירון\">מירון</a>.</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a></li></ul>\n<table class=\"collapsible autocollapse navbox nowraplinks\" style=\"width: 40%;border: 1px solid #FFD700; background-color: #EEE8AA; clear: both; margin: 0.5em auto; margin-top: 0.5em; margin-bottom: 0.5em; padding: 0.2em; text-align: right\">\n\n<tbody><tr>\n<th style=\"text-align: center; padding-top: 0.1em; padding-bottom: 0.1em; background: #FFD700\" colspan=\"3\"><b><a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a></b>\n</th></tr>\n<tr>\n<td colspan=\"2\" width=\"100%\" align=\"right\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"י&quot;ח אייר\">י\"ח אייר</a> · <a href=\"/index.php/%D7%97%D7%A5_%D7%95%D7%A7%D7%A9%D7%AA\" title=\"חץ וקשת\">חץ וקשת</a> · <a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a> · <a href=\"/index.php/%D7%9E%D7%93%D7%95%D7%A8%D7%AA_%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"מדורת ל&quot;ג בעומר\">מדורת ל\"ג בעומר</a> · <a href=\"/index.php/%D7%9E%D7%99%D7%A8%D7%95%D7%9F\" title=\"מירון\">מירון</a> · <a href=\"/index.php/%D7%A1%D7%A4%D7%99%D7%A8%D7%AA_%D7%94%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ספירת העומר\">ספירת העומר</a> · <a href=\"/index.php/%D7%94%D7%A4%D7%90%D7%A8%D7%90%D7%93_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" title=\"הפאראד אצל הרבי\">פאראד</a> · <a href=\"/index.php/%D7%A4%D7%99%D7%95%D7%98_%D7%91%D7%A8_%D7%99%D7%95%D7%97%D7%90%D7%99\" title=\"פיוט בר יוחאי\">פיוט בר יוחאי</a> · <a href=\"/index.php?title=%D7%A4%D7%99%D7%95%D7%98_%D7%95%D7%90%D7%9E%D7%A8%D7%AA%D7%9D_%D7%9B%D7%94_%D7%9C%D7%97%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"פיוט ואמרתם כה לחי (הדף אינו קיים)\">פיוט ואמרתם כה לחי</a> · <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D_%D7%9C%22%D7%92\" title=\"תהלים ל&quot;ג\">פרק ל\"ג בתהילים</a> · <a href=\"/index.php/%D7%A6%D7%99%D7%95%D7%9F_%D7%94%D7%A8%D7%A9%D7%91%22%D7%99\" class=\"mw-redirect\" title=\"ציון הרשב&quot;י\">ציון הרשב\"י</a> · <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%A2%D7%A7%D7%99%D7%91%D7%90\" title=\"רבי עקיבא\">רבי עקיבא</a> · <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%91%D7%A8_%D7%99%D7%95%D7%97%D7%90%D7%99\" title=\"רבי שמעון בר יוחאי\">רבי שמעון בר יוחאי</a> · <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%95%D7%9B%D7%AA_%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"תהלוכת ל&quot;ג בעומר\">תהלוכת ל\"ג בעומר</a>\n</td></tr></tbody></table>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ח באייר - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i><a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a></i>\n<p>אצל <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a> היה <a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a> מ<a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91\" title=\"יום טוב\">יו\"ט</a> המצויינים. מען פלעגט ארויסגעהן אויפ'ן פעלד, ער פלעגט זיך ניט וואשען, אבער נעהמען משקה, וואס מצד הבריאות האט ער עס ניט געטארט. מען האט דעמאלט געזעהן א סך מופתים. דאס רוב מופתים איז געווען בנוגע קינדער. און א גאנץ יאהר האט מען געווארט אויף לג בעומר.\n</p>\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: אצל <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a> היה <a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a> מ<a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91\" title=\"יום טוב\">יו\"ט</a> המצויינים. נהגו לצאת לשדה, לא נהג ליטול ידיים, אבל לקח משקה, שמצד הבריאות זה היה אסור עליו. ראו אז הרבה מופתים. רוב המופתים היו בנוגע לילדים. וכל השנה חיכו לל\"ג בעומר.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414022437\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.037 seconds\nReal time usage: 0.715 seconds\nPreprocessor visited node count: 141/1000000\nPost‐expand include size: 7742/2097152 bytes\nTemplate argument size: 697/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  374.607      1 -total\n