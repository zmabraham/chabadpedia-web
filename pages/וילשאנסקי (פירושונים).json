      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li><a href=\"/index.php/%D7%91%D7%A6%D7%9C%D7%90%D7%9C_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"בצלאל וילשאנסקי\">בצלאל וילשאנסקי</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> <a href=\"/index.php/%D7%90%D7%A0%22%D7%A9\" class=\"mw-redirect\" title=\"אנ&quot;ש\">אנ\"ש</a> במלבורן.</li>\n<li><a href=\"/index.php/%D7%A8%D7%A4%D7%90%D7%9C_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"רפאל וילשאנסקי\">רפאל וילשאנסקי</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> ומזכיר <a href=\"/index.php/%D7%9C%D7%A9%D7%9B%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%94%D7%90%D7%99%D7%A8%D7%95%D7%A4%D7%90%D7%99%D7%AA\" title=\"לשכת ליובאוויטש האירופאית\">לשכת ליובאוויטש האירופאית</a></li>\n<li><a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"שניאור זלמן וילשאנסקי\">שניאור זלמן וילשאנסקי</a> - רב קהילת חב\"ד מוריסטון</li>\n<li><a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"יוסף יצחק וילשאנסקי\">יוסף יצחק וילשאנסקי</a> - היה <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש</a> <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת\">ישיבות חב\"ד בצפת</a>.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"מנחם מענדל וילשאנסקי\">מנחם מענדל וילשאנסקי</a> - <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש</a> <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%97%D7%99%D7%A4%D7%94\" class=\"mw-redirect\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש חיפה\">ישיבת חב\"ד בחיפה</a>.</li>\n<li><a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"מאיר וילשאנסקי\">מאיר וילשאנסקי</a> -<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש</a> <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת (גדולה)\">ישיבת חסידי חב\"ד צפת גדולה</a>.</li>\n<li><a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"חיים אליעזר וילשאנסקי\">חיים אליעזר וילשאנסקי</a> - <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש</a> <a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9A_%D7%9C%D7%A0%D7%A2%D7%A8_(%D7%99%D7%A9%D7%99%D7%91%D7%94)\" class=\"mw-redirect\" title=\"חנוך לנער (ישיבה)\">ישיבת חנוך לנער</a>.</li>\n<li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%90%D7%9C%D7%9B%D7%A1%D7%A0%D7%93%D7%A8_%D7%A1%D7%A0%D7%93%D7%A8_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"שמואל אלכסנדר סנדר וילשאנסקי\">שמואל אלכסנדר סנדר וילשאנסקי</a> - <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש</a> ישיבת חב\"ד ב<a href=\"/index.php/%D7%9E%D7%99%D7%9C%D7%90%D7%A0%D7%95\" title=\"מילאנו\">מילאנו</a>.</li>\n<li><a href=\"/index.php?title=%D7%91%D7%A6%D7%9C%D7%90%D7%9C_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99_(%D7%97%D7%99%D7%A4%D7%94)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בצלאל וילשאנסקי (חיפה) (הדף אינו קיים)\">בצלאל וילשאנסקי</a> - שליח בשכונת פנינת הכרמל ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>.</li>\n<li><a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"ישראל שניאור זלמן וילשאנסקי\">ישראל שניאור זלמן וילשאנסקי</a> -  ראש ישיבת <a href=\"/index.php/%D7%97%D7%97%22%D7%9C_%D7%A6%D7%A4%D7%AA_%D7%A7%D7%98%D7%A0%D7%94\" class=\"mw-redirect\" title=\"חח&quot;ל צפת קטנה\">חח\"ל צפת קטנה</a>.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-fil