D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%90%D7%9C_%D7%94%27\" title=\"שיר המעלות אל ה&#39;\">ק\"כ</a> · <a href=\"/index.php/%D7%90%D7%A9%D7%90_%D7%A2%D7%99%D7%A0%D7%99_%D7%90%D7%9C_%D7%94%D7%94%D7%A8%D7%99%D7%9D\" title=\"אשא עיני אל ההרים\">קכ\"א</a> · <a href=\"/index.php/%D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%9C%D7%93%D7%95%D7%93_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"שיר המעלות לדוד (ניגון)\">קכ\"ב</a> · <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%90%D7%9C%D7%99%D7%9A\" title=\"ניגון שיר המעלות אליך\">קכ\"ג</a> · <a href=\"/index.php/%D7%9C%D7%95%D7%9C%D7%99_%D7%94%27_%D7%A9%D7%94%D7%99%D7%94_%D7%9C%D7%A0%D7%95_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"לולי ה&#39; שהיה לנו (ניגון)\">קכ\"ד</a> · <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%A9%D7%99%D7%A8_%D7%94%D7%9E%D7%A2%D7%9C%D7%95%D7%AA_%D7%94%D7%91%D7%95%D7%98%D7%97%D7%99%D7%9D_%D7%91%D7%94%27\" class=\"mw-redirect\" title=\"ניגון שיר המעלות הבוטחים בה&#39;\">קכ\"ה</a>\n<p><small>ניתן לראות את שם הניגון באמצעות ריחוף עם סמן העכבר על מספר הניגון</small>\n</p>\n</td></tr></tbody></table>\n<p>הניגון <b>אֶתְהַלֵּךְ לִפְנֵי ה' בְּאַרְצוֹת הַחַיִּים</b> הינו ניגון חסידי שהולחן במיוחד לרגל <a href=\"/index.php/%D7%99%22%D7%90_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"י&quot;א ניסן\">י\"א ניסן</a> שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a> - יום הולדתו ה-115 של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.\n</p><p>את הניגון הלחין הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9B%D7%94%D7%A0%D7%95%D7%91\" class=\"mw-redirect\" title=\"דוד כהנוב\">דוד כהנוב</a> והוא נבחר על ידי <a href=\"/index.php/%D7%95%D7%A2%D7%93%D7%AA_%D7%94%D7%A0%D7%99%D7%92%D7%95%D7%A0%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"ועדת הניגונים ליובאוויטש\">ועדת הניגונים ליובאוויטש</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, ואף התקבל בפועל בהרבה מקומות, ובראשם - בחגיגת י\"א ניסן המרכזית לכבוד הרבי בארץ הקודש בארגון מטה משיח, על ידי הזמר החסידי ר' מענדי ג'רופי, זאת במקביל לניגון שנבחר על ידי החסידים, <a href=\"/index.php/%D7%9B%D7%95%D7%A1_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA_%D7%90%D7%A9%D7%90_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" title=\"כוס ישועות אשא (ניגון)\">כוס ישועות אשא</a> - שחובר על ידי ר' <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%91%D7%A8%D7%95%D7%9B%D7%A9%D7%98%D7%98\" title=\"שלום ברוכשטט\">שלום ברוכשטט</a> והתקבל בתפוצה רחבה יותר, וניגנו אותו לאורך השנה ב<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91%D7%99\" title=\"התוועדות עם הרבי\">התוועדויות של הרבי</a>.\n</p><p><br />\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.9E.D7.99.D7.9C.D7.95.D7.AA_.D7.94.D7.A0.D7.99.D7.92.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"מילות_הניגון\">מילות הניגון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%AA%D7%94%D7%9C%D7%9A_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%27_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;מילות הניגון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%AA%D7%94%D7%9C%D7%9A_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%27_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: מילות הניגון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<blockquote dir=\"rtl\"><div class=\"hebrewQuotation\">\n<p>אֶתְהַלֵּךְ לִפְנֵי ה' בְּאַרְצוֹת הַחַיִּים:\n</p>\n<dl><dd>אֶתְהַלֵּךְ לִפְנֵי ה' בִּשְׁנַת הַחַיִּי\"ם<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>:</dd></dl>\n<p>כּוֹס יְשׁוּעוֹת אֶשָּׂא וּבְשֵׁם ה' אֶקְרָא:\n</p>\n<dl><dd>יְחִי אֲדוֹנֵנוּ מוֹרֵנוּ וְרַבֵּינוּ מֶלֶךְ הַמָּשִׁיחַ לְעוֹלָם וָעֶד:</dd></dl>\n<p>בְּחַצְרוֹת בֵּית ה' בְּתוֹכֵכִי יְרוּשָׁלַ‍ִם הַלְלוּיָהּ:\n</p>\n</div>\n<div style=\"text-align:left;border-top: 1px dotted #ccc;\">— <cite style=\"font-size:small; font-style: normal;\">תהלים קטז, ט; יג; יט</cite></div>\n </blockquote>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%AA%D7%94%D7%9C%D7%9A_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%27_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%AA%D7%94%D7%9C%D7%9A_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%27_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%A0%D7%99%D7%9D_%D7%A2%D7%9C_%D7%A4%D7%A8%D7%A7%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"ניגונים על פרקי הרבי\">ניגונים על פרקי הרבי</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D_%D7%A7%D7%98%22%D7%96\" title=\"תהלים קט&quot;ז\">תהלים קט\"ז</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%AA%D7%94%D7%9C%D7%9A_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%27_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%AA%D7%94%D7%9C%D7%9A_%D7%9C%D7%A4%D7%A0%D7%99_%D7%94%27_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%97%D7%99%D7%99%D7%9D_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://chabadpedia.co.il/images/d/d2/כהנוב_NiggunYANissan5777.mp3\">להאזנה לניגון</a></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://hageula.com/news/chabad/16622.htm\">הרב כהנוב מנגן את הניגון בהתוועדות המרכזית לכבוד י\"א ניסן ב-770</a></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/special/256781/\">אָהַבְתִּי כִּי-יִשְׁמַע: נבחר הניגון על קאפיטל קט\"ז</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">משפט זה 