et=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://chabad.info/%D7%91%D7%A2%D7%99%D7%9F-%D7%94%D7%A2%D7%93%D7%A9%D7%94/%D7%9E%D7%93%D7%95%D7%A2-%D7%94%D7%A1%D7%AA%D7%95%D7%91%D7%91-%D7%94%D7%A8%D7%91%D7%99-%D7%90%D7%9C-%D7%94%D7%9E%D7%A6%D7%9C%D7%9E%D7%94/\">מדוע הסתובב הרבי והסתכל אל המצלמה?</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://he.chabad.org/multimedia/media_cdo/aid/3520891\">הודעה באיחור</a></b> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר בית חב&quot;ד\"><img alt=\"קישור לאתר בית חב&quot;ד\" src=\"/images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/22px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG\" decoding=\"async\" width=\"22\" height=\"22\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/33px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG 1.5x, /images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/44px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG 2x\" /></a></span> חתנו הרב שמואל לו מתראיין למגזין הוידאו השבועי של חברת <a href=\"/index.php/Jem\" class=\"mw-redirect\" title=\"Jem\">jem</a></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://he.chabad.org/multimedia/media_cdo/aid/3967192\">מר מנצ'סטר</a></b>, יחידות מוקלטת של ר' זלמן יפה אצל הרבי, כ\"ה תשרי תשמ\"ג <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר בית חב&quot;ד\"><img alt=\"קישור לאתר בית חב&quot;ד\" src=\"/images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/22px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG\" decoding=\"async\" width=\"22\" height=\"22\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/33px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG 1.5x, /images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/44px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG 2x\" /></a></span></li>\n<li><b>מנחם כהנא, \"<a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/images/8/8e/%D7%94%D7%AA%D7%9E%D7%99%D7%9D_%D7%A4%D7%A1%D7%97_%D7%AA%D7%A9%D7%A4%D7%93_%D7%9E%D7%A6%D7%95%D7%A8%D7%A3_%D7%9C%D7%91%D7%99%D7%9E_1407.pdf\">בבקשה תהיה יותר ידידותי כלפיי\"</a></b>, שביבים מתוך יחידויות להן זכה אצל הרבי, בתוך 'התמים' (בית משיח) גליון נב עמוד 10</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">בת ר' שניאור זלמן איידלמן.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">צילום התעודה התפרסם במוסף 'משפחה חסידית' של <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a>, גליון 1176 עמוד 14.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://chabadlibrary.org/books/default.aspx?furl=/admur/ig/27/10343\">אגרות קודש חלק כז אגרת י'שמג</a>, מכתב מתאריך ה' אדר תשל\"ב.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">המענה נדפס בקובץ <a href=\"/index.php/%D7%A6%D7%93%D7%99%22%D7%A7_%D7%9C%D7%9E%D7%9C%D7%9A\" title=\"צדי&quot;ק למלך\">צדי\"ק למלך</a> חוברת ז' עמוד 383.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\