%A8%D7%96&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אור - ביחס לרז (הדף אינו קיים)\">אור - ביחס לרז</a> · <a href=\"/index.php?title=%D7%90%D7%95%D7%A8_-_%D7%91%D7%99%D7%97%D7%A1_%D7%9C%D7%A9%D7%9C%D7%9E%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אור - ביחס לשלמה (הדף אינו קיים)\">אור - ביחס לשלמה</a> · <a href=\"/index.php?title=%D7%90%D7%95%D7%A8_-_%D7%91%D7%99%D7%97%D7%A1_%D7%9C%D7%A9%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אור - ביחס לשם (הדף אינו קיים)\">אור - ביחס לשם</a> · <a href=\"/index.php?title=%D7%90%D7%95%D7%A8_-_%D7%91%D7%99%D7%97%D7%A1_%D7%9C%D7%A9%D7%9E%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אור - ביחס לשמים (הדף אינו קיים)\">אור - ביחס לשמים</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%95%D7%A9%D7%A4%D7%A2\" title=\"אור ושפע\">אור - ביחס לשפע</a> · <a href=\"/index.php?title=%D7%90%D7%95%D7%A8%D7%94_-_%D7%91%D7%99%D7%97%D7%A1_%D7%9C%D7%A9%D7%A9%D7%95%D7%9F_%D7%95%D7%99%D7%A7%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אורה - ביחס לששון ויקר (הדף אינו קיים)\">אורה - ביחס לששון ויקר</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A8%D7%95%D7%AA_%D7%93%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA_-_%D7%A4%D7%A9%D7%99%D7%98%D7%95%D7%AA%D7%9D_%D7%95%D7%A6%D7%99%D7%95%D7%A8%D7%9D\" title=\"אורות דספירות - פשיטותם וציורם\">אורות דספירות - פשיטותם וציורם</a>\n</td></tr>\n\n\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #FFAC99;\"><font size=\"2\">שונות</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%94%D7%A9%D7%9E%D7%A9_%D7%91%D7%A9%D7%9E%D7%A9\" title=\"אור השמש בשמש\">אור השמש בשמש</a> · <a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%95%D7%96%D7%99%D7%95&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אור וזיו (הדף אינו קיים)\">אור וזיו</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%97%D7%99%D7%95%D7%AA_%D7%95%D7%9B%D7%97\" title=\"אור חיות וכח\">אור חיות וכח</a> · <a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%9C%D7%90%D7%A8%D7%91%D7%A2%D7%94_%D7%A2%D7%A9%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אור לארבעה עשר (הדף אינו קיים)\">אור לארבעה עשר</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%9E%D7%99%D7%9D_%D7%A8%D7%A7%D7%99%D7%A2\" title=\"אור מים רקיע\">אור מים רקיע</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A8%D7%95%D7%AA_%D7%9E%D7%AA%D7%97%D7%9C%D7%A4%D7%99%D7%9D\" class=\"mw-redirect\" title=\"אורות מתחלפים\">אורות מתחלפים</a> · <a href=\"/index.php/%D7%94%D7%AA%D7%A2%D7%91%D7%95%D7%AA_%D7%94%D7%90%D7%95%D7%A8%D7%95%D7%AA\" title=\"התעבות האורות\">התעבות האורות</a> · <a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C_%D7%94%D7%90%D7%95%D7%A8_%D7%9C%D7%9E%D7%90%D7%95%D7%A8\" title=\"ביטול האור למאור\">ביטול האור למאור</a>\n</td></tr>\n</tbody></table>\n<p><b><a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a> נגה</b> הוא ביטוי הנושא משמעות כפולה והפכית: לעיתים הכוונה היא לאור נמוך כפי שהוא יורד להאיר את החושך, ואור זה הוא למטה אפילו מאור סתם, ולעיתים הכוונה למעליותא, לאור חזק ביותר כמו אור השמש בצהריים שהוא בשיא התוקף, והוא בחינה גבוהה ונעלית מאוד<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, ועליו אמרו חז\"ל ש'אור נגה' הוא האור שנברא ביום הראשון<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.95.D7.A8_.D7.A0.D7.92.D7.94_.D7.94.D7.A2.D7.9C.D7.99.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"אור_נגה_העליון\">אור נגה העליון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%A0%D7%92%D7%94&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אור נגה העליון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%A0%D7%92%D7%94&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אור נגה העליון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בטעם שהאור העליון של נגה נקרא בשם זה, מובאים בחסידות שלושה טעמים:\n</p>\n<ul><li>'נוגה' היא בחינת נעלית מאוד בקדושה, והאור שלה נקרא בשם 'אור נגה העליון'<sup id=\"cite_ref-ד_3-0\" class=\"reference\"><a href=\"#cite_note-ד-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>כיון שאור זה נמשך על ידי הבירור של <a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%A4%D7%AA_%D7%A0%D7%92%D7%94\" class=\"mw-redirect\" title=\"קליפת נגה\">קליפת נגה</a> והפיכת החשך לאור<sup id=\"cite_ref-ד_3-1\" class=\"reference\"><a href=\"#cite_note-ד-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>כיון שאור זה מאיר גם בהיכל נוגה דבריאה<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<p>אור זה שייך לבחינת המלכות, כיון ש'נגה' הוא הירח, והירח שייך לבחינת המלכות שאין לה אור משל עצמה וכל האור שלה הוא מה שמקבלת ממה שלמעלה ממנה, כמו הירח שאין לו אור עצמי רק מה שמקבל מהשמש<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בבחינות שלמעלה, אור זה הוא ב<a href=\"/index.php/%D7%9B%D7%AA%D7%A8\" title=\"כתר\">כתר</a> העליון בבחינת <a href=\"/index.php?title=%D7%9C%D7%91%D7%A0%D7%95%D7%A0%D7%99%D7%AA_%D7%93%D7%92%D7%9C%D7%92%D7%9C%D7%AA%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"לבנונית דגלגלתא (הדף אינו קיים)\">לבנונית דגלגלתא</a> שלמעלה מבחינת שערות, בחינת כתר שבכתר שמאיר בו <a href=\"/index.php?title=%D7%99%D7%A1%D7%95%D7%93_%D7%93%D7%A2%D7%AA%D7%99%D7%A7&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יסוד דעתיק (הדף אינו קיים)\">יסוד דעתיק</a> (ושייך גם למידת הנצח<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>)<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>, ולמעלה יותר - בחינת <a href=\"/index.php/%D7%A7%D7%95_%D7%95%D7%97%D7%95%D7%98\" title=\"קו וחוט\">קו וחוט</a> שנמשך מבחינת האור שלפני הצמצום<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.90.D7.95.D7.A8_.D7.A0.D7.92.D7.94_.D7.94.D7.AA.D7.97.D7.AA.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"אור_נגה_התחתון\">אור נגה התחתון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%A0%D7%92%D7%94&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;אור נגה התחתון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%A0%D7%92%D7%94&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: אור נגה התחתון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>אור נגה התחתון, הוא מלשון 'והשם יגיה חשכי'<sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\"><span class=\"cite-bracket\">&#91;</span>9<span class=\"cite-bracket\">&#93;</span></a></sup>, וכן 'וְנֹ֙גַהּ֙ כָּא֣וֹר תִּֽהְיֶ֔ה'<sup id=\"cite_ref-10\" class=\"reference\"><a href=\"#cite_note-10\"><span class=\"cite-bracket\">&#91;</span>10<span class=\"cite-bracket\">&#93;</span></a></sup> שמאיר את החושך, והאור כפי שהוא נמשך להאיר את החושך הוא נמוך יותר מהאור כמו שהוא מצד עצמו<sup id=\"cite_ref-11\" class=\"reference\"><a href=\"#cite_note-11\"><span class=\"cite-bracket\">&#91;</span>11<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>טעם נוסף לשם זה, הוא כיון שאור זה שמאיר את החושך הוא בבחינת מציאות, בליטה והרגשה, ולכן נקרא בשם נוגה בדומה ללשון 'ההוגה את השם באותיותיו'<sup id=\"cite_ref-12\" class=\"reference\"><a href=\"#cite_note-12\"><span class=\"cite-bracket\">&#91;</span>12<span class=\"cite-bracket\">&#93;</span></a></sup>, וענין זה קשור גם לטעם הראשון שמכיון שמאיר את החושך לכן יש בו הרגשה ומציאות (בדומה לאור הנר שדווקא כשמאיר את הלילה ניכר ומורגש יותר מאשר כשדולק בצהריים).\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%A0%D7%92%D7%94&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%95%D7%A8_%D7%A0%D7%92%D7%94&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://www.hebrewbooks.org/pdfpager.aspx?req=30575&amp;st=&amp;pgnum=241\">אור נגה</a></b>, ספר הערכים חב\"ד, חלק ג' עמוד תע ואילך</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap mw-references-columns\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">לקוטי תורה בלק סט, ד. אור התורה משפטים א'רעא, א'רפג.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">בראשית רבה פרשה יא, ב. פרשה יב, ו. ובהנסמן באור התורה - נ\"ך עמוד תקסב. וראה בספר הערכים ערך 'אור נגה' בסופו מספר ביאורים לקשר בין אור נגה לאור שנברא ביום הראשון.</span>\n</li>\n<li id=\"cite_note-ד-3\"><span class=\"mw-cite-backlink\">^ <sup><a href=\"#cite_ref-ד_3-0\">1</a></sup> <sup><a href=\"#cite_ref-ד_3-1\">2</a></sup></span> <span class=\"reference-text\">ליקוטי תורה בלק סט, ד. אור התורה חיי שרה קלב, ב.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">תורת לוי יצחק לש\"ס סוף עמוד קעה ואילך. ספר הערכים חב\"ד חלק ג' ערך 'אור דנגה' הערה 32.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">לקוטי תורה שבהערה הקודמת, אור התורה בראשית חלק ג' תצ, ב. אור התורה נ\"ך שבהערה הקודמת.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">אור התורה בראשית תצ, ובהנסמן שם. התבאר בספר הערכים שם.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">נסמן ב<a rel=\"nofollow\" class=\"external text\" href=\"https://www.hebrewbooks.org/pdfpager.aspx?req=30575&amp;st=&amp;pgnum=242\">ספר הערכים חלק ג' עמוד תעב</a>.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">אור התורה משפטים א'רעא, א'רפג. משפטים חלק ז' עמוד ב'תשלח.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\">שמואל ב' כב, כט. תהלים יח, כט.</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span class=\"reference-text\">חבקוק ג' ד'</span>\n</li>\n<li id=\"cite_note-11\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-11\">^</a></span> <span class=\"reference-text\">שער היחוד אדמו\"ר האמצעי פרק מ\"ו. ספר הערכים חב\"ד ערך 'אור (נהורא) אוכמא' סעיף א'.</span>\n</li>\n<li id=\"cite_note-12\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-12\">^</a></span> <span class=\"reference-text\">ספר הערכים ערך 'אור נגה' במילואים.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413061609\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.098 seconds\nReal time usage: 0.574 seconds\nPreprocessor visited node count: 377/1000000\nPost‐expand include size: 5036/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 5095/5000000 bytes\nLua time usage: 0.080/7 seconds\nLua virtual size: 5890048/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  506.385      1 -total\n 81.14%  410.904     13 תבנית:הערה\n 16.23%   82.191      1 תבנית:הערות_שוליים\n  2.38%   12.065      1 תבנית:הערות_שוליים/מרחב_שם\n  2.34%   11.836      1 תבנית:אור\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:66342-0!canonical and timestamp 20260413061609 and revision id 826461. Rendering was triggered because: page-view\n -->\n</div>"
