    "pageid": 31976,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%95%D7%93_%D7%99%D7%90%D7%A7%D7%95%D7%91%D7%A1%D7%90%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/df/%D7%93%D7%95%D7%93_%D7%99%D7%90%D7%A7%D7%95%D7%91%D7%A1%D7%90%D7%9F.jpg/220px-%D7%93%D7%95%D7%93_%D7%99%D7%90%D7%A7%D7%95%D7%91%D7%A1%D7%90%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"345\" class=\"mw-file-element\" srcset=\"/images/thumb/d/df/%D7%93%D7%95%D7%93_%D7%99%D7%90%D7%A7%D7%95%D7%91%D7%A1%D7%90%D7%9F.jpg/330px-%D7%93%D7%95%D7%93_%D7%99%D7%90%D7%A7%D7%95%D7%91%D7%A1%D7%90%D7%9F.jpg 1.5x, /images/thumb/d/df/%D7%93%D7%95%D7%93_%D7%99%D7%90%D7%A7%D7%95%D7%91%D7%A1%D7%90%D7%9F.jpg/440px-%D7%93%D7%95%D7%93_%D7%99%D7%90%D7%A7%D7%95%D7%91%D7%A1%D7%90%D7%9F.jpg 2x\" /></a><figcaption>הרב דוד יעקובסון בתקופת כהונתו כרב העיירה ליובאוויטש</figcaption></figure>\n<p>הרב <b>דוד יעקובסון</b> (<a href=\"/index.php/%D7%AA%D7%A8%D7%99%22%D7%91\" title=\"תרי&quot;ב\">תרי\"ב</a> - <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%95\" title=\"תרפ&quot;ו\">תרפ\"ו</a>) היה רב ה<a href=\"/index.php/%D7%A2%D7%99%D7%99%D7%A8%D7%94\" title=\"עיירה\">עיירה</a> <a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a> בתקופת נשיאותו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a>, שהסמיך להוראה את ה<a href=\"/index.php/%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תמימים\">תמימים</a> הלומדים ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%99%22%D7%91\" title=\"תרי&quot;ב\">תרי\"ב</a> ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a> לרב <a href=\"/index.php?title=%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בן ציון יעקובסון (הדף אינו קיים)\">בן ציון יעקובסון</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%95\" title=\"תרכ&quot;ו\">תרכ\"ו</a>, בגיל 14 שנים בלבד, <a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9F\" title=\"נישואין\">נשא</a> את רעייתו לאה בתו של הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%96%D7%9C%D7%99%D7%92%D7%A1%D7%95%D7%9F\" title=\"אברהם זליגסון\">אברהם זליגסון</a> שכיהן רב ה<a href=\"/index.php/%D7%A2%D7%99%D7%99%D7%A8%D7%94\" title=\"עיירה\">עיירה</a> בתקופת אדמו\"ר <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7)\" title=\"רבי מנחם מענדל שניאורסון (אדמו&quot;ר הצמח צדק)\">הצמח צדק</a> ו<a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9)\" title=\"רבי שמואל שניאורסון (אדמו&quot;ר המהר&quot;ש)\">אדמו\"ר המהר\"ש</a>.\n</p><p>לאחר פטירת חותנו בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%91\" title=\"תרמ&quot;ב\">תרמ\"ב</a> מונה על ידי אדמו\"ר המהר\"ש למלא את מקומו כ<a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> ה<a href=\"/index.php/%D7%A2%D7%99%D7%99%D7%A8%D7%94\" title=\"עיירה\">עיירה</a>. <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> התבטא בנוגע אליו: <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"בעל הוראה ורחוק מן המחלוקת לגמרי ויודע איך לכלכל דבר להשוות הדיעות\"</span><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בתקופה בה כיהן כ<a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> ה<a href=\"/index.php/%D7%A2%D7%99%D7%99%D7%A8%D7%94\" title=\"עיירה\">עיירה</a> הגיעה לשיא פריחתה - כ2,711 תושבים, מהם 1,660 יהודים.\n</p><p>בזיכרונותיו של הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"יהודה חיטריק\">יהודה חיטריק</a> מסופר שהממשלה הרוסית השתמשה בו על מנת להעביר הוראות ליהודים, ולדרוש ממנו שיפסוק להם שצריכים להישמע להוראות הממשלה מצד '<a href=\"/index.php/%D7%93%D7%99%D7%A0%D7%90_%D7%93%D7%9E%D7%9C%D7%9B%D7%95%D7%AA%D7%90_%D7%93%D7%99%D7%A0%D7%90\" class=\"mw-redirect\" title=\"דינא דמלכותא דינא\">דינא דמלכותא דינא</a>'. לדוגמא: מתי שהממשלה אסרה על תושבים פרטיים לייצר משקאות אלכוהוליים, הרב יעקובסון הכריז על בימת בית הכנסת המרכזי של העיירה שהעברה על החוק החדש אסור מצד דיני התורה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, יוסף חיים אב\"ד לוקמאל (lukmol) פלך <a href=\"/index.php/%D7%95%D7%95%D7%99%D7%98%D7%91%D7%A1%D7%A7\" class=\"mw-redirect\" title=\"וויטבסק\">וויטבסק</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li>בנו, זלמן</li>\n<li>בתו, זעלדא (אשת ר' שמעון מייזליש)</li>\n<li>בתו, ריסיה (ראיסה) (אשת יצחק אוקינב)</li>\n<li>בתו, טאיבה (אשת אברהם קצנלבויגן)</li>\n<li>בנו, לייזר</li>\n<li>בנו, שלמה (כונה שלמה קוטאיסער)</li>\n<li>בתו, ריבה (אשת ר' זלמן דיסקין)</li>\n<li>בנו, אבא</li>\n<li>בתו, אידה (אשת שמואל זליקסון)</li>\n<li>בתו, ליפה (אשת הלל רסינסקי).</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p><a href=\"/index.php/%D7%A8%D7%A9%D7%99%D7%9E%D7%AA_%D7%94%D7%99%D7%95%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"רשימת היומן\">רשימת היומן</a> עמ' שנו-ז.\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%95%D7%93_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://dlib.rsl.ru/viewer/01006589054#?page=26\">מכתב תשובה הלכתי שכתב לאדמו\"ר הרש\"ב</a> מתוך הארכיון הלאומי הרוסי.</li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.shturem.net/images/articles/1512_articles_07062008_54047.jpg\">מכתב ההסמכה לרבנות שהעניק לרב </a><a href=\"/index.php/%D7%92%D7%A8%D7%A9%D7%95%D7%9F_%D7%97%D7%9F\" title=\"גרשון חן\">גרשון חן</a> - רב שיכון חב\"ד בירושלים <span typeof=\"mw:File\"><a href=\"/index.php/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D_(%D7%90%D7%AA%D7%A8)\" title=\"קישור שטורעם\"><img alt=\"קישור שטורעם\" src=\"/images/thumb/8/89/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG/15px-%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG\" decoding=\"async\" width=\"15\" height=\"14\" class=\"mw-file-element\" srcset=\"/images/8/89/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG 1.5x\" /></a></span> <span class=\"grayText\"><small>(הקישור אינו פעיל)</small></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://hebrewbooks.org/pdfpager.aspx?req=31636&amp;st=&amp;pgnum=74\">אגרות קודש אדמו\"ר הרש\"ב חלק ג' עמוד ל</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ראה <a href=\"/index.php/%D7%A8%D7%A9%D7%99%D7%9E%D7%95%D7%AA_%D7%93%D7%91%D7%A8%D7%99%D7%9D_(%D7%A1%D7%A4%D7%A8)\" class=\"mw-redirect\" title=\"רשימות דברים (ספר)\">רשימות דברים</a> (הוצאת תשס\"ט) עמ' 362-3.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">אפרים ליב לואיס, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1RKHJJyiwBB8P7SxNWC4pK40-1waZPN-1/view\">מקום רבנותו של הרב יוסף חיים יעקובסון (בהר\"ד מ\"צ ליובאוויטש)</a></b>, <a href=\"/index.php/%D7%94%D7%A2%D7%A8%D7%95%D7%AA_%D7%95%D7%91%D7%99%D7%90%D7%95%D7%A8%D7%99%D7%9D_%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"הערות וביאורים אהלי תורה\">הערות וביאורים אהלי תורה</a>, גליון א'רפו (ט) לשבת פרשת משפטים תשפ\"ו עמ' 76.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414032030\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.070 seconds\nReal time