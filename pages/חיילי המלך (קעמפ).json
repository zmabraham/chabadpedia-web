      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A1%D7%9E%D7%9C_%D7%A7%D7%A2%D7%9E%D7%A4_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_-_%D7%91%D7%A8%D7%95%D7%A8.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e0/%D7%A1%D7%9E%D7%9C_%D7%A7%D7%A2%D7%9E%D7%A4_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_-_%D7%91%D7%A8%D7%95%D7%A8.png/200px-%D7%A1%D7%9E%D7%9C_%D7%A7%D7%A2%D7%9E%D7%A4_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_-_%D7%91%D7%A8%D7%95%D7%A8.png\" decoding=\"async\" width=\"200\" height=\"200\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e0/%D7%A1%D7%9E%D7%9C_%D7%A7%D7%A2%D7%9E%D7%A4_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_-_%D7%91%D7%A8%D7%95%D7%A8.png/300px-%D7%A1%D7%9E%D7%9C_%D7%A7%D7%A2%D7%9E%D7%A4_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_-_%D7%91%D7%A8%D7%95%D7%A8.png 1.5x, /images/thumb/e/e0/%D7%A1%D7%9E%D7%9C_%D7%A7%D7%A2%D7%9E%D7%A4_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_-_%D7%91%D7%A8%D7%95%D7%A8.png/400px-%D7%A1%D7%9E%D7%9C_%D7%A7%D7%A2%D7%9E%D7%A4_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_-_%D7%91%D7%A8%D7%95%D7%A8.png 2x\" /></a><figcaption>סמל הקעמפ הישן</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A.png\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c3/%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A.png/200px-%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A.png\" decoding=\"async\" width=\"200\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c3/%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A.png/300px-%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A.png 1.5x, /images/c/c3/%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A.png 2x\" /></a><figcaption>סמל הקעמפ העדכני</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%9E%D7%90%D7%A8%D7%9C%D7%95_%D7%91%D7%A7%D7%A2%D7%9E%D7%A4.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/b/b8/%D7%94%D7%A8%D7%91_%D7%9E%D7%90%D7%A8%D7%9C%D7%95_%D7%91%D7%A7%D7%A2%D7%9E%D7%A4.jpg/220px-%D7%94%D7%A8%D7%91_%D7%9E%D7%90%D7%A8%D7%9C%D7%95_%D7%91%D7%A7%D7%A2%D7%9E%D7%A4.jpg\" decoding=\"async\" width=\"220\" height=\"157\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b8/%D7%94%D7%A8%D7%91_%D7%9E%D7%90%D7%A8%D7%9C%D7%95_%D7%91%D7%A7%D7%A2%D7%9E%D7%A4.jpg/330px-%D7%94%D7%A8%D7%91_%D7%9E%D7%90%D7%A8%D7%9C%D7%95_%D7%91%D7%A7%D7%A2%D7%9E%D7%A4.jpg 1.5x, /images/thumb/b/b8/%D7%94%D7%A8%D7%91_%D7%9E%D7%90%D7%A8%D7%9C%D7%95_%D7%91%D7%A7%D7%A2%D7%9E%D7%A4.jpg/440px-%D7%94%D7%A8%D7%91_%D7%9E%D7%90%D7%A8%D7%9C%D7%95_%D7%91%D7%A7%D7%A2%D7%9E%D7%A4.jpg 2x\" /></a><figcaption>רבני שכונת המלך <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> בביקור בקעמפ, מימין לשמאל: הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%91%D7%A8%D7%95%D7%A7\" title=\"יוסף ברוק\">יוסף ברוק</a>, הרב <a href=\"/index.php/%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%91%D7%A8%D7%98%D7%95%D7%91\" title=\"דובער לברטוב\">דובער לברטוב</a>, הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%9C%D7%9E%D7%9F_%D7%9E%D7%90%D7%A8%D7%9C%D7%95\" class=\"mw-redirect\" title=\"יהודה קלמן מארלו\">יהודה קלמן מארלו</a>, הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%96%D7%93%D7%91%D7%90\" title=\"אברהם אזדבא\">אברהם אזדבא</a>, הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%92%D7%95%D7%9C%D7%93%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"חיים לוי גולדשטיין\">חיים לוי גולדשטיין</a>, הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%98%D7%95%D7%A8%D7%99%D7%9F\" title=\"אליעזר טורין\">אליעזר טורין</a>.</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:IMG_7894.JPG\" class=\"mw-file-description\"><img src=\"/images/thumb/5/58/IMG_7894.JPG/250px-IMG_7894.JPG\" decoding=\"async\" width=\"250\" height=\"110\" class=\"mw-file-element\" srcset=\"/images/thumb/5/58/IMG_7894.JPG/375px-IMG_7894.JPG 1.5x, /images/thumb/5/58/IMG_7894.JPG/500px-IMG_7894.JPG 2x\" /></a><figcaption>תמונה קבוצתית של הקעמפ חיילי בשנים הראשונות של הקעמפ</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_%D7%AA%D7%A9%D7%A4%27%27%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/6b/%D7%94%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_%D7%AA%D7%A9%D7%A4%27%27%D7%92.jpg/250px-%D7%94%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_%D7%AA%D7%A9%D7%A4%27%27%D7%92.jpg\" decoding=\"async\" width=\"250\" height=\"175\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6b/%D7%94%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_%D7%AA%D7%A9%D7%A4%27%27%D7%92.jpg/375px-%D7%94%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_%D7%AA%D7%A9%D7%A4%27%27%D7%92.jpg 1.5x, /images/thumb/6/6b/%D7%94%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_%D7%AA%D7%A9%D7%A4%27%27%D7%92.jpg/500px-%D7%94%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_%D7%AA%D7%A9%D7%A4%27%27%D7%92.jpg 2x\" /></a><figcaption>התמונה המרכזית של הקעמפ חיילי המלך בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a></figcaption></figure>\n<p><b>חיילי המלך</b> הינו <a href=\"/index.php/%D7%A7%D7%A2%D7%9E%D7%A4_%D7%92%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"קעמפ גן ישראל\">קעמפ</a> לילדי <a href=\"/index.php/%D7%90%D7%A0%22%D7%A9\" class=\"mw-redirect\" title=\"אנ&quot;ש\">אנ\"ש</a> המתקיים ב<a href=\"/index.php/%D7%99%D7%9E%D7%99_%D7%94%D7%97%D7%95%D7%A4%D7%A9\" title=\"ימי החופש\">ימי החופש</a> בלאקווקסן שבהרי פנסילבניה.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.9E.D7.97.D7.A0.D7.94_.D7.9E.D7.A0.D7.97.D7.9D\"></span><span class=\"mw-headline\" id=\"מחנה_מנחם\">מחנה מנחם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;מחנה מנחם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: מחנה מנחם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הקעמפ הוקם בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> על ידי הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A9%D7%A4%D7%A8%D7%99%D7%A6%D7%A8\" class=\"mw-redirect\" title=\"יעקב שפריצר\">יעקב שפריצר</a> בברכת ה<a href=\"/index.php/%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"רבי\">רבי</a> (באמצעות ה<a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)#כתיבה_לרבי_באמצעות_האגרות_קודש\" class=\"mw-redirect\" title=\"אגרות קודש (אדמו&quot;ר שליט&quot;א)\">אגרת קודש</a>), ובאישורו של הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%9C%D7%9E%D7%9F_%D7%9E%D7%A8%D7%9C%D7%95\" title=\"יהודה קלמן מרלו\">יהודה קלמן מרלו</a> (רבה של שכונת <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> לשעבר) ושכן במונטסלה שבניו יורק. בועד ההנהלה של הקעמפ עמדו הרב יעקב שפריצר, שמואל הבר, יוסף גאלדמן ומנחם מענדל ומאיר הרשקופ. באותה שנה השתתפו בקעמפ מעל מאתיים ילדים.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a>, עקב הצלחתו המרובה, הועבר שטח הקעמפ (תחת השם החדש \"מחנה מנחם\") ללאקווקסן שבהרי פנסילבניה, השוכן על שפת נהר ה'דעלווער', שם מתקיים הקעמפ עד היום. באותה שנה השתתפו בקעמפ מעל חמש מאות ילדים. באותה שנה התווספו לועד ההנהלה, הרב מאיר שרייבר ולוי הרטמן.\n</p><p>בשנים <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a>-<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%96\" title=\"תשנ&quot;ז\">תשנ\"ז</a> היה הקעמפ תחת הנהלתו של הרב <a href=\"/index.php?title=%D7%9E%D7%90%D7%99%D7%A8_%D7%9B%D7%94%D7%A0%D7%95%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאיר כהנוב (הדף אינו קיים)\">מאיר כהנוב</a>. משנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a> הקעמפ מתנהל תחת הנהלתו של הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%9E%D7%94_%D7%A8%D7%95%D7%98%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלמה רוטמן (הדף אינו קיים)\">שלמה רוטמן</a>, חתנו של הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A9%D7%A4%D7%A8%D7%99%D7%A6%D7%A8\" class=\"mw-redirect\" title=\"יעקב שפריצר\">יעקב שפריצר</a>.\n</p><p>בשנת תשנ\"ו התעוררה מחלוקת בנוגע להתנהלות הקעמפ והנושא הועבר לדין תורה אצל הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%9C%D7%9E%D7%9F_%D7%9E%D7%A8%D7%9C%D7%95\" title=\"יהודה קלמן מרלו\">יהודה קלמן מרלו</a>, שפסק ביו\"ד <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> תשנ\"ח כי על הרב שפריצער לנהל את הקעמפ (במקום שאר השותפים). מאחר ששאר השותפים העדיפו לא לציית לפסק דינו של הרב מרלו, הועבר הדיון (בחורף תשנ\"ח) לבית משפט, שם נמשך המשפט במשך שנים. באחת ההזדמנוית (ב<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a>) הופיע הרב מרלו בעצמו בבית משפט בכדי להעיד (ולתמוך) בצידו של הרב שפריצער.\n</p>\n<h2><span id=\".D7.97.D7.99.D7.99.D7.9C.D7.99_.D7.94.D7.9E.D7.9C.D7.9A\"></span><span class=\"mw-headline\" id=\"חיילי_המלך\">חיילי המלך</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;חיילי המלך&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: חיילי המלך\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> העביר בית המשפט את שטח הקעמפ לבעלותו של הרשקופ, והחל מאותה שנה לא נפתח הקעמפ, ושטח הקעמפ נותר מיותם ומוזנח. במשך כמה שנים השכיר הרשקופ את שטח הקעמפ לחסידי <a href=\"/index.php/%D7%A9%D7%95%D7%A9%D7%9C%D7%AA_%D7%91%D7%90%D7%91%D7%95%D7%91\" class=\"mw-redirect\" title=\"שושלת באבוב\">באבוב</a>. בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> עקב בעיות כספיות הכריז ועד \"מחנה מנחם\" על פשיטת רגל, ושטח הקעמפ הועמד למכירה בבית משפט.\n</p><p>בית המשפט מכר את שטח הקעמפ לרב שפריצער, ובקיץ <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> נפתח הקעמפ מחדש תחת שמו החדש \"חיילי המלך\". וכיום הוא גודל משנה לשנה בכמות ובאיכות.\n</p>\n<h2><span id=\".D7.90.D7.95.D7.93.D7.95.D7.AA_.D7.94.D7.A7.D7.A2.D7.9E.D7.A4\"></span><span class=\"mw-headline\" id=\"אודות_הקעמפ\">אודות הקעמפ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אודות הקעמפ&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אודות הקעמפ\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הקעמפ מצטיין במערך לימודי ייחודי. מלבד הפעילויות והטיולים, מושם דגש מיוחד על התוכן החינוכי שמועבר לחיילים, באמצעות חומר לימודים מיוחד שבתוכו משולבים תכנים חסידיים בעניינים של: <a href=\"/index.php/%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"רבי\">רבי</a>, <a href=\"/index.php/%D7%94%D7%AA%D7%A7%D7%A9%D7%A8%D7%95%D7%AA\" title=\"התקשרות\">התקשרות</a>, <a href=\"/index.php/%D7%99%D7%9E%D7%95%D7%AA_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"ימות המשיח\">ימות המשיח</a>, הנהגות חסידיות ועוד. שיטה זו הוכיחה את עצמה במשך השנים כשיטה מצליחה מעל ומעבר. בנוסף לכך, מקפידים בקעמפ על ניצול מקסימלי של הזמן כדי להחדיר כמה שיותר תכנים חסידיים ל'חיילים': בזמני הנסיעות באוטובוסים משננים החיילים <a href=\"/index.php/%D7%9E%D7%A9%D7%A0%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"משניות\">משניות</a> ו<a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"תניא\">תניא</a> בעל-פה וכן גם בזמני הארוחות.\n</p>\n<h2><span id=\".D7.A4.D7.A2.D7.95.D7.9C.D7.95.D7.AA_.D7.94.D7.A7.D7.A2.D7.9E.D7.A4_.D7.91.D7.9E.D7.A9.D7.9A_.D7.94.D7.A9.D7.A0.D7.94\"></span><span class=\"mw-headline\" id=\"פעולות_הקעמפ_במשך_השנה\">פעולות הקעמפ במשך השנה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;פעולות הקעמפ במשך השנה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: פעולות הקעמפ במשך השנה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הקעמפ שומר על קשר עם החיילים גם במשך ימות השנה. צוות הקעמפ פועלים ועומדים בקשר עם החניכים מספר פעמים בשנה, בהם מארגנים התוועדויות וטיולים עם ההחניכים והמדרכים. ב<a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">ימי הולדת</a> של החניכים הוא מקבל שי מיוחד שנשלחים על ידי צוות הקעמפ. מבצעי הכנה לקראת <a href=\"/index.php/%D7%99%D7%95%D7%9E%D7%90_%D7%93%D7%A4%D7%92%D7%A8%D7%90\" class=\"mw-redirect\" title=\"יומא דפגרא\">יומי דפגרא</a>. כמו כן במשך כו\"כ שנים י\"ל מידי חודש עלון חודשי מהודר בשם \"חיילי המלך ניוזלעטער\"<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.99.D7.A9.D7.99.D7.91.D7.AA_.D7.A7.D7.99.D7.A5\"></span><span class=\"mw-headline\" id=\"ישיבת_קיץ\">ישיבת קיץ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;ישיבת קיץ&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: ישיבת קיץ\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בנוסף, במשך כמה שנים התקיים בקעמפ גם '<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%A7%D7%99%D7%A5_%D7%A1%D7%99%D7%A0%D7%A1%D7%99%D7%A0%D7%98%D7%99\" class=\"mw-redirect\" title=\"ישיבת קיץ סינסינטי\">ישיבת קיץ</a>'. מסגרת ל<a href=\"/index.php/%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תמימים\">תמימים</a> הלומדים ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%A7%D7%98%D7%A0%D7%94\" class=\"mw-redirect\" title=\"ישיבה קטנה\">ישיבות קטנות</a> בכלל, ובישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A1%D7%99%D7%A0%D7%A1%D7%99%D7%A0%D7%98%D7%99\" title=\"תומכי תמימים סינסינטי\">תומכי תמימים סינסינטי</a> בפרט. ה'ישיבת קיץ' הייתה תחת הנהלתו של <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש ישיבת</a> תומכי תמימים סינסינטי הרב <a href=\"/index.php/%D7%92%D7%A8%D7%A9%D7%95%D7%9F_%D7%90%D7%91%D7%A6%D7%9F\" class=\"mw-redirect\" title=\"גרשון אבצן\">גרשון אבצן</a>.\n</p><p>ה'ישיבת קיץ' הוקמה לראשונה בקיץ <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a>, ומאז משנה לשנה היא הולכת ומתרחבת, בכמות ובאיכות. הן בפן ה<a href=\"/index.php/%D7%92%D7%A9%D7%9E%D7%99%D7%95%D7%AA\" title=\"גשמיות\">גשמי</a> והן בפן ה<a href=\"/index.php/%D7%A8%D7%95%D7%97%D7%A0%D7%99%D7%95%D7%AA\" title=\"רוחניות\">רוחני</a>.\n</p><p>במשך שעות הבוקר ה<a href=\"/index.php/%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תמימים\">תמימים</a> משתתפים ולומדים ב<a href=\"/index.php/%D7%A1%D7%93%D7%A8\" title=\"סדר\">סדרי</a> הלימוד הרגילים. ולאחר מכן יוצאים לשחק במשחקי ספורט, ולהנות מפעילויות שטח. לעת ערב חוזרים התמימים ללימוד בסדר <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a>. כמו כן מפעם לפעם יוצאים התלמידים לטיולים ואטרקציות בפארקים ובאתרי תירות.\n</p>\n<h2><span id=\".D7.A9.D7.99.D7.A8.D7.99_.D7.94.D7.A7.D7.A2.D7.9E.D7.A4\"></span><span class=\"mw-headline\" id=\"שירי_הקעמפ\">שירי הקעמפ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;שירי הקעמפ&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: שירי הקעמפ\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a> הפיק הקעמפ קלטת עם שירי הקעמפ. שמה של הקלטת \"Sitting on a wooden Bench\" (יושב על ספסל עץ).\nבשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> הפיק הקעמפ דיסק ובו תשעה משיר הקעמפ מהשנים האחרונות. שמו של הדיסק הראשון הוא: \"holding hands united\" (מחזיקים ידיים מאוחדים).\nבשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> הפיק הקעמפ דיסק (הדיסק הופק ברמה גבוהה על ידי חוני מילעקי) ובו תשעה משיר הקעמפ מהשנים האחרונות. שמו של הדיסק השני הוא: \"open your eyes\" (לפתוח את העיניים)<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%A7%D7%99%D7%A5_%D7%A1%D7%99%D7%A0%D7%A1%D7%99%D7%A0%D7%98%D7%99\" class=\"mw-redirect\" title=\"ישיבת קיץ סינסינטי\">ישיבת קיץ סינסינטי</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;veaction=edit&amp;section=8\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%94%D7%9E%D7%9C%D7%9A_(%D7%A7%D7%A2%D7%9E%D7%A4)&amp;action=edit&amp;section=8\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.chayol.com\">אתר הבית של הקעמפ</a></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/php/audio.php?action=playdisk&amp;id=57\">לשמיעת הדיסק</a> <span class=\"grayText\"><small>(הקישור אינו פעיל, כ\"ד ניסן תשפ\"ד)</small></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/index.php?url=article_he&amp;id=48138\">גלריות סיכום מרהיבות מהקעמפ משנת תשס\"ט</a></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/index.php?url=article_he&amp;id=63769\">קליפ סיכום קעמפ קיץ תשע\"א</a> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span> <span class=\"grayText\"><small>(הקישור אינו פעיל, כ\"ד ניסן תשפ\"ד)</small></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/child/809327/\">חיילי המלך: הצצה לשבוע ראשון של פעילות והנאה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%AA%D7%9E%D7%95%D7%A0%D7%94\" title=\"קובץ תמונה\"><img alt=\"קובץ תמונה\" src=\"/images/thumb/2/28/Picture_icon_BLACK.svg.png/20px-Picture_icon_BLACK.svg.png\" decoding=\"async\" width=\"20\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/2/28/Picture_icon_BLACK.svg.png/30px-Picture_icon_BLACK.svg.png 1.5x, /images/thumb/2/28/Picture_icon_BLACK.svg.png