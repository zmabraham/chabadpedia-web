(הדף אינו קיים)\">22</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%9C%D7%95%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושלוש (הדף אינו קיים)\">23</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%90%D7%A8%D7%91%D7%A2\" title=\"עשרים וארבע\">24</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%97%D7%9E%D7%A9\" title=\"עשרים וחמש\">25</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%A9&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושש (הדף אינו קיים)\">26</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%91%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושבע (הדף אינו קיים)\">27</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%A9%D7%9E%D7%95%D7%A0%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ושמונה (הדף אינו קיים)\">28</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A2%D7%A9%D7%A8%D7%99%D7%9D_%D7%95%D7%AA%D7%A9%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עשרים ותשע (הדף אינו קיים)\">29</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%A9%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלושים (הדף אינו קיים)\">30</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D\" title=\"ארבעים\">40</a>\n</td>\n<td><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2%D7%99%D7%9D_%D7%95%D7%AA%D7%A9%D7%A2\" title=\"ארבעים ותשע\">49</a>\n</td>\n<td><a href=\"/index.php/%D7%97%D7%9E%D7%99%D7%A9%D7%99%D7%9D\" title=\"חמישים\">50</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%99%D7%A9%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שישים (הדף אינו קיים)\">60</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%99%D7%A9%D7%99%D7%9D_%D7%95%D7%A9%D7%9E%D7%95%D7%A0%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שישים ושמונה (הדף אינו קיים)\">68</a>\n</td>\n<td><a href=\"/index.php/%D7%A9%D7%91%D7%A2%D7%99%D7%9D\" title=\"שבעים\">70</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%91%D7%A2%D7%99%D7%9D_%D7%95%D7%A9%D7%AA%D7%99%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שבעים ושתיים (הדף אינו קיים)\">72</a>\n</td>\n<td><a href=\"/index.php/%D7%A9%D7%91%D7%A2%D7%99%D7%9D_%D7%95%D7%97%D7%9E%D7%A9\" title=\"שבעים וחמש\">75</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%A0%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמונים (הדף אינו קיים)\">80</a>\n</td>\n<td><a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%A0%D7%99%D7%9D_%D7%95%D7%90%D7%A8%D7%91%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמונים וארבע (הדף אינו קיים)\">84</a>\n</td>\n<td><a href=\"/index.php?title=%D7%AA%D7%A9%D7%A2%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"תשעים (הדף אינו קיים)\">90</a>\n</td></tr>\n<tr>\n<th colspan=\"12\" style=\"background:#BFD7FF; text-align:center\">מאות ואלפים\n</th></tr>\n<tr style=\"text-align:center;\">\n<td colspan=\"12\">\n<table style=\"width:100%;\">\n<tbody><tr>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%9E%D7%90%D7%94\" title=\"מאה\">100</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%9E%D7%90%D7%94_%D7%95%D7%90%D7%97%D7%93\" title=\"מאה ואחד\">101</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php?title=%D7%9E%D7%90%D7%AA%D7%99%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאתיים (הדף אינו קיים)\">200</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%A8%D7%99%22%D7%95\" title=\"רי&quot;ו\">216</a>\n</td>\n<td style=\"width:15%\"><a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%A9_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלוש מאות (הדף אינו קיים)\">300</a>\n</td>\n<td style=\"width:15%\"><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2_%D7%9E%D7%90%D7%95%D7%AA\" title=\"ארבע מאות\">400</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php/%D7%97%D7%9E%D7%A9_%D7%9E%D7%90%D7%95%D7%AA\" title=\"חמש מאות\">500</a>\n</td>\n<td style=\"width:14%\"><a href=\"/index.php?title=%D7%A9%D7%A9_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שש מאות (הדף אינו קיים)\">600</a>\n</td></tr>\n<tr style=\"text-align:center;\">\n<td colspan=\"12\">\n<table style=\"width:100%;\">\n<tbody><tr>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%A9%D7%91%D7%A2_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שבע מאות (הדף אינו קיים)\">700</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/770_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"770 (מספר)\">770</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%A0%D7%94_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמונה מאות (הדף אינו קיים)\">800</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php?title=%D7%AA%D7%A9%D7%A2_%D7%9E%D7%90%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"תשע מאות (הדף אינו קיים)\">900</a>\n</td>\n<td style=\"width:17%\"><a class=\"mw-selflink selflink\">1000</a>\n</td>\n<td style=\"width:17%\"><a href=\"/index.php/%D7%A9%D7%99%D7%A9%D7%99%D7%9D_%D7%A8%D7%99%D7%91%D7%95%D7%90\" title=\"שישים ריבוא\">600,000</a>\n</td></tr>\n</tbody></table>\n</td></tr>\n</tbody></table>\n</td></tr>\n</tbody></table>\n<p>המספר <b>אלף</b> מורה על דרגת השלימות המוחלטת, את <a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"עולם האצילות\">עולם האצילות</a> ואת בחינת ה\"בלי גבול\" החודרת לתוך המציאות המוגבלת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.91.D7.97.D7.A1.D7.99.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"בחסידות\">בחסידות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;בחסידות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: בחסידות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>מוסבר<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> שהמספר 1,000 הוא כנגד <a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"עולם האצילות\">עולם האצילות</a>. בדרגת האצילות, כל ספירה כלולה מ-100 (עשר כפול עשר), ולכן היא מגיעה לערך של 1,000, כלומר, באצילות האור הוא \"בלי גבול\" יחסית לעולמות התחתונים, כי הוא כולל את כל הפרטים כפול כל הפרטים. לכן המספר 1,000 מבטא את \"בחינת המקיף\" או את האור של עולם האצילות שחודר למטה.\n</p><p><a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> הסביר<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>, שההבדל בין המילה \"<a href=\"/index.php/%D7%92%D7%95%D7%9C%D7%94\" class=\"mw-redirect\" title=\"גולה\">גולה</a>\" למילה \"<a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"גאולה\">גאולה</a>\" הוא האות <a href=\"/index.php/%D7%90%27\" class=\"mw-redirect\" title=\"א&#39;\">א'</a> (אל\"ף). ה\"אל\"ף\" מייצגת את \"<a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A4%D7%95_%D7%A9%D7%9C_%D7%A2%D7%95%D7%9C%D7%9D\" title=\"אלופו של עולם\">אלופו של עולם</a>\", וכאשר מחדירים את הדרגה של \"אלף\" – שהיא <a href=\"/index.php/%D7%90%D7%99%D7%9F_%D7%A1%D7%95%D7%A3\" title=\"אין סוף\">אין סוף</a> לתוך המציאות המוגבלת, העולם מפסיק להיות מקום של גלות והופך לדירה לו יתברך בתכלית השלימות. וזאת בגלל שהמספר 1,000 - ה\"יחידה\" (1) מתפשטת בכל עשר הספירות (10x10x10). וכן המספר 1,000 מסמל את המצב שבו השליח אינו פועל רק בכוחותיו המוגבלים (יחידות או עשרות), אלא הוא \"חד\" עם המשלח (הדרגה של אלף), ובכך הוא פועל מעל מגבלות הטבע.\n</p>\n<h2><span id=\".D7.90.D7.9C.D7.A3_.D7.90.D7.95.D7.A8.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אלף_אורות\">אלף אורות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;אלף אורות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: אלף אורות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בזוהר מובא כי ב<a href=\"/index.php/%D7%9E%D7%A2%D7%9E%D7%93_%D7%94%D7%A8_%D7%A1%D7%99%D7%A0%D7%99\" class=\"mw-redirect\" title=\"מעמד הר סיני\">מעמד הר סיני</a> ניתנו ל<a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%A0%D7%95\" class=\"mw-redirect\" title=\"משה רבנו\">משה רבנו</a> \"אלף אורות\". אורות אלו מייצגים את <a href=\"/index.php/%D7%A4%D7%A0%D7%99%D7%9E%D7%99%D7%95%D7%AA_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פנימיות התורה\">פנימיות התורה</a> ואת עומק המושגים האלוקיים כפי שהם מצד המאציל. מוסבר שבעקבות חטא העגל נסתלקו ממשה אלף האורות ונותרה בו רק בחינת \"קרן עור פניו\", אך הם חוזרים ומאירים בכל שבת בזמן \"<a href=\"/index.php/%D7%A8%D7%A2%D7%95%D7%95%D7%90_%D7%93%D7%A8%D7%A2%D7%95%D7%95%D7%99%D7%9F\" class=\"mw-redirect\" title=\"רעווא דרעווין\">רעווא דרעווין</a>\". לימוד <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a> נחשב לטעימה מאותם אלף אורות העתידים להתגלות בשלמותם בגאולה<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".22.D7.90.D7.9C.D7.A3_.D7.A4.D7.A2.D7.9E.D7.99.D7.9D_.D7.9B.D7.9B.D7.94.22\"></span><span class=\"mw-headline\" id=\"&quot;אלף_פעמים_ככה&quot;\">\"אלף פעמים ככה\"</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;&quot;אלף פעמים ככה&quot;&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: &quot;אלף פעמים ככה&quot;\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>כאשר הרבי היה רוצה לשבח מעשה של חסיד, היה אומר: \"אלף פעמים ככה\". ביטוי זה מסמל איכות שהיא מעל ומעבר למדידה הרגילה.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A3_(%D7%9E%D7%A1%D7%A4%D7%A8)&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9E%D7%90%D7%94\" title=\"מאה\">מאה</a></li>\n<li><a href=\"/index.php/%D7%90%D7%9C%D7%A3_(%D7%90%D7%95%D7%AA)\" class=\"mw-redirect\" title=\"אלף (אות)\">אלף (אות)</a></li>\n<li><a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A4%D7%95_%D7%A9%D7%9C_%D7%A2%D7%95%D7%9C%D7%9D\" title=\"אלופו של עולם\">אלופו של עולם</a></li>\n<li><a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA_%D7%A2%D7%A9%D7%A8%D7%95%D7%AA_%D7%9E%D7%90%D7%95%D7%AA_%D7%90%D7%9C%D7%A4%D7%99%D7%9D_%D7%A8%D7%91%D7%91%D7%95%D7%AA\" title=\"יחידות עשרות מאות אלפים רבבות\">יחידות עשרות מאות אלפים רבבות</a></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" class=\"mw-redirect\" title=\"תורה אור\">תורה אור</a> פרשת ויקהל, דף פ\"ח, ב', ולקוטי תורה פרשת פינחס, דף פ', א'</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%A9%D7%9C%D7%99%D7%97%D7%95%D7%AA\" title=\"ספר השליחות\">ספר השליחות</a>, פרשת משפטים תשנ\"ב</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">תורה אור, פרשת תצוה, פ\"ג, ב', לקוטי תורה, פרשת ברכה, צ\"ח, א' ומאמרי אדמו\"ר הזקן (הנחות הר\"פ), עמ' קס\"ד.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413055245\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.071 seconds\nReal time usage: 0.868 seconds\nPreprocessor visited node count: 150/1000000\nPost‐expand include size: 3668/2097152 bytes\nTemplate argument size: 64/2097152 