      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table border=\"0\" cellpadding=\"4\" cellspacing=\"0\" style=\"margin: 0 1.5em 0 0; float:left; clear:left; border:1px solid #aaa; background-color:#f9f9f9; width:200px; direction:rtl;\">\n\n<tbody><tr>\n<th colspan=\"12\" style=\"background:#98FB98; text-align:center\">מספר אלף\n</th></tr>\n<tr>\n<td colspan=\"12\" style=\"background:white; text-align:center; padding:0;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%A1%D7%A4%D7%A8_1000.png\" class=\"mw-file-description\"><img src=\"/images/thumb/0/01/%D7%9E%D7%A1%D7%A4%D7%A8_1000.png/150px-%D7%9E%D7%A1%D7%A4%D7%A8_1000.png\" decoding=\"async\" width=\"150\" height=\"90\" class=\"mw-file-element\" srcset=\"/images/thumb/0/01/%D7%9E%D7%A1%D7%A4%D7%A8_1000.png/225px-%D7%9E%D7%A1%D7%A4%D7%A8_1000.png 1.5x, /images/thumb/0/01/%D7%9E%D7%A1%D7%A4%D7%A8_1000.png/300px-%D7%9E%D7%A1%D7%A4%D7%A8_1000.png 2x\" /></a></span>\n</td></tr>\n<tr>\n<th colspan=\"12\" style=\"background:#BFD7FF; text-align:center\">אחדות ועשרות\n</th></tr>\n<tr style=\"text-align:center;\">\n<td style=\"width:10%\"><a href=\"/index.php?title=%D7%90%D7%A4%D7%A1&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אפס (הדף אינו קיים)\">0</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/1_(%D7%9E%D7%A1%D7%A4%D7%A8)\" title=\"1 (מספר)\">1</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%AA%D7%99%D7%99%D7%9D\" title=\"שתיים\">2</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%A9\" title=\"שלוש\">3</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2\" title=\"ארבע\">4</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%97%D7%9E%D7%A9\" title=\"חמש\">5</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%A9\" title=\"שש\">6</a>\n</td>\n<td style=\"width:10%\"><a href=\"/index.php/%D7%A9%D7%91%D7%A2\" title=\"שבע\">7</a>\n</td>\n<td