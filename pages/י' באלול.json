      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">&gt;&gt;</a></span>\n<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"א&#39; באלול\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ב&#39; באלול\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ג&#39; באלול\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ד&#39; באלול\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ה&#39; באלול\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ו&#39; באלול\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ז&#39; באלול\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ח&#39; באלול\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ט&#39; באלול\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;א באלול\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ב באלול\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ג באלול\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ד באלול\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ט&quot;ו באלול\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ט&quot;ז באלול\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ז באלול\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ח באלול\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"י&quot;ט באלול\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&#39; באלול\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;א באלול\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ב באלול\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ג באלול\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ד באלול\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ה באלול\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ו באלול\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ז באלול\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ח באלול\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"כ&quot;ט באלול\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י' באלול</b> הוא היום העשירי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'ק\"ה – לקראת סיום ה<a href=\"/index.php/%D7%9E%D7%91%D7%95%D7%9C\" class=\"mw-redirect\" title=\"מבול\">מבול</a> שילח <a href=\"/index.php/%D7%A0%D7%97\" title=\"נח\">נח</a> עורב מחלון ה<a href=\"/index.php/%D7%AA%D7%99%D7%91%D7%AA_%D7%A0%D7%97\" title=\"תיבת נח\">תיבה</a>. לאחר שיטוט קצר שב העורב ל<a href=\"/index.php/%D7%AA%D7%99%D7%91%D7%AA_%D7%A0%D7%97\" title=\"תיבת נח\">תיבה</a> כיון שלא מצא מנוח לכף רגלו.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%90\" title=\"תקנ&quot;א\">תקנ\"א</a> – רבי <a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%A9%D7%A4%D7%99%D7%A8%D7%90\" class=\"mw-redirect\" title=\"פנחס שפירא\">פנחס שפירא</a> מקוריץ, מחבר ספר 'אמרי פנחס', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%97\" title=\"תרל&quot;ח\">תרל\"ח</a> – רבי אליעזר לבטון, מחכמי ארם-צובא – <a href=\"/index.php/%D7%A1%D7%95%D7%A8%D7%99%D7%94\" title=\"סוריה\">סוריה</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%93\" title=\"תרנ&quot;ד\">תרנ\"ד</a> – רבי ברוך ירושלמי, מחכמי קושטא – <a href=\"/index.php/%D7%98%D7%95%D7%A8%D7%A7%D7%99%D7%94\" title=\"טורקיה\">טורקיה</a>, מחבר ספר 'ברוך מבנים', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%95\" title=\"תרנ&quot;ו\">תרנ\"ו</a> – רבי יצחק פרידמן מבוהוש (הראשון), נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> – רבי משה יהודה לייב פרידמן מפאשקן, מחבר ספר 'ברכת משה', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%97\" title=\"תקנ&quot;ח\">תקנ\"ח</a> – נפתח התיק הפלילי נגד <a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a> שהוביל ל<a href=\"/index.php/%D7%9E%D7%90%D7%A1%D7%A8_%D7%95%D7%92%D7%90%D7%95%D7%9C%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"מאסר וגאולת אדמו&quot;ר הזקן\">מאסרו</a>, כאשר הגנרל-פרוקורור הגיש את המלשינות אל הקיסר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%90\" title=\"תרנ&quot;א\">תרנ\"א</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F_(%D7%97%D7%AA%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9)\" class=\"mw-redirect\" title=\"משה הורנשטיין (חתן אדמו&quot;ר המהר&quot;ש)\">משה הורנשטיין</a> <a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9F\" title=\"נישואין\">התחתן</a> עם <a href=\"/index.php/%D7%97%D7%99%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%90_%D7%94%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9)\" class=\"mw-redirect\" title=\"חיה מושקא הורנשטיין (בת אדמו&quot;ר המהר&quot;ש)\">חיה מושקא הורנשטיין</a>, בת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a> – בית המשפט הפדארלי הסיר את ההגבלות שהוטלו על פי בקשת מספר עסקנים חב\"דיים, והתיר את המודעות החב\"דיות שעסקו ב<a href=\"/index.php/%D7%A4%D7%A8%D7%A1%D7%95%D7%9D_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" title=\"פרסום גאולה ומשיח\">פרסום גאולה ומשיח</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a> - הרבי ישב במרפסת במשך כשעה ומשהו ללא כובע (באופן נדיר) ואכל עוגה<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%95\" title=\"תרפ&quot;ו\">תרפ\"ו</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%96%D7%9C%D7%9E%D7%A0%D7%95%D7%91\" title=\"יהודה לייב זלמנוב\">יהודה לייב זלמנוב</a>, ממייסדי <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"צעירי אגודת חב&quot;ד בארץ הקודש\">צעירי אגודת חב\"ד בארץ הקודש</a> ומראשי הפעילים ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C_%D7%A1%D7%95%D7%A4%D7%A8\" class=\"mw-redirect\" title=\"יהושע יחזקאל סופר\">יהושע יחזקאל סופר</a>, מרצה וסופר בתורת חב\"ד ומחשבת ישראל.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%96\" title=\"תשי&quot;ז\">תשי\"ז</a> - הרב <a href=\"/index.php/%D7%92%D7%A8%D7%A9%D7%95%D7%9F_%D7%90%D7%95%D7%95%D7%A2%D7%A8%D7%9C%D7%90%D7%A0%D7%93%D7%A2%D7%A8\" class=\"mw-redirect\" title=\"גרשון אווערלאנדער\">גרשון אווערלאנדער</a>, שליח בבית חב\"ד הנדון, <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%98%D7%A0%D7%99%D7%94\" title=\"בריטניה\">אנגליה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%90\" title=\"תשכ&quot;א\">תשכ\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%91%D7%9C%D7%99%D7%A0%D7%95%D7%91\" title=\"יוסף יצחק בלינוב\">יוסף יצחק בלינוב</a>, רב מרכז העיר <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a> וראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C\" title=\"כולל\">כולל</a> פעמי יעקב.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a> - הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%95%D7%A7%D7%A6%D7%99%D7%9F\" title=\"מאיר ישראל בוקצין\">מאיר ישראל בוקצין</a>, מעסקני <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> וחבר הועד הגשמי של <a href=\"/index.php/%D7%90%D7%99%D7%92%D7%95%D7%93_%D7%AA%D7%9C%D7%9E%D7%99%D7%93%D7%99_%D7%94%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"איגוד תלמידי הקבוצה\">איגוד תלמידי הקבוצה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> – הרב <a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%90%D7%9C_%D7%93%D7%A8%D7%99%D7%99%D7%A4%D7%95%D7%A1\" class=\"mw-redirect\" title=\"נתנאל דרייפוס\">נתנאל דרייפוס</a>, משלוחי הרבי ב<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a> ורב ומשפיע קהילת חב\"ד סמילנסקי בעיר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> – מר <a href=\"/index.php/%D7%9E%D7%99%D7%9B%D7%90%D7%9C_%D7%A9%D7%95%D7%95%D7%A8%D7%A5\" title=\"מיכאל שוורץ\">מיכאל שוורץ</a>, אומן וצייר בינלאומי שיצר על פי הוראות הרבי את סמל <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"צבאות השם\">צבאות השם</a> ו<a href=\"/index.php/%D7%94%D7%9E%D7%A8%D7%9B%D7%96_%D7%9C%D7%A2%D7%A0%D7%99%D7%A0%D7%99_%D7%97%D7%99%D7%A0%D7%95%D7%9A\" class=\"mw-redirect\" title=\"המרכז לעניני חינוך\">המרכז לעניני חינוך</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י' באלול - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>גדולי זקני <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסידי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">רבינו הזקן</a> היו אומרים, אשר \"<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a>\" פירושו: קלאר, אפגעשטעלט, פאראיינציגט (=בירור, קביעה, איחוד) - מקור ג' פירושים אלו הוא בדרז\"ל: <a href=\"/index.php/%D7%9E%D7%A1%D7%9B%D7%AA_%D7%A9%D7%A7%D7%9C%D7%99%D7%9D\" title=\"מסכת שקלים\">שקלים</a> פרק ו' משנה ב', <a href=\"/index.php/%D7%9E%D7%A1%D7%9B%D7%AA_%D7%99%D7%91%D7%9E%D7%95%D7%AA\" title=\"מסכת יבמות\">יבמות</a> ס\"ב עמוד א', בראשית רבה פרק כ'-.\n<p>זאת אומרת כי ענין ה<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> הוא לברר את מצבו, ולקבוע אופן עבודתו בסור מרע ולקרב את המדות הטובות, ולהתקשר בהתאחדות גמורה ולמסור עצמו, איבערגעבען זיך מיט אלע רצונות (=למסור עצמו עם כל הרצונות).\n</p>\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראו: יומן 770, י' אלול תשנ\"ג, באתר \"יומני בית חיינו 770\".</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">וידאו מי' אלול התשנ\"ג לחצו <a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1BTq4rt6TD4_N8nPcIwkauLYwJT264Z54/view?usp=drive_link\">כאן.</a></span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260414092142\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.053 seconds\nReal time usage: 0.291 seconds\nPreprocessor visited node count: 167/1000000\nPost‐expand include size: 6647/2097152 bytes\nTemplate argument size: 696/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 302/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5201920/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  235.060      1 -total\n 82.24%  193.308      2 תבנית:הערה\n 12.35%   29.020      1 תבנית:להיום_יום\n  6.32%   14.849      1 תבנית:היום_יום/י&#039;_אלול\n  5.27%   12.386      1 תבנית:חודש_אלול\n  3.28%    7.718      1 תבנית:לוח_שנה_חסר\n  1.58%    3.718      1 תבנית:כתב_קטן\n-->