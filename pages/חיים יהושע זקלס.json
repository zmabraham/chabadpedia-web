      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/5b/%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1.jpg/220px-%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/5/5b/%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1.jpg/330px-%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1.jpg 1.5x, /images/thumb/5/5b/%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1.jpg/440px-%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1.jpg 2x\" /></a><figcaption>הרב זקלס (<a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%94\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;ה\">ה'תשפ\"ה</a>)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97_%D7%96%D7%A7%D7%9C%D7%A1.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/2c/%D7%97_%D7%96%D7%A7%D7%9C%D7%A1.jpg/220px-%D7%97_%D7%96%D7%A7%D7%9C%D7%A1.jpg\" decoding=\"async\" width=\"220\" height=\"146\" class=\"mw-file-element\" srcset=\"/images/thumb/2/2c/%D7%97_%D7%96%D7%A7%D7%9C%D7%A1.jpg/330px-%D7%97_%D7%96%D7%A7%D7%9C%D7%A1.jpg 1.5x, /images/thumb/2/2c/%D7%97_%D7%96%D7%A7%D7%9C%D7%A1.jpg/440px-%D7%97_%D7%96%D7%A7%D7%9C%D7%A1.jpg 2x\" /></a><figcaption>הרב חיים זקלס (מימין) - יחד עם חמיו הרב שמעון אייזנבך - מוסר לראש העיר אילת ספר שכתבה רעייתו (תשע\"ה)</figcaption></figure>\n<p>הרב <b>חיים יהושע זקלס</b> (נולד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a>, 1983) הוא <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%9C%D7%A2%D7%93\" title=\"תומכי תמימים אלעד\">תומכי תמימים אלעד</a> ו<a href=\"/index.php/%D7%9E%D7%97%D7%A0%D7%9A\" class=\"mw-redirect\" title=\"מחנך\">מחנך כיתה</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A1%D7%A4%D7%A8_%D7%A0%D7%98\" title=\"בית ספר נט\">חיידר נט</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a> שב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" title=\"קריית מלאכי\">קריית מלאכי</a> ב<a href=\"/index.php/%D7%9B%22%D7%94_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"כ&quot;ה ניסן\">כ\"ה ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a> לר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%96%D7%A7%D7%9C%D7%A1\" title=\"יוסף יצחק זקלס\">יוסף יצחק זקלס</a> ולשרה זקלס. \n</p><p>זכה לקבל מכתב ברכה אישי מ<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בשנת <a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> בהיותו ילד בגיל 7 בלבד<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>למד בישיבות <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"בית הר&quot;מ נחלת הר חב&quot;ד\">בית הר\"מ נחלת הר חב\"ד</a>, <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"תומכי תמימים בני ברק\">תומכי תמימים בני ברק</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"תומכי תמימים קריית גת (גדולה)\">תומכי תמימים קריית גת</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> נסע ללמוד ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_770\" class=\"mw-redirect\" title=\"ישיבת תומכי תמימים המרכזית - 770\">ישיבת תומכי תמימים המרכזית - 770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> נשא את מרת נחמה דינה בת הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%90%D7%99%D7%99%D7%96%D7%A0%D7%91%D7%9A_(%D7%90%D7%99%D7%9C%D7%AA)\" title=\"שמעון בן ציון אייזנבך (אילת)\">שמעון אייזנבך</a> שליח הרבי לעיר <a href=\"/index.php/%D7%90%D7%99%D7%9C%D7%AA\" title=\"אילת\">אילת</a>. \n</p><p>לאחר החתונה החל להתגורר במשך תקופה קצרה ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>. \n</p><p>לאחר מכן עבר ל<a href=\"/index.php/%D7%90%D7%9C%D7%A2%D7%93\" title=\"אלעד\">אלעד</a> והחל לשמש כ<a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> וכ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%9C%D7%A2%D7%93\" title=\"תומכי תמימים אלעד\">תומכי תמימים אלעד</a>, נכון לשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> משמש כמשפיע ב<a href=\"/index.php?title=%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%91%27&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שיעור ב&#39; (הדף אינו קיים)\">שיעור ב'</a>.\n</p><p>הרב זקלס שימש גם כמשפיע בבית הכנסת \"בית מנחם\" באלעד. והוא מסר שיעורים קבועים ב<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> בקהילת \"מעייני ישראל\" שבעיר.\n</p><p>הרב זקלס משמש כמורה ומחנך ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A1%D7%A4%D7%A8_%D7%A0%D7%98\" title=\"בית ספר נט\">חיידר נט</a>, נכון לשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> משמש כ<a href=\"/index.php/%D7%9E%D7%97%D7%A0%D7%9A\" class=\"mw-redirect\" title=\"מחנך\">מחנך</a> בכיתה ג'.\n</p><p>לקראת <a href=\"/index.php/%D7%99%27_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"י&#39; שבט\">י' שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a> הלחין את הניגון \"מתגברים\"<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> של הזמר <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A1%D7%A3_%D7%97%D7%A4%D7%A5\" title=\"אליסף חפץ\">אליסף חפץ</a> המבוסס על קטע ממכתבו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> לר' <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%A8%D7%99%D7%96\" title=\"אברהם פריז\">אברהם פריז</a>. השיר תפס תאוצה בחב\"ד וזכה לפופולריות רבה.\n</p><p>לקראת <a href=\"/index.php/%D7%99%27_%D7%91%D7%A9%D7%91%D7%98\" title=\"י&#39; בשבט\">י' בשבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> הלחין את הניגון \"ער איז דא\"<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup> של הזמר <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A1%D7%A3_%D7%97%D7%A4%D7%A5\" title=\"אליסף חפץ\">אליסף חפץ</a> המבוסס על שיחה מהתוועדות <a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%A9%D7%91%D7%98\" title=\"ט&quot;ו בשבט\">ט\"ו בשבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a>, השיר גם הוא יצר תאוצה וזכה לתגובות רבות ומרגשות.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>גיסו, הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%96%D7%95%D7%A0%D7%A0%D7%A4%D7%9C%D7%93\" title=\"אליעזר זוננפלד\">אליעזר זוננפלד</a> - <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> בישיבת תות\"ל באלעד</li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"נחום יצחק גורליק\">נחום יצחק גורליק</a> - שליח הרבי לקאזאן שב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%A2%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99\" class=\"mw-redirect\" title=\"לוי יצחק גערליצקי\">לוי יצחק גערליצקי</a> - שליח הרבי ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%90%D7%A9%D7%9B%D7%A0%D7%96%D7%99_(%D7%91%D7%90%D7%A8_%D7%90%D7%95%D7%A8%D7%94)\" title=\"מנחם מענדל אשכנזי (באר אורה)\">מנחם מענדל אשכנזי (באר אורה)</a> - שליח הרבי בבאר אורה</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%96%D7%A7%D7%9C%D7%A1&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://col.org.il/news/161232\">כשבחור מעיר את המשפיע שלו ב-12:30 בלילה</a></b> - באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span> ח' אדר ב' תשפ\"ד</li>\n<li><b>לקט התוועדויות של הרב זקלס:</b> <a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/uploads/original/2024/08/66b6146f8dfa5_1723208815.pdf\"><b>אויפגעהויבן</b></a>, <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>; <a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/uploads/original/2025/07/688295130e020_1753388307.pdf\"><b>אנווארמען</b></a>, <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a><sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup><span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/170939\">החתן שלי שלח לרבי ציורים של פרחים בגיל 7. זו התשובה שקיבל <span typeof=\"mw:File\"></span></a><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/video/musical-videos/chassidic-music/895394/\">הלהיט המרגש לי' שבט: אליסף חפץ משיק ניגון מעורר געגועים</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/musicnews/1178744/\">אליסף חפץ בסינגל קליפ מרגש וסוחף – \"ער איז דא\"</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/164126\">כשהתמימים החליטו לכתוב את התוועדויות המשפיע. זו התוצאה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\"