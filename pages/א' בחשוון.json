      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ב&#39; בחשוון\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ג&#39; בחשוון\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ד&#39; בחשוון\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ה&#39; בחשוון\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ו&#39; בחשוון\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ז&#39; בחשוון\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ח&#39; בחשוון\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ט&#39; בחשוון\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&#39; בחשוון\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&quot;א בחשוון\">יא</