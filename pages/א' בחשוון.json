"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בחשוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בחשוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בחשוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בחשוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ל&#39; בחשוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>א&#39; בחשוון</b> הוא היום הראשון\nבחודש השני<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי.\n</p><p>תאריך זה חל בתקופת תשרי&#160;והוא יכול לחול בימים&#160;שני, רביעי, חמישי ושבת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תתקל\"ה (-826 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - הסתיימה בנייתו של <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" title=\"בית המקדש הראשון\">בית המקדש הראשון</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A4\" title=\"תר&quot;פ\">תר\"פ</a> (25/10/1919 למניינם) - רבי <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A2%D7%A0%D7%92%D7%99%D7%9C\" title=\"יוסף ענגיל\">יוסף ענגיל</a>, ראב\"ד קראקא (קרקוב), מחבר ספר 'אוצרות יוסף', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%91\" title=\"תרמ&quot;ב\">תרמ\"ב</a> (24/10/1881 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרבנית מרת <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%94_%D7%93%D7%99%D7%A0%D7%94_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%A9%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6)\" title=\"נחמה דינה שניאורסון (אשת אדמו&quot;ר הריי&quot;צ)\">נחמה דינה שניאורסון</a>, רעייתו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> - הרב <a href=\"/index.php/%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%A7%D7%90%D7%9C%D7%99%D7%A4%D7%90\" title=\"ירמיהו קאליפא\">ירמיהו קאליפא</a> שליח <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ל<a href=\"/index.php/%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2\" title=\"באר שבע\">באר שבע</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a> - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%95%D7%99%D7%99%D7%A0%D7%A8\" title=\"שמעון ויינר\">שמעון ויינר</a> שליח הרבי ביהוד.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%98\" title=\"תקצ&quot;ט\">תקצ\"ט</a> (20/10/1838 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A0%D7%AA%D7%9F_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94_(%D7%95%D7%95%D7%99%D7%A2%D7%98%D7%A7%D7%90)\" title=\"נתן גוראריה (וויעטקא)\">נתן גוראריה</a>, רב וראש ישיבה בעיר ויעטקא, ומגדולי תלמידיו המובהקים של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> (29/10/2011 למניינם) - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%91%D7%9C%D7%A1%D7%A7%D7%99\" title=\"משה אבלסקי\">משה אבלסקי</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> ומפעילי לשכת <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%AA_%D7%90%D7%97%D7%99%D7%9D\" class=\"mw-redirect\" title=\"עזרת אחים\">עזרת אחים</a> ליהודי חבר העמים.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - א' במר-חשוון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>במנחה - וכן בשני וחמישי דשבוע הבא עלינו לטובה - קורין לישראל מפסוק וירא ה' אל אברם גו'.\n<p>כ\"ק אאמו\"ר (<a href=\"/index.php/%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"הרש&quot;ב\">הרש\"ב</a>) אמר לאחד על <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a>: מאז שאמר הקב\"ה ל<a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"אברהם אבינו\">אברהם אבינו</a> ע\"ה \"לך לך מארצך גו'\" וכתיב \"ויסע אברם הלוך ונסוע הנגבה\" - הותחל סוד ה<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%91%D7%99%D7%A8%D7%95%D7%A8%D7%99%D7%9D\" title=\"עבודת הבירורים\">בירורים</a> ועל פי גזירת ה<a href=\"/index.php/%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%A4%D7%A8%D7%98%D7%99%D7%AA\" title=\"השגחה פרטית\">השגחה העליונה</a> האדם הולך למסעיו במקום אשר ה<a href=\"/index.php/%D7%A0%D7%99%D7%A6%D7%95%D7%A6%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ניצוצות\">ניצוצות</a> הצריכים להתברר על ידו מחכים לגאולתם.\n</p><p>הצדיקים שהם בעלי ראיה רואים באיזה מקום הבירורים שלהם מחכים להם והולכים שמה בעצמם. ועמא דבר [פשוטי העם שבחוץ], הנה עילת כל העילות וסיבת כל הסיבות [הקב\"ה] מסבב כמה עילות וסיבות שיבואו למקום ההוא, שם הוטלה עליהם העבודה בעבודת הבירורים.\n</p>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השמיני\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413094326\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.094 seconds\nReal time usage: 0.534 seconds\nPreprocessor visited node count: 374/1000000\nPost‐expand include size: 9722/2097152 bytes\nTemplate argument size: 731/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 471/5000000 bytes\nLua time usage: 0.070/7 seconds\nLua virtual size: 6115328/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  498.638      1 -total\n 88.43%  440.933      1 תבנית:פתיח_יום\n 19.11%   95.307      5 תבנית:מילה_אחרונה\n 17.21%   85.794      1 תבנית:הערה\n 10.93%   54.518      2 תבנית:רווח\n  9.74%   48.557      1 תבנית:הסר_מילה_ראשונה\n  7.77%   38.750      2 תבנית:מילה_ראשונה\n  7.63%   38.069      1 תבנית:להיום_יום\n  5.62%   28.035      1 תבנית:חודש_חשוון\n  3.88%   19.358      1 תבנית:הערות_שוליים\n-->\n\n<!-- Saved in parser cache with key chabad