      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99.png\" class=\"mw-file-description\"><img src=\"/images/thumb/8/8e/%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99.png/220px-%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99.png\" decoding=\"async\" width=\"220\" height=\"211\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8e/%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99.png/330px-%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99.png 1.5x, /images/thumb/8/8e/%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99.png/440px-%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%90%D7%A6%D7%9C_%D7%94%D7%A8%D7%91%D7%99.png 2x\" /></a><figcaption>הרב קוביטשעק מגיש <a href=\"/index.php/%D7%A4%22%D7%A0\" class=\"mw-redirect\" title=\"פ&quot;נ\">פ\"נ</a> ל<a href=\"/index.php/%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"רבי\">רבי</a> ומקבל ממנו דולר לברכה בסיום <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA_%D7%9B%D7%9C%D7%9C%D7%99%D7%AA\" title=\"יחידות כללית\">יחידות כללית</a></figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%91%D7%9E%D7%91%D7%A6%D7%A2%D7%99%D7%9D.png\" class=\"mw-file-description\"><img src=\"/images/thumb/a/ad/%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%91%D7%9E%D7%91%D7%A6%D7%A2%D7%99%D7%9D.png/250px-%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%91%D7%9E%D7%91%D7%A6%D7%A2%D7%99%D7%9D.png\" decoding=\"async\" width=\"250\" height=\"235\" class=\"mw-file-element\" srcset=\"/images/thumb/a/ad/%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%91%D7%9E%D7%91%D7%A6%D7%A2%D7%99%D7%9D.png/375px-%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%91%D7%9E%D7%91%D7%A6%D7%A2%D7%99%D7%9D.png 1.5x, /images/a/ad/%D7%A8%27_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7_%D7%A2%27%27%D7%94_%D7%91%D7%9E%D7%91%D7%A6%D7%A2%D7%99%D7%9D.png 2x\" /></a><figcaption>הרב קוביטשעק ב<a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" title=\"מבצע תפילין\">מבצע תפילין</a></figcaption></figure>\n<p>הרב <b>יצחק יהודה קוביטשעק</b> (<a href=\"/index.php/%D7%99%22%D7%92_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"י&quot;ג מנחם אב\">י\"ג מנחם אב</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%93\" title=\"תרצ&quot;ד\">תרצ\"ד</a>-<a href=\"/index.php/%D7%9B%22%D7%91_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"כ&quot;ב כסלו\">כ\"ב כסלו</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a>) היה מזקני חסידי חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, עבד ב<a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C\" title=\"כולל\">כולל</a> שומרי החומות ונמנה על פעילי דוכן התפילין ב<a href=\"/index.php/%D7%9B%D7%95%D7%AA%D7%9C_%D7%94%D7%9E%D7%A2%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"כותל המערבי\">כותל המערבי</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת תרצ\"ד ב<a href=\"/index.php/%D7%94%D7%95%D7%A0%D7%92%D7%A8%D7%99%D7%94\" title=\"הונגריה\">הונגריה</a> לאביו ר' אהרן משה ולאמו מרת פרומט, כעבור מספר שנים עלה לארץ והחל ללמוד ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA\" class=\"mw-redirect mw-disambig\" title=\"ישיבת תורת אמת\">ישיבת תורת אמת</a> בירושלים שם התקרב ל<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> והפך ל<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חסיד חב&quot;ד\">חסיד חב\"ד</a>.\n</p><p>התחתן עם קיילא חדוה רות לבית גרינברגר. \n</p><p>לאחר נישואיו קבע את מגוריו בירושלים.\n</p><p>עבד בכולל שומרי החומות בעיר ונמנה על פעילי דוכן התפילין ב<a href=\"/index.php/%D7%9B%D7%95%D7%AA%D7%9C_%D7%94%D7%9E%D7%A2%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"כותל המערבי\">כותל המערבי</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%92\" title=\"תשי&quot;ג\">תשי\"ג</a> חתם יחד עם חסידים נוספים על מכתב ל<a href=\"/index.php/%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"רבי\">רבי</a> בבקשה שיבוא לביקור בארץ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>הרבי עודד את הרב קוביטשעק לשמר קשר עם אישים עימם נפגש בנסיעותיו ולקרבם לתורה ומצוות<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> תרם <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%AA%D7%95%D7%A8%D7%94\" title=\"ספר תורה\">ספר תורה</a> ל<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> העתיק בסרטוב שם משמש בנו הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%99%D7%A8_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7\" title=\"יעקב מאיר קוביטשעק\">יעקב מאיר</a> כשליח<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>נפטר בכ\"ב כסלו תשע\"ז כשהוא בן 82 ונטמן ב<a href=\"/index.php/%D7%94%D7%A8_%D7%94%D7%96%D7%99%D7%AA%D7%99%D7%9D\" title=\"הר הזיתים\">הר הזיתים</a><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://media.chabad.info/chabadinfoheb/wp-content/uploads/2019/03/10-03-2019-13-36-39-%D7%AA%D7%A9%D7%95%D7%A8%D7%94-%D7%A2%D7%A8%D7%A0%D7%98%D7%A8%D7%95%D7%99-%D7%9C%D7%A4%D7%A8%D7%A1%D7%95%D7%9D.pdf\">מכתבי הרבי לרב קוביטשעק</a></b> נדפסו בתשורה משמחת נישואי צאצאיו עמ' 15 ואילך</li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/101687\">\"הבטחתי להניח תפילין ולדווח לרב קובישטעק. השבוע הוא נפטר\"</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>שבועון כפר חב\"ד, כ\"ח טבת תשע\"ז.</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>לרב קוביטשעק ולרעייתו עשרה ילדים, חמישה בנים וחמש בנות. \n</p>\n<ul><li>הרב שמואל קוביטשעק, ירושלים.</li>\n<li>הרב אשר קוביטשעק – קרית גת.</li>\n<li>הרב יוסף קוביטשעק – אשדוד.</li>\n<li>הרב שניאור קוביטשעק – כפר חב\"ד.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%99%D7%A8_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7\" title=\"יעקב מאיר קוביטשעק\">יעקב מאיר קוביטשעק</a> – שליח הרבי בסרטוב, רוסיה.</li>\n<li>גב' שרה נשואה לר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%9C%D7%99%D7%A4%D7%90_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"יוסף ליפא אלפרוביץ&#39;\">יוסף ליפא אלפרוביץ'</a> – ירושלים.</li>\n<li>גב' יענטע לאה נשואה לר' יעקב שלום ערנטרוי – ירושלים.</li>\n<li>גב' חנה נשואה לר' <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%95%D7%97%D7%98\" title=\"מנחם ישראל שוחט\">מנחם ישראל שוחט</a>– ירושלים.</li>\n<li>גב' פרומה נשואה לר' חיים גיל (כתב <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a>) – ירושלים.</li>\n<li>גב' שושנה רייזל נשואה לר' שניאור זלמן דוח – ירושלים.</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">נדפס בתשורה שבקישורים חיצוניים עמ' 6.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">מכתבים מ<a href=\"/index.php/%D7%99%22%D7%90_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"י&quot;א טבת\">י\"א טבת</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%97\" title=\"תשי&quot;ח\">תשי\"ח</a> ו<a href=\"/index.php/%D7%99%27_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"י&#39; מנחם אב\">י' מנחם אב</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%98\" title=\"תשי&quot;ט\">תשי\"ט</a>, נדפסו בתשורה שבקישורים חיצוניים עמודים 16 ו- 17.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/35268\">ידיעה באתר COL</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/bdh/232947/\">ידיעה על פטירתו באתר חב\"ד אינפו</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n</ol></div></d