      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<p><br />\n</p>\n<ul><li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" title=\"חיים הלברשטאם\">חיים הלברשטאם</a> האדמו\"ר בעל ה\"דברי חיים\" מצאנז.</li>\n<li><a href=\"/index.php/%D7%A0%D7%A4%D7%AA%D7%9C%D7%99_%D7%A6%D7%91%D7%99_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" title=\"נפתלי צבי הלברשטאם\">נפתלי צבי הלברשטאם</a> - האדמו\"ר מבאבוב</li>\n<li><a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" title=\"שלמה הלברשטאם\">שלמה הלברשטאם</a> - האדמו\"ר מבאבוב</li>\n<li><a href=\"/index.php/%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" title=\"בן ציון הלברשטאם\">בן ציון הלברשטאם</a> (הראשון) - האדמו\"ר מבאבוב שנהרג בשואה</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A7%D7%95%D7%AA%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" title=\"יקותיאל יהודה הלברשטאם\">יקותיאל יהודה הלברשטאם</a> האדמו\"ר מצאנז-קלויזנבורג.</li>\n<li><a href=\"/index.php/%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C_%D7%A9%D7%A8%D7%92%D7%90_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" class=\"mw-redirect\" title=\"יחזקאל שרגא ליפשיץ הלברשטאם\">יחזקאל שרגא ליפשיץ הלברשטאם</a> - האדמו\"ר מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%98%D7%A8%D7%95%D7%A4%D7%A7%D7%95%D7%91\" title=\"חסידות סטרופקוב\">סטרופקוב</a></li>\n<li><a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A9%D7%9C%D7%95%D7%9D_%D7%99%D7%A9%D7%A9%D7%9B%D7%A8_%D7%93%D7%91_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5-%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D_%D7%9E%D7%A1%D7%98%D7%A8%D7%95%D7%A4%D7%A7%D7%95%D7%91\" class=\"mw-redirect\" title=\"אברהם שלום יששכר דב ליפשיץ-הלברשטאם מסטרופקוב\">אברהם שלום יששכר דב ליפשיץ-הלברשטאם מסטרופקוב</a> - האדמו\"ר הנוכחי מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%98%D7%A8%D7%95%D7%A4%D7%A7%D7%95%D7%91\" title=\"חסידות סטרופקוב\">סטרופקוב</a></li>\n<li><a href=\"/index.php/%D7%97%D7%A0%D7%A0%D7%99%D7%94_%D7%A1%D7%99%D7%A0%D7%99_%D7%93%D7%95%D7%93_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%9D\" class=\"mw-redirect\" title=\"חנניה סיני דוד הלברשטם\">חנניה סיני דוד הלברשטם</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%91%22%D7%A7\" class=\"mw-redirect\" title=\"משב&quot;ק\">משב\"ק</a> אצל <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a></li>\n<li><a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%91%D7%A8%D7%95%D7%9A_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%9D\" title=\"חיים ברוך הלברשטם\">חיים ברוך הלברשטם</a> - מהאחראים על ועד <a href=\"/index.php/%D7%91%D7%93%D7%A7_%D7%94%D7%91%D7%99%D7%AA_(770)\" title=\"בדק הבית (770)\">בדק הבית</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%99%D7%99%D7%A0%D7%95\" class=\"mw-redirect mw-disambig\" title=\"בית חיינו\">בית חיינו</a>.ומייסד את 'חדר השידורים' וחברת <a href=\"/index.php/WLCC\" class=\"mw-redirect\" title=\"WLCC\">WLCC</a> - '<a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%A9%D7%99%D7%93%D7%95%D7%A8%D7%99_%D7%97%D7%91%22%D7%93\" title=\"מרכז שידורי חב&quot;ד\">מרכז שידורי חב\"ד</a>'.</li>\n<li><a href=\"/index.php/%D7%90%D7%A8%D7%99_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%9D\" title=\"ארי הלברשטם\">ארי הלברשטם</a> - בנו של המשב\"ק <a href=\"/index.php/%D7%97%D7%A0%D7%A0%D7%99%D7%94_%D7%A1%D7%99%D7%A0%D7%99_%D7%93%D7%95%D7%93_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%9D\" class=\"mw-redirect\" title=\"חנניה סיני דוד הלברשטם\">חס\"ד</a>. נרצח (כשהיה בחור) על ידי ערבים על גשר ברוקלין.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\