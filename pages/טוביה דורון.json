    "pageid": 32291,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/ae/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F.jpg/220px-%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/a/ae/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F.jpg/330px-%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F.jpg 1.5x, /images/thumb/a/ae/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F.jpg/440px-%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F.jpg 2x\" /></a><figcaption>נואם בכינוס מטעם ארגון <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה האמיתית והשלימה</a></figcaption></figure>\n<p>הרב <b>טוביה דורון</b> (<a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a> - <a href=\"/index.php/%D7%94%27_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ה&#39; אלול\">ה' אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a>; 1955 - 29/08/2025) היה מ<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שלוחי</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ב<a href=\"/index.php/%D7%91%D7%AA_%D7%99%D7%9D\" title=\"בת ים\">בת ים</a>, כיהן כרב ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> חב\"ד בשכונת רמת הנשיא בעיר, <a href=\"/index.php/%D7%A1%D7%95%D7%A4%D7%A8_%D7%A1%D7%AA%22%D7%9D\" title=\"סופר סת&quot;ם\">סופר סת\"ם</a>, חבר <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה האמיתית והשלימה</a>, פרסם טורי הגות בבמות שונות.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%95_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"כ&quot;ו תשרי\">כ\"ו תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a> בקיבוץ גבע שבעמק יזרעאל להוריו דב וצביה דורון. בצעירותו <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"בעל תשובה\">חזר בתשובה</a> והתקרב לחסידות על ידי חסידי חב\"ד ב<a href=\"/index.php/%D7%A2%D7%A4%D7%95%D7%9C%D7%94\" title=\"עפולה\">עפולה</a>. למד חסידות אצל הרב <a href=\"/index.php/%D7%A1%D7%A2%D7%93%D7%99%D7%94_%D7%92%27%D7%A8%D7%95%D7%A4%D7%99\" title=\"סעדיה ג&#39;רופי\">סעדיה ג'רופי</a> ובהמשך נכנס ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a>.\n</p><p>לאחר נישואיו למרת לאה, בתו של הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A2%D7%A7%D7%91_%D7%94%D7%A8%D7%A9%D7%A7%D7%95%D7%91%D7%99%D7%A5\" title=\"אברהם יעקב הרשקוביץ\">אברהם יעקב הרשקוביץ</a>, התיישב הזוג ב<a href=\"/index.php/%D7%91%D7%AA_%D7%99%D7%9D\" title=\"בת ים\">בת ים</a> והחל לפעול בשליחות הרבי להפצת יהדות במקום.\n</p><p>עם התפתחות קהילת חב\"ד בעיר, קיבל תחת אחריותו את ניהול <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> המרכזי של קהילת חב\"ד המקומית הממוקם במקלט גדול בשכונת רמת הנשיא, והחל לשמש במקום כ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> וכרב בית הכנסת.\n</p><p>לצד עזרתו לפעולות השליח הראשי בעיר הרב <a href=\"/index.php/%D7%96%D7%9E%D7%A8%D7%95%D7%A0%D7%99_%D7%A6%D7%99%D7%A7\" class=\"mw-redirect\" title=\"זמרוני ציק\">זמרוני ציק</a> התמחה בכתיבת סת\"ם, והחל לעסוק בתחום זה לפרנסתו.\n</p><p>החל משנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a> התמסר יותר ויותר לתמלול ותרגום שיחות הרבי נאמן ככל האפשר לשפת המקור בו הם נאמרו בשפת היידיש, מתוך ההקלטות.\n</p><p>עסק רבות בנושאים: הנחת <a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2_%D7%96%D7%95%D7%92%D7%95%D7%AA_%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ארבע זוגות תפילין\">ארבע זוגות תפילין</a>, <a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C_%D7%94%D7%A6%D7%95%D7%9E%D7%95%D7%AA_%D7%9C%D7%A2%D7%AA%D7%99%D7%93_%D7%9C%D7%91%D7%95%D7%90\" title=\"ביטול הצומות לעתיד לבוא\">ביטול הצומות לעתיד לבוא</a>, הכרזת יחי לפני מודה אני, האמונה ב<a href=\"/index.php/%D7%A0%D7%A6%D7%97%D7%99%D7%95%D7%AA_%D7%97%D7%99%D7%99%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" title=\"נצחיות חייו של הרבי\">נצחיות חייו של הרבי</a> ההגדרה של הרבי כמשיח ודאי, וביסוס המקורות התורניים בנושאים אלו.\n</p>\n<h2><span id=\".D7.A4.D7.A2.D7.99.D7.9C.D7.95.D7.AA.D7.95_.D7.9B.D7.97.D7.91.D7.A8_.D7.94.D7.90.D7.92.D7.95.D7.93.D7.94\"></span><span class=\"mw-headline\" id=\"פעילותו_כחבר_האגודה\">פעילותו כחבר האגודה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;פעילותו כחבר האגודה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: פעילותו כחבר האגודה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הרב דורון היה חבר ב'ועד כינוסי הקהל הארצי' שתחתיו התקיימו <a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97_-_%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"כינוסי גאולה ומשיח - תשנ&quot;ה\">כינוסי גאולה ומשיח בשנת תשנ\"ה</a> - <a href=\"/index.php/%D7%94%D7%A7%D7%94%D7%9C\" title=\"הקהל\">הקהל</a>.\n</p><p>הקים יחד עם הרב <a href=\"/index.php/%D7%92%D7%99%D7%93%D7%99_%D7%A9%D7%A8%D7%95%D7%9F\" class=\"mw-redirect\" title=\"גידי שרון\">גידי שרון</a> את '<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%A8%D7%91%D7%99_%D7%90%D7%95%D7%A6%D7%A8%D7%95_%D7%A9%D7%9C_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"מכון הרבי אוצרו של משיח\">מכון הרבי אוצרו של משיח</a>' שהיה הראשון להנגיש את ספריו של הרבי לציבור הרחב על רשת ה<a href=\"/index.php/%D7%90%D7%99%D7%A0%D7%98%D7%A8%D7%A0%D7%98\" title=\"אינטרנט\">אינטרנט</a>.\n</p><p>הרב דורון פירסם טורי הגות ב<a href=\"/index.php/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)\" title=\"הגאולה (אתר)\">אתר 'הגאולה'</a>, ונאם רבות בכנסים המאורגנים על ידי <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה האמיתית והשלימה</a>.\n</p><p>במשך השנים עזר להקים את האירוע המרכזי שמתקיים כל שנה בבת ים \"<a href=\"/index.php/%D7%A2%D7%A6%D7%A8%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" title=\"עצרת גאולה ומשיח\">עצרת גאולה ומשיח</a>\".\n</p><p>כמו כן היה שותף בפעולות האגודה כגון: הוצאת העלון <a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%AA_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"שיחת הגאולה\">שיחת הגאולה</a>, עיתון <a href=\"/index.php/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94_(%D7%A2%D7%99%D7%AA%D7%95%D7%9F)\" title=\"הגאולה האמיתית והשלימה (עיתון)\">הגאולה</a>, אתר הגאולה, התוועדויות שמתקיימות מידי תקופה לכבוד תאריכים מיוחדים, פרסומים סביב משיח בעיתונים בישראל ועוד.\n</p><p>כמו כן הפעיל הרב דורון ערוץ יוטיוב בשם משיח וגאולה.\n</p><p>הרב דורון נפטר ב<a href=\"/index.php/%D7%94%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ה&#39; באלול\">ה' באלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, עמיהוד דורון - אחוזת ברק</li>\n<li>אחיו, חגי דורון - מולדת</li>\n<li>אחיו, הרב <a href=\"/index.php/%D7%9E%D7%99%D7%9B%D7%90%D7%9C_%D7%93%D7%95%D7%A8%D7%95%D7%9F\" title=\"מיכאל דורון\">מיכאל דורון</a> - משלוחי הרבי ב<a href=\"/index.php/%D7%A2%D7%A4%D7%95%D7%9C%D7%94\" title=\"עפולה\">עפולה</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%94%D7%A8%D7%A9%D7%A7%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יוסף הרשקוביץ\">יוסף הרשקוביץ</a> - מנהל <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%93%D7%A8_%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"חיידר אידיש\">חיידר אידיש</a> כפר חב\"ד</li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%94%D7%A8%D7%A9%D7%A7%D7%95%D7%91%D7%99%D7%A5\" title=\"ישראל הרשקוביץ\">ישראל הרשקוביץ</a> - שליח הרבי, רב קהילת חב\"ד ויו\"ר המוסדות ב<a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A7%D7%99%D7%9D\" title=\"אופקים\">אופקים</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%94%D7%A8%D7%A9%D7%A7%D7%95%D7%91%D7%99%D7%A5\" title=\"מאיר יחיאל הרשקוביץ\">מאיר יחיאל הרשקוביץ</a> מביתר עילית - משלוחי הרבי למרכז הפצת המעיינות היכל מנחם בירושלים</li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%94%D7%A8%D7%A9%D7%A7%D7%95%D7%91%D7%99%D7%A5\" title=\"צבי הרשקוביץ\">צבי הרשקוביץ</a> - סגן רב כללית שירותי בריאות ומנהל מחלקת דת וכשרות</li></ul>\n<dl><dt>בניו וחתניו</dt></dl>\n<ul><li>בנו, הרב מנחם מענדל דורון - חבר בצוות הרוחני של <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A0%D7%95%D7%9A_%D7%9C%D7%A0%D7%A2%D7%A8\" class=\"mw-redirect\" title=\"ישיבת חנוך לנער\">ישיבת חנוך לנער</a></li>\n<li>בנו, הרב ישראל דורון - משלוחי הרבי ב<a href=\"/index.php/%D7%91%D7%AA_%D7%99%D7%9D\" title=\"בת ים\">בת ים</a></li>\n<li>בנו, הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%93%D7%95%D7%A8%D7%95%D7%9F\" title=\"לוי יצחק דורון\">לוי יצחק דורון</a> - שליח הרבי בשכונת נווה דקלים שיפר ב<a href=\"/index.php/%D7%A4%D7%AA%D7%97_%D7%AA%D7%A7%D7%95%D7%95%D7%94\" title=\"פתח תקווה\">פתח תקווה</a> ומשפיע ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים ראשון לציון (קטנה)\">ישיבה קטנה ראשון לציון</a></li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A7%D7%95%D7%A4%D7%A6%27%D7%99%D7%A7\" title=\"יחיאל יהודה קופצ&#39;יק\">יחיאל יהודה קופצ'יק</a>, הנשוי לבתו טובה יפה ברכה - מנהל חינוכי בתלמוד תורה חב\"ד בית שמש ושליח הרבי ברמה ד'2</li>\n<li>חתנו, הרב אברהם קופצ'יק, הנשוי לבתו חנה - מחברי הצוות הרוחני ור\"מ בישיבת <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד ליובאוויטש צפת\">חסידי חב\"ד ליובאוויטש צפת</a></li>\n<li>חתנו, הרב שמואל זלמנוב, הנשוי לבתו חיה מושקא - משלוחי הרבי בקישינב <a href=\"/index.php/%D7%9E%D7%95%D7%9C%D7%93%D7%95%D7%91%D7%94\" title=\"מולדובה\">מולדובה</a>.</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1vL1TeVsakIA4vCZmKJyqoFiscsyBQFI1/view\">המבט שאמר את הכל</a> שיחת הגאולה גליון 115</li></ul>\n<ul><li>מנחם זיגלבוים,&#160;‏<b>חייל בשירות הגאולה</b>, שבועון בית משיח, גיליון 1475 עמוד 20 (תשפ\"ה) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%93%D7%95%D7%A8%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: 