n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a>, <a href=\"/index.php/%D7%93%D7%A8%D7%9A_%D7%9E%D7%A6%D7%95%D7%95%D7%AA%D7%99%D7%9A\" class=\"mw-redirect\" title=\"דרך מצוותיך\">דרך מצוותיך</a>, מצוות <a href=\"/index.php/%D7%97%D7%9E%D7%A5\" title=\"חמץ\">חמץ</a> ו<a href=\"/index.php/%D7%9E%D7%A6%D7%94\" title=\"מצה\">מצה</a>.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">ה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a>, <a href=\"/index.php/%D7%9B%D7%AA%D7%A8_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"כתר שם טוב\">כתר שם טוב</a> חלק ראשון מא.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">ישעיה מ, כו</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">אדמו\"ר <a href=\"/index.php/%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"הצמח צדק\">הצמח צדק</a> ספר החקירה דרך אמונה חקירה ל' רס\"ג כ\"א פרקים יד, א.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">ישעיה א, ב.</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%A9%D7%99%D7%97%D7%95%D7%AA\" title=\"לקוטי שיחות\">לקוטי שיחות</a> כרך לט מכתב כללי.</span>\n</li>\n<li id=\"cite_note-10\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-10\">^</a></span> <span 