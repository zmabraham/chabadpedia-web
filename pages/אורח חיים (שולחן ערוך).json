A%D7%99%D7%A0%D7%95%D7%A7_%D7%A9%D7%A0%D7%A9%D7%91%D7%94\" title=\"תינוק שנשבה\">תינוק שנשבה</a> - <a href=\"/index.php/%D7%9E%D7%99%D7%9D_%D7%90%D7%97%D7%A8%D7%95%D7%A0%D7%99%D7%9D\" title=\"מים אחרונים\">מים אחרונים</a> - <a href=\"/index.php/%D7%97%D7%99%D7%A0%D7%95%D7%9A\" title=\"חינוך\">חינוך</a> - <a href=\"/index.php/%D7%A7%D7%98%D7%9F\" title=\"קטן\">קטן</a> - <a href=\"/index.php/%D7%A9%D7%99%D7%A0%D7%94_%D7%91%D7%A1%D7%95%D7%9B%D7%94\" title=\"שינה בסוכה\">שינה בסוכה</a> - <a href=\"/index.php/%D7%9E%D7%90%D7%94_%D7%91%D7%A8%D7%9B%D7%95%D7%AA\" title=\"מאה ברכות\">מאה ברכות</a> - <a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%AA_%D7%92%D7%95%D7%96%D7%96\" title=\"מלאכת גוזז\">מלאכת גוזז</a> - <a href=\"/index.php/%D7%94%D7%A9%D7%95%D7%97%D7%98\" class=\"mw-redirect\" title=\"השוחט\">השוחט</a> - <a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%AA_%D7%A1%D7%95%D7%97%D7%98\" title=\"מלאכת סוחט\">מלאכת סוחט</a> - <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%A9%D7%9C_%D7%9B%D7%A8%D7%9B%D7%99%D7%9D\" title=\"בית הכנסת של כרכים\">בית הכנסת של כרכים</a> - <a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%AA_%D7%9E%D7%9C%D7%91%D7%9F\" title=\"מלאכת מלבן\">מלאכת מלבן</a> - <a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%AA_%D7%A6%D7%93\" class=\"mw-redirect\" title=\"מלאכת צד\">מלאכת צד</a> - <a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%AA_%D7%92%D7%95%D7%96%D7%96\" title=\"מלאכת גוזז\">מלאכת גוזז</a> - <a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%AA_%D7%93%D7%A9\" title=\"מלאכת דש\">מלאכת דש</a> - <a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%AA_%D7%A7%D7%95%D7%A6%D7%A8\" title=\"מלאכת קוצר\">מלאכת קוצר</a> - <a href=\"/index.php/%D7%AA%D7%A7%D7%99%D7%A2%D7%AA_%D7%A9%D7%95%D7%A4%D7%A8\" title=\"תקיעת שופר\">תקיעת שופר</a>, ועוד.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9B.D7.9F_.D7.90.D7.95.D7.A8.D7.97_.D7.97.D7.99.D7.99.D7.9D_.D7.91.D7.98.D7.95.D7.A8_.D7.95.D7.91.D7.A9.D7.95.22.D7.A2\"></span><span class=\"mw-headline\" id=