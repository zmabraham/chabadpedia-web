      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%99%D7%A2%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/6d/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%99%D7%A2%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5.jpg/220px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%99%D7%A2%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6d/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%99%D7%A2%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5.jpg/330px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%99%D7%A2%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5.jpg 1.5x, /images/thumb/6/6d/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%99%D7%A2%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5.jpg/440px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A9%D7%99%D7%A2%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5.jpg 2x\" /></a><figcaption>הרב רייניץ נואם ב<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"התוועדות\">התוועדות</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a></figcaption></figure>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%91%D7%A8%D7%9E%D7%9C%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5_%D7%A0%D7%95%D7%90%D7%9D_%D7%91%D7%A2%D7%A8%D7%91_%D7%9E%D7%9C%D7%95%D7%95%D7%94_%D7%9E%D7%9C%D7%9B%D7%94_%D7%97%D7%92%D7%99%D7%92%D7%99_%D7%9C%D7%9E%D7%AA%D7%A0%D7%93%D7%91%D7%99_%D7%90%D7%A9%27%27%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/a7/%D7%90%D7%91%D7%A8%D7%9E%D7%9C%D7%94_%D7%A8%D7%99%D7%99%D7%A0%D7%99%D7%A5_%D7%A0%D7%95%D7%90%D7%9D_%D7%91%D7%A2%D7%A8%D7%91_%D7%9E%D7%9C%D7%