      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">&gt;&gt;</a></span>\n<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"א&#39; בתמוז\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ב&#39; בתמוז\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ג&#39; בתמוז\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ד&#39; בתמוז\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ה&#39; בתמוז\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ו&#39; בתמוז\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ז&#39; בתמוז\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ח&#39; בתמוז\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ט&#39; בתמוז\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&#39; בתמוז\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;א בתמוז\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ג בתמוז\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ד בתמוז\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ט&quot;ו בתמוז\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ט&quot;ז בתמוז\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ז בתמוז\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ח בתמוז\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ט בתמוז\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&#39; בתמוז\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;א בתמוז\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ב בתמוז\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ג בתמוז\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ד בתמוז\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ה בתמוז\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ו בתמוז\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ז בתמוז\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ח בתמוז\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ט בתמוז\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י&#34;ב בתמוז</b> הוא היום השניים עשר\nבחודש העשירי<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי.\n</p><p>תאריך זה חל בתקופת תמוז&#160;והוא יכול לחול בימים&#160;שני, שלישי, חמישי ושבת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'ק\"ג (בערך)<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> – רבינו <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%91%D7%9F_%D7%90%D7%A9%D7%A8\" class=\"mw-redirect\" title=\"יעקב בן אשר\">יעקב בן אשר</a> מחבר <a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2%D7%94_%D7%98%D7%95%D7%A8%D7%99%D7%9D\" title=\"ארבעה טורים\">ארבעה טורים</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> – נערך פוגרום אכזרי ביהודים תושבי העיר קהיר, על ידי הערביים המקומיים. למעלה מאלף חמש מאות יהודים נהרגו.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%92\" title=\"תרנ&quot;ג\">תרנ\"ג</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> הגיע לגיל מצוות. סעודה התקיימה ב<a href=\"/index.php/%D7%94%D7%96%D7%90%D7%9C_%D7%94%D7%92%D7%93%D7%95%D7%9C_(%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9)\" title=\"הזאל הגדול (ליובאוויטש)\">זאל הגדול שבליובאוויטש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%94\" title=\"תרנ&quot;ה\">תרנ\"ה</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> הכניס את בנו אדמו\"ר הריי\"צ לעסקנות ציבורית, ומינה אותו למזכירו<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A4\" title=\"תר&quot;פ\">תר\"פ</a> – התקיימו קישורי התנאים של הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A8%D7%99%D7%94%D7%95_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"שמריהו גוראריה\">שמריהו גוראריה</a>, גיס הרבי וחתן <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a>, עם רעייתו <a href=\"/index.php/%D7%97%D7%A0%D7%94_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"חנה גוראריה\">חנה גוראריה</a>.</li>\n<li><b><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%96\" title=\"תרפ&quot;ז\">תרפ\"ז</a> – אדמו\"ר הריי\"צ התבשר על שחרורו המלא מ<a href=\"/index.php/%D7%9E%D7%90%D7%A1%D7%A8_%D7%95%D7%92%D7%90%D7%95%D7%9C%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" title=\"מאסר וגאולת הרבי הריי&quot;צ\">מאסרו</a></b> (בעקבות חג מקומי, הנפיק המשרד את תעודת השחרור רק למחרת – ב<a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ג בתמוז\">י\"ג בתמוז</a>).</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%94\" title=\"תרצ&quot;ה\">תרצ\"ה</a> – החלה הוצאתו לאור של העלון <a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%91%D7%95%D7%9C%D7%A2%D7%98%D7%99%D7%9F\" class=\"mw-redirect\" title=\"חב&quot;ד בולעטין\">חב\"ד בולעטין</a>, ביטאון <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"אגודת חסידי חב&quot;ד בארצות הברית\">אגודת חסידי חב\"ד בארצות הברית</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> – נפתח בית חב\"ד בשכונת <a href=\"/index.php/%D7%92%D7%99%D7%9C%D7%94_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" title=\"גילה (ירושלים)\">גילה</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%94\" title=\"תשמ&quot;ה\">תשמ\"ה</a> – ב<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"התוועדות\">התוועדות</a> חג הגאולה הרבי חשף לראשונה ברבים את <a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%94%D7%A1%D7%A4%D7%A8%D7%99%D7%9D\" title=\"פרשת הספרים\">פרשת הספרים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a> - התקיים אירוע <a href=\"/index.php/%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%9B%D7%99%D7%9B%D7%A8\" title=\"משיח בכיכר\">משיח בכיכר</a> שזכה לפרסום אדיר בכל כלי התקשורת.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><b><a href=\"/index.php/%D7%AA%D7%A8%22%D7%9E\" title=\"תר&quot;מ\">תר\"מ</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> נולד ל<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> ולהרבנית <a href=\"/index.php/%D7%A9%D7%98%D7%A2%D7%A8%D7%A0%D7%90_%D7%A9%D7%A8%D7%94_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%A9%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91)\" title=\"שטערנא שרה שניאורסון (אשת אדמו&quot;ר הרש&quot;ב)\">שטערנא שרה שניאורסון</a></b>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> – הרב <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%9E%D7%99%D7%9C%D7%91%D7%A1%D7%A7%D7%99\" title=\"צבי מילבסקי\">צבי מילבסקי</a>, מבאי ביתו של <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"רבי לוי יצחק שניאורסון\">רבי לוי יצחק שניאורסון</a> – אביו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%96\" title=\"תרפ&quot;ז\">תרפ\"ז</a> – הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" title=\"יצחק גנזבורג\">יצחק (איטשקע) גאנזבורג</a>, מפעילי <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"צעירי אגודת חב&quot;ד\">צעירי אגודת חב\"ד</a> וחבר הנהלת <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"רשת אהלי יוסף יצחק בארץ הקודש\">רשת אהלי יוסף יצחק בארץ הקודש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%98\" title=\"תרצ&quot;ט\">תרצ\"ט</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%9C%D7%99%D7%A4%D7%A9\" title=\"משה ליפש\">משה ליפש</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> כשרות בתל אביב, וחבר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ועד כפר חב&quot;ד\">ועד כפר חב\"ד</a> בין השנים <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a>-<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> – הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%A8%D7%96%D7%95%D7%91\" title=\"מאיר וורזוב\">מאיר וורזוב</a>, מפעילי ארגון <a href=\"/index.php/%D7%97%D7%9E%22%D7%94\" class=\"mw-redirect\" title=\"חמ&quot;ה\">חמ\"ה</a> ו<a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"אגודת חסידי חב&quot;ד ארץ הקודש\">אגודת חסידי חב\"ד ארץ הקודש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a> – הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"אברהם גולדברג\">אברהם גולדברג</a>, ממייסדי ועסקני הקהילה החב\"דית ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>, וממייסדי ישיבת <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד ליובאוויטש צפת\">חסידי חב\"ד ליובאוויטש צפת</a> ומכון <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%A0%D7%94_(%D7%A6%D7%A4%D7%AA)\" title=\"בית חנה (צפת)\">בית חנה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%94\" title=\"תרכ&quot;ה\">תרכ\"ה</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%99%D7%95%D7%A1%D7%A3_%D7%A8%D7%99%D7%91%D7%9C%D7%99%D7%9F\" title=\"אליהו יוסף ריבלין\">אליהו יוסף ריבלין</a>, מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסידיהם</a> הגדולים של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a> ו<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%22%D7%A9\" title=\"ת&quot;ש\">ת\"ש</a> – הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%9E%D7%95%D7%95%D7%99%D7%A2%D7%9C%D7%99%D7%96,_%D7%9C%D7%95%D7%93%D7%96%27)\" title=\"שניאור זלמן שניאורסון (מוויעליז, לודז&#39;)\">שניאור זלמן שניאורסון (מוויעליז, לודז')</a>, מחשובי חסידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a> – הרב <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F_%D7%9E%D7%99%D7%A0%D7%93%D7%9C\" title=\"ניסן מינדל\">ניסן מינדל</a>, מזכיר של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, ומעורכי הוצאת הספרים <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> – הרב <a href=\"/index.php/%D7%99%D7%A7%D7%95%D7%AA%D7%99%D7%90%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D_%D7%A8%D7%90%D7%A4\" title=\"יקותיאל מנחם ראפ\">יקותיאל מנחם ראפ</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח ראשי</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" title=\"תומכי תמימים המרכזית 770\">תומכי תמימים המרכזית 770</a> ומנהל בית חב\"ד שדה התעופה JFK קנדי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> – הת' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A0%D7%95%D7%9C\" title=\"משה שמואל נול\">משה שמואל נול</a>, סמל ראשון ב<a href=\"/index.php/%D7%A6%D7%94%22%D7%9C\" title=\"צה&quot;ל\">צה\"ל</a>, לוחם בגדוד נצח יהודה. נרצח בקרב בצפון רצועת עזה במהלך <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%97%D7%A8%D7%91%D7%95%D7%AA_%D7%91%D7%A8%D7%96%D7%9C\" title=\"מלחמת חרבות ברזל\">מלחמת חרבות ברזל</a>.</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9E%D7%90%D7%A1%D7%A8_%D7%95%D7%92%D7%90%D7%95%D7%9C%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" title=\"מאסר וגאולת הרבי הריי&quot;צ\">מאסר וגאולת הרבי הריי\"צ</a></li>\n<li><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%9C%D7%99%22%D7%91_%D7%99%22%D7%92_%D7%AA%D7%9E%D7%95%D7%96\" title=\"ניגון לי&quot;ב י&quot;ג תמוז\">ניגון לי\"ב י\"ג תמוז</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://77012.blogspot.com/search/label/י%22ב%20תמוז\">תגית: חג הגאולה י\"ב תמוז</a></b>, באתר '<a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\">לחלוחית גאולתית</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_