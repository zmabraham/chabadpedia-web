    "pageid": 60698,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/19/%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98.jpg/250px-%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98.jpg\" decoding=\"async\" width=\"250\" height=\"361\" class=\"mw-file-element\" srcset=\"/images/thumb/1/19/%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98.jpg/375px-%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98.jpg 1.5x, /images/thumb/1/19/%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98.jpg/500px-%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98.jpg 2x\" /></a><figcaption>הרב זאב וולף שטיינגארט</figcaption></figure>\n<p>הרב <b>זאב וולף שטיינגארט</b> (כונה <b>וועלוועל באטשייקאווער</b>; <a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%98\" title=\"תרמ&quot;ט\">תרמ\"ט</a> - <a href=\"/index.php/%D7%9B%22%D7%90_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"כ&quot;א שבט\">כ\"א שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a>) היה מתלמידי תומכי תמימים בליובאוויטש, סוחר במוסקבה, ישב בכלא שנים רבות על סיוע בעסקנות הכלל.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%A0%D7%92%D7%90%D7%A8%D7%98.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/4d/%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%A0%D7%92%D7%90%D7%A8%D7%98.jpg/250px-%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%A0%D7%92%D7%90%D7%A8%D7%98.jpg\" decoding=\"async\" width=\"250\" height=\"390\" class=\"mw-file-element\" srcset=\"/images/thumb/4/4d/%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%A0%D7%92%D7%90%D7%A8%D7%98.jpg/375px-%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%A0%D7%92%D7%90%D7%A8%D7%98.jpg 1.5x, /images/thumb/4/4d/%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%A0%D7%92%D7%90%D7%A8%D7%98.jpg/500px-%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%A0%D7%92%D7%90%D7%A8%D7%98.jpg 2x\" /></a><figcaption>ר' וועלוועל שטיינגארט</figcaption></figure>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%98\" title=\"תרמ&quot;ט\">תרמ\"ט</a> לאביו ר' שלום פנחס ולאמו מרת סטריקא בעיירה באצייקעוו שברוסיה.\n</p><p>למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"תומכי תמימים בליובאוויטש\">תומכי תמימים בליובאוויטש</a> בחצרו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> משנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%91\" title=\"תרס&quot;ב\">תרס\"ב</a> עד שנת <a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a>. כונה בשם 'וועלוועל באטשייקאווער' על שם עיירת הולדתו.\n</p><p><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> התבטא עליו שהוא 'בעל חושים טובים'.\n</p><p>לפני חתונתו <a href=\"/index.php/%D7%A1%D7%9E%D7%99%D7%9B%D7%94_%D7%9C%D7%A8%D7%91%D7%A0%D7%95%D7%AA\" title=\"סמיכה לרבנות\">הוסמך לרבנות</a>.\n</p><p>אחר חתונתו עם רעייתו חנה, בתו של ר' <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%97%D7%94_%D7%97%D7%9F\" title=\"מאיר שמחה חן\">מאיר שמחה חן</a> התיישב ב<a href=\"/index.php/%D7%A0%D7%A2%D7%95%D7%95%D7%A2%D7%9C\" class=\"mw-redirect\" title=\"נעוועל\">נעוועל</a> ובהמשך עבר להתגורר ב<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a> והיה בעל עסק.\n</p><p>בתחילת <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%99%D7%94\" title=\"מלחמת העולם השנייה\">מלחמת העולם השנייה</a> נאסר באשמת ריגול לטובת גרמניה, היתה זו עלילה גמורה אף שלא היה לו שום שייכות לגרמניה, והוגלה למחנה עבודה בזירבולק הסמוכה לסמרקנד משם הוגלה למחנות עבודה נוספים וישב בסך הכל במשך 22 שנה על קשריו לעסקנות הכלל החב\"דית ברוסיה.\n</p><p>לאחר שחרורו חזר להתגורר במוסקבה שם נותר לחיות עד אחרית ימיו.\n</p><p>נפטר ב<a href=\"/index.php/%D7%9B%22%D7%90_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"כ&quot;א שבט\">כ\"א שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> ב<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%D7%90%D7%91_%D7%95%D7%95%D7%9C%D7%A3_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%92%D7%A8%D7%98&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בתו מרת רחל לאה, רעיית ר' <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A7%D7%A8%D7%99%D7%A6%27%D7%91%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"יעקב קריצ&#39;בסקי\">יעקב (יאני) קריצ'בסקי</a>.</li>\n<li>בנו, ר' שלום פנחס שטיינגארט</li>\n<li>בתו, מרת שטערנא</li>\n<li>בתו, מרת חייקא</li>\n<li>בתו מרת רבקה דינה, רעיית הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%94%D7%A8%D7%9F_%D7%92%D7%99%D7%99%D7%A1%D7%99%D7%A0%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"משה אהרן גייסינסקי\">משה אהרן גייסינסקי</a>.</li>\n<li>בתו, מרת מנוחה</li>\n<li>בתו, מרת שרה</li></ul>\n<!-- \nNewPP limit report\nCached time: 20260413122309\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.018 seconds\nReal time usage: 0.044 seconds\nPreprocessor visited node count: 25/1000000\nPost‐expand include size: 0/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 2/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%    0.000      1 -total\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:60698-0!canonical and timestamp 20260413122309 and revision id 825210. Rendering was triggered because: page-view\n -->\n</div>"
