php/%D7%90%D7%9E%D7%A9%D7%99%D7%A0%D7%95%D7%91\" class=\"mw-redirect\" title=\"אמשינוב\">אמשינוב</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%94\" title=\"תשמ&quot;ה\">תשמ\"ה</a> – רבי יצחק מאיר העשיל מ<a href=\"/index.php/%D7%9E%D7%96%27%D7%91%D7%95%D7%96%27\" class=\"mw-redirect\" title=\"מז&#39;בוז&#39;\">מז'בוז'</a> – <a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%94\" title=\"תרפ&quot;ה\">תרפ\"ה</a> – <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A9%D7%90%D7%95%D7%9C%D7%96%D7%95%D7%9F\" title=\"שמואל אלעזר שאולזון\">שמואל אלעזר שאולזון</a> – מצאצאי משפחת רבותינו נשיאינו, וסגן ראש עיריית ירושלים.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%92\" title=\"תשל&quot;ג\">תשל\"ג</a> – הסופר החב\"די ר' <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%96%D7%99%D7%92%D7%9C%D7%91%D7%95%D7%99%D7%9D\" title=\"מנחם זיגלבוים\">מנחם זיגלבוים</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%94%D7%91%D7%A8\" class=\"mw-redirect\" title=\"יעקב טוביה הבר\">יעקב טוביה הבר</a>, מזקני חסידי חב\"ד ב<a href=\"/index.php?title=%D7%95%D7%95%D7%90%D7%A8%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ווארקי (הדף אינו קיים)\">ווארקי</a> וחמיו של הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%A8%D7%99%D7%91%D7%A7%D7%99%D7%9F\" title=\"משה דובער ריבקין\">משה דובער ריבקין</a> נרצח ב<a href=\"/index.php/%D7%94%D7%A9%D7%95%D7%90%D7%94\" title=\"השואה\">שואה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> – הרב <a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%93%D7%91_%D7%95%D7%99%D7%99%D7%A0%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אברהם דב ויינר (הדף אינו קיים)\">אברהם דב ויינר</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"תשכ&quot;ג\">תשכ\"ג</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%A9%D7%98%D7%95%D7%A7%D7%94%D7%90%D7%9E%D7%A8\" title=\"דוד שטוקהאמר\">דוד שטוקהאמר</a>, מראשוני חסידי חב\"ד בארצות הברית, וממייסדי ישיבת <a href=\"/index.php/%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%95%D7%90%D7%A8%D7%A7\" title=\"אחי תמימים נוארק\">אחי תמימים נוארק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"תשל&quot;ה\">תשל\"ה</a> – הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%96%D7%90%D7%91_%D7%9C%D7%99%D7%A4%D7%A1%D7%A7%D7%A8\" title=\"אריה זאב ליפסקר\">אריה זאב ליפסקר</a>, ממקימי שיכון חב\"ד ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"תשל&quot;ה\">תשל\"ה</a> – הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%A9%D7%9E%D7%A8%D7%99%D7%94%D7%95_%D7%A9%D7%A9%D7%95%D7%A0%D7%A7%D7%99%D7%9F\" class=\"mw-redirect\" title=\"נחום שמריהו ששונקין\">נחום שמריהו ששונקין</a> (שמער'ל באטומער), מחסידי חב\"ד ש<a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%A8%D7%95%D7%AA_%D7%A0%D7%A4%D7%A9\" title=\"מסירות נפש\">מסרו נפשם</a> על <a href=\"/index.php/%D7%94%D7%A4%D7%A6%D7%AA_%D7%99%D7%94%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הפצת יהדות\">הפצת יהדות</a> ב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%94%D7%A1%D7%95%D7%91%D7%99%D7%99%D7%98%D7%99%D7%AA\" class=\"mw-redirect\" title=\"רוסיה הסובייטית\">רוסיה הסובייטית</a> ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> קהילת חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> – הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%99%D7%9B%D7%98%D7%A8\" title=\"אהרן יצחק לייכטר\">אהרן יצחק לייכטר</a>, מ<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שלוחי</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ל<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> – הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%91%D7%99%D7%A1%D7%98%D7%A8%D7%99%D7%A6%D7%A7%D7%99\" title=\"לוי ביסטריצקי\">לוי ביסטריצקי</a>, <a href=\"/index.php/%D7%9E%D7%A8%D7%90_%D7%93%D7%90%D7%AA%D7%A8%D7%90\" class=\"mw-redirect\" title=\"מרא דאתרא\">רב</a> העיר <a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a> ו<a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">משלוחי הרבי לארץ הקודש</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ט במנחם אב - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>המתפללים בארבעה זוגות <a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"תפילין\">תפילין</a> כך נוהגים: א) מניחים תפילין של יד ותפילין של ראש ה<a href=\"/index.php/%D7%A8%D7%A9%22%D7%99\" title=\"רש&quot;י\">רש\"י</a> קודם אמירת פרק \"<a href=\"/index.php/%D7%90%D7%99%D7%96%D7%94%D7%95_%D7%9E%D7%A7%D7%95%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"איזהו מקומן\">איזהו</a>\", ומתפללים בהם עד אחרי \"<a href=\"/index.php/%D7%90%D7%9C_%D7%AA%D7%99%D7%A8%D7%90\" title=\"אל תירא\">אך צדיקים</a>\" גו'. ב) מסירים תפילין של ראש דרש\"י, ומניחים - בלא ברכה - תפילין של ראש דשמושא רבא וקוראים \"שמע\" גו' עד \"אמת\" ואומרים מזמורי <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D\" title=\"תהלים\">תהלים</a> כפי שנחלק לימי החודש והמהדרים היו לומדים אותם עם פירש\"י ומצודות. ג) אחר כך מניחים תפלין ד<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%AA%D7%9D\" title=\"רבינו תם\">רבינו תם</a> - בלא ברכה - וקוראים \"שמע\" גו' עד \"אמת\", פרשת \"קדש\" גו' ו<a href=\"/index.php/%D7%A9%D7%A9_%D7%96%D7%9B%D7%99%D7%A8%D7%95%D7%AA\" title=\"שש זכירות\">הזכירות</a> שנדפסו ב<a href=\"/index.php/%D7%A1%D7%99%D7%93%D7%95%D7%A8\" title=\"סידור\">סידור</a> ולומדים פרק <a href=\"/index.php/%D7%9E%D7%A9%D7%A0%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"משניות\">משניות</a> כל אחד לפי הבנתו. ד) מסירים תפילין של ראש דרבינו תם ומניחים תפילין של ראש דראב\"ד - בלא ברכה - וקוראים \"שמע\" גו' עד \"אמת\" ולומדים פרשה <a href=\"/index.php/%D7%97%D7%95%D7%9E%D7%A9_(%D7%A1%D7%A4%D7%A8)\" title=\"חומש (ספר)\">חומש</a> עם פירוש רש\"י - מפרשת השבוע: יום א' עד שני ביום ב' פרשה ב' וכו'\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413214602\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.030 seconds\nReal time usage: 0.251 seconds\nPreprocessor visited node count: 91/1000000\nPost‐expand include size: 7201/2097152 bytes\nTemplate argument size: 680/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  123.685      1 -total\n 50.68%   62.678      1 תבנית:חודש_אב\n 40.48%   50.073      1 תבנית:להיום_יום\n 25.66%   31.743      1 תבנית:היום_יום/י&quot;ט_מנחם_אב\n 24.85%  