      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91_%D7%91%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%A0%D7%9B%D7%93%D7%95.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/ad/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91_%D7%91%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%A0%D7%9B%D7%93%D7%95.jpg/250px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91_%D7%91%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%A0%D7%9B%D7%93%D7%95.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/a/ad/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91_%D7%91%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%A0%D7%9B%D7%93%D7%95.jpg/375px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91_%D7%91%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%A0%D7%9B%D7%93%D7%95.jpg 1.5x, /images/thumb/a/ad/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91_%D7%91%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%A0%D7%9B%D7%93%D7%95.jpg/500px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91_%D7%91%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%A0%D7%9B%D7%93%D7%95.jpg 2x\" /></a><figcaption>(תשפ\"ג)</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%99_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e5/%D7%99%D7%95%D7%A1%D7%99_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91.jpg/250px-%D7%99%D7%95%D7%A1%D7%99_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91.jpg\" decoding=\"async\" width=\"250\" height=\"220\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e5/%D7%99%D7%95%D7%A1%D7%99_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91.jpg/375px-%D7%99%D7%95%D7%A1%D7%99_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91.jpg 1.5x, /images/e/e5/%D7%99%D7%95%D7%A1%D7%99_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91.jpg 2x\" /></a><figcaption>בראיון באולפני <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%D7%AA_%D7%94%D7%A9%D7%9D_(%D7%99%D7%A9%D7%A8%D7%90%D7%9C)\" title=\"צבאות השם (ישראל)\">צבאות השם</a> (תשע\"ד)</figcaption></figure>\n<p>הרב <b>יוסף יצחק ליברוב</b> (<b>ליבעראוו</b>, יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a>, 1955) הוא מ<a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"שלוחי הרבי לארץ הקודש\">שלוחי הרבי לארץ הקודש</a>, ומנהל <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7\" title=\"מכון לוי יצחק\">מכון לוי יצחק</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%A9%D7%91%D7%99%D7%A2%D7%99_%D7%A9%D7%9C_%D7%A4%D7%A1%D7%97\" title=\"שביעי של פסח\">שביעי של פסח</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a> לאביו הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91\" title=\"חיים שמואל מנחם מענדל ליברוב\">חיים שמואל מנחם מענדל ליברוב</a> ולאמו דאברושא. מצד אימו, הוא נכדו הגדול של ה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ר' <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%95%D7%98%D7%A8%D7%A4%D7%A1\" title=\"מנחם מענדל פוטרפס\">מענדל פוטערפאס</a>.\n</p><p>בח' אלול תשל\"א התייתם מאימו שנפטרה בתאונת דרכים ל\"ע. \n</p><p>בצעירותו, למד בישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90\" class=\"mw-redirect\" title=\"תומכי תמימים ברינוא\">תומכי תמימים ברינוא</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A8%D7%99%D7%A1%D7%98%D7%95%D7%9F\" title=\"תומכי תמימים מוריסטון\">מוריסטון</a> ובשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a> הגיע ללמוד בישיבה המרכזית ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a> נכלל בקבוצת <a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">השלוחים לארץ הקודש</a> לעיר ירושלים. הקבוצה נשלחה באופן אישי על ידי הרבי לחזק את הפעילות החב\"דית בארץ, ולאחר סיום מסלול לימודיו <a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9F\" title=\"נישואין\">נישא</a> לרעייתו אידא, בתו של הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8\" title=\"מרדכי אליהו שניאור\">מרדכי אליהו שניאור</a>- ממשפיעה המיתולגים של הישיבה בלוד.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a> החל לנהל את <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7\" title=\"מכון לוי יצחק\">מכון לוי יצחק</a> הפועל להפצת תורתו של הרבי בתרגום ל<a href=\"/index.php/%D7%9C%D7%A9%D7%95%D7%9F_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"לשון הקודש\">לשון הקודש</a> באמצעות תרגום השיחות שנדפסו במקורן ב<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a> והפצתם בעברית, והחל בתרגום השיחות שב<a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%A9%D7%99%D7%97%D7%95%D7%AA\" title=\"לקוטי שיחות\">לקוטי שיחות</a> לפי הסדר.\n</p><p>לאחר <a href=\"/index.php/%D7%94%D7%A1%D7%AA%D7%9C%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הסתלקות\">הסתלקות</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%97%D7%99%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%90\" class=\"mw-redirect\" title=\"הרבנית חיה מושקא\">הרבנית חיה מושקא</a>, בשנת תשמ\"ח, יזם את הוצאת סדרת הספרים <a href=\"/index.php/%D7%9E%D7%A2%D7%99%D7%9F_%D7%97%D7%99\" class=\"mw-redirect\" title=\"מעין חי\">מעין חי</a> - שיחות של הרבי מעובדות באופן מתאים גם לילדים.\n</p><p>המבוגר הראשון שהחל לחבוש <a href=\"/index.php/%D7%9B%D7%99%D7%A4%D7%AA_%D7%99%D7%97%D7%99\" title=\"כיפת יחי\">כיפת יחי</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a>.\n</p><p>גם אחרי <a href=\"/index.php/%D7%92%27_%D7%AA%D7%9E%D7%95%D7%96_%D7%AA%D7%A9%D7%A0%22%D7%93\" class=\"mw-redirect\" title=\"ג&#39; תמוז תשנ&quot;ד\">ג' תמוז</a> המשיך בפירסום האמונה הטהורה ב<a href=\"/index.php/%D7%A0%D7%A6%D7%97%D7%99%D7%95%D7%AA_%D7%97%D7%99%D7%99%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" title=\"נצחיות חייו של הרבי\">נצחיות חייו של הרבי </a> והתגשמות <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%9B%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"הרבי כמלך המשיח\">נבואת הגאולה</a>, ואף השתתף ב<a href=\"/index.php/%D7%9B%D7%99%D7%A0%D7%95%D7%A1%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97_-_%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"כינוסי גאולה ומשיח - תשנ&quot;ה\">כינוסי גאולה ומשיח</a> שהתקיימו בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> לחיזוק האמונה ב<a href=\"/index.php/%D7%A0%D7%A6%D7%97%D7%99%D7%95%D7%AA_%D7%97%D7%99%D7%99%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" title=\"נצחיות חייו של הרבי\">נצחיות חייו של הרבי</a> ופרסום זהותו <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%9E%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%9B%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"הרבי מליובאוויטש כמלך המשיח\">כמלך המשיח</a>.\n</p><p>הרב ליבעראוו מתגורר וממשפיעי בית הכנסת ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_%D7%91%27\" title=\"כפר חב&quot;ד ב&#39;\">כפר חב\"ד ב'</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<dl><dt>בניו</dt>\n<dd></dd></dl>\n<ul><li>הרב שניאור זלמן ליבעראוו - <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a></li>\n<li>ישראל אריה לייב (ארי) ליבעראוו - <a href=\"/index.php/%D7%99%D7%A4%D7%95\" class=\"mw-redirect\" title=\"יפו\">יפו</a> - <a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a></li>\n<li>הרב משה סעדי' ליבעראוו - מלמד ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94\" title=\"תלמוד תורה\">תלמוד תורה</a> <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>,</li>\n<li>ר' מאיר שלמה ליבעראוו - <a href=\"/index.php?title=%D7%A6%D7%95%D7%A8%D7%99%D7%90%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"צוריאל (הדף אינו קיים)\">צוריאל</a></li>\n<li>ר' לוי ליבעראוו - מנהל סניף מאוחדת באחיעזר -<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a> אחיסמך</li></ul>\n<dl><dt>חתניו</dt>\n<dd></dd></dl>\n<ul><li>הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%94%D7%A2%D7%A0%D7%93%D7%9C\" class=\"mw-redirect\" title=\"שלום דובער הענדל\">שלום דובער הענדל</a> ראש ישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים אור יהודה\">תומכי תמימים</a> ומשלוחי הרבי ב<a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" title=\"אור יהודה\">אור יהודה</a></li>\n<li>ר' שרגא מרזל- <a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a></li>\n<li>ר' אלחנן צייגר <a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a> אחיסמך</li>\n<li>ר' דניאל עמאר-בני ברק.</li>\n<li>ר' יהונתן הלוי בייץ' <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a></li>\n<li>