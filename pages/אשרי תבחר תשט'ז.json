9%D7%9E%D7%97_%D7%AA%D7%A9%D7%9E%D7%97_%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"המשך שמח תשמח תרנ&quot;ז\">המשך שמח תשמח תרנ\"ז</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%A8%D7%A0%22%D7%98\" class=\"mw-redirect\" title=\"המשך רנ&quot;ט\">המשך רנ\"ט</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91_%D7%A9%D7%9C_%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94_%D7%AA%D7%A8%D7%A1%22%D7%95\" title=\"המשך יום טוב של ראש השנה תרס&quot;ו\">המשך תרס\"ו</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%A9%D7%A2%D7%94_%D7%A9%D7%94%D7%A7%D7%93%D7%99%D7%9E%D7%95_%D7%AA%D7%A2%D7%A8%22%D7%91\" title=\"בשעה שהקדימו תער&quot;ב\">המשך תער\"ב</a> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%AA%D7%A9%D7%A8%D7%99_%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"המשך תשרי תשכ&quot;ג\">המשך תשרי תשכ\"ג</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #33cccc;\"><font size=\"2\">מושגים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%94%D7%9B%D7%A0%D7%94_%D7%9C%D7%9E%D7%90%D7%9E%D7%A8\" class=\"mw-redirect\" title=\"ניגון הכנה למאמר\">ניגון הכנה למאמר</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C\" title=\"דיבור המתחיל\">דיבור המתחיל</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%99%D7%90%D7%99%D7%A8_%D7%A0%D7%AA%D7%99%D7%91_(%D7%9E%D7%95%D7%A9%D7%92)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יאיר נתיב (מושג) (הדף אינו קיים)\">יאיר נתיב</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%99%D7%9B%D7%9C%D7%90%D7%9A\" title=\"ביכלאך\">ביכלאך</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%9C%D7%AA%D7%99_%D7%9E%D7%95%D7%92%D7%94\" title=\"בלתי מוגה\">בלתי מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9E%D7%95%D7%92%D7%94\" title=\"מוגה\">מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשך</a>\n</td></tr>\n</tbody></table>\n<p><b>אשרי תבחר תשט\"ז</b> הוא <a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C\" title=\"דיבור המתחיל\">דיבור המתחיל</a> של <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמר</a> מאת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> הפותח במילות הפסוק \"אשרי תבחר ותקרב\" (פסוק זה נאמר במהלך הברית על ידי ה<a href=\"/index.php/%D7%9E%D7%95%D7%94%D7%9C\" class=\"mw-redirect\" title=\"מוהל\">מוהל</a>), ונהוג לחזור על מאמר זה ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%9E%D7%99%D7%9C%D7%94\" title=\"ברית מילה\">ברית מילה</a>. \n</p>\n<h2><span id=\".D7.90.D7.9E.D7.99.D7.A8.D7.AA_.D7.94.D7.9E.D7.90.D7.9E.D7.A8_.D7.95.D7.94.D7.93.D7.A4.D7.A1.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"אמירת_המאמר_והדפסתו\">אמירת המאמר והדפסתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אמירת המאמר והדפסתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אמירת המאמר והדפסתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>המאמר נאמר במקורו לרב <a href=\"/index.php/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%99%D7%9C%D7%A1\" title=\"אפרים אליעזר ילס\">אפרים אליעזר ילס</a> בליל ה<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ברית\">ברית</a> של נכדו ב<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> פרטית בחדרו של הרבי בחודש <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a>.\n</p><p>לאחר ה<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> כתב הרב יאלעס את ראשי פרקים מהמאמר הטרי, ובהמשך נערך ונדפס המאמר ב<a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%9E%D7%90%D7%9E%D7%A8%D7%99%D7%9D\" class=\"mw-redirect mw-disambig\" title=\"ספר המאמרים\">ספר המאמרים</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a> (בהוצאת '<a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9B%D7%AA%D7%91%D7%99_%D7%A7%D7%95%D7%93%D7%A9\" title=\"ועד כתבי קודש\">ועד כתבי קודש</a>').\n</p><p>לקראת <a href=\"/index.php/%D7%97%22%D7%99_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ח&quot;י ניסן\">ח\"י ניסן</a> <a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> בעת מלאות שמונים ותשע שנה לברית של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> נערך המאמר פעם נוספת באריכות, הוגה על ידי הרבי, ונדפס בקונטרס ח\"י <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> <a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> לאחר מכן ונדפס ב<a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%9E%D7%90%D7%9E%D7%A8%D7%99%D7%9D_%D7%9E%D7%9C%D7%95%D7%A7%D7%98\" class=\"mw-redirect\" title=\"ספר המאמרים מלוקט\">ספר המאמרים מלוקט</a> חלק ה'.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9B.D7.9F_.D7.94.D7.9E.D7.90.D7.9E.D7.A8\"></span><span class=\"mw-headline\" id=\"תוכן_המאמר\">תוכן המאמר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;תוכן המאמר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: תוכן המאמר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"plainlinks\" style=\"border: 1px solid #ddd;font-size:smaller; text-align: right; padding:5px 1em 5px 1em; width: auto;\">\n<span typeof=\"mw:File\"><span><img src=\"/images/thumb/3/34/Gnome-colors-edit-find-replace.svg/25px-Gnome-colors-edit-find-replace.svg.png\" decoding=\"async\" width=\"25\" height=\"25\" class=\"mw-file-element\" srcset=\"/images/thumb/3/34/Gnome-colors-edit-find-replace.svg/38px-Gnome-colors-edit-find-replace.svg.png 1.5x, /images/thumb/3/34/Gnome-colors-edit-find-replace.svg/50px-Gnome-colors-edit-find-replace.svg.png 2x\" /></span></span> פרק זה טעון <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A9%D7%9B%D7%AA%D7%95%D7%91_%D7%95%D7%A2%D7%A8%D7%99%D7%9B%D7%94\" class=\"mw-redirect\" title=\"חב&quot;דפדיה:שכתוב ועריכה\">שכתוב</a>. אנא <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%A8%D7%95%D7%9B%D7%99%D7%9D_%D7%94%D7%91%D7%90%D7%99%D7%9D#כתיבה_לחב&quot;דפדיה\" title=\"חב&quot;דפדיה:ברוכים הבאים\">תרמו</a> לחב\"דפדיה <a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php?title=%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96&amp;action=edit\">ועזרו לשכתב אותו</a>.  </div>\n<p>המאמר פותח בפסוק \"אשרי תבחר ותקרב ישכון חצריך נשבעה בטוב ביתך קדוש היכלך\" שנהוג שהמוהל אומר אותו במהלך ה<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ברית\">ברית</a>, הרבי מבאר את הקשר של הפסוק לברית ומסביר שהפסוק מונה ד' ענינים: שני חצרות (חצריך לשון רבים) - חצר שאינה מקורה וחצר מקורה, ביתך והיכל, ומסביר שד' דרגות אלו נמצאים גם באדם ובעולמות, באדם הם בירור <a href=\"/index.php/%D7%A0%D7%A4%D7%A9_%D7%94%D7%91%D7%94%D7%9E%D7%99%D7%AA\" class=\"mw-redirect\" title=\"נפש הבהמית\">נפש הבהמית</a>, ששמירתה הוא ע\"י חצר שאינה מקורה, ו<a href=\"/index.php/%D7%A0%D7%A4%D7%A9_%D7%94%D7%A9%D7%9B%D7%9C%D7%99%D7%AA\" title=\"נפש השכלית\">נפש השכלית</a> שדומה לעוף, צריכה שמירה גדולה יותר שמרומזת בחצר מקורה.\n</p><p>וזהו גם ענין הביטול בנפש הבהמית ושכלית, \"ביתך והיכלך\" זהו ב' מדרגות בביטול ב<a href=\"/index.php/%D7%A0%D7%A4%D7%A9_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA\" class=\"mw-redirect\" title=\"נפש האלוקית\">נפש האלוקית</a> הכוחות של הנפש כפי שמתלבשות בנפש הבהמית, והם בביטול היש וכפי שהם מצד עצמם ביטול במציאות, וכן בעולמות: עולמות <a href=\"/index.php/%D7%A2%D7%A9%D7%99%D7%94\" class=\"mw-redirect\" title=\"עשיה\">עשיה</a> ו<a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"יצירה\">יצירה</a> הם מציאות, ועולם ה<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%90%D7%94\" class=\"mw-redirect\" title=\"בריאה\">בריאה</a> הוא אפשרות המציאות ועולם ה<a href=\"/index.php/%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אצילות\">אצילות</a> הוא בביטול לאלוקות ברמה שאין שום אפשרות למציאות אחרת, והסיבה לחילוק בין העולמות נובעת מהדרגות ברמות הביטול שלהם, שבעולמות <a href=\"/index.php/%D7%A2%D7%A9%D7%99%D7%94\" class=\"mw-redirect\" title=\"עשיה\">עשיה</a> ו<a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"יצירה\">יצירה</a> הביטול הוא <a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C_%D7%94%D7%99%D7%A9\" class=\"mw-redirect\" title=\"ביטול היש\">ביטול היש</a>, ובעולמות <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%90%D7%94\" class=\"mw-redirect\" title=\"בריאה\">בריאה</a> ו<a href=\"/index.php/%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אצילות\">אצילות</a> הביטול הוא <a href=\"/index.php/%D7%91%D7%99%D7%98%D7%95%D7%9C_%D7%91%D7%9E%D7%A6%D7%99%D7%90%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ביטול במציאות\">ביטול במציאות</a>, ולכן נהוג לומר את הפסוק הזה לפני הברית, מכיוון שברית מילה היא המשכה שלמעלה מהשתלשלות, ובשביל המשכה זו צריך את שלימות השתלשלות (כמו שמתבטאת בפסוק \"אשרי תבחר ותקרב)\".\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%22%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://chabadlibrary.org/books/default.aspx?furl=/admur/mlukat/3/24\">המאמר בגרסת טקסט</a></b> באתר <a href=\"/index.php/%D7%A1%D7%A4%D7%A8%D7%99%D7%99%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"ספריית ליובאוויטש\">ספריית ליובאוויטש</a></li>\n<li>[מפגש עם הנכד שלכבודו נאמר המאמר <a rel=\"nofollow\" class=\"external free\" href=\"http://www.shturem.net/index.php?section=news&amp;id=96635\">http://www.shturem.net/index.php?section=news&amp;id=96635</a>] <span class=\"grayText\"><small>(הקישור אינו פעיל)</small></span></li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%A1%D7%A3_%D7%97%D7%A0%D7%95%D7%9A_%D7%A4%D7%A8%D7%95%D7%9E%D7%A8\" title=\"אסף חנוך פרומר\">אסף חנוך פרומר</a>, <a href=\"/images/b/b3/%D7%90%D7%A9%D7%A8%D7%99_%D7%AA%D7%91%D7%97%D7%A8_%D7%AA%D7%A9%D7%98%27%27%D7%96_-_%D7%9E%D7%90%D7%9E%D7%A8_%D7%9E%D7%91%D7%95%D7%90%D7%A8.pdf\" class=\"internal\" title=\"אשרי תבחר תשט&#39;&#39;ז - מאמר מבואר.pdf\">המאמר</a> עם ביאור <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8_%D7%9E%D7%91%D7%95%D7%90%D7%A8\" title=\"מאמר מבואר\">מאמר מבואר</a> בהוצאת <a href=\"/index.php/%D7%90%D7%AA%22%D7%94_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" class=\"mw-redirect\" title=\"את&quot;ה העולמי\">את\"ה העולמי</a></li></ul>\n<!-- \nNewPP limit report\nCached time: 20260413221801\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.061 seconds\nReal time usage: 0.137 seconds\nPreprocessor visited node count: 190/1000000\nPost‐expand include size: 9578/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 3/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5480448/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  110.293      1 -total\n 83.49%   92.087      1 תבנית:לשכתב\n  9.39%   10.358      1 תבנית:קישור_שבור\n  6.87%    7.578      1 תבנית:מאמרי_רבותינו_נשיאינו\n  2.19%    2.418     36 תבנית:*\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:25272-0!canonical and timestamp 20260413221801 and revision id 828805. Rendering was triggered because: page-view\n -->\n</div>"
