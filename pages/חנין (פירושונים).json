    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>ОћОљОЮ ОћОфОЏОЋОЋОаОфОЮ Ою...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%97%D7%90%D7%A0%D7%99%D7%9F\" title=\"ОъОаОЌОЮ ОаОЌОЋОЮ ОЎОдОЌОД ОљОЎОЎОќОЎОД ОЌОљОаОЎОЪ\">ОъОаОЌОЮ ОаОЌОЋОЮ ОЎОдОЌОД ОљОЎОЎОќОЎОД ОЌОљОаОЎОЪ</a> - '<a href=\"/index.php/%D7%97%D7%95%D7%96%D7%A8\" title=\"ОЌОЋОќОе\">ОЌОЋОќОе</a>' ОъОфОДОЋОцОф <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"ОљОЊОъОЋ&quot;Ое ОћОљОъОдОбОЎ\">ОљОЊОъОЋ\"Ое ОћОљОъОдОбОЎ</a>, <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"ОљОЊОъОЋ&quot;Ое ОћОдОъОЌ ОдОЊОД\">ОљОЊОъОЋ\"Ое ОћОдОъОЌ ОдОЊОД</a> ОЋ<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"ОљОЊОъОЋ&quot;Ое ОћОъОћОе&quot;ОЕ\">ОљОЊОъОЋ\"Ое ОћОъОћОе\"ОЕ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%A7%D7%9C_%D7%97%D7%90%D7%A0%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ОЌОЎОЎОДОю ОЌОљОаОЎОЪ\">ОЌОЎОЎОДОю ОЌОљОаОЎОЪ</a> - ОъОфОюОъОЎОЊОЎ <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ</a>, ОњОЉОЎОе ОЌОАОЎОЊОЎ, ОћОъОъОъОЪ ОћОбОЎОДОеОЎ ОЕОю ОцОбОЋОюОЋОф ОЋОбОЊ ОћОћОдОюОћ ОЉ<a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%95\" title=\"ОЎОдОЎОљОф ОеОЋОАОЎОћ ОфОЕ&quot;ОЋ\">ОЎОдОЎОљОф ОеОЋОАОЎОћ ОфОЕ\"ОЋ</a>. <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"ОДОеОљОЋОЪ ОћОЎОЎОўОА\">ОДОеОљОЋОЪ ОћОЎОЎОўОА</a>.</li>\n<li>ОЉОаОЋ, ОћОеОЉ <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%97%D7%A0%D7%99%D7%9F\" title=\"ОЕОаОЎОљОЋОе ОќОюОъОЪ ОЎОдОЌОД ОЎОћОЋОЕОб ОЌОаОЎОЪ\">ОЕОаОЎОљОЋОе ОќОюОъОЪ ОЎОдОЌОД ОЎОћОЋОЕОб ОЌОаОЎОЪ</a> - ОЎОЋОЕОЉ ОеОљОЕ Оћ<a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9C%D7%94%D7%A4%D7%A6%D7%AA_%D7%A9%D7%99%D7%97%D7%95%D7%AA\" title=\"ОЋОбОЊ ОюОћОцОдОф ОЕОЎОЌОЋОф\">ОЋОбОЊ ОюОћОцОдОф ОЕОЎОЌОЋОф</a>. <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"ОДОеОљОЋОЪ ОћОЎОЎОўОА\">ОДОеОљОЋОЪ ОћОЎОЎОўОА</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%AA%D7%A8_%D7%97%D7%A0%D7%99%D7%9F\" title=\"ОЎОбОДОЉ ОљОюОфОе ОЌОаОЎОЪ\">ОЎОбОДОЉ ОљОюОфОе ОЌОаОЎОЪ</a> - ОъОЕОЋОъОеОЎ ОћОњОЌОюОф ОћОЎОћОЋОЊОЎОф ОЉ<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ОЉОеОЎОф ОћОъОЋОбОдОЋОф\">ОЉОеОЎОф ОћОъОЋОбОдОЋОф</a>. ОЋОюОљОЌОе ОъОЏОЪ <a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"ОњОЉОљОЎ\">ОњОЉОљОЎ</a> ОЉОЉОЎОф ОћОЏОаОАОф <a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ОаОЌОюОф ОЉОаОЎОъОЎОЪ\">ОъОеОЏОќ ОЌОЉ\"ОЊ ОфОю ОљОЉОЎОЉ (ОаОЌОюОф ОЉОаОЎОъОЎОЪ)</a>.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\"><img alt=\"ОцОЎОеОЋОЕОЋОаОЎОЮ\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>ОцОЎОеОЋОЕОЋОаОЎОЮ</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> ОќОћОЋ ОЊОБ <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"ОЌОЉ&quot;ОЊОцОЊОЎОћ:ОцОЎОеОЋОЕОЋОаОЎОЮ\">ОцОЎОеОЋОЕОЋОаОЎОЮ</a>, ОЕОъОўОеОфОЋ ОюОћОЉОЌОЎОЪ ОЉОЎОЪ ОбОеОЏОЎОЮ ОЕОЋОаОЎОЮ ОЉОбОюОЎ ОЕОЮ ОЊОЋОъОћ.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/42px-Gnome-searchtool.svg.png 2x\" /></a></span> ОљОЮ ОюОљ ОъОдОљОфОЮ ОЉОеОЕОЎОъОф ОћОцОЎОеОЋОЕОЋОаОЎОЮ ОљОф ОћОбОеОџ ОЕОћОфОЏОЋОЋОаОфОЮ ОљОюОЎОЋ, ОаОАОЋ:\n</p>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%93%D7%A4%D7%99%D7%9D_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C%D7%99%D7%9D_%D7%91/%D7%97%D7%A0%D7%99%D7%9F\" title=\"ОъОЎОЋОЌОЊ:ОЊОцОЎОЮ ОћОъОфОЌОЎОюОЎОЮ ОЉ/ОЌОаОЎОЪ\">ОЊОцОЎОЮ ОЕОЕОъОЮ ОъОфОЌОЎОю ОЉРђЮОЌОаОЎОЪРђю</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/intitle:%D7%97%D7%A0%D7%99%D7%9F%22\" title=\"ОъОЎОЋОЌОЊ:ОЌОЎОцОЋОЕ/intitle:ОЌОаОЎОЪ&quot;\">ОЊОцОЎОЮ ОЕОЕОъОЮ ОъОЏОЎОю РђЮОЌОаОЎОЪРђю</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/~%22%D7%97%D7%A0%D7%99%D7%9F%22\" title=\"ОъОЎОЋОЌОЊ:ОЌОЎОцОЋОЕ/~&quot;ОЌОаОЎОЪ&quot;\">ОЌОЎОцОЋОЕ РђЮОЌОаОЎОЪРђю ОЉОЌОЉ\"ОЊОцОЊОЎОћ</a></li></ul>\n</div>\n</td>\n</tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414042947\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.041 seco