      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"infobox\" style=\"width:20%; border: 1px solid #E4DB77; background-color: #F6F4D5; margin-bottom: 0.5em; margin-right: 1em; padding: 0.2em; color: black; float: left; text-align: center; font-size: 85%; clear:right;\">\n\n<tbody><tr style=\"background:lightblue;\">\n<th style=\"background-color: #E4DB77;\"><font size=\"4\"><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%AA_%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"שמות הוי&quot;ה\">שמותיו של הקב\"ה</a></font>\n</th></tr>\n\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">7 שמות שאינם נמחקים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94_(%D7%A9%D7%9D)\" title=\"הוי&quot;ה (שם)\">הוי\"ה</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A0%22%D7%99\" title=\"אדנ&quot;י\">אדנ\"י</a> · <a href=\"/index.php/%D7%90%22%D7%9C\" title=\"א&quot;ל\">א\"ל</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%99%D7%9D\" title=\"אלקים\">אלהי\"ם</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%22%D7%94\" class=\"mw-redirect\" title=\"אלו&quot;ה\">אלו\"ה</a> · <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%22%D7%AA\" class=\"mw-redirect\" title=\"צבאו&quot;ת\">צבאו\"ת</a> · <a href=\"/index.php/%D7%A9%D7%93%22%D7%99\" class=\"mw-redirect\" title=\"שד&quot;י\">שד\"י</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%AA_%D7%94%D7%95%D7%99%27_%D7%91%D7%9E%D7%99%D7%9C%D7%95%D7%90%D7%9D_(%D7%A2%22%D7%91_%D7%A1%22%D7%92_%D7%9E%22%D7%94_%D7%91%22%D7%9F)\" title=\"שמות הוי&#39; במילואם (ע&quot;ב ס&quot;ג מ&quot;ה ב&quot;ן)\">מילויים לשם הוי\"ה</a></font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A9%D7%9D_%D7%A2%22%D7%91\" title=\"שם ע&quot;ב\">שם ע\"ב</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%A1%22%D7%92\" title=\"שם ס&quot;ג\">שם ס\"ג</a> · <a href=\"/inde