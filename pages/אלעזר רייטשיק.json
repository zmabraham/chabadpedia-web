%A7_%D7%9C%D7%A6%D7%93_%D7%94%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%9E%D7%A1%D7%90%D7%98%D7%9E%D7%A8_%D7%9E%D7%94%D7%A8%22%D7%90.jpeg 2x\" /></a><figcaption>הרב רייטשיק וחתנו ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%90%D7%A4\" class=\"mw-redirect\" title=\"יוסי ראפ\">יוסי ראפ</a> משוחחים עם הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%98%D7%99%D7%99%D7%98%D7%9C%D7%91%D7%95%D7%99%D7%9D\" title=\"אהרן טייטלבוים\">אהרן טייטלבוים</a> האדמו\"ר מסאטמר אודות פעולותיו של הרב רייטשיק בעניני מקוואות</figcaption></figure>\n<p>הרב <b>אלעזר</b> הלוי <b>רייטשיק</b> הוא מומחה מקוואות עולמי, תושב שכונת <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9C%D7%95%D7%A1_%D7%90%D7%A0%D7%92%27%D7%9C%D7%A1\" title=\"לוס אנג&#39;לס\">לוס אנג'לס</a> שב<a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%A4%D7%95%D7%A8%D7%A0%D7%99%D7%94\" title=\"קליפורניה\">קליפורניה</a> לרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%93%D7%95%D7%93_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7\" title=\"מנחם שמואל דוד רייטשיק\">מנחם שמואל דוד רייטשיק</a>, השליח הראשון של הרבי במקום.\n</p><p>כבר כבחור, נמנה על המסייעים בהקמת הוועד לכתיבת ה<a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%AA%D7%95%D7%A8%D7%94_%D7%A9%D7%9C_%D7%99%D7%9C%D7%93%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"ספר תורה של ילדי ישראל\">ספר תורה של ילדי ישראל</a>.\n</p><p>כבחור היה אחראי של משמרות השמירה סביב ביתו של הרבי.\n</p><p>בחודש <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a> בא בקשרי הנישואין עם בת הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%9C%D7%96%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלום דובער גלזמן (הדף אינו קיים)\">שלום דובער גלזמן</a>.\n</p><p>לאחר החתונה קבע את מגוריו ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>, ונמנה על שמשי ב<a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%97%D7%91%22%D7%93_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99_-_770\" class=\"mw-redirect\" title=\"מרכז חב&quot;ד העולמי - 770\">מרכז חב\"ד העולמי - 770</a>.\n</p><p>לאורך השנים צבר התמחות רבה בהקמת <a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94\" title=\"מקווה\">מקוואות טהרה</a>, הן בהיבט ההלכתי והן בהיבט המעשי, ובדגש על שיטת אדמו\"ר הרש\"ב עם הפרטים השונים בהידורים הנובעים ממנה.\n</p><p>כחלק מפעולותיו ועיסוקו בנושא, הוציא לאור סדרת קונטרסים בשם 'תורת טבלין' (מלשון טבילה), המבררים ענינים שונים במקווה על פי שיטתו של אדמו\"ר הרש\"ב.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, ר' יוסף יצחק רייטשיק, קראון הייטס</li>\n<li>בנו, ר' אברהם רייטשיק, מאימי פלורידה</li>\n<li>חתנו, ר' שלום דובער הלר</li>\n<li>חתנו, ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%90%D7%A4\" class=\"mw-redirect\" title=\"יוסי ראפ\">יוסי ראפ</a></li></ul>\n<p>חתנו, גוראריה<sup><span class=\"clarification-needed\" style=\"cursor: help; font-size: 90%;\" title=\"מה השם פרטי\">[דרושה הבהרה]</span></sup>\n</p>\n<ul><li>חתנו, ר' יעקב יוסף גולדשטיין, קראון הייטס</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>תורת טבלין: <a rel=\"nofollow\" class=\"external text\" href=\"https://files.anash.org/uploads/2019/11/%D7%AA%D7%95%D7%A8%D7%AA-%D7%98%D7%91%D7%9C%D7%99%D7%9F.pdf\">חלק ב' - חשוון תש\"פ</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/uploads/original/2022/12/63907c5e35b49_1670413406.pdf\">חלק ג' - מנחם אב תשפ\"ב</a></b><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">חלק א' נדפס בחודש כסלו תשע\"א.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413162853\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.071 seconds\nReal time usage: 0.957 seconds\nPreprocessor visited node count: 122/1000000\nPost‐expand include size: 954/2097152 bytes\nTemplate argument size: 113/2097152 bytes\nHighest expansion depth: 7/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 398/5000000 bytes\nLua time usage: 0.030/7 seconds\nLua virtual si