"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בחשוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בחשוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בחשוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בחשוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ל&#39; בחשוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י' בחשוון</b> הוא היום העשירי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חודש חשוון</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>א'תרנו (-2105 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - מתושלח נפטר ובעקבות כך המבול נדחה בשבעה ימים.</li>\n<li>ב'קצ\"ח (-1563 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%92%D7%93\" title=\"גד\">גד</a> בן <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"יעקב אבינו\">יעקב אבינו</a>, נולד.</li>\n<li>ב'שכ\"א (-1440 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%92%D7%93\" title=\"גד\">גד</a> בן <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"יעקב אבינו\">יעקב אבינו</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%99\" title=\"תק&quot;י\">תק\"י</a> (22/10/1749 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי אריה לייב אויערבך מסטניסלב, מחבר 'נחלת אריה', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%98\" title=\"תרפ&quot;ט\">תרפ\"ט</a> (24/10/1928 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי מנחם מנדל מנדלסון, ראש ישיבת פלוצק, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%95\" title=\"תשכ&quot;ו\">תשכ\"ו</a> (5/11/1965 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%93%D7%95%D7%91_%D7%91%D7%A2%D7%A8%D7%99%D7%A9_%D7%95%D7%99%D7%93%D7%A0%D7%A4%D7%9C%D7%93\" title=\"דוב בעריש וידנפלד\">דוב בעריש וידנפלד</a> (הגאון מצ'בין), ראש ישיבת 'כוכב מיעקב' ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, ממנהיגי היהדות החרדית בדור התקומה ומראשי מועצת גדולי התורה בארץ ישראל, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%94\" title=\"תקצ&quot;ה\">תקצ\"ה</a> - <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%A8%D7%91%D7%A7%D7%94\" class=\"mw-redirect\" title=\"הרבנית רבקה\">הרבנית רבקה</a>, אשת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"הרבי המהר&quot;ש\">הרבי המהר\"ש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> (12/11/1910 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%99%D7%A6%D7%97%D7%A7_%D7%96%D7%A2%D7%9C%D7%99%D7%92_%D7%94%D7%9C%D7%A4%D7%A8%D7%99%D7%9F\" title=\"ישראל יצחק זעליג הלפרין\">ישראל יצחק זעליג הלפרין</a>, חסיד <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, וממייסדי סניף <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"צעירי אגודת חב&quot;ד בישראל\">צא\"ח</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a> (27/10/1982 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A0%D7%97_%D7%91%D7%9C%D7%A0%D7%99%D7%A6%D7%A7%D7%99\" class=\"mw-redirect\" title=\"ישראל נח בלניצקי\">ישראל נח בלניצקי</a>, מנהל ישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%9E%D7%A0%D7%A6%27%D7%95%D7%92\" class=\"mw-redirect\" title=\"תומכי תמימים קרמנצ&#39;וג\">תומכי תמימים קרמנצ'וג</a>, <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"תומכי תמימים סמרקנד\">סמרקנד</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" title=\"תומכי תמימים ברינואה\">ברינואה</a>, ומחשובי המשפיעים ב<a href=\"/index.php/%D7%94%D7%93%D7%95%D7%A8_%D7%94%D7%A9%D7%91%D7%99%D7%A2%D7%99\" class=\"mw-redirect\" title=\"הדור השביעי\">דור השביעי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> (20/10/1999 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%A9%D7%9C%D7%9E%D7%94_%D7%92%D7%A8%D7%A9%D7%95%D7%91%D7%99%D7%A5\" title=\"דוד שלמה גרשוביץ\">דוד שלמה גרשוביץ</a>, פרטיזן שלחם בנאצים ב<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%99%D7%94\" title=\"מלחמת העולם השנייה\">מלחמת העולם השנייה</a>, ומראשוני המתיישבים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a> (5/11/2003 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%A8%D7%99%D7%94_%D7%A9%D7%98%D7%A8%D7%9F\" title=\"משה אריה שטרן\">משה אריה שטרן</a>, מחנך ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תלמוד תורה מגדל העמק\">תלמוד תורה מגדל העמק</a> ורב כלא דמון בצפון הארץ.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י' בחשוון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>דער <a href=\"/index.php/%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"רבי\">רבי</a> (<a href=\"/index.php/%D7%A8%D7%91%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבנו הזקן\">רבנו הזקן</a>) פלעגט זאגען אויף <a href=\"/index.php/%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אצילות\">אצילות</a> \"אויבען\". מען דערציילט אז אין כתב פלעגט ער פון התרגשות, מער ווי \"אצי\" ניט קענען אנשרייבען.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: הרבי (<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a>) היה אומר על <a href=\"/index.php/%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אצילות\">אצילות</a> \"למעלה\". מספרים, שבכתב, מ<a href=\"/index.php?title=%D7%94%D7%AA%D7%A8%D7%92%D7%A9%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"התרגשות (הדף אינו קיים)\">התרגשות</a>, יותר מ\"אצי\" הוא לא היה יכול לכתוב.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414065045\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.028 seconds\nReal time usage: 0.077 seconds\nPreprocessor visited node count: 103/1000000\nPost‐expand include size: 5456/2097152 bytes\nTemplate argument size: 599/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   47.638      1 -total\n 35.21%   16.773      1 תבנית:חודש_חשוון\n 33.81%   16.105      1 תבנית:להיום_יום\n 30.42%   14.491      1 תבנית:ה\n 25.21%   12.011      1 תבנית:לוח_שנה\n  9.88%    4.709      1 תבנית:היום_יום/י&#039;_חשוון\n  9.46%    4.508      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19415-0!canonical and timestamp 20260414065045 and revision id 548576. Rendering was triggered because: page-view\n -->\n</div>"
