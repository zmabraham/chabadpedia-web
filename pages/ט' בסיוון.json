%95%D7%9F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ט' בסיוון</b> הוא היום התשיעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">חודש סיוון</a>.\n</p>\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>תמ\"ד – רבי משה רבקש, מחבר ספר 'באר הגולה', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%98\" title=\"תקצ&quot;ט\">תקצ\"ט</a> – רבי ישראל משקלוב, מנהיג עליית תלמידי <a href=\"/index.php/%D7%94%D7%92%D7%A8%22%D7%90\" class=\"mw-redirect\" title=\"הגר&quot;א\">הגר\"א</a> ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a> ומחבר הספר 'פאת השולחן', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%92\" title=\"תרל&quot;ג\">תרל\"ג</a> – רבי יצחק אייזיק, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php?title=%D7%96%D7%99%D7%93%D7%99%D7%98%D7%A9%D7%95%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"זידיטשוב (הדף אינו קיים)\">זידיטשוב</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%98\" title=\"תרל&quot;ט\">תרל\"ט</a> – רבי אהרן קונוורטי, ראש ישיבת המקובלים 'בית אל' ומחבר הספר 'כפי אהרן', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%98\" title=\"תרצ&quot;ט\">תרצ\"ט</a> – רבי יעקב חיים סופר, יליד בבל רבתי ועלה לירושלים, מחבר הספרים 'החפץ בחיים', 'חיים עד העולם' 'קול יעקב' 'כף החיים' 'באר מים חיים', ועוד, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%91_%D7%91%D7%A2%D7%A8_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"שלום דב בער גוראריה\">שלום דב בער גוראריה</a>, משלוחי הרבי ביוהנסבורג ומרבני חב\"ד בדרום אפריקה.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ט' בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>די וועלט דארף האבען טהרת האויר. טהרת האויר איז נאר דורך <a href=\"/index.php/%D7%90%D7%95%D7%AA%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אותיות\">אותיות</a> ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>. די אותיות שבתורה זיינען א שמירה כללית און א שמירה פרטית. חלוקת השתא סדרי משנה (בעל-פה) איז א \"ובלכתך בדרך\"'דיקער. די משנה וואס מען וועט חזר'ן וואו מען וועט זיין, אין וואס פאר א פלאץ מען וועט זיין, וועט מען באלייכטען די פארבינדונג פון ישראל מיט קוב\"ה. משנה איז אותיות <a href=\"/index.php/%D7%A0%D7%A9%D7%9E%D7%94\" class=\"mw-redirect\" title=\"נשמה\">נשמה</a>. עס איז זייער שווער צו געפינען די ווערטער אויסצודריקען דעם גרעסטען תועלת בעזה\"י אין דער שמירה כללית און דער שמירה פרטית, וואס דער כסדר'דיגער חזר'ן משניות וועט בעזה\"י בריינגען. און עס פעלען אויס די ווערטער צו באשרייבען דעם גרויסען נחת רוח, וואס מען וועט פארשאפען דעם בורא עולם ברוך הוא.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: ה<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D\" class=\"mw-redirect mw-disambig\" title=\"עולם\">עולם</a> זקוק לטהרת ה<a href=\"/index.php/%D7%90%D7%95%D7%99%D7%A8\" title=\"אויר\">אויר</a>. טהרת האויר היא רק על ידי <a href=\"/index.php/%D7%90%D7%95%D7%AA%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אותיות\">אותיות</a> ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>. האותיות שבתורה הינם שמירה כללית ושמירה פרטית. חלוקת הששה סדרי <a href=\"/index.php/%D7%9E%D7%A9%D7%A0%D7%94\" title=\"משנה\">משנה</a> (בעל פה) היא \"ובלכתך בדרך\". המשנה שיחזרו היכן שימצאו, ובכל מקום שרק ימצאו, תאיר את הקשר של ישראל עם קודשא בריך הוא. משנה היא אותיות <a href=\"/index.php/%D7%A0%D7%A9%D7%9E%D7%94\" class=\"mw-redirect\" title=\"נשמה\">נשמה</a>. קשה מאוד למצוא את המילים לבטא את התועלת הגדולה בעזרת השם יתברך בשמירה הכללית ובשמירה הפרטית, שתביא בעזה\"י חזרת משניות כסדר. וחסרות המילים בשביל לכתוב את גדול הנחת רוח, שיגרם לבורא העולם ברוך הוא.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413211222\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.023 seconds\nReal time usage: 0.029 seconds\nPreprocessor visited node count: 78/1000000\nPost‐expand include size: 8485/2097152 bytes\nTemplate argument size: 557/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   11.800      1 -total\n 64.45%    7.605      1 תבנית:חודש_סיוון\n 46.96%    5.542      1 תבנית:לוח_שנה\n 34.08%    4.021      1 תבנית:להיום_יום\n 18.79%    2.217      1 תבנית:כתב_קטן\n 14.33%    1.691      1 תבנית:היום_יום/ט&#039;_סיון\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:22548-0!canonical and timestamp 20260413211222 and revision id 834816. Rendering was triggered because: page-view\n -->\n</div>"
