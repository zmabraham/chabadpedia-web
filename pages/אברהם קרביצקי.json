      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%AA%D7%A9%D7%A4%22%D7%95_%D7%91%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%9C%D7%91%D7%A0%D7%95.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/48/%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%AA%D7%A9%D7%A4%22%D7%95_%D7%91%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%9C%D7%91%D7%A0%D7%95.jpg/220px-%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%AA%D7%A9%D7%A4%22%D7%95_%D7%91%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%9C%D7%91%D7%A0%D7%95.jpg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/4/48/%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%AA%D7%A9%D7%A4%22%D7%95_%D7%91%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%9C%D7%91%D7%A0%D7%95.jpg/330px-%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%AA%D7%A9%D7%A4%22%D7%95_%D7%91%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%9C%D7%91%D7%A0%D7%95.jpg 1.5x, /images/thumb/4/48/%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%AA%D7%A9%D7%A4%22%D7%95_%D7%91%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%9C%D7%91%D7%A0%D7%95.jpg/440px-%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%AA%D7%A9%D7%A4%22%D7%95_%D7%91%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%9C%D7%91%D7%A0%D7%95.jpg 2x\" /></a><figcaption>הרב קרביצקי (משמאל) לצד הרב <a href=\"/index.php/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"טוביה זילברשטרום\">טוביה זילברשטרום</a> (<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a>)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%A2%D7%A8%D7%99%D7%9B%D7%AA_%D7%94%D7%92%D7%A8%D7%9C%D7%94_%D7%91%D7%9B%D7%95%D7%9C%D7%9C_%D7%91%D7%A8%D7%90%D7%A9%D7%95%D7%AA%D7%95.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/81/%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%A2%D7%A8%D7%99%D7%9B%D7%AA_%D7%94%D7%92%D7%A8%D7%9C%D7%94_%D7%91%D7%9B%D7%95%D7%9C%D7%9C_%D7%91%D7%A8%D7%90%D7%A9%D7%95%D7%AA%D7%95.jpg/220px-%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%A2%D7%A8%D7%99%D7%9B%D7%AA_%D7%94%D7%92%D7%A8%D7%9C%D7%94_%D7%91%D7%9B%D7%95%D7%9C%D7%9C_%D7%91%D7%A8%D7%90%D7%A9%D7%95%D7%AA%D7%95.jpg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/8/81/%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%A2%D7%A8%D7%99%D7%9B%D7%AA_%D7%94%D7%92%D7%A8%D7%9C%D7%94_%D7%91%D7%9B%D7%95%D7%9C%D7%9C_%D7%91%D7%A8%D7%90%D7%A9%D7%95%D7%AA%D7%95.jpg/330px-%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%A2%D7%A8%D7%99%D7%9B%D7%AA_%D7%94%D7%92%D7%A8%D7%9C%D7%94_%D7%91%D7%9B%D7%95%D7%9C%D7%9C_%D7%91%D7%A8%D7%90%D7%A9%D7%95%D7%AA%D7%95.jpg 1.5x, /images/thumb/8/81/%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%A2%D7%A8%D7%99%D7%9B%D7%AA_%D7%94%D7%92%D7%A8%D7%9C%D7%94_%D7%91%D7%9B%D7%95%D7%9C%D7%9C_%D7%91%D7%A8%D7%90%D7%A9%D7%95%D7%AA%D7%95.jpg/440px-%D7%94%D7%A8%D7%91_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99_%D7%91%D7%A2%D7%A8%D7%99%D7%9B%D7%AA_%D7%94%D7%92%D7%A8%D7%9C%D7%94_%D7%91%D7%9B%D7%95%D7%9C%D7%9C_%D7%91%D7%A8%D7%90%D7%A9%D7%95%D7%AA%D7%95.jpg 2x\" /></a><figcaption>הרב קרביצקי (יושב,עורך את ההגרלה, <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a>)</figcaption></figure>\n<p>הרב <b>אברהם קרביצקי</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"תשל&quot;ב\">תשל\"ב</a>) הוא שליח הרבי לשכונת המחנה בנחלת הר חב\"ד, ראש כולל תפארת נפתלי בנחלת הר חב\"ד ומו\"ל הוצאת תפארת.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/db/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99.jpg/220px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99.jpg\" decoding=\"async\" width=\"220\" height=\"146\" class=\"mw-file-element\" srcset=\"/images/thumb/d/db/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99.jpg/330px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99.jpg 1.5x, /images/thumb/d/db/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99.jpg/440px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99.jpg 2x\" /></a><figcaption>הרב קרביצקי (מימין, <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a>)</figcaption></figure>\n<p>נולד לרב <a href=\"/index.php/%D7%A0%D7%A4%D7%AA%D7%9C%D7%99_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99\" title=\"נפתלי קרביצקי\">נפתלי קרביצקי</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ולאמו רבקה לבית רובשקין.\n</p><p>גדל והתחנך במוסדות חב\"ד המקומיים ולמד ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> נסע לשנת הקבוצה אצל הרבי.<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>\n</p><p>התחתן עם אהובה בת הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"חיים אהרון דוברוסקין\">חיים אהרון דוברוסקין</a> מ<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a> ותיישב בנחלת הר חב\"ד.\n</p><p>לאחר פטירת אביו הקים את \"<a href=\"/index.php?title=%D7%9B%D7%95%D7%9C%D7%9C_%D7%AA%D7%A4%D7%90%D7%A8%D7%AA_%D7%A0%D7%A4%D7%AA%D7%9C%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כולל תפארת נפתלי (הדף אינו קיים)\">כולל תפארת נפתלי</a>\"<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup> לעילוי נשמתו במטרה לעודד ולחזק את לימוד החסידות ודרכי החסידות שבמסגרתו מתקיימים מדי יום שיעורים בנגלה ובחסידות על ידי מיטב מגידי השיעורים בנחלת הר-חב\"ד, הכולל הגריל כרטיסי טיסה<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup> והיה מאוד פעיל, הכולל קיים גם מסעות למקומות שונים כמו קברי צדיקים בארץ הקודש.<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>\n</p><p>הוא משמש גם כשליח הרבי לשכונת המחנה ופועל רבות בקרב תושבי השכונה בהפצת המעיינות.\n</p><p>כמו כן עוסק הוא בהוצאה לאור וכיו\"ר הוצאת תפארת המוציאה לאור חומרים רבים מכל הסוגים.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב אשר קרביצקי.</li>\n<li>בנו, הרב נפתלי קרביצקי.</li>\n<li>בנו, הרב יוסי קרביצקי.</li>\n<li>חתנו, הרב צביקי מאיירס.</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;הערות שוליים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: הערות שוליים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">בנו של הרב <a href=\"/index.php/%D7%90%D7%A9%D7%A8_%D7%A7%D7%A8%D7%91%D7%99%D7%A6%D7%A7%D7%99\" title=\"אשר קרביצקי\">אשר קרביצקי</a> וגיסו של הרב <a href=\"/index.php/%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A7%D7%A8%D7%99%D7%A6%27%D7%91%D7%A1%D7%A7%D7%99\" title=\"מענדל קריצ&#39;בסקי\">מענדל קריצ'בסקי</a></span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">בגיליון 500 של <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"בית משיח (שבועון)\">בית משיח</a> התראיין לעיתון על זכרונותיו מהתקופה הקשה של לאחר <a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ז באדר\">כ\"ז באדר</a></span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/24219\">נחלת הר חב\"ד: שיעורים ללא הפסקה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/8029\">בנחל'ה מתמידים בלימוד חסידות</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/6041\">תנופה ל'כולל חסידות' בנחלת הר חב\"ד</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcs