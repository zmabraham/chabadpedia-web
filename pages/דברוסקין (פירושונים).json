    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>ОћОљОЮ ОћОфОЏОЋОЋОаОфОЮ Ою...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li><a href=\"/index.php/%D7%93%D7%91_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ОЊОЉ ОЊОЋОЉОеОЋОАОДОЎОЪ\">ОЊОЉ ОЊОЋОЉОеОЋОАОДОЎОЪ</a>- ОљОЌОЊ Оъ<a href=\"/index.php?title=%D7%94%D7%91%D7%A2%D7%A8%D7%9C%D7%A2%D7%9A&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОћОЉОбОеОюОбОџ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОћОЉОбОеОюОбОџ</a> Оъ<a href=\"/index.php/%D7%A7%D7%A8%D7%9E%D7%A0%D7%A6%27%D7%95%D7%92\" title=\"ОДОеОъОаОд&#39;ОЋОњ\">ОДОеОъОаОд'ОЋОњ</a> ОћОъОЏОЋОаОћ Ое' ОЉОбОеОю ОъОЕОћ'ОА.</li>\n<li><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"ОЕОъОЋОљОю ОЊОЋОЉОеОЋОАОДОЎОЪ\">ОЕОъОЋОљОю ОЊОЋОЉОеОЋОАОДОЎОЪ</a> - <a href=\"/index.php/%D7%A9%D7%95%D7%97%D7%98\" title=\"ОЕОЋОЌОў\">ОЕОЋОЌОў</a> ОЕОаОЎОћОю ОљОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%95%D7%9C%D7%98%D7%95%D7%91%D7%94\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОцОЋОюОўОЋОЉОћ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОцОЋОюОўОЋОЉОћ</a>, ОаОеОдОЌ ОбОю ОЎОЊОЎ ОћОЕОюОўОЋОаОЋОф ОћОАОЋОЉОЎОЎОўОЎОЮ.</li>\n<li><a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%A8%D7%99%D7%94_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"ОЎОЕОеОљОю ОљОеОЎОћ ОЊОЋОЉОеОЋОАОДОЎОЪ\">ОЎОЕОеОљОю ОљОеОЎОћ ОЊОЋОЉОеОЋОАОДОЎОЪ</a> - ОфОюОъОЎОЊ <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЋОЊ\">ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЋОЊ</a>, ОЕОћОЋОцОДОЊ ОбОю ОЎОЊОЎ <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a> ОЏ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉ<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A1%D7%A4%D7%A8_%D7%9C%D7%9E%D7%9C%D7%90%D7%9B%D7%94\" class=\"mw-redirect\" title=\"ОЉОЎОф ОћОАОцОе ОюОъОюОљОЏОћ\">ОЉОЎОф ОћОАОцОе ОюОъОюОљОЏОћ</a> ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a> ОЋОаОеОдОЌ ОбОю ОЎОЊОЎ ОъОЌОЉОюОЎ Оћ'ОцОЊОљОЎОЋОЪ'.</li>\n<li><a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"ОЌОЎОЎОЮ ОљОћОеОЋОЪ ОЊОЋОЉОеОЋОАОДОЎОЪ\">ОЌОЎОЎОЮ ОљОћОеОЋОЪ ОЊОЋОЉОеОЋОАОДОЎОЪ</a> - ОљОЎОЕ ОЌОЎОаОЋОџ ОЋОфОЎОД, ОъОаОЏОЉОЊОЎ ОДОћОЎОюОф ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ОЎОеОЋОЕОюОЎОЮ\">ОЎОеОЋОЕОюОЎОЮ</a> ОЋОъОќОДОаОЎ ОЌОЉ\"ОЊ ОЉОљОеОЦ ОћОДОЋОЊОЕ.</li>\n<li><a href=\"/index.php/%D7%93%D7%91_%D7%9E%D7%A0%D7%97%D7%9D_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"ОЊОЉ ОъОаОЌОЮ ОЊОЋОЉОеОЋОАОДОЎОЪ\">ОЊОЉ ОъОаОЌОЮ ОЊОЋОЉОеОЋОАОДОЎОЪ</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОъОњОЊОю ОћОбОъОД\">ОЉОЎОЕОЎОЉОф ОЌОЉ\"ОЊ</a> ОЉ<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"ОъОњОЊОю ОћОбОъОД\">ОъОњОЊОю ОћОбОъОД</a>, ОЋОъОеОдОћ ОъОЉОЋОДОЕ ОЉОЏОю ОеОЌОЉОЎ ОћОљОеОЦ. ОЕОЎОъОЕ ОЏОљОЌОЊ Оћ'<a href=\"/index.php/%D7%97%D7%95%D7%96%D7%A8\" title=\"ОЌОЋОќОе\">ОЌОЋОќОеОЎОЮ</a>' ОЋОћ'<a href=\"/index.php/%D7%94%D7%A0%D7%97%D7%94\" title=\"ОћОаОЌОћ\">ОъОаОЎОЌОЎОЮ</a>' ОЕОю ОЕОЎОЌОЋОфОЎОЋ ОЕОю ОћОеОЉОЎ.</li>\n<li><a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A9%D7%9B%D7%A0%D7%90_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"ОЎОЕОеОљОю ОЕОЏОаОљ ОЊОЋОЉОеОЋОАОДОЎОЪ\">ОЎОЕОеОљОю ОЕОЏОаОљ ОЊОЋОЉОеОЋОАОДОЎОЪ</a> - ОъОЕОцОЎОб ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>, ОеОЉ ОЉОеОЉОаОЋОф ОфОю ОљОЉОЎОЉ, ОъОеОдОћ ОЉОъОЏОюОюОф <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A8%D7%91%D7%A7%D7%94_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЉОЎОф ОеОЉОДОћ ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЉОЎОф ОеОЉОДОћ ОЏОцОе ОЌОЉ\"ОЊ</a> ОЋОъОЌОЉОе ОАОЊОеОф ОћОАОцОеОЎОЮ 'ОћОъОљОЋОе ОЕОЉОфОЋОеОћ' ОбОю ОъОљОъОеОЎ <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ ОћОдОъОЌ ОдОЊОД\">ОћОеОЉОЎ ОћОдОъОЌ ОдОЊОД</a>.</li>\n<li><a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%99%D7%9B%D7%9C_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F_(%D7%91%D7%99%D7%AA%D7%A8)\" title=\"ОЎОЌОЎОљОю ОъОЎОЏОю ОЊОЋОЉОеОЋОАОДОЎОЪ (ОЉОЎОфОе)\">ОЎОЌОЎОљОю ОъОЎОЏОю ОЊОЋОЉОеОЋОАОДОЎОЪ (ОЉОЎОфОе)</a> - <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%94%D7%99%D7%A9%D7%99%D7%91%D7%94\" class=\"mw-redirect\" title=\"ОеОљОЕ ОћОЎОЕОЎОЉОћ\">ОеОљОЕ ОћОЎОЕОЎОЉОћ</a> ОЉ<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%A7%D7%98%D7%A0%D7%94_%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA\" title=\"ОЎОЕОЎОЉОћ ОДОўОаОћ ОфОЋОеОф ОљОъОф\">ОЎОЕОЎОЉОћ ОДОўОаОћ ОфОЋОеОф ОљОъОф</a>.</li>\n<li><a href=\"/index.php/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9E%D7%99%D7%9B%D7%9C_%D7%93%D7%95%D7%91%D7%A8%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ОЎОЌОЎОљОю ОъОЎОЏОю ОЊОЋОЉОеОЋОАОДОЎОЪ\">ОЎОЌОЎОљОю ОъОЎОЏОю ОЊОЋОЉОеОЋОАОДОЎОЪ</a> - ОЌОЉОе <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"ОЉОЎОф ОЊОЎОЪ ОеОЉОаОЎ ОЌОЉ&quot;ОЊ ОЉОљОеОЦ ОћОДОЋОЊОЕ\">ОЉОЎОф ОЊОЎОЪ ОеОЉОаОЎ ОЌОЉ\"ОЊ ОЉОљОеОЦ ОћОДОЋОЊОЕ</a>, ОЋОеОЉ ОДОћОЎОюОф ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"ОЌОЎОцОћ\">ОЌОЎОцОћ</a></li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\