      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_1.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/72/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_1.jpg/250px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_1.jpg\" decoding=\"async\" width=\"250\" height=\"278\" class=\"mw-file-element\" srcset=\"/images/thumb/7/72/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_1.jpg/375px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_1.jpg 1.5x, /images/thumb/7/72/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_1.jpg/500px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_1.jpg 2x\" /></a><figcaption>הרב אברהם ליסון</figcaption></figure>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90.%D7%9C._%D7%95%D7%94%D7%A8%D7%91%D7%99.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/a4/%D7%90.%D7%9C._%D7%95%D7%94%D7%A8%D7%91%D7%99.jpeg/220px-%D7%90.%D7%9C._%D7%95%D7%94%D7%A8%D7%91%D7%99.jpeg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/a/a4/%D7%90.%D7%9C._%D7%95%D7%94%D7%A8%D7%91%D7%99.jpeg/330px-%D7%90.%D7%9C._%D7%95%D7%94%D7%A8%D7%91%D7%99.jpeg 1.5x, /images/thumb/a/a4/%D7%90.%D7%9C._%D7%95%D7%94%D7%A8%D7%91%D7%99.jpeg/440px-%D7%90.%D7%9C._%D7%95%D7%94%D7%A8%D7%91%D7%99.jpeg 2x\" /></a><figcaption>אצל הרבי בחלוקת דולרים</figcaption></figure>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f5/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA.jpg/220px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA.jpg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f5/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA.jpg/330px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA.jpg 1.5x, /images/thumb/f/f5/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA.jpg/440px-%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA.jpg 2x\" /></a><figcaption>בהתוועדות</figcaption></figure>\n<p>הרב <b>אברהם ליסון</b> (<a href=\"/index.php/%D7%99%22%D7%91_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"י&quot;ב חשוון\">י\"ב חשוון</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%92\" title=\"תרפ&quot;ג\">תרפ\"ג</a>, 1922 – <a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%A9%D7%91%D7%98\" title=\"ט&quot;ו בשבט\">ט\"ו בשבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a>), היה זקן תושבי כפר חב\"ד, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%91%D7%99%D7%AA_%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"בית הכנסת בית נחום יצחק (כפר חב&quot;ד)\">בית הכנסת בית נחום יצחק</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>. בעבר כיהן בתפקידים חינוכיים שונים בהנהלת בית הספר של <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">רשת אהלי יוסף יצחק</a> בזרנוגה, ומוקדם יותר - משפיע בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%90%D7%A7%D7%99%D7%A0%D7%92\" class=\"mw-redirect\" title=\"תומכי תמימים פאקינג\">תומכי תמימים פאקינג</a>. היה מגדולי ה'<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%AA%D7%A4%D7%99%D7%9C%D7%94\" title=\"עבודת התפילה\">עובדים</a>' בדורנו.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%99%22%D7%91_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"י&quot;ב חשוון\">י\"ב חשוון</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%92\" title=\"תרפ&quot;ג\">תרפ\"ג</a> ב<a href=\"/index.php/%D7%A2%D7%99%D7%99%D7%A8%D7%94\" title=\"עיירה\">עיירה</a> הליטאית <a href=\"/index.php/%D7%A4%D7%95%D7%A0%D7%99%D7%91%D7%96%27\" title=\"פוניבז&#39;\">פוניבז'</a> לרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%9C%D7%99%D7%A1%D7%95%D7%9F\" title=\"שמואל צבי הירש ליסון\">שמואל צבי הירש ליסון</a> והרבנית יענטא, ונקרא על שם סבו הרב אברהם ליסון, חתנו של ר' שמואל צבי חסיד <a href=\"/index.php/%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"הצמח צדק\">הצמח צדק</a>, וגיסו של ר' שמחה גינזבורג.\n</p><p>בצעירותו, למד בישיבה המקומית אצל הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A9%D7%9C%D7%9E%D7%94_%D7%9B%D7%94%D7%A0%D7%9E%D7%9F\" title=\"יוסף שלמה כהנמן\">יוסף שלמה כהנמן</a>, והיה אחד הבודדים מתלמידי הישיבה ששרד את מאורעות ה<a href=\"/index.php/%D7%A9%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"שואה\">שואה</a>.\n</p><p>ב<a href=\"/index.php/%D7%9B%22%D7%98_%D7%A1%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"כ&quot;ט סיון\">כ\"ט סיון</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> עזב את משפחתו בגפו וברח ל<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>, שם התחבר ל<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד\">חסידי חב\"ד</a> והמשיך לברוח יחד איתם לעומק רוסיה בכיוון העיר <a href=\"/index.php/%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"סמרקנד\">סמרקנד</a>, שם נכנס ללמוד בסניף ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"תומכי תמימים סמרקנד\">תומכי תמימים המקומית</a>. בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> הצטרף ל<a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%95\" title=\"יציאת רוסיה תש&quot;ו\">בריחה הגדולה</a> של חסידי חב\"ד והצליח להבריח את הגבול תחת זהות פולנית בדויה.\n</p><p>הוא הגיע למחנה המעבר <a href=\"/index.php/%D7%A4%D7%90%D7%A7%D7%99%D7%A0%D7%92\" class=\"mw-redirect\" title=\"פאקינג\">פאקינג</a>, שם התמנה כ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> הישיבה שהוקמה.\n</p><p>בהמשך, הגיע לתחנת המעבר ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"ברינואה\">ברינואה</a> שב<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>, שם נשא חן בעיני המשפיע החסידי הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%97%D7%99%D7%99%D7%9D_%D7%A7%D7%A1%D7%9C%D7%9E%D7%9F\" title=\"שלמה חיים קסלמן\">שלמה חיים קסלמן</a> ששידך אותו עם בתו יהודית. החתונה התקיימה בלא נוכחות הוריו שנספו ב<a href=\"/index.php/%D7%A9%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"שואה\">שואה</a>, ותקופה קצרה לאחר מכן הזוג הצעיר קיבל הוראה מ<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> לעלות ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a> ולהימנות על גרעין המייסדים של היישוב החב\"די החדש <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p><p>לפרנסתו, החל לעסוק כמחנך, ובהמשך התמנה כחבר הנהלת בית הספר של <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">רשת אהלי יוסף יצחק</a> ביישוב זרנוגה.\n</p><p>במשך שנים רבות יצא ל<a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" title=\"מבצע תפילין\">מבצע תפילין</a> ואייש באופן קבוע את העמדה שהוקמה בתחנה המרכזית (הישנה) ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>.\n</p><p>הרב ליסון נהג למסור שיעורי חסידות בסגנונו הייחודי בספרי '<a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"לקוטי תורה\">לקוטי תורה</a>' ו'<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" class=\"mw-redirect\" title=\"תורה אור\">תורה אור</a>' ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%91%D7%99%D7%AA_%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"בית הכנסת בית נחום יצחק (כפר חב&quot;ד)\">בית הכנסת בית נחום יצחק</a> בשיכונים בכפר חב\"ד. וכן היה מוסר שיעור בתניא היומי ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%27%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%27_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"בית כנסת &#39;המרכזי&#39; כפר חב&quot;ד\">בית הכנסת 'המרכזי</a>' בכפר חב\"ד.\n</p><p>הרבה לעורר ולעסוק בהפצת בשורת הגאולה וזהות <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%9B%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"הרבי כמלך המשיח\">הרבי כמלך המשיח</a>, חינך להכרזת <a href=\"/index.php/%D7%99%D7%97%D7%99_%D7%90%D7%93%D7%95%D7%A0%D7%A0%D7%95\" class=\"mw-redirect\" title=\"יחי אדוננו\">יחי אדוננו</a>, ואף השתתף ונאם בכינוסים שארגנה <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה האמיתית והשלימה</a>.\n</p><p>בימיו האחרונים ר' אברהם ליסון לא הרגיש בטוב ועבר להתגורר בבית חתנו המשפיע ר' <a href=\"/index.php/%D7%A2%D7%95%D7%96%D7%A8_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"עוזר אלפרוביץ&#39;\">עוזר אלפרוביץ'</a>. ביום בו נפטר העיר אותו ר' עוזר, כשהתעורר ביקש ר' אברהם מר' עוזר כוס תה, כשהביא לו את כוס התה חזר ר' אברהם לישון, שינה ממנה לא קם. נפטר ב<a href=\"/index.php/%D7%98%22%D7%95_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"ט&quot;ו שבט\">ט\"ו שבט</a> <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A2%22%D7%98\" class=\"mw-redirect\" title=\"ה&#39;תשע&quot;ט\">ה'תשע\"ט</a> בגיל 96 בשיבה טובה.\n</p>\n<h2><span id=\".D7.91.D7.A2.D7.9C_.D7.9E.D7.A0.D7.92.D7.9F\"></span><span class=\"mw-headline\" id=\"בעל_מנגן\">בעל מנגן</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;בעל מנגן&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: בעל מנגן\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הרב ליסון ניחן בכשרון נגינה ייחודי, ובמקביל לעבודתו ב<a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">רשת אהלי יוסף יצחק</a> ובפעילות החב\"דית ברחבי הארץ, השתתף ב<a href=\"/index.php/%D7%A2%D7%A8%D7%91_%D7%97%D7%91%22%D7%93\" title=\"ערב חב&quot;ד\">ערבי חב\"ד</a> רבים שם קירב רבים ל<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a> באמצעות שירתו העריבה.\n</p><p>כאשר הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9E%D7%A8%D7%98%D7%95%D7%9F\" title=\"יוסף יהודה מרטון\">יוסף יהודה מרטון</a> ייסד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"תשכ&quot;ג\">תשכ\"ג</a> את המקהלה החב\"דית הראשונה, הצטרף למקהלה, והיה אחד מה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%9E%D7%A0%D7%92%D7%9F\" title=\"בעל מנגן\">בעלי-מנגנים</a> הבולטים בה.\n</p><p>ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש סיון\">חודש סיון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> <a href=\"/index.php/%D7%A0%D7%A1%D7%99%D7%A2%D7%94_%D7%9C%D7%A8%D7%91%D7%99\" title=\"נסיעה לרבי\">הגיע לבקר</a> בחצר <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, ומספר ימים לפני קיומו של ה<a href=\"/index.php/%D7%A8%D7%90%D7%9C%D7%99\" title=\"ראלי\">ראלי</a> לכבוד <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a> ביקש ממנו הרבי שיופיע בפני הילדים, ובאם הדבר אפשרי - שיתחיל את ההופעה שלו אחרי שהרבי יצטרף לכינוס. הרב ליסון קיבל על עצמו להשתתף בכינוס והופיע בפני הרבי, והרבי חייך בזמן ההופעה שלו ומחא את כפיו, והראה שביעות רצון רבה משירתו.\n</p><p>ר' אברהם חיבר ניגון \"<a href=\"/index.php/%D7%9B%D7%99_%D7%A8%D7%92%D7%A2_%D7%91%D7%90%D7%A4%D7%95_(%D7%A0%D7%99%D7%92%D7%95%D7%9F)\" class=\"mw-redirect\" title=\"כי רגע באפו (ניגון)\">כי רגע באפו (ניגון)</a>\", והוא מילים מתוך <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%99%D7%9D_%D7%9C%27\" title=\"תהלים ל&#39;\">פרק ל'</a> בתהלים \"מזמור שיר חנכת הבית לדוד\" על תנועות ניגון התועדות מקרמצ'וג שהוא ניגון ר' ב<a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%A0%D7%99%D7%92%D7%95%D7%A0%D7%99%D7%9D\" title=\"ספר הניגונים\">ספר הניגונים</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>את <a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%A9%D7%9E%D7%97%D7%94#מסורת_הניגונים\" title=\"ניגון שמחה\">ניגון שמחה מסורת הניגונים (קצ\"ז)</a> שקיבל מהמשפיע ר' <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%93%D7%A8%D7%99%D7%96%D7%99%D7%9F_(%D7%9E%D7%90%D7%99%D7%95%D7%A8)\" title=\"אברהם דריזין (מאיור)\">אברהם דריזין</a> הלביש על המילים \"גם כי אלך בגיא צלמות לא אירא רע כי אתה עמדי\"<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> <sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>. \n</p>\n<h3><span id=\".D7.A8.D7.95.D7.A7.D7.93_.D7.A2.D7.9C_.D7.99.D7.93.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"רוקד_על_ידיו\">רוקד על ידיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;רוקד על ידיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: רוקד על ידיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%91%D7%A8%D7%94%D7%9D-%D7%9C%D7%99%D7%A1%D7%95%D7%9F-%D7%A2%D7%9C-%D7%99%D7%93%D7%99%D7%95.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/d/d1/%D7%90%D7%91%D7%A8%D7%94%D7%9D-%D7%9C%D7%99%D7%A1%D7%95%D7%9F-%D7%A2%D7%9C-%D7%99%D7%93%D7%99%D7%95.jpeg/220px-%D7%90%D7%91%D7%A8%D7%94%D7%9D-%D7%9C%D7%99%D7%A1%D7%95%D7%9F-%D7%A2%D7%9C-%D7%99%D7%93%D7%99%D7%95.jpeg\" decoding=\"async\" width=\"220\" height=\"192\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d1/%D7%90%D7%91%D7%A8%D7%94%D7%9D-%D7%9C%D7%99%D7%A1%D7%95%D7%9F-%D7%A2%D7%9C-%D7%99%D7%93%D7%99%D7%95.jpeg/330px-%D7%90%D7%91%D7%A8%D7%94%D7%9D-%D7%9C%D7%99%D7%A1%D7%95%D7%9F-%D7%A2%D7%9C-%D7%99%D7%93%D7%99%D7%95.jpeg 1.5x, /images/thumb/d/d1/%D7%90%D7%91%D7%A8%D7%94%D7%9D-%D7%9C%D7%99%D7%A1%D7%95%D7%9F-%D7%A2%D7%9C-%D7%99%D7%93%D7%99%D7%95.jpeg/440px-%D7%90%D7%91%D7%A8%D7%94%D7%9D-%D7%9C%D7%99%D7%A1%D7%95%D7%9F-%D7%A2%D7%9C-%D7%99%D7%93%D7%99%D7%95.jpeg 2x\" /></a><figcaption>באחד מגלגולי הראש המפורסמים שלו, לשמחת ליבם של ילדי ישראל.</figcaption></figure>\n<p>הרב אברהם ליסון נהג לרקוד על ידיו באירועים חסידיים ו<a href=\"/index.php/%D7%A2%D7%A8%D7%91_%D7%97%D7%91%22%D7%93\" title=\"ערב חב&quot;ד\">ערבי חב\"ד</a> ובמיוחד באירועי ה<a href=\"/index.php/%D7%91%D7%A8_%D7%9E%D7%A6%D7%95%D7%94_%D7%9C%D7%99%D7%AA%D7%95%D7%9E%D7%99_%D7%A6%D7%94%22%D7%9C\" class=\"mw-redirect\" title=\"בר מצוה ליתומי צה&quot;ל\">בר מצוה ליתומי צה\"ל</a> שבכפר חב\"ד<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בי\"ב תמוז תשכ\"ה אמר כ\"ק אדמו\"ר שליט\"א&#160;: \"אולי יש כאן מישהו שגם יכול לעשות כן ליסון - היה עושה זאת, ומסתמא עושה כן עתה בכפר חב\"ד, ושיהי' לו לתועלת ולבריאות... - <b>להמשיך הענין דראש למטה ורגלים למעלה שזהו דבר המובן בשעת שמחה גדולה</b>\".\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%9E%D7%94_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלמה חיים ליסון (הדף אינו קיים)\">שלמה חיים ליסון</a>, משלוחי הרבי ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>.</li>\n<li>בנו, הרב יוסף יצחק ליסון, <a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>.</li>\n<li>בנו, הרב שמואל צבי ליסון, כפר חב\"ד.</li>\n<li>בנו, הרב יום טוב ליסון, מונטריאול - קנדה.</li>\n<li>חתנו, ה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> הרב <a href=\"/index.php/%D7%A2%D7%95%D7%96%D7%A8_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"עוזר אלפרוביץ&#39;\">עוזר אלפרוביץ'</a>, כפר חב\"ד בעל סטרנה בתו.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A9%D7%9E%D7%95%D7%9C%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יעקב שמולביץ\">יעקב שמולביץ</a> ע\"ה, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"שליח הרבי\">שליח הרבי</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A9%D7%90%D7%9F\" title=\"בית שאן\">בית שאן</a> בעל חנה בתו.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%99%D7%A8%D7%9E%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%99%D7%9C%D7%93%D7%A7%D7%A8%D7%95%D7%99%D7%98\" title=\"ירמיהו יהודה לייב שילדקרויט\">יהודה ירמיהו (לייבל) שילדקרויט</a>, משלוחי הרבי לארץ, מנכ\"ל מוסדות חב\"ד חיפה והקריות בעל רבקה יענטא בתו.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%99%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://teshura.com/teshurapdf/%D7%AA%D7%A9%D7%95%D7%A8%D7%94%20%20%D7%A8%D7%99%D7%91%D7%A7%20-%20%D7%9C%D7%99%D7%A1%D7%95%D7%9F.pdf\">מדור לדור</a></b>, תשורה ריבק-ליסון י\"ג סיון ה'תשפ\"ה <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadlive.org/lison\">יש 'להתפלל' טוב יותר: התוועדות אותנטית של הרב אברהם ליסון</a></b>, באתר '<a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"חב&quot;ד לייב\">חב\"ד לייב</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/41px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 1.5x, /images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/54px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 2x\" /></a></span> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A6%D7%9C%D7%99%D7%9C\" title=\"קובץ שמע\"><img alt=\"קובץ שמע\" src=\"/images/thumb/4/42/%D7%A9%D7%9E%D7%A2.png/16px-%D7%A9%D7%9E%D7%A2.png\" decoding=\"async\" width=\"16\" height=\"16\" class=\"mw-file-element\" srcset=\"/images/thumb/4/42/%D7%A