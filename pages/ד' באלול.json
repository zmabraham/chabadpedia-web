\n<p><b>ד' באלול</b> הוא היום הרביעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">חודש אלול</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>קנ\"א – החלו פרעות ביהודי טולדו וברצלונה – <a href=\"/index.php/%D7%A1%D7%A4%D7%A8%D7%93\" title=\"ספרד\">ספרד</a>, במסגרת 'גזירות קנ\"א'.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a> – רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%99%D7%93%D7%99%D7%93%D7%99%D7%94_%D7%A4%D7%A8%D7%A0%D7%A7%D7%9C\" title=\"יצחק ידידיה פרנקל\">יצחק ידידיה פרנקל</a>, רבה של <a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%93\" title=\"תשי&quot;ד\">תשי\"ד</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%94%D7%A8%D7%95%D7%A0%D7%95%D7%91\" title=\"יוסף יצחק אהרונוב\">יוסף יצחק אהרונוב</a>, יושב ראש <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"צעירי אגודת חב&quot;ד בארץ הקודש\">צעירי אגודת חב\"ד בארץ הקודש</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%94%D7%9C%D7%9C_%D7%A9%D7%A4%D7%A8%D7%99%D7%A0%D7%92%D7%A8\" title=\"חיים הלל שפרינגר\">חיים הלל שפרינגר</a>, סגן מנכ\"ל <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%A0%D7%94_(%D7%A6%D7%A4%D7%AA)\" title=\"בית חנה (צפת)\">בית חנה (צפת)</a> רב ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%97%22%D7%9C_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"ישיבת חח&quot;ל צפת\">ישיבת חח\"ל צפת</a> ומנהל <a href=\"/index.php/%D7%90%D7%AA%22%D7%94_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" class=\"mw-redirect\" title=\"את&quot;ה העולמי\">את\"ה העולמי</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%90%D7%9C%D7%95%D7%9C&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%98\" title=\"תרע&quot;ט\">תרע\"ט</a> – נרצח על קידוש ה' הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%97%D7%9F\" title=\"שלמה מנחם מענדל חן\">שלמה מנחם מענדל חן</a>, רבה של <a href=\"/index.php/%D7%A0%D7%99%D7%A2%D7%96%27%D7%99%D7%9F\" class=\"mw-redirect\" title=\"ניעז&#39;ין\">ניעז'ין</a> ויד ימינו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> בעסקנות הכלל.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%AA%D7%A8_%D7%94%D7%99%D7%9C%D7%91%D7%99%D7%A5\" title=\"אלתר הילביץ\">אלתר הילביץ</a>, מחסידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ומעורכי ה<a href=\"/index.php/%D7%90%D7%A0%D7%A6%D7%99%D7%A7%D7%9C%D7%95%D7%A4%D7%93%D7%99%D7%94_%D7%AA%D7%9C%D7%9E%D7%95%D7%93%D7%99%D7%AA\" title=\"אנציקלופדיה תלמודית\">אנציקלופדיה תלמודית</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ד' באלול - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>סדר <a href=\"/index.php/%D7%91%D7%A8%D7%9B%D7%AA_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" title=\"ברכת התורה\">ברכות התורה</a>: נוגע <a href=\"/index.php/%D7%98%D7%9C%D7%99%D7%AA\" title=\"טלית\">בטליתו</a> בתחילת ה<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" title=\"קריאת התורה\">קריאה</a> ובסופה, נושק הטלית במקום שנגע ב<a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%AA%D7%95%D7%A8%D7%94\" title=\"ספר תורה\">ספר תורה</a>, גולל הספר תורה, מפנה פניו, קצת, לימין ומברך. פותח הספר תורה וקורא.</i>\n<p>במעלת מין האנושי, ישנם ארבעה תוארים: <a href=\"/index.php/%D7%90%D7%93%D7%9D_(%D7%A9%D7%9D_%D7%AA%D7%95%D7%90%D7%A8)\" class=\"mw-redirect\" title=\"אדם (שם תואר)\">אדם</a> – מעלת ה<a href=\"/index.php/%D7%9E%D7%95%D7%97%D7%99%D7%9F\" class=\"mw-redirect\" title=\"מוחין\">מוחין</a> וה<a href=\"/index.php/%D7%A9%D7%9B%D7%9C\" class=\"mw-redirect\" title=\"שכל\">שכל</a>, איש – מעלת ה<a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a> וה<a href=\"/index.php/%D7%9E%D7%99%D7%93%D7%95%D7%AA_(%D7%91%D7%90%D7%93%D7%9D)\" title=\"מידות (באדם)\">מידות</a>, אנוש – החלישות באחד מהם בשכל או במידות, או בשתיהם, גבר – מתגבר על עצמו להסיר המניעות ועיכובים להשיג אחת המעלות או ב<a href=\"/index.php/%D7%A9%D7%9B%D7%9C\" class=\"mw-redirect\" title=\"שכל\">שכל</a> או ב<a href=\"/index.php/%D7%9E%D7%99%D7%93%D7%95%D7%AA_(%D7%91%D7%90%D7%93%D7%9D)\" title=\"מידות (באדם)\">מידות</a>, היינו דגבר עוסק עם האנוש להגביהו למעלת איש או אדם.\n</p><p>ומאחר דאפשר לעשות מאנוש איש או אדם, הרי בהכרח דגם באנוש ישנם כל אותם המעלות שישנם באיש וגם באדם.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414045330\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.025 seconds\nReal time usage: 0.036 seconds\nPreprocessor visited node count: 84/1000000\nPost‐expand include size: 7073/2097152 bytes\nTemplate argument size: 696/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   14.387      1 -total\n 66.30%    9.538      1 תבנית:חודש_אלול\n 33.51%    4.821      1 תבנית:לוח_שנה_חסר\n 32.91%    4.735      1 תבנית:להיום_יום\n 14.80%    2.129      1 תבנית:היום_יום/ד&#039;_אלול\n 13.87%    1.995      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:18793-0!canonical and timestamp 20260414045330 and revision id 799163. Rendering was triggered because: api-parse\n -->\n</div>"
