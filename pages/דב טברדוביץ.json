      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/9e/%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg/300px-%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg\" decoding=\"async\" width=\"300\" height=\"200\" class=\"mw-file-element\" srcset=\"/images/thumb/9/9e/%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg/450px-%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg 1.5x, /images/thumb/9/9e/%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg/600px-%D7%94%D7%A8%D7%91_%D7%93%D7%95%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5_%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA.jpeg 2x\" /></a><figcaption>הרב טברדוביץ בתוכנית הוידאו של ארגון '<a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\">לחלוחית גאולתית</a>'</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/33/%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5.jpg/250px-%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5.jpg\" decoding=\"async\" width=\"250\" height=\"187\" class=\"mw-file-element\" srcset=\"/images/thumb/3/33/%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5.jpg/375px-%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5.jpg 1.5x, /images/thumb/3/33/%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5.jpg/500px-%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5.jpg 2x\" /></a><figcaption>הרב טברדוביץ מוסר שיעור בהלכה בהיכל ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"תומכי תמימים בני ברק\">תומכי תמימים בני ברק</a></figcaption></figure>\n<p>הרב <b>דב טברדוביץ</b> (נולד ב<a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כ\"ו בסיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a>, יוני 1955) הוא דיין ומורה צדק ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, המכהן כראש מכון ל<a href=\"/index.php/%D7%A1%D7%9E%D7%99%D7%9B%D7%94_%D7%9C%D7%A8%D7%91%D7%A0%D7%95%D7%AA\" title=\"סמיכה לרבנות\">סמיכה</a> ולהוראה, ורב ביהכ\"נ מנין זושא ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D\" class=\"mw-redirect\" title=\"בית מנחם\">בית מנחם</a>. מחבר ספרי <a href=\"/index.php/%D7%94%D7%9C%D7%9B%D7%94\" title=\"הלכה\">הלכה</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97_%D7%9B%D7%A9%D7%A8%D7%95%D7%AA\" title=\"משגיח כשרות\">משגיח כשרות</a> בעל <a href=\"/index.php/%D7%9B%D7%A9%D7%A8%D7%95%D7%AA\" title=\"כשרות\">הכשר</a> למסעדות ומלונות, וחבר בסגל רבני \"התקשרות - חווייה יהודית רוחנית\", ו<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_-_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"מכון הלכה - חב&quot;ד\">מכון הלכה - חב\"ד</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> ב<a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כ\"ו בסיוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a> לרב יעקב טברדוביץ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ולחוה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> בת הגאון הגדול דב פייבל מועד זצ\"ל.\n</p><p>בצעירותו, למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> וישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a> ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> בחצר <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>כשחזר <a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארצה</a> <a href=\"/index.php/%D7%A0%D7%99%D7%A9%D7%95%D7%90%D7%99%D7%9F\" title=\"נישואין\">נשא</a> את רעייתו ברכה, בתו של ה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%A6%D7%91%D7%99_%D7%94%D7%91%D7%A8\" title=\"ישראל צבי הבר\">ישראל צבי הבר</a>, והתיישב ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> שם התמנה כ<a href=\"/index.php/%D7%9E%D7%92%D7%99%D7%93_%D7%A9%D7%99%D7%A2%D7%95%D7%A8\" class=\"mw-redirect\" title=\"מגיד שיעור\">מגיד שיעור</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a> (כיום משמש כנו\"נ בישיבה. הרב טברדוביץ' מוציא לאור בישיבה מידי שבוע מנשר מיוחד בשם 'הלכה למעשה', ובו הלכות הנוגעות לחיי היום יום של התמימים).\nבמקביל עסק בלימודי דיינות והתמחה בעיקר בהלכות שבת וטהרת המשפחה.\n</p><p>עם השנים התבסס מעמדו כ<a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"מורה צדק\">מורה צדק</a> חב\"די מהשורה הראשונה, ואף התמנה לעמוד בראש מכון להסמכת צעירים חב\"דיים לרבנות ולהוראה.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a> הצטרף לרבנים שחתמו על <a href=\"/index.php/%D7%A4%D7%A1%D7%A7_%D7%94%D7%93%D7%99%D7%9F_%D7%A9%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%95%D7%90_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"פסק הדין שהרבי הוא מלך המשיח\">פסק הדין שהרבי הוא מלך המשיח</a>.\n</p><p>עם הקמתה של עמותת <a href=\"/index.php/%D7%94%D7%AA%D7%A7%D7%A9%D7%A8%D7%95%D7%AA_-_%D7%97%D7%95%D7%99%D7%94_%D7%99%D7%94%D7%95%D7%93%D7%99%D7%AA_%D7%A8%D7%95%D7%97%D7%A0%D7%99%D7%AA\" title=\"התקשרות - חויה יהודית רוחנית\">התקשרות - חויה יהודית רוחנית</a>, צורף לצוות הרוחני של העמותה.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> הוציא לאור את ספרו הראשון על הלכות שבת, שהפך לרב מכר וזכה לשלוש מהדורות נוספות שנדפסו תחת השם 'הלכתא כרב'.\n</p><p>בהמשך לספר העוסק בהלכות שבת, הוציא לאור את הספר 'חוסן ישועות' העוסק בהנהגות והליכות הבית היהודי על פי מנהגי חב\"ד.\n</p><p>בנוסף, מתמחה הרב טברדוביץ בדיני כשרות ומעניק השגחה מהודרת לאולמות קייטרינגים וקבוצות נופש המתארחים במלונות.\n</p><p>רעייתו ברכה טברדוביץ משמשת כמשפיעה לנשות <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>, מלווה קבוצות ל<a href=\"/index.php/%D7%A0%D7%A1%D7%99%D7%A2%D7%94_%D7%9C%D7%A8%D7%91%D7%99\" title=\"נסיעה לרבי\">נסיעה לרבי</a>, מרצה ומחברת ספרים בנושאי זוגיות וטהרת המשפחה, חברת ועדת ה<a href=\"/index.php/%D7%A6%D7%A0%D7%99%D7%A2%D7%95%D7%AA\" title=\"צניעות\">צניעות</a> של כפר חב\"ד, ומדריכת כלות.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> הצטרף לרבני '<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_-_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"מכון הלכה - חב&quot;ד\">מכון הלכה - חב\"ד</a>'.\n</p>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ספריו\">ספריו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ספריו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ספריו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%95%D7%A1%D7%9F_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e3/%D7%97%D7%95%D7%A1%D7%9F_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA.jpg/150px-%D7%97%D7%95%D7%A1%D7%9F_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA.jpg\" decoding=\"async\" width=\"150\" height=\"200\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e3/%D7%97%D7%95%D7%A1%D7%9F_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA.jpg/225px-%D7%97%D7%95%D7%A1%D7%9F_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA.jpg 1.5x, /images/thumb/e/e3/%D7%97%D7%95%D7%A1%D7%9F_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA.jpg/300px-%D7%97%D7%95%D7%A1%D7%9F_%D7%99%D7%A9%D7%95%D7%A2%D7%95%D7%AA.jpg 2x\" /></a><figcaption>כריכת ספרו 'חוסן ישועות'</figcaption></figure>\n<ul><li><b><a href=\"/index.php/%D7%94%D7%9C%D7%9B%D7%AA%D7%90_%D7%9B%D7%A8%D7%91\" class=\"mw-redirect\" title=\"הלכתא כרב\">הלכתא כרב</a></b> - <a href=\"/index.php/%D7%91%D7%AA_%D7%99%D7%9D\" title=\"בת ים\">בת ים</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> (מהדורה ראשונה)</li>\n<li><b>חוסן ישועות</b> - <a href=\"/index.php/%D7%91%D7%AA_%D7%99%D7%9D\" title=\"בת ים\">בת ים</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> (מהדורה ראשונה)</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב שמואל טברדוביץ - משלוחי הרבי במיאמי (סורפסייד - באל הארבור).</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5%27\" title=\"מנחם מענדל טברדוביץ&#39;\">מנחם מענדל טברדוביץ</a> - ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"תומכי תמימים אנטוורפן\">תו\"ת אנטוורפן</a> (ישיבה קטנה) ולשעבר ראש מכון סמיכה ומשלוחי הרבי באנטוורפן, בלגיה.</li>\n<li>בנו, הרב חיים טברדוביץ - שליח בקרית מוצקין.</li>\n<li>בנו, הרב משה טברדוביץ - משלוחי הרבי ברחובות.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%90%D7%95%D7%A8%D7%99_%D7%9C%D7%9E%D7%91%D7%A8%D7%92\" title=\"אורי למברג\">אורי למברג</a> - ראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D\" class=\"mw-redirect\" title=\"כולל אברכים\">כולל</a> ללימודי <a href=\"/index.php/%D7%A1%D7%9E%D7%99%D7%9B%D7%94\" class=\"mw-redirect\" title=\"סמיכה\">סמיכה</a> ודיינות, חיפה.</li>\n<li>חתנו, הרב אפרים מרזל - חבר הצוות הרוחני של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%9E%D7%AA_%D7%90%D7%91%D7%99%D7%91\" title=\"תומכי תמימים רמת אביב\">תומכי תמימים רמת אביב</a>.</li>\n<li>חתנו, הרב חנוך רוזנפלד - משלוחי הרבי בצפת.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%94%D7%9B%D7%98\" title=\"לוי הכט\">לוי הכט</a> - משלוחי הרבי ב<a href=\"/index.php/%D7%90%D7%99%D7%9C%D7%AA\" title=\"אילת\">אילת</a>.</li>\n<li>חתנו, הרב <a href=\"/index.php?title=%D7%99%D7%A9%D7%99_%D7%A7%D7%9C%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ישי קלי (הדף אינו קיים)\">ישי קלי</a> - שליח הרבי בשכונת בת גלים, חיפה.</li>\n<li>חתנו, הרב שאול לידר - מורה ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"תלמוד תורה אוהלי תורה כפר חב&quot;ד\">תלמוד תורה אוהלי תורה כפר חב\"ד</a>.</li>\n<li>חתנו, הרב גרשון רודרמן.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadlive.org/2025/03/%d7%94%d7%93%d7%a8%d7%9a-%d7%9c%d7%94%d7%a9%d7%a4%d7%99%d7%a2-%d7%95%d7%9c%d7%a9%d7%a0%d7%95%d7%aa-%d7%90%d7%97%d7%a8%d7%99%d7%9d-%d7%91%d7%90%d7%9e%d7%a6%d7%a2%d7%95%d7%aa-%d7%a2%d7%91%d7%95%d7%93.html\">הדרך להשפיע ולשנות אחרים באמצעות עבודת התפילה • הרב דוב טברדוביץ בראיון</a></b>, באתר '<a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"חב&quot;ד לייב\">חב\"ד לייב</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/41px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 1.5x, /images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/54px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 2x\" /></a></span> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://machon-halacha.co.il/%D7%A8%D7%91%D7%A0%D7%99%D7%9D/%d7%94%d7%a8%d7%91-%d7%93%d7%91-%d7%98%d7%91%d7%a8%d7%93%d7%95%d7%91%d7%99%d7%a5/\">פסיקות, תשובות, מאמרים וסרטונים</a></b> של הרב טברדוביץ באתר פורטל ההלכה של מכון הלכה חב\"ד <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%22%D7%93\" title=\"קישור לאתר מכון הלכה\"><img alt=\"קישור לאתר מכון הלכה\" src=\"/images/thumb/a/ad/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg/32px-%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg\" decoding=\"async\" width=\"32\" height=\"22\" class=\"mw-file-element\" srcset=\"/images/thumb/a/ad/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg/48px-%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg 1.5x, /images/thumb/a/ad/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg/64px-%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%9C%D7%9B%D7%94_%D7%97%D7%91%D7%93.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://www.col.org.il/show_news.rtx?artID=42144\">כיצד להכשיר ולטבול כלים</a></b> - שיעור הלכתי עם הרב טברדוביץ <span typeof=\"mw:File\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A6%D7%9C%D7%99%D7%9C\" title=\"קובץ שמע\"><img alt=\"קובץ שמע\" src=\"/images/thumb/4/42/%D7%A9%D7%9E%D7%A2.png/16px-%D7%A9%D7%9E%D7%A2.png\" decoding=\"async\" width=\"16\" height=\"16\" class=\"mw-file-element\" srcset=\"/images/thumb/4/42/%D7%A9%D7%9E%D7%A2.png/24px-%D7%A9%D7%9E%D7%A2.png 1.5x, /images/thumb/4/42/%D7%A9%D7%9E%D7%A2.png/32px-%D7%A9%D7%9E%D7%A2.png 2x\" /></a></span> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\