/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/44px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.shturem.net/index.php?section=news&amp;id=51620\">הרבי ניבא את הכאוס במצרים</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D_(%D7%90%D7%AA%D7%A8)\" title=\"קישור שטורעם\"><img alt=\"קישור שטורעם\" src=\"/images/thumb/8/89/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG/15px-%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG\" decoding=\"async\" width=\"15\" height=\"14\" class=\"mw-file-element\" srcset=\"/images/8/89/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D.PNG 1.5x\" /></a></span> <span class=\"grayText\"><small>(הקישור אינו פעיל)</small></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למרות דעתם של שר הביטחון והרמטכ\"ל, שטענו שרצונו של סאדאת הוא לעורר פרובוקציה</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">שיחת ט' כסלו ה'תשל\"ח</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">שיחת כ\"ד טבת ה'תשל\"ח</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">שיחת ח\"י אלול ה'תשל\"ח</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">שיחת יו\"ד שבט ה'תשל\"ח</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">כך סיפר יו\"ר <a href=\"/index.php/%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D\" title=\"יד לאחים\">יד לאחים</a> הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"שלום דובער ליפשיץ\">שלום דובער ליפשיץ</a>, שישב ב<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"התוועדות\">התוועדות</a> זו סמוך לרבי.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">מומחה לייצוב חולות. במסגרת עבודתו, סייע בשיחות על ההסכם</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://col.org.il/show_news.rtx?artID=77467\">כשהרבי ניבא: מי יכול לשער מה יהיה שם בעוד שלושים שנה?</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%9E%D7%95%D7%A0%D7%93%D7%A9%D7%99%D7%99%D7%9F\" title=\"יהושע מונדשיין\">יהושע מונדשיין</a> במדורו <a rel=\"nofollow\" class=\"external text\" href=\"https://www.kramim.info/category/%D7%A1%D7%99%D7%A4%D7%95%D7%A8%D7%99%D7%9D-%D7%95%D7%92%D7%9C%D7%92%D7%95%D7%9C%D7%99%D7%94%D7%9D\">סיפורים וגלגוליהם</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414053002\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.170 seconds\nReal time usage: 0.729 seconds\nPreprocessor visited node count: 386/1000000\nPost‐expand include size: 3242/2097152 bytes\nTemplate argument size: 593/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 4330/5000000 bytes\nLua time usage: 0.100/7 seconds\nLua virtual size: 5746688/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  566.105      1 -total\n 80.31%  454.655      9 תבנית:הערה\n  6.94%   39.315      1 תבנית:הערות_שוליים\n  6.83%   38.650      1 תבנית:חבד_בישראל\n  5.84%   33.061      1 תבנית:קישור_שבור\n  4.68%   26.495      2 תבנית:חב&quot;ד_און_ליין\n  1.55%    8.800      1 תבנית:קובץ\n  1.09%    6.148      1 תבנית:בית_חבד_(אתר)\n  1.05%    5.950      1 תבנית:הערות_שוליים/מרחב_שם\n  0.97%    5.465      1 תבנית:שטורעם\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:40420-0!canonical and timestamp 20260414053002 and revision id 832562. Rendering was triggered because: page-view\n -->\n</div>"
