\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בחשוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בחשוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בחשוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בחשוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ל&#39; בחשוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"א בחשוון</b> הוא היום האחד עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חודש חשוון</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>א'תרנ\"ו (- 1665 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\"> לפנה\"ס</a>) - לפי שיטת ר\"א נפטר מתושלח בן חנוך, סבו של נח.</li>\n<li>ב'ר\"ח (-1453 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - לפי אחת השיטות<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> <a href=\"/index.php/%D7%A8%D7%97%D7%9C_%D7%90%D7%9E%D7%A0%D7%95\" title=\"רחל אמנו\">רחל אמנו</a>, בדרכה מפדן ארם ל<a href=\"/index.php/%D7%97%D7%91%D7%A8%D7%95%D7%9F\" title=\"חברון\">חברון</a>, נפטרה.</li>\n<li>ב'ר\"ח (-1453 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F\" title=\"בנימין\">בנימין</a> בן <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91\" class=\"mw-redirect\" title=\"יעקב\">יעקב</a>, נולד.</li>\n<li>ב'שי\"ז (-1444 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F\" title=\"בנימין\">בנימין</a> בן <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91\" class=\"mw-redirect\" title=\"יעקב\">יעקב</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%9B%22%D7%91\" title=\"תקכ&quot;ב\">תקכ\"ב</a> (8/11/1761 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%A2%D7%A7%D7%99%D7%91%D7%90_%D7%90%D7%99%D7%92%D7%A8\" title=\"עקיבא איגר\">עקיבא איגר</a> נולד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%97\" title=\"תקנ&quot;ח\">תקנ\"ח</a> (31/10/1797 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A0%D7%97%D7%95%D7%9D_%D7%9E%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%9C\" title=\"מנחם נחום מצ&#39;רנוביל\">מנחם נחום טברסקי</a>, אבי שושלת <a href=\"/index.php/%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%9C\" class=\"mw-redirect\" title=\"צ&#39;רנוביל\">צ'רנוביל</a> ומחבר 'מאור עינים', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%94\" title=\"תקע&quot;ה\">תקע\"ה</a> (25/10/1814 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יעקב גינצבורג, מחבר 'זרע יעקב', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%93\" title=\"תרמ&quot;ד\">תרמ\"ד</a> (11/11/1883 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי אברהם וינברג, אבי שושלת <a href=\"/index.php/%D7%A1%D7%9C%D7%95%D7%A0%D7%99%D7%9D\" class=\"mw-redirect mw-disambig\" title=\"סלונים\">סלונים</a>, מחבר 'יסוד העבודה' 'באר אברהם' ו'חסד לאברהם', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%94\" title=\"תרמ&quot;ה\">תרמ\"ה</a> (30/10/1884 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי מרדכי מאליק, מחבר 'גדולת מרדכי', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\