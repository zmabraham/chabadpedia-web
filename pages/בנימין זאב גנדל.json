93%D7%9C_%D7%91%D7%AA%D7%A4%D7%99%D7%9C%D7%94_.jpg 1.5x, /images/thumb/1/18/27-08-2025-10-41-20-%D7%94%D7%A8%D7%91_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_%D7%91%D7%AA%D7%A4%D7%99%D7%9C%D7%94_.jpg/440px-27-08-2025-10-41-20-%D7%94%D7%A8%D7%91_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_%D7%91%D7%AA%D7%A4%D7%99%D7%9C%D7%94_.jpg 2x\" /></a><figcaption>הרב בנימין זאב גנדל בתפילה, אלול תשפ\"ה</figcaption></figure>\n<p>הרב <b>בנימין זאב גנדל</b> (נולד ב<a href=\"/index.php/%D7%99%22%D7%96_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"י&quot;ז חשוון\">י\"ז חשוון</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"תשמ&quot;ז\">תשמ\"ז</a>, 1986) הוא <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת (קטנה)\">ישיבת חסידי חב\"ד ליובאוויטש צפת (קטנה)</a>. שימש בעבר כחבר הצוות החינוכי בישיבות ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים נתניה</a>, <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A2%D7%9E%D7%A0%D7%95%D7%90%D7%9C\" title=\"תומכי תמימים עמנואל\">תומכי תמימים עמנואל</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%95%D7%A3_%D7%94%D7%92%D7%9C%D7%99%D7%9C\" class=\"mw-redirect\" title=\"תומכי תמימים נוף הגליל\">תומכי תמימים נוף הגליל</a>.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a> לרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%AA%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%92%D7%A0%D7%93%D7%9C\" class=\"mw-redirect\" title=\"יצחק נתן ישראל גנדל\">יצחק נתן ישראל גנדל</a> ולעופרה גנדל (למשפחת בס), בילדותו עברה משפחתו להתגורר ב<a href=\"/index.php/%D7%A2%D7%9E%D7%A0%D7%95%D7%90%D7%9C\" title=\"עמנואל\">עמנואל</a>.\n</p><p>כנער למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים נתניה</a> וב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת (גדולה)\">ישיבת חסידי חב\"ד ליובאוויטש צפת (גדולה)</a>.\n</p><p>לקראת שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a>, נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> בחצר הרבי ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>כבר כבחור התייחד ב<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%AA%D7%A4%D7%99%D7%9C%D7%94\" title=\"עבודת התפילה\">עבודת התפילה</a> שלו ובעיסוק מיוחד בלימוד עניני <a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"גאולה ומשיח\">גאולה ומשיח</a>.\n</p><p>שימש כמשפיע בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A2%D7%9E%D7%A0%D7%95%D7%90%D7%9C\" title=\"תומכי תמימים עמנואל\">תומכי תמימים עמנואל</a>.  \n</p><p>לאחר נישואיו עם נסיה בת הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%95%D7%95%D7%9C%D7%A4%D7%90\" title=\"שלום דובער וולפא\">שלום דובער וולפא</a> התיישב ב<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a> ושימש מספר שנים כ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת חב\"ד המקומית, לאחריהם עבר לשמש כמשגיח ראשי וחבר ההנהלה החינוכית של ישיבה קטנה <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A0%D7%95%D7%A3_%D7%94%D7%92%D7%9C%D7%99%D7%9C_(%D7%A7%D7%98%D7%A0%D7%94)\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד ליובאוויטש נוף הגליל (קטנה)\">חסידי חב\"ד ליובאוויטש נוף הגליל</a>, וכיום משמש כמשפיע ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת (קטנה)\">ישיבת חסידי חב\"ד ליובאוויטש צפת (קטנה)</a>. \n</p><p>מתגורר כיום בשכונת כנען ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>. \n</p>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>מנחם כהנא<b>, <a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/moshiach/1101801/\">\"צריך להיות פשוט אצלינו שהרבי מתגלה היום!\",</a></b> שבועון בית משיח גליון 1364.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/tag/%D7%94%D7%A8%D7%91-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F-%D7%92%D7%A0%D7%93%D7%9C/\">תגית: בנימין גנדל</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadlive.org/category/%d7%91%d7%a0%d7%99%d7%9e%d7%99%d7%9f-%d7%92%d7%a0%d7%93%d7%9c\">תגית: הרב בנימין גנדל</a></b>, באתר '<a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"חב&quot;ד לייב\">חב\"ד לייב</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/41px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 1.5x, /images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/54px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 2x\" /></a></span></li>\n<li>הרב גנדל: \"כיצד נראית הנסיעה למלך המשיח\" - פודקאסט הרב גנדל בתכנית אזניים לשמוע מבית את\"ה העולמי <a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/news/995567/\">באתר חב\"ד אינפו</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27