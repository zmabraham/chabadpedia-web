      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_-_%D7%A1%D7%95%D7%A3_%D7%AA%D7%A9%D7%A4%22%D7%92.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/75/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_-_%D7%A1%D7%95%D7%A3_%D7%AA%D7%A9%D7%A4%22%D7%92.jpeg/220px-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_-_%D7%A1%D7%95%D7%A3_%D7%AA%D7%A9%D7%A4%22%D7%92.jpeg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/7/75/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_-_%D7%A1%D7%95%D7%A3_%D7%AA%D7%A9%D7%A4%22%D7%92.jpeg/330px-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_-_%D7%A1%D7%95%D7%A3_%D7%AA%D7%A9%D7%A4%22%D7%92.jpeg 1.5x, /images/thumb/7/75/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_-_%D7%A1%D7%95%D7%A3_%D7%AA%D7%A9%D7%A4%22%D7%92.jpeg/440px-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_-_%D7%A1%D7%95%D7%A3_%D7%AA%D7%A9%D7%A4%22%D7%92.jpeg 2x\" /></a><figcaption>הרב בנימין זאב גנדל, אלול תשפ\"ג</figcaption></figure>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_%D7%90%D7%99%D7%99%D7%A8_%D7%AA%D7%A9%D7%A4%22%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/5d/%D7%94%D7%A8%D7%91_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%92%D7%A0%D7%93%D7%9C_%D7%90%D7%99%D7%99%D7%A8_%D7%AA%D7%A9%D7%A4%22%D7%94.jpg/220px-%D7%94%D7%A8%D7%91_%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96