      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">&gt;&gt;</a></span>\n<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">חודש אייר</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"א&#39; באייר\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ב&#39; באייר\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ג&#39; באייר\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ד&#39; באייר\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ה&#39; באייר\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ו&#39; באייר\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ז&#39; באייר\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ח&#39; באייר\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ט&#39; באייר\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;א באייר\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ב באייר\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ג באייר\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ד באייר\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ט&quot;ו באייר\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"ט&quot;ז באייר\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ז באייר\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ח באייר\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"י&quot;ט באייר\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&#39; באייר\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;א באייר\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ב באייר\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ג באייר\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ד באייר\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ה באייר\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ו באייר\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ז באייר\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ח באייר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ט באייר\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י' באייר</b> הוא היום העשירי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">חודש אייר</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תת\"ע – <a href=\"/index.php?title=%D7%A2%D7%9C%D7%99_%D7%94%D7%9B%D7%94%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"עלי הכהן (הדף אינו קיים)\">עלי הכהן</a> ושני בניו נפטרו וארון האלוקים, אותו בנה <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%99%D7%A0%D7%95\" title=\"משה רבינו\">משה רבינו</a> ב<a href=\"/index.php?title=%D7%9E%D7%93%D7%91%D7%A8_%D7%A1%D7%99%D7%A0%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מדבר סיני (הדף אינו קיים)\">מדבר סיני</a>, נשבה.</li>\n<li>ד'תתס\"ד – רבינו <a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%9C%D7%A4%D7%A1%D7%99_(%D7%94%D7%A8%D7%99%22%D7%A3)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יצחק אלפסי (הרי&quot;ף) (הדף אינו קיים)\">יצחק אלפסי (הרי\"ף)</a>, מגדולי הפוסקים ומפרשי התלמוד בתקופת הראשונים, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%A0\" title=\"תק&quot;נ\">תק\"נ</a> – רבי <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%9E%D7%A8%D7%92%D7%9C%D7%99%D7%95%D7%AA\" title=\"מאיר מרגליות\">מאיר מרגליות</a> מאוסטרהא, מ<a href=\"/index.php/%D7%94%D7%97%D7%91%D7%A8%D7%99%D7%90_%D7%A7%D7%93%D7%99%D7%A9%D7%90\" title=\"החבריא קדישא\">החבריא קדישא</a> של <a href=\"/index.php/%D7%94%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" title=\"הבעל שם טוב\">הבעל שם טוב</a> ומחבר הספר 'מאיר נתיבים', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%91\" title=\"תקנ&quot;ב\">תקנ\"ב</a> – רבי יוסף תאומים, מחבר הספר 'פרי מגדים', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%90\" title=\"תקצ&quot;א\">תקצ\"א</a> – רבי משה גולדמן, אבי שושלת <a href=\"/index.php/%D7%96%D7%95%D7%95%D7%99%D7%94%D7%9C\" class=\"mw-redirect\" title=\"זוויהל\">זוויהל</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%93\" title=\"תרל&quot;ד\">תרל\"ד</a> – רבי יצחק אייזיק יהודה יחיאל, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php?title=%D7%A7%D7%95%D7%9E%D7%A8%D7%A0%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"קומרנא (הדף אינו קיים)\">קומרנא</a> ומחבר הספר 'שולחן הטהור', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%91\" title=\"תרמ&quot;ב\">תרמ\"ב</a> – רבי דוד טברסקי, אבי שושלת <a href=\"/index.php/%D7%98%D7%95%D7%9C%D7%A0%D7%90\" class=\"mw-redirect\" title=\"טולנא\">טולנא</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%90\" title=\"תרנ&quot;א\">תרנ\"א</a> – רבי הלל ליכטנשטיין מקולומיא, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a> – רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A4%D7%9C%D7%A7%D7%A1%D7%A8\" title=\"יצחק פלקסר\">יצחק פלקסר</a>, ראב\"ד בד\"ץ <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"אגודת ישראל\">אגודת ישראל</a>, ראש ישיבת <a href=\"/index.php/%D7%92%D7%95%D7%A8\" class=\"mw-redirect\" title=\"גור\">גור</a> 'שפת אמת' ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> ומחבר הספר 'שערי יצחק', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%9C\" title=\"תק&quot;ל\">תק\"ל</a> – הרבנית <a href=\"/index.php/%D7%A8%D7%97%D7%9C_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" title=\"רחל (בת אדמו&quot;ר הזקן)\">רחל שיינעס</a> בת <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%9E%D7%9C%D7%99%D7%90%D7%93%D7%99_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" title=\"רבי שניאור זלמן מליאדי (אדמו&quot;ר הזקן)\">אדמו\"ר הזקן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%93\" title=\"תרע&quot;ד\">תרע\"ד</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יוסף גולדברג\">יוסף גולדברג</a>, <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש ישיבת</a> <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" title=\"תומכי תמימים ברינואה\">תומכי תמימים ברינואה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A0%D7%A4%D7%98%D7%A8\" class=\"mw-redirect\" title=\"נפטר\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%95%D7%95%D7%99%D7%99%D7%A1\" title=\"שלום ווייס\">שלום ווייס,</a> מנהל ישיבת <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%9E%D7%A0%D7%A6%27%D7%A1%D7%98%D7%A8\" title=\"ישיבת ליובאוויטש מנצ&#39;סטר\">ישיבת ליובאוויטש מנצ'סטר</a> במשך עשרות שנים.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י' באייר - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>כה לעומר. נוהגין להטביל פרוסת המוציא שלש פעמים במלח, ולא לזרוק המלח על הפרוסה.</i>\n<p>יום ב' ד<a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%90\" title=\"תרכ&quot;א\">תרכ\"א</a> בסעודה סיפר ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a>: יום ב' דחג השבועות <a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%94\" title=\"תקנ&quot;ה\">תקנ\"ה</a> בסעודה אמר אבי אדוני זקני מורי ורבי (<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a>): ביום ב' דחג השבועות <a href=\"/index.php/%D7%AA%D7%A7%D7%9B%22%D7%94\" title=\"תקכ&quot;ה\">תקכ\"ה</a> בסעודה אמר כ\"ק מורי ורבי (<a href=\"/index.php/%D7%94%D7%9E%D7%92%D7%99%D7%93_%D7%9E%D7%9E%D7%A2%D7%96%D7%A8%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"המגיד ממעזריטש\">המגיד ממעזריטש</a>) \"וספרתם לכם\", \"וספרתם\" הוא מלשון ספירות ובהירות. \"וספרתם לכם\", צריכים לעשות שיהיה ה'לכם' בהיר. וישען כ\"ק אבי אדוני זקני מורי ורבי על זרועות קדשו וישורר את ה<a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ניגון\">ניגון</a> של <a href=\"/index.php/%D7%93%27_%D7%91%D7%91%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ד&#39; בבות\">ד' בבות</a> ב<a href=\"/index.php/%D7%93%D7%91%D7%A7%D7%95%D7%AA\" class=\"mw-redirect\" title=\"דבקות\">דבקות</a> גדולה. אחר כך הגביה את ראשו הקדוש ויאמר - בניגון של שאלה: \"ובמה מספרים את ה'לכם'?\" ותוך כדי דיבור אמר - בניגון של תשובה: \"בשבע שבתות תמימות, בבירור שבע ה<a href=\"/index.php/%D7%9E%D7%99%D7%93%D7%95%D7%AA_(%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA)\" title=\"מידות (ספירות)\">מדות</a>, שכל מדה ומדה תהיה כלולה משבע, ושבע המדות עצמם יהיו שבע <a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבתות</a>, דשבת אינה צריכה <a href=\"/index.php/%D7%91%D7%99%D7%A8%D7%95%D7%A8\" class=\"mw-redirect\" title=\"בירור\">בירור</a>.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414123445\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.031 seconds\nReal time usage: 0.040 seconds\nPreprocessor visited node count: 101/1000000\nPost‐expand include size: 7485/2097152 bytes\nTemplate argument size: 693/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   14.228      1 -total\n 52.05%    7.405      1 תבנית:חודש_אייר\n 47.05%    6.694      1 תבנית:להיום_יום\n 32.44%    4.616      1 תבנית:לוח_שנה_חסר\n 21.72%    3.090      1 תבנית:היום_יום/י&#039;_אייר\n 12.39%    1.763      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:22111-0!canonical and timestamp 20260414123445 and revision id 831314. Rendering was triggered because: api-parse\n -->\n</div>"
