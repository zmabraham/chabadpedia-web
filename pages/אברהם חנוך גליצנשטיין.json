%A9%D7%99%D7%A2%D7%95%D7%A8%D7%99%D7%9D_%D7%91%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%A0%D7%99%D7%90\" title=\"שיעורים בספר התניא\">שיעורים בספר התניא</a></b>, (4 כרכים) <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a>.</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אביו, הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"שמעון גליצנשטיין\">שמעון גליצנשטיין</a>, מזכיר ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li>אחיו, הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"יצחק גליצנשטיין\">יצחק גליצנשטיין</a>.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%95%D7%99%D7%99%D7%A1%D7%A4%D7%99%D7%A9\" class=\"mw-redirect\" title=\"מנחם וייספיש\">מנחם וייספיש</a> - ירושלים.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=8\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=8\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.hebrewbooks.org/pdfpager.aspx?req=15752&amp;st=&amp;pgnum=1&amp;hilite=\">הספר 'שערי החכמה העליונה' בהיברו-בוקס</a>.</li>\n<li>\"בבירת ליובאוויטש\", יומנו מחודש תשרי במחיצת הרבי תש\"כ, <b><a href=\"/index.php?title=%D7%A7%D7%95%D7%91%D7%A5_%D7%9C%D7%97%D7%99%D7%96%D7%95%D7%A7_%D7%94%D7%94%D7%AA%D7%A7%D7%A9%D7%A8%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"קובץ לחיזוק ההתקשרות (הדף אינו קיים)\">קובץ לחיזוק ההתקשרות</a></b>, <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%AA%D7%9C%D7%9E%D7%99%D7%93%D7%99_%D7%94%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" class=\"mw-redirect\" title=\"ועד תלמידי התמימים העולמי\">ועד תלמידי התמימים העולמי</a>, תשרי <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a>: <a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/old/files/0.85089848984_9918211.pdf\">חלק ראשון</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/old/files/0.92951175117_8794470.pdf\">חלק שני</a></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=9\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9C%D7%99%D7%A6%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=9\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a href=\"/index.php/%D7%90%D7%95%D7%A6%D7%A8%D7%95%D7%AA_(%D7%A1%D7%A4%D7%A8)\" title=\"אוצרות (ספר)\">אוצרות</a></b>, שורת שליחויות וסיפורים והוראות מהרבי בהם היה מעורב, מתוך הארכיון שהותיר לאחר פטירתו, <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a>-בעריכת הרב <a href=\"/index.php/%D7%96%D7%95%D7%A9%D7%90_%D7%95%D7%95%D7%9C%D7%A3\" title=\"זושא וולף\">זושא וולף</a>, שמעון ומנחם וייספיש<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li><a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%91%D7%A8%D7%92%D7%A8\" class=\"mw-redirect\" title=\"שניאור ברגר\">שניאור ברגר</a>, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://www.scribd.com/doc/259312370/966\">איש אשר רוח בו</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span> <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> גליון 966 עמוד 25.</li>\n<li><b>והיו מספרים</b> מוסף <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"בית משיח (שבועון)\">בית משיח</a> לחג הפסח תשפ\"ד, עמ' 4-9 29.</li>\n<li>אגרות קודש בפרסום ראשון אל הרב גליצנשטיין, <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> גיליון 1435 ע' 10-12</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">אגרות קודש אדמו\"ר הריי\"צ חלק יז אגרת ו'תשנה.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ראה בהמשך בפיסקה \"ספריו\".</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">‏סקירה על הספר: <b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/135128\">שבוע לה' טבת האוצר נחשף: ארכיון ר' חנוך גליצנשטיין</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413180453\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.073 seconds\nReal time usage: 0.140 seconds\nPreprocessor visited node count: 222/1000000\nPost‐expand include size: 720/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 2040/5000000 bytes\nLua time usage: 0.030/7 seconds\nLua virtual size: 5623808/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--