    "pageid": 77581,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/b/bc/%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99.jpg/218px-%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99.jpg\" decoding=\"async\" width=\"218\" height=\"250\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99.jpg/327px-%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99.jpg 1.5x, /images/b/bc/%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99.jpg 2x\" /></a><figcaption>הרב קיי בברית</figcaption></figure>\n<p>הרב <b>גדעון פישל קיי</b> (יליד <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a>), הינו <a href=\"/index.php/%D7%9E%D7%95%D7%94%D7%9C\" class=\"mw-redirect\" title=\"מוהל\">מוהל</a> חב\"די, חבר קהילת חב\"ד ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a> ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%98%D7%A0%D7%99%D7%94\" title=\"בריטניה\">בריטניה</a>, לאביו ר' חנוך קיי ולאמו מרת חיה רחל.\n</p><p>בבחרותו למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>. \n</p><p>לקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>לאחר שנת הקבוצה נכנס לכולל של הרב מאיר אהרון ע\"ה בו למד עד לשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%96\" title=\"תשנ&quot;ז\">תשנ\"ז</a> התחתן עם נחמה דינה לבית משפחת הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%94%D7%9B%D7%94%D7%9F_%D7%9B%D7%94%D7%9F\" title=\"דוד הכהן כהן\">דוד הכהן כהן</a>.\n</p>\n<h3><span id=\".D7.A2.D7.99.D7.A1.D7.95.D7.A7.D7.95_.D7.9B.D7.9E.D7.95.D7.94.D7.9C\"></span><span class=\"mw-headline\" id=\"עיסוקו_כמוהל\">עיסוקו כמוהל</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;עיסוקו כמוהל&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: עיסוקו כמוהל\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>הרב קיי למד את אומנות המילה אצל הרב עמנואל משולם והרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A4%D7%9C%D7%99%D7%99%D7%A9%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"מנחם פליישמן\">מנחם פליישמן</a> מרחובות ובשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> הוכשר כמוהל מוסמך על ידי הרבנות הראשית לישראל. \n</p><p>הוא רואה בעבודתו שליחות, ומשמש כמוהל-שליח המקרב משפחות ליהדות בקיבוצים ומושבים בצפון. לפני כל ברית, הוא נוהג לכתוב <a href=\"/index.php/%D7%9B%D7%AA%D7%99%D7%91%D7%94_%D7%9C%D7%A8%D7%91%D7%99\" title=\"כתיבה לרבי\">מכתב לרבי</a> דרך <a href=\"/index.php/%D7%9B%D7%AA%D7%99%D7%91%D7%94_%D7%9C%D7%A8%D7%91%D7%99_%D7%91%D7%90%D7%9E%D7%A6%D7%A2%D7%95%D7%AA_%D7%94%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9\" title=\"כתיבה לרבי באמצעות האגרות קודש\">האגרות קודש</a> ולבקש ברכה. בנוסף, הוא מנהל קבוצה וירטואלית בה הוא מייעץ למוהלים רבים בנוגע למקרים שונים.\n</p><p>כמו כן בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> השלים הרב קיי את לימודי ה<a href=\"/index.php/%D7%94%D7%A1%D7%9E%D7%9B%D7%94_%D7%9C%D7%A8%D7%91%D7%A0%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הסמכה לרבנות\">הסמכה לרבנות</a> וקיבל תעודת הוראה \"יורה יורה\", וכושר לרב עיר מטעם \"היכל שלמה\" של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%95%D7%AA_%D7%94%D7%A8%D7%90%D7%A9%D7%99%D7%AA_%D7%9C%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"הרבנות הראשית לישראל\">הרבנות הראשית לישראל</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> השתלם והוכשר למוהל <b>מומחה</b> ע\"י הרבנות הראשית לישראל ומשרד הבריאות המתמחה בבריתות רגילות ומסובכות. הוא נמנה על קבוצה מצומצמת של מוהלים מומחים בארץ שקיבלו תעודה זו.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו ר' שלום דובער קיי - ר\"מ ומשפיע בישי\"ג <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%93%D7%A2%D7%AA\" title=\"תומכי תמימים דעת\">תות\"ל דעת רחובות</a>.</li>\n<li>חתנו, ר' יצחק אלחנן קרנגל, שליח ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%AA_%D7%A9%D7%9E%D7%95%D7%A0%D7%94\" class=\"mw-redirect\" title=\"קרית שמונה\">קרית שמונה</a>.</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%92%D7%93%D7%A2%D7%95%D7%9F_%D7%A7%D7%99%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/file/d/1qyJoU9dTlbuQ_Rm-TauOzS4p2787DPWg/view?usp=sharing\">מלאכי הברית החב\"דיים</a>, <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> גיליון 1043 עמוד 38 <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/a/a5/%D7%92%D7%95%D7%92%D7%9C_%D7%93%D7%A8%D7%99%D7%99%D7%91.png/18px-%D7%92%D7%95%D7%92%D7%9C_%D7%93%D7%A8%D7%99%D7%99%D7%91.png\" decoding=\"async\" width=\"18\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/a/a5/%D7%92%D7%95%D7%92%D7%9C_%D7%93%D7%A8%D7%99%D7%99%D7%91.png/27px-%D7%92%D7%95%D7%92%D7%9C_%D7%93%D7%A8%D7%99%D7%99%D7%91.png 1.5x, /images/thumb/a/a5/%D7%92%D7%95%D7%92%D7%9C_%D7%93%D7%A8%D7%99%D7%99%D7%91.png/36px-%D7%92%D7%95%D7%92%D7%9C_%D7%93%D7%A8%D7%99%D7%99%D7%91.png 2x\" /></span></span></li></ul>\n<!-- \nNewPP limit report\nCached time: 20260414012318\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.018 seconds\nReal time usage: 0.028 seconds\nPreprocess