      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%A9%D7%9C_-_%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/9c/%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%A9%D7%9C_-_%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F.jpg/220px-%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%A9%D7%9C_-_%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"331\" class=\"mw-file-element\" srcset=\"/images/thumb/9/9c/%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%A9%D7%9C_-_%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F.jpg/330px-%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%A9%D7%9C_-_%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F.jpg 1.5x, /images/thumb/9/9c/%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%A9%D7%9C_-_%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F.jpg/440px-%D7%AA%D7%9E%D7%95%D7%A0%D7%94_%D7%A9%D7%9C_-_%D7%94%D7%A8%D7%91_%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F.jpg 2x\" /></a><figcaption>הרב חיים לוי יצחק סלומון</figcaption></figure>\n<p>הרב <b>חיים לוי יצחק סלומון</b> (נולד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a>) הוא <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"שלוחי הרבי\">שליח הרבי</a> וסמנכ\"ל בית חב\"ד <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%99%D7%95%D7%A0%D7%94\" title=\"כפר יונה\">כפר יונה</a> שבאזור השרון.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%A0%D7%99%D7%A1%D7%9F\" title=\"י&quot;א בניסן\">י\"א ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> לר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"יוסף סלומון (כפר חב&quot;ד)\">יוסף</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ולדבוניא<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> סלומון כנכד לר' <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A8%D7%A1%D7%A7%D7%99%D7%9F_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"מנחם מענדל רסקין (כפר חב&quot;ד)\">מנחם מענדל רסקין.</a>\n</p><p>למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> ובישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a>.\n</p><p>לקראת שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a>, נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" title=\"תומכי תמימים המרכזית 770\">תומכי תמימים המרכזית 770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%90\" title=\"תשס&quot;א\">תשס\"א</a> נשא את רעייתו פנינה - בת המחנך הרב אפרים קעניג מ<a href=\"/index.php/%D7%A9%D7%9B%D7%95%D7%A0%D7%AA_%D7%A1%D7%A0%D7%94%D7%93%D7%A8%D7%99%D7%94\" title=\"שכונת סנהדריה\">סנהדריה</a> שב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, ובקיץ <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> יצאו ב<a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"שלוחי הרבי\">שליחות הרבי</a>, לפתוח מוסדות לימוד חב\"דיים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%99%D7%95%D7%A0%D7%94\" title=\"כפר יונה\">כפר יונה</a>, תחת השליח הראשי - הרב <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%99%D7%94_%D7%A9%D7%9E%D7%A8%D7%9C%D7%99%D7%A0%D7%92\" title=\"נחמיה שמרלינג\">נחמיה שמרלינג</a>.\n</p><p>לקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a> הקים את גן חב\"ד הראשון ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%99%D7%95%D7%A0%D7%94\" title=\"כפר יונה\">כפר יונה</a> - 'גן דבוניא'. נכון לשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> מונים 4 גני חב\"ד שתחת ניהולו למעלה מ-120 ילדים.\n</p><p>בנוסף לניהול מוסדות חינוך חב\"ד, ניהל את בית הכנסת חב\"ד בעיר (שאותו ייסד ר' אריה שמעיה) עד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a>, בה עבר בית כנסת חב\"ד בעיר למבנה אחר, בניהול השליח הרב מנחם מענדל טורנהיים.\n</p><p>פעולות נוספות של הרב סלומון בעיר: הקמת ארגון '<a href=\"/index.php/%D7%90%D7%A8%D7%92%D7%95%D7%9F_%D7%A9%D7%A4%D7%A8%D7%94_%D7%95%D7%A4%D7%95%D7%A2%D7%94\" title=\"ארגון שפרה ופועה\">שפרה ופועה</a>' לעזרה ליולדות ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%99%D7%95%D7%A0%D7%94\" title=\"כפר יונה\">כפר יונה</a>, <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%95%D7%9B%D7%AA_%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"תהלוכת ל&quot;ג בעומר\">תהלוכות ל\"ג בעומר</a>, <a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"מבצע חנוכה\">אירועי חנוכה</a> חב\"דיים בעיר ועוד.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>חתנו, הרב חנן ליפש - שליח הרבי לשכונת גבעת אלונים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%99%D7%95%D7%A0%D7%94\" title=\"כפר יונה\">כפר יונה</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%95%D7%9E%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/7553\">גן ילדים חבד\"י חדש בכפר יונה</a> באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/113229\">כפר יונה: נחנכו מבני גני חב\"ד החדשים והמפוארים</a> באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">נפטר ב<a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ט באדר\">כ\"ט אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a></span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">נפטרה ב<a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%98%D7%91%D7%AA\" title=\"י&quot;ז בטבת\">י\"ז בטבת</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%90\" title=\"תשס&quot;א\">תשס\"א</a></span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://cha