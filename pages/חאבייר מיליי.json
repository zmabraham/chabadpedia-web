      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/40/%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99.jpg/200px-%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99.jpg\" decoding=\"async\" width=\"200\" height=\"264\" class=\"mw-file-element\" srcset=\"/images/thumb/4/40/%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99.jpg/300px-%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99.jpg 1.5x, /images/thumb/4/40/%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99.jpg/400px-%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99.jpg 2x\" /></a><figcaption>נשיא <a href=\"/index.php/%D7%90%D7%A8%D7%92%D7%A0%D7%98%D7%99%D7%A0%D7%94\" title=\"ארגנטינה\">ארגנטינה</a> <b>חאבייר מיליי</b></figcaption></figure>\n<figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%97%D7%A0%D7%95%D7%9B%D7%99%D7%94_%D7%9C%D7%96%D7%9C%D7%A0%D7%A1%D7%A7%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/4e/%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%97%D7%A0%D7%95%D7%9B%D7%99%D7%94_%D7%9C%D7%96%D7%9C%D7%A0%D7%A1%D7%A7%D7%99.jpg/200px-%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%97%D7%A0%D7%95%D7%9B%D7%99%D7%94_%D7%9C%D7%96%D7%9C%D7%A0%D7%A1%D7%A7%D7%99.jpg\" decoding=\"async\" width=\"200\" height=\"211\" class=\"mw-file-element\" srcset=\"/images/thumb/4/4e/%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%97%D7%A0%D7%95%D7%9B%D7%99%D7%94_%D7%9C%D7%96%D7%9C%D7%A0%D7%A1%D7%A7%D7%99.jpg/300px-%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%97%D7%A0%D7%95%D7%9B%D7%99%D7%94_%D7%9C%D7%96%D7%9C%D7%A0%D7%A1%D7%A7%D7%99.jpg 1.5x, /images/thumb/4/4e/%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%97%D7%A0%D7%95%D7%9B%D7%99%D7%94_%D7%9C%D7%96%D7%9C%D7%A0%D7%A1%D7%A7%D7%99.jpg/400px-%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%97%D7%A0%D7%95%D7%9B%D7%99%D7%94_%D7%9C%D7%96%D7%9C%D7%A0%D7%A1%D7%A7%D7%99.jpg 2x\" /></a><figcaption>נשיא <a href=\"/index.php/%D7%90%D7%A8%D7%92%D7%A0%D7%98%D7%99%D7%A0%D7%94\" title=\"ארגנטינה\">ארגנטינה</a> חאבייר מיליי (מימין), מעניק חנוכיה לנשיא <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"אוקראינה\">אוקראינה</a> ולדימיר זלנסקי (משמאל)</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Milei_en_el_koisel.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/b/b0/Milei_en_el_koisel.jpg/200px-Milei_en_el_koisel.jpg\" decoding=\"async\" width=\"200\" height=\"133\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b0/Milei_en_el_koisel.jpg/300px-Milei_en_el_koisel.jpg 1.5x, /images/thumb/b/b0/Milei_en_el_koisel.jpg/400px-Milei_en_el_koisel.jpg 2x\" /></a><figcaption>נשיא <a href=\"/index.php/%D7%90%D7%A8%D7%92%D7%A0%D7%98%D7%99%D7%A0%D7%94\" title=\"ארגנטינה\">ארגנטינה</a> חאבייר מיליי ב<a href=\"/index.php/%D7%94%D7%9B%D7%95%D7%AA%D7%9C_%D7%94%D7%9E%D7%A2%D7%A8%D7%91%D7%99\" title=\"הכותל המערבי\">כותל המערבי</a></figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%9E%D7%93%D7%9C%D7%99%D7%A7_%D7%A0%D7%A8.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/a2/%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%9E%D7%93%D7%9C%D7%99%D7%A7_%D7%A0%D7%A8.jpeg/200px-%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%9E%D7%93%D7%9C%D7%99%D7%A7_%D7%A0%D7%A8.jpeg\" decoding=\"async\" width=\"200\" height=\"133\" class=\"mw-file-element\" srcset=\"/images/thumb/a/a2/%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%9E%D7%93%D7%9C%D7%99%D7%A7_%D7%A0%D7%A8.jpeg/300px-%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%9E%D7%93%D7%9C%D7%99%D7%A7_%D7%A0%D7%A8.jpeg 1.5x, /images/thumb/a/a2/%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%9E%D7%93%D7%9C%D7%99%D7%A7_%D7%A0%D7%A8.jpeg/400px-%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99_%D7%9E%D7%93%D7%9C%D7%99%D7%A7_%D7%A0%D7%A8.jpeg 2x\" /></a><figcaption>נשיא ארגנטינה חאבייר מיליי מדליק נר לעילוי נשמת הנרצחים ב<a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%AA_%D7%AA%D7%95%D7%A8%D7%94\" title=\"שמחת תורה\">שמחת תורה</a>.</figcaption></figure>\n<p><b>חאבייר חררדו מיליי</b> (נולד ב<a href=\"/index.php/%D7%9B%22%D7%90_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"כ&quot;א תשרי\">כ\"א תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a>) הוא נשיא <a href=\"/index.php/%D7%90%D7%A8%D7%92%D7%A0%D7%98%D7%99%D7%A0%D7%94\" title=\"ארגנטינה\">ארגנטינה</a> וכלכלן ארגנטינאי המקיים קשר חם עם <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חסידות חב\"ד</a> ו<a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"שלוחי הרבי\">שלוחי הרבי</a> במקום.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%90_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"כ&quot;א תשרי\">כ\"א תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a> ב<a href=\"/index.php/%D7%91%D7%95%D7%90%D7%A0%D7%95%D7%A1_%D7%90%D7%99%D7%99%D7%A8%D7%A1\" title=\"בואנוס איירס\">בואנוס איירס</a> למשפחה ממוצא <a href=\"/index.php/%D7%90%D7%99%D7%98%D7%9C%D7%99%D7%94\" title=\"איטליה\">איטלקי</a>. הוא למד כלכלה ועבד ככלכלן, כמרצה וכשדרן רדיו.<br />ביום היבחרו לנשיאות ארגנטינה לאחר ספירת 95% מהקלפיות זכה ב- 56% מהקולות ובכך גבר על מועמד השמאל-מרכז שר הכלכלה לשעבר סרחיו מאסה שזכה ב-44% מהקולות בלבד. זהו שלטון ימין ראשון אחרי עשרות שנים שארגנטינה הייתה תחת שלטון הנחשב לשמאל.\n<br />מיליי תומך מובהק של <a href=\"/index.php/%D7%9E%D7%93%D7%99%D7%A0%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"מדינת ישראל\">מדינת ישראל</a>. במהלך קמפיין הבחירות הבטיח מיליי להעביר את שגרירות ארגנטינה בישראל ל<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, והצהיר כי ארגנטינה בראשותו תהיה \"בת ברית קרובה\" של ישראל. הייתה תקופה בה מיליי ענד על חליפתו דגלון כפול של ארגנטינה וישראל.\nכמו כן, ב<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%97%D7%A8%D7%91%D7%95%D7%AA_%D7%91%D7%A8%D7%96%D7%9C\" title=\"מלחמת חרבות ברזל\">מלחמת חרבות ברזל</a> הפגין הנשיא תמיכה במדינת ישראל בפרט וב<a href=\"/index.php/%D7%99%D7%94%D7%93%D7%95%D7%AA\" title=\"יהדות\">יהדות</a> בכלל, ואף ביקר ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ישראל</a> בשלהי חודש <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%93\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;ד\">ה'תשפ\"ד</a>, בעיצומה של המלחמה.\n</p>\n<h2><span id=\".D7.A7.D7.A9.D7.A8.D7.99.D7.95_.D7.A2.D7.9D_.D7.94.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"קשריו_עם_היהדות\">קשריו עם היהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;קשריו עם היהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: קשריו עם היהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>מיליי הביע רצון ל<a href=\"/index.php/%D7%92%D7%99%D7%95%D7%A8\" title=\"גיור\">התגייר</a>, והסביר כי נמנע מכך בגלל הקושי בשמירת ה<a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבת</a> כנשיא מדינה.<br />ב<a href=\"/index.php/%D7%9B%22%D7%96_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"כ&quot;ז כסלו\">כ\"ז כסלו</a> <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%93\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;ד\">ה'תשפ\"ד</a> ובנאומו הראשון כנשיא, קישר את המעמד הנשיאותי עם <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%97%D7%A0%D7%95%D7%9B%D7%94\" class=\"mw-redirect\" title=\"חג החנוכה\">חג&#160;החנוכה</a>&#160;באומרו: <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"אין זה מקרה שההשבעה הנשיאותית מתרחשת במהלך חג החנוכה, חג האור, החג של החירות האמיתית . . מלחמת המכבים היא סמל לניצחון של החלשים על החזקים, של המעט על הרב, של האור על החושך, ובעיקר של האמת על פני השקר. כי אתם יודעים שאני מעדיף להגיד לכם את האמת הלא נוחה מאשר לשקר לכם בנוחות.\"</span><br /> ביום <a href=\"/index.php/%D7%9B%22%D7%96_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"כ&quot;ז שבט\">כ\"ז שבט</a> <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%93\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;ד\">ה'תשפ\"ד</a>, הגיע מיליי לביקור ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a>, ואף ביקר ב<a href=\"/index.php/%D7%9B%D7%95%D7%AA%D7%9C_%D7%94%D7%9E%D7%A2%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"כותל המערבי\">כותל המערבי</a>. אחד מהדברים שהזכיר בביקורו, שהוא יעביר את השגרירות הארגנטינאית ל<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>. בביקורו, פגש ברב <a href=\"/index.php/%D7%A1%D7%99%D7%9E%D7%95%D7%9F_%D7%99%D7%A2%D7%A7%D7%91%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סימון יעקבסון\">סימון יעקבסון</a> בירושלים.\nלפני חזרתו לארגנטינה נפגש עם השלוחים הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%91%D7%A8%D7%95%D7%9A_%D7%90%D7%95%D7%99%D7%A8%D7%9B%D7%9E%D7%9F\" title=\"חיים ברוך אוירכמן\">חיים ברוך אוירכמן</a> ואביו <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%90%D7%95%D7%99%D7%A8%D7%9B%D7%9E%D7%9F\" title=\"משה שמואל אוירכמן\">משה שמואל אוירכמן</a> וסיפר להם על כוונתו לקבוע מזוזה בבית הוורוד בארגנטינה (בית השלטון המקומי) וכן הוענק לו שטר חמישים שקל שניתן מידיו הקדושות של הרבי. \n</p>\n<h3><span id=\".D7.A7.D7.A9.D7.A8.D7.99.D7.95_.D7.A2.D7.9D_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"קשריו_עם_חב&quot;ד\">קשריו עם חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קשריו עם חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קשריו עם חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3><p>\nבתיעוד שהתפרסם מביתו של מיליי, נראית תלויה תמונה גדולה של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.<br />חאבייר ביקר ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770 - בית אגו\"ח</a> ב<a href=\"/index.php/%D7%A0%D7%99%D7%95-%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ניו-יורק\">ניו-יורק</a> (עוד לפני ניצחונו בבחירות)<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. כמו כן ביקר ב<a href=\"/index.php/%D7%90%D7%95%D7%94%D7%9C_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" title=\"אוהל אדמו&quot;ר הריי&quot;צ\">אוהל אדמו\"ר הריי\"צ</a> מספר פעמים לפני ניצחונו בבחירות ואף לאחריו<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.<br />הראיון הראשון של חאבייר לאחר ניצחונו בבחירות הוענק לשבועון החב\"די <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\">'כפר חב\"ד'</a><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.<br />ב<a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"חנוכה\">חג החנוכה</a> <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%93\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;ד\">ה'תשפ\"ד</a> השתתף מיליי במעמד <a href=\"/index.php/%D7%94%D7%93%D7%9C%D7%A7%D7%AA_%D7%A0%D7%A8%D7%95%D7%AA_%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"הדלקת נרות חנוכה\">הדלקת נרות חנוכה</a> במוצאי ה<a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבת</a>, יחד עם <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D\" class=\"mw-redirect\" title=\"שלוחים\">שלוחי</a> <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"חסידות חב&quot;ד\">חב\"ד</a> במדינה ונציגים מ<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%97%D7%A8%D7%91%D7%95%D7%AA_%D7%91%D7%A8%D7%96%D7%9C#משפחות_החטופים\" title=\"מלחמת חרבות ברזל\">משפחות החטופים</a> שהינם בעלי אזרחות ארגנטינאית, בנוכחות שר החוץ הישראלי אלי כהן שהגיע במיוחד להשבעה של הנשיא החדש<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>. בהמשך אותו החג, הגיע הנשיא עם סידור שבתוכו תמונה של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> להדלקת נרות חנוכה מרכזית.<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.<br />ביום השלישי לנשיאותו השתתף הנשיא באירוע חנוכה של <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> בפארק שבכיכר המרכזית בארגנטינה, בו הוא נשא נאום, הדליק נר&#160;בחנוכיה&#160;הענקית והחזיק בשלט של שני חטופים.<br />בימים הראשונים לנשיאותו, בראיונות לכלי התקשורת הארגנטינאים הוא מספר בהערצה על <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, פעם - לאחר שקיבל מהרב <a href=\"/index.php/%D7%A1%D7%99%D7%9E%D7%95%D7%9F_%D7%99%D7%A2%D7%A7%D7%91%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סימון יעקבסון\">סימון יעקבסון</a> את הספר \"הדרך לחיים של משמעות\" הוא סיפר למרואיין כי הספר מבוסס על שיחותיו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> והסביר למיליוני הצופים כיצד נערכת חזרה על שיחות שהרבי אמר בשבת: </p><blockquote dir=\"rtl\"><div class=\"hebrewQuotation\">\n<p>הרבי הרי מדבר בשבת, ובשבת אסור לכתוב. אז איך הם רשמו את הדברים? תשמע דבר מעניין: ישבו מולו חמישה חסידים עם זיכרון נדיר ומיד אחרי השבת הם ישבו לכתוב הכל מזכרונם! ואחר כך הרבי ערך והגיה את זה, והייתה לי הזכות להיפגש עם אחד מאותם רבנים והוא העניק לי את הספר הזה!\n</p>\n</div>\n<div style=\"text-align:left;border-top: 1px dotted #ccc;\">— <cite style=\"font-size:small; font-style: normal;\">תרגום חופשי מהראיון</cite></div>\n </blockquote>\n<p>גם בדברים שנשא לתקשורת הכללית אמר <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"דמותו של הרבי משפיעה עליי מאוד\"</span>.\n</p><p>בחודש אייר תשפ\"ד קיבל במתנה חמישה חומשי תורה מתורגמים לספרדית, עם פירושים מהרבי.\nהסט מפאר את לשכת הנשיאות בארגנטינה.\n</p>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>צוות כתבי 'כפר חב\"ד',&#160;‏<b>הידיד שלנו בבית הוורוד</b>, שבועון כפר חב\"ד, גיליון 2039 עמוד 42 (תשפ\"ד) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\"><img src=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/45px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg\" decoding=\"async\" width=\"45\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/68px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 1.5x, /images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/90px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 2x\" /></a></span></li></ul>\n<ul><li>יוסף סולומון,&#160;‏<b>\"נבחר כאן נשיא - חסיד של הרבי...\"</b>, שבועון בית משיח, גיליון 1391 עמוד 24 (תשפ\"ד) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span></li>\n<li><b>הדרך לחאבייר של משמעות</b>, שבועון כפר חב\"ד, (תשפ\"ד) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\"><img src=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/45px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg\" decoding=\"async\" width=\"45\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/68px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 1.5x, /images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/90px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%90%D7%91%D7%99%D7%99%D7%A8_%D7%9E%D7%99%D7%9C%D7%99%D7%99&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/tag/חאבייר-מיליי/\">תגית חאבייר מיליי</a>, באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/feed?type=tags&amp;id=1221\">תגית ארגנטינה</a>, באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%