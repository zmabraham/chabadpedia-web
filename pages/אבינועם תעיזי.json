      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/32/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99.jpg/302px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99.jpg\" decoding=\"async\" width=\"302\" height=\"201\" class=\"mw-file-element\" srcset=\"/images/thumb/3/32/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99.jpg/453px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99.jpg 1.5x, /images/thumb/3/32/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99.jpg/604px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99.jpg 2x\" /></a><figcaption>הרב תעיזי (<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a>)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99_2.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/ff/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99_2.jpg/220px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99_2.jpg\" decoding=\"async\" width=\"220\" height=\"146\" class=\"mw-file-element\" srcset=\"/images/thumb/f/ff/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99_2.jpg/330px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99_2.jpg 1.5x, /images/thumb/f/ff/%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99_2.jpg/440px-%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99_2.jpg 2x\" /></a><figcaption>הרב תעיזי בחנוכת המקווה</figcaption></figure>\n<p>הרב <b>אבינועם ניסים תעיזי</b> (נולד ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ח במנחם אב\">כ\"ח במנחם אב</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%95\" title=\"תשכ&quot;ו\">תשכ\"ו</a>) הוא שליח הרבי ורב היישוב תלמי יחיאל שב<a href=\"/index.php/%D7%9E%D7%95%D7%A2%D7%A6%D7%94_%D7%90%D7%96%D7%95%D7%A8%D7%99%D7%AA_%D7%91%D7%90%D7%A8_%D7%98%D7%95%D7%91%D7%99%D7%94\" title=\"מועצה אזורית באר טוביה\">מועצה אזורית באר טוביה</a>, משגיח ראשי ומשיב בישיבת '<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"בית הר&quot;מ נחלת הר חב&quot;ד\">בית הר\"מ</a>' שב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" title=\"קריית מלאכי\">קריית מלאכי</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%A9%D7%99%D7%9B%D7%95%D7%9F_%D7%97%D7%91%22%D7%93_%D7%9C%D7%95%D7%93\" class=\"mw-redirect\" title=\"שיכון חב&quot;ד לוד\">שיכון חב\"ד לוד</a> ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ח במנחם אב\">כ\"ח במנחם אב</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%95\" title=\"תשכ&quot;ו\">תשכ\"ו</a> לרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%AA%D7%A2%D7%99%D7%96%D7%99\" title=\"דוד תעיזי\">דוד תעיזי</a> ולכוכבה.\n</p><p>בשל כשרונו והתמדתו הרבה נכנס ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> עוד בהיותו בגיל אחד עשרה. בהמשך למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%94\" title=\"תשמ&quot;ה\">תשמ\"ה</a> נסע ל<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ישיבת תומכי תמימים המרכזית\">ישיבת תומכי תמימים המרכזית</a> שב-770 במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>', ושהה שם עד לשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>.\n</p><p>בשנת תשמ\"ח נישא לרעייתו אורלי, בת הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%99%D7%9E%D7%99%D7%A0%D7%99\" title=\"יעקב ימיני\">יעקב ימיני</a>.\n</p><p>זמן קצר לאחר נישואיו נתמנה לרב היישוב 'תלמי יחיאל' שבמישור החוף הדרומי, סמוך לעיר קריית מלאכי, והחל לפעול בו בשליחות הרבי להפצת התורה, המצוות והחסידות.\n</p><p>מספר שנים לאחר כך החל לשמש כמשגיח ומשיב בישיבת '<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"בית הר&quot;מ נחלת הר חב&quot;ד\">בית הר\"מ</a>' שבנחלת הר חב\"ד, בעיר קריית מלאכי הסמוכה.\n</p><p>הרב תעיזי חתם על <a href=\"/index.php/%D7%A4%D7%A1%D7%A7_%D7%94%D7%93%D7%99%D7%9F_%D7%A9%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%95%D7%90_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"פסק הדין שהרבי הוא מלך המשיח\">פסק הדין שהרבי הוא מלך המשיח</a>.\n</p>\n<h2><span id=\".D7.A4.D7.A2.D7.99.D7.9C.D7.95.D7.AA.D7.95_.D7.91.D7.99.D7.99.D7.A9.D7.95.D7.91\"></span><span class=\"mw-headline\" id=\"פעילותו_ביישוב\">פעילותו ביישוב</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;פעילותו ביישוב&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: פעילותו ביישוב\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הרב תעיזי מנהל פעילויות רבות ביישוב ובאזור - יישובי מועצה אזורית באר טוביה - בכלל; בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"תשנ&quot;ב\">תשנ\"ב</a> חנך <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA\" title=\"בית כנסת\">בית כנסת</a> חדש ומפואר ביישוב.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a> חנך <a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94\" title=\"מקווה\">מקווה טהרה</a> חדש ומפואר על פי <a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94_%D7%97%D7%91%22%D7%93\" title=\"מקווה חב&quot;ד\">שיטת חב\"ד</a> בהשתתפות רבנים ואישי ציבור.\n</p><p>במהלך השבוע מוסר הרב תעיזי <a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%AA%D7%95%D7%A8%D7%94\" title=\"מבצע תורה\">שיעורי תורה</a> רבים ביישוב - בהלכה, נגלה וחסידות.\n</p><p>ב<a href=\"/index.php/%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ל&quot;ג בעומר\">ל\"ג בעומר</a> בכל שנה מפעיל <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%95%D7%9B%D7%94\" title=\"תהלוכה\">תהלוכה</a> לתושבי הישוב והאזור בכלל, וכן מקיים פעילויות חינוכיות בגני הילדים באזור סמוך לחגים.\n</p><p>גישתו הייחודית מתאפיינת בהרעפת רגש חם ולבביות על כל יהודי הבא אתו במגע.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%AA%D7%A2%D7%99%D7%96%D7%99\" title=\"יוסף יצחק תעיזי\">יוסף יצחק תעיזי</a>, שליח הרבי ורב היישוב עזריאל שבשרון</li>\n<li>גיסו - הרב <a href=\"/index.php?title=%D7%99%D7%90%D7%99%D7%A8_%D7%91%D7%A1&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יאיר בס (הדף אינו קיים)\">יאיר בס</a>, משגיח ומגיד שיעור ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים קריית גת (קטנה)\">ישיבת תומכי תמימים בקריית גת (קטנה)</a></li>\n<li>גיסו - ה<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%9C%D7%9C_(%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94)\" title=\"משה הלל (אור יהודה)\">משה הלל (אור יהודה)</a></li>\n<li>חתנו - הרב מנחם מענדל גדסי, לוד</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%99%D7%A0%D7%95%D7%A2%D7%9D_%D7%AA%D7%A2%D7%99%D7%96%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/76465\">חג בתלמי יחיאל: נחנך מקווה בשיטת חב\"ד</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/25842\">אור החנוכה האיר בתלמי יחיאל</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/82978\">ל\"ג בעומר בתלמי יחיאל</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/54937\">קבלת התורה לגני הילדים במועצה האזורית באר טוביה</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D