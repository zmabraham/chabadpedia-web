      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"א&#39; בחשוון\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ב&#39; בחשוון\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ג&#39; בחשוון\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ד&#39; בחשוון\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ה&#39; בחשוון\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ו&#39; בחשוון\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ז&#39; בחשוון\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ח&#39; בחשוון\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ט&#39; בחשוון\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&#39; בחשוון\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&quot;א בחשוון\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&quot;ב בחשוון\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&quot;ג בחשוון\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ט&quot;ו בחשוון\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ט&quot;ז בחשוון\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&quot;ז בחשוון\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&quot;ח בחשוון\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"י&quot;ט בחשוון\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&#39; בחשוון\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;א בחשוון\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ב בחשוון\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ג בחשוון\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ד בחשוון\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ה בחשוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בחשוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בחשוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בחשוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בחשוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"ל&#39; בחשוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ד בחשוון</b> הוא היום הארבעה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חודש חשוון</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> (15/11/1940 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - גיטו <a href=\"/index.php/%D7%95%D7%A8%D7%A9%D7%94\" title=\"ורשה\">ורשה</a> נסגר ובו הריכוז ה<a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%99\" class=\"mw-redirect\" title=\"יהודי\">יהודי</a> הגדול ביותר בעולם.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%92\" title=\"תש&quot;ג\">תש\"ג</a> (25/10/1942 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הסתלק רבי אברהם אלימלך פרלוב מקרלין הי\"ד נספה בשואה.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A4%22%D7%94\" title=\"תקפ&quot;ה\">תקפ\"ה</a> (5/11/1824 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%91%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7)\" title=\"יהודה לייב שניאורסון (בן אדמו&quot;ר הצמח צדק)\">יהודה לייב שניאורסון</a>, בנו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a>, התחתן עם בתו של ר' <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%A4%D7%A8%D7%99%D7%99%D7%93%D7%A1\" title=\"שלמה פריידס\">שלמה פריידס</a> מ<a href=\"/index.php/%D7%A9%D7%A7%D7%9C%D7%95%D7%91\" title=\"שקלוב\">שקלוב</a> - מגדולי חסידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a>. <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a> השתתף בחתונה ואמר כמה מאמרי חסידות.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%90\" title=\"תרכ&quot;א\">תרכ\"א</a> (30/10/1860 למניינם) - הסתיימה כתיבת <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"ספר התורה\">ספר התורה</a> שנכתבה בהוראת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a> לקראת לידתו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> (4/11/1941 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הנאצים השמידו את ה<a href=\"/index.php/%D7%A2%D7%99%D7%99%D7%A8%D7%94\" title=\"עיירה\">עיירה</a> <a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a> והחריבו את <a href=\"/index.php/%D7%90%D7%95%D7%94%D7%9C_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7_%D7%95%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אוהל אדמו&quot;ר הצמח צדק ואדמו&quot;ר מהר&quot;ש\">אוהל אדמו\"ר הצמח צדק ואדמו\"ר מהר\"ש</a>, במהלך <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%99%D7%94\" title=\"מלחמת העולם השנייה\">מלחמת העולם השנייה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> - רכבת משא (\"עשאלון\") ועליה קבוצה של מאות חסידים יצאה מ<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> במסגרת הבריחה הגדולה <a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%96\" class=\"mw-redirect\" title=\"יציאת רוסיה תש&quot;ז\">יציאת רוסיה תש\"ז</a>.</li></ul>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%95%D7%99%D7%9C%D7%95%D7%9F..._2.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c5/%D7%94%D7%95%D7%99%D7%9C%D7%95%D7%9F..._2.jpg/250px-%D7%94%D7%95%D7%99%D7%9C%D7%95%D7%9F..._2.jpg\" decoding=\"async\" width=\"250\" height=\"166\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c5/%D7%94%D7%95%D7%99%D7%9C%D7%95%D7%9F..._2.jpg/375px-%D7%94%D7%95%D7%99%D7%9C%D7%95%D7%9F..._2.jpg 1.5x, /images/thumb/c/c5/%D7%94%D7%95%D7%99%D7%9C%D7%95%D7%9F..._2.jpg/500px-%D7%94%D7%95%D7%99%D7%9C%D7%95%D7%9F..._2.jpg 2x\" /></a><figcaption>הוילון נסגר בפעם האחרונה לעת עתה - <b>י\"ד מר-חשוון <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A0%22%D7%93\" class=\"mw-redirect\" title=\"ה&#39;תשנ&quot;ד\">ה'תשנ\"ד</a></b></figcaption></figure>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> (29/10/1993 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הפעם האחרונה <b>לעת עתה</b> בה נראה הרבי לחסידים, כשיצא ל<a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%AA_%D7%9E%D7%A0%D7%97%D7%94\" title=\"תפילת מנחה\">תפילת מנחה</a> ב<a href=\"/index.php/%D7%94%D7%9E%D7%A8%D7%A4%D7%A1%D7%AA\" title=\"המרפסת\">מרפסת</a>, כשהוא מעודד את שירת \"<a href=\"/index.php/%D7%99%D7%97%D7%99_%D7%90%D7%93%D7%95%D7%A0%D7%A0%D7%95_%D7%9E%D7%95%D7%A8%D7%A0%D7%95_%D7%95%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%A2%D7%95%D7%9C%D7%9D_%D7%95%D7%A2%D7%93\" title=\"יחי אדוננו מורנו ורבינו מלך המשיח לעולם ועד\"><span style=\"color: ;\">יחי אדוננו מורנו ורבינו מלך המשיח לעולם ועד</span></a>\"<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%96\" title=\"תרע&quot;ז\">תרע\"ז</a> (10/11/1916 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"מאיר גרינברג\">מאיר גרינברג</a>, רב העיר וואסטר שבמסצ'וסטס, והעיר פטרסון שבניו ג'רזי, וראש ישיבת תומכי תמימים ניו ג'רזי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A6\" title=\"תר&quot;צ\">תר\"צ</a> (17/11/1929 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%96%D7%90%D7%91_%D7%93%D7%91_%D7%94%D7%9C%D7%A4%D7%A8%D7%99%D7%9F_(%D7%A1%D7%A0%D7%94%D7%93%D7%A8%D7%99%D7%94)\" title=\"זאב דב הלפרין (סנהדריה)\">זאב דב הלפרין</a>, משפיע בקהילת חב\"ד סנהדריה ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> (28/10/1947 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%91%D7%A8%D7%95%D7%9A_%D7%92%D7%A8%D7%9C%D7%99%D7%A6%D7%A7%D7%99\" title=\"אברהם יצחק ברוך גרליצקי\">אברהם יצחק ברוך גרליצקי</a>, ר\"מ בישיבת <a href=\"/index.php/%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94_(%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1)\" class=\"mw-redirect\" title=\"אהלי תורה (קראון הייטס)\">אהלי תורה</a> ומנהל מערכת <a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5_%D7%94%D7%A2%D7%A8%D7%95%D7%AA_%D7%95%D7%91%D7%99%D7%90%D7%95%D7%A8%D7%99%D7%9D_%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"קובץ הערות וביאורים אהלי תורה\">קובץ הערות וביאורים אהלי תורה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%98\" title=\"תשי&quot;ט\">תשי\"ט</a> (28/10/1958 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%9C%D7%91%D7%A7%D7%99%D7%91%D7%A7%D7%A8\" class=\"mw-redirect\" title=\"ברוך לבקיבקר\">ברוך לבקיבקר</a>, רב, מחנך ו<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> ב<a href=\"/index.php/%D7%A6%D7%A4%D7%AA\" title=\"צפת\">צפת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"תשל&quot;ו\">תשל\"ו</a> (19/10/1975 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A8%D7%97%D7%9E%D7%99%D7%90%D7%9C_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"יוסף ירחמיאל הבלין\">יוסף ירחמיאל הבלין</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> לעיר פרנקפורט שב<a href=\"/index.php/%D7%92%D7%A8%D7%9E%D7%A0%D7%99%D7%94\" title=\"גרמניה\">גרמניה</a> ו<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%99%D7%A9%D7%99%D7%91%D7%94\" title=\"ראש ישיבה\">ראש ישיבת</a> <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%A8%D7%A0%D7%A7%D7%A4%D7%95%D7%A8%D7%98\" title=\"תומכי תמימים פרנקפורט\">חב\"ד בפרנקפורט</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%93_%D7%91%D7%97%D7%A9%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> (20/10/2022 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניים</a>) - הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%95%D7%91%D7%99%D7%A5\" title=\"משה מושקוביץ\">משה מושקוביץ</a>, מ<a href=\"/index.php/%D7%9E%D7%99%D7%9C%D7%95%D7%9F_%D7%97%D7%A1%D7%99%D7%93%D7%99:%D7%90%D7%A0%22%D7%A9\" title=\"מילון חסידי:אנ&quot;ש\">אנ\"ש</a> ב<a href=\"/index.php/%D7%A9%D7%99%D7%9B%D7%95%D7%9F_%D7%97%D7%91%22%D7%93_%D7%91%D7%9C%D7%95%D7%93\" class=\"mw-redirect\" title=\"שיכון חב&quot;ד בלוד\">שיכון חב\"ד בלוד</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ד בחשוון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>מ<a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94_(%D7%A9%D7%9D)\" title=\"הוי&quot;ה (שם)\">ה'</a> מצעדי גבר כוננו, לכל אחד מ<a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"ישראל\">ישראל</a> יש לו תעודה רוחנית בחיים, והוא להתעסק בעבודת הבנין לעשות <a href=\"/index.php/%D7%93%D7%99%D7%A8%D7%94_%D7%91%D7%AA%D7%97%D7%AA%D7%95%D7%A0%D7%99%D7%9D\" title=\"דירה בתחתונים\">דירה לו יתברך</a>. וכל אחד באשר הוא ובכל מקום שהוא צריך להתעניין בכל מאמצי כוחו לחפש בחפש מחופש למצוא איזה פרנסה רוחנית כמו שהוא מחפש אחר פרנסה גשמית. והוא לפי שדרכו - של הקדוש ברוך הוא - יחפץ, כדכתיב ב<a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D\" class=\"mw-redirect\" title=\"אברהם\">אברהם</a> כי ידעתיו גו' ושמרו דרך ה', כי יש שני דרכים: דרך ה<a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"טבע\">טבע</a> וש<a href=\"/index.php?title=%D7%9C%D7%9E%D7%A2%D7%9C%D7%94_%D7%9E%D7%9F_%D7%94%D7%98%D7%91%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"למעלה מן הטבע (הדף אינו קיים)\">למעלה מן הטבע</a>, העולם בראו הקדוש ברוך הוא להיות נראה כמו שהוא בדרך הטבע - בעיני בשר - והוא דרך <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%99%D7%9D\" title=\"אלקים\">אלקים</a>. <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> ו<a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מצות\">מצות</a> הם דרך <a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"הוי&quot;ה\">הוי\"ה</a> והוא המשכה ש<a href=\"/index.php?title=%D7%9C%D7%9E%D7%A2%D7%9C%D7%94_%D7%9E%D7%9F_%D7%94%D7%98%D7%91%D7%A2&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"למעלה מן הטבע (הדף אינו קיים)\">למעלה מן הטבע</a> ב<a href=\"/index.php/%D7%98%D7%91%D7%A2\" title=\"טבע\">טבע</a>, אשר בגלל זאת הנה הקדוש ברוך הוא משפיע לישראל למעלה מן הטבע בטבע.\n</td></tr></tbody></table>\n<p><br />\n</p>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/114029\">י\"ד חשוון תשנ\"ד: כשהוילון נסגר<span typeof=\"mw:File\"></span></a><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7