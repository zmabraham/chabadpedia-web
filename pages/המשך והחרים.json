      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"infobox\" style=\"width:25%; border: 1px solid #339999; background-color: #cceeee; margin-bottom: 0.5em; margin-right: 1em; padding: 0.2em; color: black; float: left; text-align: center; font-size: 85%; clear:right;\">\n\n<tbody><tr style=\"background:lightblue;\">\n<th style=\"background-color: #339999;\"><font size=\"4\"><a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמרי</a> <a href=\"/index.php/%D7%A8%D7%91%D7%95%D7%AA%D7%99%D7%A0%D7%95_%D7%A0%D7%A9%D7%99%D7%90%D7%A0%D7%95\" class=\"mw-redirect\" title=\"רבותינו נשיאנו\">רבותינו נשיאנו</a></font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%94%D7%90%D7%9E%D7%A0%D7%9D\" title=\"האמנם\">האמנם</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%93%D7%A2%D7%A8_%D7%A4%D7%A8%D7%95%D7%9E%D7%A2%D7%A8_%D7%95%D7%90%D7%A8%D7%90\" title=\"דער פרומער וארא\">דער פרומער וארא</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%9C_%D7%AA%D7%A6%D7%A8_%D7%90%D7%AA_%D7%9E%D7%95%D7%90%D7%91\" title=\"אל תצר את מואב\">אל תצר את מואב</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%99%D7%AA%D7%90_%D7%91%D7%9E%D7%93%D7%A8%D7%A9_%D7%AA%D7%99%D7%9C%D7%99%D7%9D\" title=\"איתא במדרש תילים\">איתא במדרש תילים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%95%D7%94%D7%93%D7%A8%D7%AA_%D7%A4%D7%A0%D7%99_%D7%96%D7%A7%D7%9F_(%D7%9E%D7%90%D7%9E%D7%A8)\" title=\"והדרת פני זקן (מאמר)\">והדרת פני זקן</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9B%D7%AA%D7%91_%D7%99%D7%93_%D7%93%D7%90%22%D7%97_%D7%99%D7%A9%D7%9F_%D7%9C%D7%90_%D7%A0%D7%95%D7%93%D7%A2_%D7%9C%D7%9E%D7%99\" title=\"כתב יד דא&quot;ח ישן לא נודע למי\">כתב יד דא\"ח ישן לא נודע למי</a> <span st