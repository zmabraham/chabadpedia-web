    "pageid": 21421,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/34/%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99.jpg/220px-%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99.jpg\" decoding=\"async\" width=\"220\" height=\"223\" class=\"mw-file-element\" srcset=\"/images/thumb/3/34/%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99.jpg/330px-%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99.jpg 1.5x, /images/thumb/3/34/%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99.jpg/440px-%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99.jpg 2x\" /></a><figcaption>הרב אלאשוילי</figcaption></figure>\n<p>הרב <b>אברהם אלאשווילי</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a>, 1964) הוא <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסיד</a> <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> המתגורר ב<a href=\"/index.php/%D7%A9%D7%99%D7%9B%D7%95%D7%9F_%D7%97%D7%91%22%D7%93_%D7%9C%D7%95%D7%93\" class=\"mw-redirect\" title=\"שיכון חב&quot;ד לוד\">שיכון חב\"ד לוד</a>, עורכם ומחברם של ספרים תורניים רבים ויושב ראש '<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%A1%D7%A4%D7%A8\" title=\"מכון הספר\">מכון הספר</a>'.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בעיירה קולאשי שב<a href=\"/index.php/%D7%92%D7%A8%D7%95%D7%96%D7%99%D7%94\" class=\"mw-redirect\" title=\"גרוזיה\">גרוזיה</a> ב<a href=\"/index.php/%D7%9B%22%D7%96_%D7%90%D7%91\" class=\"mw-redirect\" title=\"כ&quot;ז אב\">כ\"ז אב</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%93\" title=\"תשכ&quot;ד\">תשכ\"ד</a> לאביו החכם <a href=\"/index.php/%D7%A8%D7%A4%D7%90%D7%9C_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99\" title=\"רפאל אלאשוילי\">רפאל אלאשוילי</a>, שלימים שימש כרבה של העדה הגרוזינית בישראל ודיינה.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"תשל&quot;ב\">תשל\"ב</a> עלה יחד עם משפחתו ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a> והתיישב ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>. בצעירותו למד בישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a>, <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_770\" class=\"mw-redirect\" title=\"תומכי תמימים 770\">תומכי תמימים 770</a>.\n</p><p>לאחר חתונתו עם רעייתו מלכה בת ר' אבישי בטאשווילי התיישב ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>, לצידו של אביו, ולמד בכולל האברכים לעולי גרוזיה.\n</p>\n<h2><span id=\".D7.A2.D7.A8.D7.99.D7.9B.D7.AA_.D7.A1.D7.A4.D7.A8.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"עריכת_ספרים\">עריכת ספרים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;עריכת ספרים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: עריכת ספרים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>במהלך לימוד הלכות שבת החל בעריכת 'קיצור להלכות שבת' מ<a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_%D7%94%D7%A8%D7%91\" class=\"mw-redirect\" title=\"שולחן ערוך הרב\">שולחן ערוך הרב</a>. לאחר פתיחת <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%90%D7%94%D7%9C%D7%99_%D7%A9%D7%9D\" class=\"mw-redirect\" title=\"מכון אהלי שם\">מכון אהלי שם</a> התקבל כחבר במכון, והמשיך בעריכת הקיצור (יחד עם הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%94%D7%95%D7%A8%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יעקב הורביץ\">יעקב הורביץ</a> מ<a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" title=\"ראשון לציון\">ראשון לציון</a>), בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A0\" title=\"תש&quot;נ\">תש\"נ</a> הו\"ל את הקיצורים כספר.\n</p><p>בהמשך עבודתו במכון הוציא לאור מספר ספרים, כשהבולט שבהם הוא <a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%94%D7%9E%D7%9C%D7%9A\" class=\"mw-redirect\" title=\"שולחן המלך\">שולחן המלך</a> - לקט מביאורי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> על <a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"שולחן ערוך אדמו&quot;ר הזקן\">שולחן ערוך אדמו\"ר הזקן</a>.\n</p><p>במהלך השנים פרש הרב אלאשווילי מן המכון [שכיום מוציא [בדר\"כ] רק את כתבי מייסדו ר' <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%99%D7%95%D7%97%D7%A0%D7%9F_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"אליהו יוחנן גוראריה\">אליהו יוחנן גורארי</a>'] ופתח את <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%A1%D7%A4%D7%A8\" title=\"מכון הספר\">מכון הספר</a> (מקביל ל\"נחלת הספר\" <sup>[דרושה הבהרה: מה זה נחלת הספר?]</sup>). במסגרת עבודתו במכון ערך והוציא את הספר <a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90_%D7%9E%D7%91%D7%95%D7%90%D7%A8\" class=\"mw-redirect\" title=\"תניא מבואר\">תניא מבואר</a>  [התניא הראשון שיש בו גם ביאור קצר, גם ללא שינוי צורת הדף, וגם עם שפע מראי מקומות], תדפיס מ\"רמב\"ם מבואר\", הלכות משו\"ע <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> מנקודות ומבוארות, \"חשבונו של עולם\" על הנהגות הרבי בשנים <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>-<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> (נערך על ידי <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%9C%D7%99%D7%A4%D7%A7%D7%99%D7%9F\" title=\"בנימין ליפקין\">בנימין ליפקין</a>) הרז\"א, ועוד.\n</p><p>בד בבד, החל בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> (במסגרת <a href=\"/index.php/%D7%9E%D7%A2%D7%A8%D7%9B%D7%AA_%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מערכת אוצר החסידים\">מערכת אוצר החסידים</a>) את עריכת המהדורה החדשה של <a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"שולחן ערוך אדמו&quot;ר הזקן\">שולחן ערוך אדמו\"ר הזקן</a>, בליווי שפע של הערות, מראי מקומות וציונים. את המלאכה השלים הרב אלאשווילי (יחד עם הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%95%D7%99%D7%9F\" title=\"שלום דובער לוין\">שלום דובער לוין</a> וחברי מערכת נוספים) בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a>.\n</p><p>בשנים האחרונות פתח הרב אלאשווילי בשלושה פרויקטים חדשים: א) הוצאת הלכות שבת ל<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> בליווי מקורות, מקבילות, טעמים ותוספת דינים. פרקים מיצירה זו מתפרסמים מזמן לזמן במקומות שונים. ב) <a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%A0%D7%91%D7%95%D7%9B%D7%99%D7%9D\" title=\"מורה נבוכים\">מורה נבוכים</a> עם הערות והארות מתורתם של <a href=\"/index.php/%D7%A8%D7%91%D7%95%D7%AA%D7%99%D7%A0%D7%95_%D7%A0%D7%A9%D7%99%D7%90%D7%A0%D7%95\" class=\"mw-redirect\" title=\"רבותינו נשיאנו\">רבותינו נשיאנו</a>. ג) אש\"ל אברהם - <a href=\"/index.php/%D7%97%D7%95%D7%9E%D7%A9_(%D7%A1%D7%A4%D7%A8)\" title=\"חומש (ספר)\">חומש</a> בו מתבארים שלושת הפרשנים המרכזיים - תרגום אונקלוס, שבה במהדורה זו עם ביאורי מילים והדגשת תוספת פירוש של אונקלוס. <a href=\"/index.php/%D7%A8%D7%A9%22%D7%99\" title=\"רש&quot;י\">רש\"י</a> - עם ביאורים מלוקטים מגדולי המפרשים, מנשיא דורנו וביאורי העורך וליקוט מיוחד מפירושי <a href=\"/index.php/%D7%94%D7%A8%D7%9E%D7%91%22%D7%9D\" class=\"mw-redirect\" title=\"הרמב&quot;ם\">הרמב\"ם</a> לתורה. יצאו לאור חמשה כרכים על חמשת חומשי התורה.\n</p><p>משנת תשע\"ד יזם מבצע לימוד מיוחד - מבחן בשו\"ע הרב, שנערך בכל שנה בכ\"ד טבת יום ההילולא של אדמו\"ר הזקן, בו נבחנים אלפי אברכים בכל שנה על חלקים נבחרים בשו\"ע הרב בעיון.\n</p><p>לקראת <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%99%22%D7%98_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חג הגאולה י&quot;ט כסלו\">חג הגאולה י\"ט כסלו</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> השיק הרב אלאשווילי (יחד עם אחיו הרב אהרן אלאשווילי) את <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%A0%D7%99%D7%90\" title=\"ספר התניא\">ספר התניא</a> במהדורה מתורגמת לשפה הגיאורגית.\n</p><p>כמו כן משמש הרב אלאשווילי כחבר בוועד הביקורת של \"פרס הספרות החב\"די\" שעל ידי 'מכון תפארת לוי', ועומד בראש בית המדרש הווירטואלי \"חברים מקשיבים\".\n</p>\n<h3><span id=\".D7.97.D7.A9.D7.99.D7.A4.D7.AA_.D7.A9.D7.95.D7.A8.D7.95.D7.AA_.D7.97.D7.93.D7.A9.D7.95.D7.AA_.D7.91.D7.A9.D7.95.D7.9C.D7.97.D7.9F_.D7.A2.D7.A8.D7.95.D7.9A_.D7.90.D7.93.D7.9E.D7.95.22.D7.A8_.D7.94.D7.96.D7.A7.D7.9F\"></span><span class=\"mw-headline\" id=\"חשיפת_שורות_חדשות_בשולחן_ערוך_אדמו&quot;ר_הזקן\">חשיפת שורות חדשות בשולחן ערוך אדמו\"ר הזקן</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;חשיפת שורות חדשות בשולחן ערוך אדמו&quot;ר הזקן&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: חשיפת שורות חדשות בשולחן ערוך אדמו&quot;ר הזקן\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>בפורים קטן <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a>, התפרסם ב<a href=\"/index.php/%D7%A2%D7%99%D7%AA%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"עיתון כפר חב&quot;ד\">עיתון כפר חב\"ד</a>, שהרב אלאשוילי, הצליח למצא בתוך ספר בכתב יד (מכונה \"ביכל\") שהגיע העתק ממנו תקופה קצרה קודם לכן מספריה בשם \"אוסף שוקן\", ל<a href=\"/index.php/%D7%A1%D7%A4%D7%A8%D7%99%D7%99%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" class=\"mw-redirect\" title=\"ספריית ליובאוויטש\">ספריית ליובאוויטש</a>, שורות נוספות במספר סעיפים בסימנים קנ\"ה-קנ\"ו. החשיפה הביאה לרעש גדול בכל עולם התורה היהודי.\n</p><p>הדבר נעשה בזכות שכמה ימים קודם לכן, עלתה מכתב היד סריקה לאתר הספריה, הרב אלאשוילי מצא באמצע 'ביכל' שרובו מאמרים ארבע עמודים שלשם נעתקו סימנים מ<a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_%D7%94%D7%A8%D7%91\" class=\"mw-redirect\" title=\"שולחן ערוך הרב\">שולחן ערוך הרב</a>, ושם מצא מספר שורות שלא נודעו עד אז.\n</p><p>חלקים גדולים של <a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"שולחן ערוך אדמו&quot;ר הזקן\">שולחן ערוך אדמו\"ר הזקן</a> נשרפו, ושני סימנים אלו לא היו אצל בני הגאון המחבר בזמן שהדפיסו את השולחן ערוך, ונוספו רק במהדורות מאוחרות יותר מהעתקים של חסידים, והרב אלאשוילי מצא העתק עם חלקים נוספים.\n</p><p>שורות אלו נדפסו ב<a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"שולחן ערוך אדמו&quot;ר הזקן\">שולחן ערוך אדמו\"ר הזקן</a> ע\"י מערכת \"<a href=\"/index.php/%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" title=\"אוצר החסידים\">אוצר החסידים</a>\" בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.91.D7.99.D7.A9.D7.99.D7.91.D7.94_.D7.91.D7.9C.D7.95.D7.93\"></span><span class=\"mw-headline\" id=\"בישיבה_בלוד\">בישיבה בלוד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;בישיבה בלוד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: בישיבה בלוד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>במשך שנים ארוכות שימש הרב אלאשווילי כ<a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> ו<a href=\"/index.php/%D7%A0%D7%95%22%D7%A0\" class=\"mw-redirect\" title=\"נו&quot;נ\">נו\"נ</a> ב<a href=\"/index.php/%D7%92%D7%9E%D7%A8%D7%90\" class=\"mw-redirect\" title=\"גמרא\">גמרא</a> לגירסא בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a>. פרישתו היתה עקב עיסוקיו הרבים.\n</p><p>בשנים תש\"ע-תשע\"ט החל הרב אלאשווילי למסור מדי שבוע במוצאי השבת (בחורף) שיעור בהלכה, בו מוצגים בפניו שאלות שונות בהלכה מאת תלמידי הישיבה ועליהם הוא עונה במקום.\n</p>\n<h2><span id=\".D7.97.D7.99.D7.91.D7.95.D7.A8.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"חיבוריו\">חיבוריו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;חיבוריו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: חיבוריו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>שולחן המלך</b> - ביאורים והערות מ<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> על <a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"שולחן ערוך אדמו&quot;ר הזקן\">שולחן ערוך אדמו\"ר הזקן</a></li>\n<li><b>שו\"ע אדמו\"ר הזקן </b> - מהדורה חדשה בתוספת הערות, מראי מקומות וציונים ומפתח ענינים וספרים על שו\"ע אדה\"ז (עורך-שותף)</li>\n<li><b>שולחן ערוך המבואר</b> - שו\"ע אדה\"ז בתוספת פירוש והסבר בלשון קלה</li>\n<li><b>קיצור הלכות שבת</b> - קיצור הלכות שבת מתוך שו\"ע אדה\"ז</li>\n<li><b>חומש אשל אברהם</b> - ביאור מקיף על תרגום אונקלוס ורש\"י ופירוש מלוקט מהרמב\"ם על התורה</li>\n<li><b>היום יום המבואר</b> - מבאר בהרחבה את פתגמי '<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>' כשהוא מביא את כל הביאורים שנאמרו ונכתבו על ידי הרבי במשך השנים</li>\n<li><b>חשבונו של עולם</b> - המתאר את הנהגות הרבי בשנים תשמ\"ח - תשנ\"ד</li>\n<li><b>מורה נבוכים</b> - ביאורים על הספר מורה נבוכים בתפיסת חסידות חב\"ד</li>\n<li><b>שער היחוד והאמונה</b> - ביאור קצר על אגרת התשובה ושער היחוד והאמונה</li>\n<li><b>תניא מבואר</b> - ביאור מקיף וקצר על כל ספר התניא עם פיסוק מלא בתוך גוף הספר</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://shulchanharav.com/\">אתר שולחן הרב</a> של הרב אלאשוילי</li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.shturem.net/index.php?section=news&amp;id=74731\">\"בגלל מה שעבר, אבי סירב שאירש את מקומו כמנהיג העדה הגיאורגית\"</a>&#160;- ב<a href=\"/index.php/%D7%A9%D7%98%D7%95%D7%A8%D7%A2%D7%9D_(%D7%90%D7%AA%D7%A8)\" title=\"שטורעם (אתר)\">אתר שטורעם</a> <span class=\"grayText\"><small>(הקישור אינו פעיל, ג' סיון תשפ\"ג)</small></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://anash.org/scholar-discovers-new-sections-of-alter-rebbes-shulchan-aruch/\">כתבה באנגלית על חשיפת השורות בשולחן ערוך אדמו\"ר הזקן על ידי הרב אלאשוילי</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%90%D7%A0%22%D7%A9_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר אנ&quot;ש\"><img alt=\"קישור לאתר אנ&quot;ש\" src=\"/images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/22px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg\" decoding=\"async\" width=\"22\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/33px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg 1.5x, /images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/44px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/136730\">חשיפה היסטורית בשבועון 'כפר חב\"ד': סעיפים חדשים מאדה\"ז</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/140913\">תגלית השנה ומשאלה לתשפ\"ג</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">כרך א' לאחר לוח התיקונים וההשוואות בעמוד 68.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413192416\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.070 seconds\nReal time usage: 0.404 seconds\nPreprocessor visited node count: 183/1000000\nPost‐expand include size: 1035/2097152 bytes\nTemplate argument size: 186/2097152 bytes\nHighest expansion depth: 7/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 425