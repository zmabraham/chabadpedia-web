      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%90_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/7a/%D7%99%D7%90_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A.jpg/250px-%D7%99%D7%90_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A.jpg\" decoding=\"async\" width=\"250\" height=\"312\" class=\"mw-file-element\" srcset=\"/images/thumb/7/7a/%D7%99%D7%90_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A.jpg/375px-%D7%99%D7%90_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A.jpg 1.5x, /images/thumb/7/7a/%D7%99%D7%90_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A.jpg/500px-%D7%99%D7%90_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A.jpg 2x\" /></a><figcaption>הרב יעקב אליעזר פרידריך</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%9E%D7%99%D7%99%D7%A2%D7%A8%D7%A1.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/64/%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%9E%D7%99%D7%99%D7%A2%D7%A8%D7%A1.jpg/220px-%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%9E%D7%99%D7%99%D7%A2%D7%A8%D7%A1.jpg\" decoding=\"async\" width=\"220\" height=\"133\" class=\"mw-file-element\" srcset=\"/images/thumb/6/64/%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%9E%D7%99%D7%99%D7%A2%D7%A8%D7%A1.jpg/330px-%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%9E%D7%99%D7%99%D7%A2%D7%A8%D7%A1.jpg 1.5x, /images/thumb/6/64/%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%9E%D7%99%D7%99%D7%A2%D7%A8%D7%A1.jpg/440px-%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%9E%D7%99%D7%99%D7%A2%D7%A8%D7%A1.jpg 2x\" /></a><figcaption>הרב פרידריך (משמאל) לצד הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9E%D7%A9%D7%94_%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F\" title=\"דוד משה ליברמן\">דוד משה ליברמן</a>, מזקני חסידי חב\"ד ורב הקהילה היהודית ב<a href=\"/index.php/%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"אנטוורפן\">אנטוורפן</a> שב<a href=\"/index.php/%D7%91%D7%9C%D7%92%D7%99%D7%94\" title=\"בלגיה\">בלגיה</a> (מימין) והרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%93%D7%A0%D7%99%D7%90%D7%9C_%D7%9E%D7%99%D7%99%D7%A8%D7%A1\" title=\"אליעזר דניאל מיירס\">אליעזר דניאל מיירס</a>, מראשוני פעילי חב\"ד ב<a href=\"/index.php/%D7%90%D7%9E%D7%A1%D7%98%D7%A8%D7%93%D7%9D\" class=\"mw-redirect\" title=\"אמסטרדם\">אמסטרדם</a> (במרכז)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%99%D7%9A.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/2c/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%99%D7%9A.jpg/220px-%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%99%D7%9A.jpg\" decoding=\"async\" width=\"220\" height=\"146\" class=\"mw-file-element\" srcset=\"/images/thumb/2/2c/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%99%D7%9A.jpg/330px-%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%99%D7%9A.jpg 1.5x, /images/thumb/2/2c/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%99%D7%9A.jpg/440px-%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%99%D7%9A.jpg 2x\" /></a><figcaption>הרב פרידריך עובר לפני הרבי בחלוקת דולרים</figcaption></figure>\n<p>הרב <b>יעקב אליעזר פרידריך</b> (<a href=\"/index.php/%D7%99%22%D7%90_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"י&quot;א חשוון\">י\"א חשוון</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%91\" title=\"תרפ&quot;ב\">תרפ\"ב</a> - <a href=\"/index.php/%D7%99%22%D7%91_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"י&quot;ב תשרי\">י\"ב תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a>), היה זקן חסידי חב\"ד, מרבני קהילת חב\"ד ב<a href=\"/index.php/%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"אנטוורפן\">אנטוורפן</a> שב<a href=\"/index.php/%D7%91%D7%9C%D7%92%D7%99%D7%94\" title=\"בלגיה\">בלגיה</a>, ממייסדי וחבר הנהלת תלמוד תורה חב\"ד ב<a href=\"/index.php/%D7%90%D7%9E%D7%A1%D7%98%D7%A8%D7%93%D7%9D\" class=\"mw-redirect\" title=\"אמסטרדם\">אמסטרדם</a>, ופעיל בהפצת <a href=\"/index.php/%D7%A9%D7%91%D7%A2_%D7%9E%D7%A6%D7%95%D7%95%D7%AA_%D7%91%D7%A0%D7%99_%D7%A0%D7%97\" title=\"שבע מצוות בני נח\">שבע מצוות בני נח</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%99%22%D7%90_%D7%97%D7%A9%D7%95%D7%9F\" class=\"mw-redirect\" title=\"י&quot;א חשון\">י\"א חשון</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%91\" title=\"תרפ&quot;ב\">תרפ\"ב</a> ב<a href=\"/index.php/%D7%90%D7%99%D7%A8%D7%95%D7%A4%D7%94\" title=\"אירופה\">אירופה</a> בתקופה שבין מלחמת העולם הראשונה והשניה, כאשר זמן קצר קודם לידתו עזב אביו את דרך התורה והמצוות, ובעודו ילד רך בגיל שש בלבד נטש אביו את המשפחה והותיר אותו אצל איכר קתולי.\n</p><p>כעבור תלאות שונות, אימצה אותו משפחת שומרת תורה ומצוות ב<a href=\"/index.php/%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"אנטוורפן\">אנטוורפן</a>, שגאלה אותו מידי המשפחה הקתולית שם השאיר אותו אביו.\n</p><p>במקביל ללימודיו, נאלץ לשמש במקביל כשוליית צורף כדי שלא ליפול לנטל על הקהילה במימון לימודיו.\n</p><p>כאשר פרצה <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%99%D7%94\" title=\"מלחמת העולם השנייה\">מלחמת העולם השנייה</a>, נכשל בנסיון להימלט מבלגיה, ונותר באנטוורפן שנכבשה על ידי הנאצים, והיה עד לראשית הגירוש וההשמדה של יהדות <a href=\"/index.php/%D7%94%D7%95%D7%9C%D7%A0%D7%93\" title=\"הולנד\">הולנד</a>. כיון ששמע את הזוועות המתחוללות במדינות השכנות, לא נשמע להוראות המשטרה היהודית והתחבא לאורך כל התקופה מעין רואים וניצל בניסים מידי הנאצים.\n</p><p>לאחר סיום המלחמה נותר באנטוורפן, וקבע את מגוריו במרכז העיר שם היה מהדמויות המרכזיות בקהילה היהודית המתחדשת.\n</p><p>התקרב לחסידות בין השאר על ידי הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A6%D7%97%D7%95%D7%91%D7%9C\" title=\"משה צחובל\">משה צחובל</a>, וזכה לחוויות אישיות וניסים הן עם אדמו\"ר הריי\"צ והן עם הרבי.\n</p><p>היה נוסע לעיתים תכופות ל<a href=\"/index.php/%D7%90%D7%9E%D7%A1%D7%98%D7%A8%D7%93%D7%9D\" class=\"mw-redirect\" title=\"אמסטרדם\">אמסטרדם</a> שבהולנד ולערוך התוועדויות ושיעורים בהם קירב צעירים לחסידות, וסייע בתרגום שיחות קודש של הרבי לשפת המקום.\n</p><p>בשעה שסייע להרב <a href=\"/index.php/%D7%90%D7%95%D7%A8%D7%99_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9B%D7%94%D7%9F\" title=\"אורי יהודה כהן\">אורי יהודה כהן</a> בהקמת תלמוד תורה חב\"די באמסטרדם, זכה לחוות נס גלוי כאשר אדם הרחוק משמירת תורה ומצוות פגש בו והניח עבור הבניה בדיוק את הסכום הגדול שהיה צריך לשלם לקבלן הבניה<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>כאשר דיווח לרבי על מסירת שיעור קבוע בפני קבוצות נשים, הורה לו הרבי שבשל אופי אוכלוסיית הנשים יש להקדיש חלק מזמן השיעור כדי לתת להן את האפשרות לשאול שאלות במטרה לעניין אותן יותר ולמשוך אותן לשיעורים<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>הרב פרידריך היה מזקני קהילת חב\"ד ב<a href=\"/index.php/%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"אנטוורפן\">אנטוורפן</a> שבבלגיה, ממייסדי וחבר הנהלת תלמוד תורה חב\"ד באמסטרדם, ופעיל בהפצת <a href=\"/index.php/%D7%A9%D7%91%D7%A2_%D7%9E%D7%A6%D7%95%D7%95%D7%AA_%D7%91%D7%A0%D7%99_%D7%A0%D7%97\" title=\"שבע מצוות בני נח\">שבע מצוות בני נח</a>.\n</p><p>נפטר ב<a href=\"/index.php/%D7%99%22%D7%91_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"י&quot;ב תשרי\">י\"ב תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> בסמיכות לגיל 102. הלוויתו יצאה מבית קהילת 'מחזיקי הדת' באנטוורפן שב<a href=\"/index.php/%D7%91%D7%9C%D7%92%D7%99%D7%94\" title=\"בלגיה\">בלגיה</a> לעבר בית החיים פיטע שב<a href=\"/index.php/%D7%94%D7%95%D7%9C%D7%A0%D7%93\" title=\"הולנד\">הולנד</a>, שם נטמן<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"ספרו\">ספרו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ספרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ספרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%A1%D7%A4%D7%A8.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/52/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%A1%D7%A4%D7%A8.jpg/220px-%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%A1%D7%A4%D7%A8.jpg\" decoding=\"async\" width=\"220\" height=\"330\" class=\"mw-file-element\" srcset=\"/images/thumb/5/52/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%A1%D7%A4%D7%A8.jpg/330px-%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%A1%D7%A4%D7%A8.jpg 1.5x, /images/thumb/5/52/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%A1%D7%A4%D7%A8.jpg/440px-%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A_%D7%A1%D7%A4%D7%A8.jpg 2x\" /></a><figcaption>ספרו של הרב פרידריך</figcaption></figure>\n<ul><li><b>By the Hand of Hashem</b> (ביד השם), הוצאת פלדהיים <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> (יצא גם בתרגום לעברית בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> תחת השם <b>הושענא נפש מבהלה</b> ובתרגום לאידיש תחת השם <b>אליין אויפן פראנט</b>)</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, ר' ישראל סאנדל פרידריך - אנטוורפן (נפטר ב<a href=\"/index.php/%D7%91%27_%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"ב&#39; אייר\">ב' אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a>)</li>\n<li>בנו, ר' אברהם פרידריך - מנצ'סטר</li>\n<li>בתו מרת אדלר - לונדון</li>\n<li>בתו, מרת גולדמן - בורו פארק</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9E%D7%A2%D7%A0%D7%93%D7%99_%D7%A7%D7%95%D7%A8%D7%98%D7%A1\" class=\"mw-redirect\" title=\"מענדי קורטס\">מענדי קורטס</a>, <b>אוד מוצל מבריסל</b>, שבועון כפר חב\"ד גליון 1991, פרשת ויגש תשפ\"ג.</li></ul>\n<ul><li>הושענא נפש מבהלה, זכרונות רבי יעקב פריעדריך, הוצאת תפארת, חשוון תשע\"ט. (על התקשרותו לרבי הריי\"צ ולרבי, מסופר בפרק שלושה עשר: \"קשר וקרבה לאדמור\"י ליובאוויטש\").</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://www.teshura.com/teshurapdf/%D7%AA%D7%A9%D7%95%D7%A8%D7%94%20%D7%97%D7%AA%D7%95%D7%A0%D7%AA%20%D7%9E%D7%90%D7%99%D7%A8%20%D7%A9%D7%9C%D7%9E%D7%94%20%D7%95%D7%97%D7%99%27%20%D7%9E%D7%95%D7%A9%D7%A7%D7%90%20%D7%91%D7%A8%D7%95%D7%A7.pdf\">מכתבים שקיבל מהרבי</a></b>, בתוך תשורה מנישואי צאצאיו, ל' תשרי תשפ\"ג</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">גיליון 'אגעדאנק' פקודי תשע\"ט.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">אגרות קודש חלק ט' עמוד פד אגרת ב'תרצז.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/bdh/1010684/\">אבל בחב\"ד: הרב יעקב אליעזר פרידריך ע\"ה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/147926\">זקן חסידי חב\"ד: הרב יעקב אליעזר פרידריך ע\"ה נפטר בגיל 102</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414063049\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.07