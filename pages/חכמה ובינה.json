D7%94%D7%99%D7%A1%D7%95%D7%93\" title=\"ספירת היסוד\">יסוד</a> · <a href=\"/index.php/%D7%A1%D7%A4%D7%99%D7%A8%D7%AA_%D7%94%D7%9E%D7%9C%D7%9B%D7%95%D7%AA\" title=\"ספירת המלכות\">מלכות</a>\n</td></tr>\n<tr>\n<th style=\"padding-left:15px;padding-right:15px;background:#E5E5FF; color: #000000;\"><span style=\"white-space: nowrap;\">חלוקת הספירות</span>\n</th>\n<td colspan=\"2\" width=\"100%\" align=\"right\"><a href=\"/index.php/%D7%A7%D7%95_%D7%94%D7%99%D7%9E%D7%99%D7%9F\" title=\"קו הימין\">קו הימין</a> · <a href=\"/index.php/%D7%A7%D7%95_%D7%94%D7%A9%D7%9E%D7%90%D7%9C\" title=\"קו השמאל\">קו השמאל</a> · <a href=\"/index.php/%D7%A7%D7%95_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" title=\"קו האמצעי\">קו האמצעי</a> · <a href=\"/index.php/%D7%9E%D7%95%D7%97%D7%99%D7%9F\" class=\"mw-redirect\" title=\"מוחין\">מוחין</a> · <a href=\"/index.php/%D7%9E%D7%99%D7%93%D7%95%D7%AA_(%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA)\" title=\"מידות (ספירות)\">מידות</a>\n</td></tr>\n<tr>\n<th style=\"padding-left:15px;padding-right:15px;background:#E5E5FF; color: #000000;\"><span style=\"white-space: nowrap;\">ספירות-זוגות</span>\n</th>\n<td colspan=\"2\" width=\"100%\" align=\"right\"><a href=\"/index.php?title=%D7%9B%D7%AA%D7%A8_%D7%95%D7%97%D7%9B%D7%9E%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כתר וחכמה (הדף אינו קיים)\">כתר וחכמה</a> · <a href=\"/index.php?title=%D7%9B%D7%AA%D7%A8_%D7%95%D7%91%D7%99%D7%A0%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כתר ובינה (הדף אינו קיים)\">כתר ובינה</a> · <a href=\"/index.php?title=%D7%9B%D7%AA%D7%A8_%D7%95%D7%93%D7%A2%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כתר ודעת (הדף אינו קיים)\">כתר ודעת</a> · <a class=\"mw-selflink selflink\">חכמה ובינה</a> · <a href=\"/index.php/%D7%91%D7%99%D7%A0%D7%94_%D7%95%D7%9E%D7%99%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"בינה ומידות\">בינה ומידות</a> · <a href=\"/index.php?title=%D7%97%D7%9B%D7%9E%D7%94_%D7%95%D7%9E%D7%9C%D7%9B%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חכמה ומלכות (הדף אינו קיים)\">חכמה ומלכות</a> · <a href=\"/index.php?title=%D7%91%D7%99%D7%A0%D7%94_%D7%95%D7%9E%D7%9C%D7%9B%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בינה ומלכות (הדף אינו קיים)\">בינה ומלכות</a> · <a href=\"/index.php/%D7%A0%D7%A6%D7%97_%D7%95%D7%94%D7%95%D7%93\" title=\"נצח והוד\">נצח והוד</a> · <a href=\"/index.php?title=%D7%99%D7%A1%D7%95%D7%93_%D7%95%D7%9E%D7%9C%D7%9B%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יסוד ומלכות (הדף אינו קיים)\">יסוד ומלכות</a>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">על פי שיעור של הרב יואל כאהן לפרק יח בתניא.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ראה <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%96%D7%95%D7%94%D7%A8\" title=\"ספר הזוהר\">ספר הזוהר</a> חלק ב' דף נו עמוד א. חלק ג' דף ד עמוד א</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">ראה אמרי בינה שער הק\"ש פנ\"ו ואילך. סה\"מ תרנ\"ד ע' רפו ואילך.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">מאמר ד\"ה חסידים ואנשי מעשה ה'תשכ\"א</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">שם</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">לקוטי תורה פרשת ראה