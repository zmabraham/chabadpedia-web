    "pageid": 62923,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li>הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"אהרן מרדכי זילברשטרום\">אהרן מרדכי זילברשטרום</a> - ממקימי <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"רשת אהלי יוסף יצחק\">רשת אהלי יוסף יצחק</a> ומנהל תלמוד תורה 'שילה' בירושלים.</li>\n<li>הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A4%D7%A8%D7%A5_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"אליהו פרץ זילברשטרום\">אליהו פרץ זילברשטרום</a> - איש חינוך, משפיע קהילת חב\"ד בשכונת נוה יעקב בירושלים.</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9A_%D7%94%D7%A2%D7%A0%D7%99%D7%9A_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"חנוך העניך זילברשטרום\">חנוך העניך זילברשטרום</a> - איש חינוך תושב כפר חב\"ד, ר\"מ בישיבת מאור מנחם ברחובות.</li>\n<li>התמים <a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"שמחה זילברשטרום\">שמחה זילברשטרום</a> - מדריך ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A1%D7%A4%D7%A8_%D7%9C%D7%9E%D7%9C%D7%90%D7%9B%D7%94_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"בית הספר למלאכה כפר חב&quot;ד\">בית הספר למלאכה כפר חב\"ד</a>, שנרצח על ידי מחבלי ה'פדאיון' ב<a href=\"/index.php/%D7%A8%D7%A6%D7%97_%D7%99%D7%93_%D7%94%D7%97%D7%9E%D7%99%D7%A9%D7%94\" class=\"mw-redirect\" title=\"רצח יד החמישה\">רצח יד החמישה</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"יוסף יצחק זילברשטרום\">יוסף יצחק זילברשטרום</a> - ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים קריית גת (קטנה)\">תומכי תמימים קריית גת</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A0%D7%97%D7%95%D7%9D_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"בנימין נחום זילברשטרום\">בנימין נחום זילברשטרום</a> - איש חינוך ותיק, מראשי פעילי צעירי אגודת חב\"ד, משפיע ו'משיב' בישיבת תורת אמת ובקהילת שיכון חב\"ד בירושלים, ממייסדי מרכז החסידות 'היכל מנחם' בעיר, ומבוני בניין העתק 770 ברמת שלמה בעיר.</li>\n<li>הרב <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A0%D7%97%D7%95%D7%9D_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D_(%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F)\" title=\"בנימין נחום זילברשטרום (ראשון לציון)\">בנימין נחום זילברשטרום</a> - מראשי קהילת חב\"ד ב<a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" title=\"ראשון לציון\">ראשון לציון</a>, מנהל תלמוד תורה אור מלכה, ומייסד ומנהל בית ה<a href=\"/index.php/%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8\" title=\"הוצאה לאור\">הוצאה לאור</a> 'אשל' ו'ופרצת'.</li>\n<li>הרב <a href=\"/index.php/%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"טוביה זילברשטרום\">טוביה זילברשטרום</a> - רב בית הכנסת \"היכל לוי יצחק\" ומד\"א של קהילת אנ\"ש בשיכון חב\"ד בירושלים, מחנך במוסדות החינוך בירושלים ובנחלת הר חב\"ד.</li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%93%D7%91_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"משה דב זילברשטרום\">משה דב זילברשטרום</a> - מחנך בתלמוד תורה בני מנחם חב\"ד בבני ברק, משפיע כללי בישיבת תומכי תמימים אלעד ומשפיע בקהילת חב\"ד אלעד.</li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"מנחם מענדל זילברשטרום\">מנחם מענדל זילברשטרום</a> - משפיע בישיבה גדולה קרית גת.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"יהודה לייב זילברשטרום\">יהודה לייב זילברשטרום</a> - ר\"מ ומגיד שיעור בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a> וחבר ההנהלה הרוחנית של הישיבה.</li>\n<li>הרב <a href=\"/index.php?title=%D7%99%D7%A2%D7%A7%D7%91_(%D7%99%D7%A2%D7%A0%D7%A7%D7%99)_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יעקב (יענקי) זילברשטרום (הדף אינו קיים)\">יעקב (יענקי) זילברשטרום</a> - משגיח ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים מגדל העמק</a>.</li></ul>\n<dl><dt>נשים</dt></dl>\n<ul><li>גברת <a href=\"/index.php/%D7%A9%D7%A8%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"שרה זילברשטרום\">שרה זילברשטרום</a> - אשת חינוך בולטת המשמשת כיום כמנהלת הוועדה המשרדית 'חיים בשותפות' מטעם לשכת שרת החינוך.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/42px-Gnome-searchtool.svg.png 2x\" /></a></span> אם לא מצאתם ברשימת הפירושונים את הערך שהתכוונתם אליו, נסו:\n</p>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%93%D7%A4%D7%99%D7%9D_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C%D7%99%D7%9D_%D7%91/%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"מיוחד:דפים המתחילים ב/זילברשטרום\">דפים ששמם מתחיל ב”זילברשטרום“</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/intitle:%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D%22\" title=\"מיוחד:חיפוש/intitle:זילברשטרום&quot;\">דפים ששמם מכיל ”זילברשטרום“</a></li>\n<li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%97%D7%99%D7%A4%D7%95%D7%A9/~%22%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D%22\" title=\"מיוחד:חיפוש/~&quot;זילברשטרום&quot;\">חיפוש ”זילברשטרום“ בחב\"דפדיה</a></li></ul>\n</div>\n</td>\n</tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414112104\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.081 seconds\nReal time usage: 0.209 seconds\nPreprocessor visited node count: 63/1000000\nPost‐expand include size: 4481/2097152 bytes\nTemplate argument size: 2855/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 2/100\nU