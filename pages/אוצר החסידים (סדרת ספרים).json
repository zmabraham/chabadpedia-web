ndex.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%93%D7%91%D7%95%D7%A1%D7%A7%D7%99%D7%9F\" title=\"אליעזר דבוסקין\">אליעזר דבוסקין</a> (תשורה גורקאוו עמוד 13)</li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.col.org.il/show_news.rtx?fromAdmin=yes&amp;artID=91695\"><b>ידיעה על הופעת הכרך הרביעי אוצר החסידים בפולין ובברית המועצות</b></a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">הספר השלישי הוקדש על ידי המחבר לסבו, הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%A9%D7%9B%D7%A0%D7%96%D7%99\" title=\"משה אשכנזי\">משה אשכנזי</a>, שמדור מיוחד הוקדש לזכרו.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ספר זה הוקדש על ידי המחבר לעילוי נשמת אביו הרב <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%