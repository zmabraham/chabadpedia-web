9%D7%9E%D7%97_%D7%AA%D7%A9%D7%9E%D7%97_%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"המשך שמח תשמח תרנ&quot;ז\">המשך שמח תשמח תרנ\"ז</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%A8%D7%A0%22%D7%98\" class=\"mw-redirect\" title=\"המשך רנ&quot;ט\">המשך רנ\"ט</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91_%D7%A9%D7%9C_%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94_%D7%AA%D7%A8%D7%A1%22%D7%95\" title=\"המשך יום טוב של ראש השנה תרס&quot;ו\">המשך תרס\"ו</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%A9%D7%A2%D7%94_%D7%A9%D7%94%D7%A7%D7%93%D7%99%D7%9E%D7%95_%D7%AA%D7%A2%D7%A8%22%D7%91\" title=\"בשעה שהקדימו תער&quot;ב\">המשך תער\"ב</a> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%AA%D7%A9%D7%A8%D7%99_%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"המשך תשרי תשכ&quot;ג\">המשך תשרי תשכ\"ג</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #33cccc;\"><font size=\"2\">מושגים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%94%D7%9B%D7%A0%D7%94_%D7%9C%D7%9E%D7%90%D7%9E%D7%A8\" class=\"mw-redirect\" title=\"ניגון הכנה למאמר\">ניגון הכנה למאמר</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C\" title=\"דיבור המתחיל\">דיבור המתחיל</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%99%D7%90%D7%99%D7%A8_%D7%A0%D7%AA%D7%99%D7%91_(%D7%9E%D7%95%D7%A9%D7%92)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יאיר נתיב (מושג) (הדף אינו קיים)\">יאיר נתיב</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%99%D7%9B%D7%9C%D7%90%D7%9A\" title=\"ביכלאך\">ביכלאך</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%9C%D7%AA%D7%99_%D7%9E%D7%95%D7%92%D7%94\" title=\"בלתי מוגה\">בלתי מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9E%D7%95%D7%92%D7%94\" title=\"מוגה\">מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשך</a>\n</td></tr>\n</tbody></table>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A9%D7%A2%D7%A8_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%27%27%D7%96.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/58/%D7%A9%D7%A2%D7%A8_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%27%27%D7%96.jpg/300px-%D7%A9%D7%A2%D7%A8_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%27%27%D7%96.jpg\" decoding=\"async\" width=\"300\" height=\"477\" class=\"mw-file-element\" srcset=\"/images/thumb/5/58/%D7%A9%D7%A2%D7%A8_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%27%27%D7%96.jpg/450px-%D7%A9%D7%A2%D7%A8_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%27%27%D7%96.jpg 1.5x, /images/5/58/%D7%A9%D7%A2%D7%A8_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%27%27%D7%96.jpg 2x\" /></a><figcaption>שער הספר</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%95%D7%9B%D7%9B%D7%94.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/3d/%D7%95%D7%9B%D7%9B%D7%94.jpg/250px-%D7%95%D7%9B%D7%9B%D7%94.jpg\" decoding=\"async\" width=\"250\" height=\"397\" class=\"mw-file-element\" srcset=\"/images/thumb/3/3d/%D7%95%D7%9B%D7%9B%D7%94.jpg/375px-%D7%95%D7%9B%D7%9B%D7%94.jpg 1.5x, /images/thumb/3/3d/%D7%95%D7%9B%D7%9B%D7%94.jpg/500px-%D7%95%D7%9B%D7%9B%D7%94.jpg 2x\" /></a><figcaption>כריכת ה<a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשך</a> - הוצאת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%94\" title=\"תש&quot;ה\">תש\"ה</a></figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91%D7%99_%D7%A2%D7%9D_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/a3/%D7%94%D7%A8%D7%91%D7%99_%D7%A2%D7%9D_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C.jpg/250px-%D7%94%D7%A8%D7%91%D7%99_%D7%A2%D7%9D_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C.jpg\" decoding=\"async\" width=\"250\" height=\"175\" class=\"mw-file-element\" srcset=\"/images/thumb/a/a3/%D7%94%D7%A8%D7%91%D7%99_%D7%A2%D7%9D_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C.jpg/375px-%D7%94%D7%A8%D7%91%D7%99_%D7%A2%D7%9D_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C.jpg 1.5x, /images/thumb/a/a3/%D7%94%D7%A8%D7%91%D7%99_%D7%A2%D7%9D_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C.jpg/500px-%D7%94%D7%A8%D7%91%D7%99_%D7%A2%D7%9D_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C.jpg 2x\" /></a><figcaption><a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> יוצא מסוכתו כשבידו המשך וככה תרל\"ז. <a href=\"/index.php/%D7%9B%22%D7%90_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"כ&quot;א תשרי\">כ\"א תשרי</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a></figcaption></figure>\n<p><b>המשך וככה תרל\"ז</b> הוא <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשך</a> מאמרי חסידות של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a> הנחשב לאחד מ'ההמשכים' הידועים בתורת החסידות ומכונה \"<b>וככה הגדול</b>\"<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ההמשך כולל מ\"ו מאמרי חסידות הכוללים קל\"ה פרקים. מתחיל מדיבור המתחיל \"וככה תאכלו אותו\", <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A4%D7%A1%D7%97\" class=\"mw-redirect\" title=\"חג הפסח\">חג הפסח</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%96\" title=\"תרל&quot;ז\">תרל\"ז</a>, ומסתיים בשבת פרשת שמות <a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%97\" title=\"תרל&quot;ח\">תרל\"ח</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.95.D7.93.D7.95.D7.AA.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"אודותיו\">אודותיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אודותיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אודותיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> כתב<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> אודות ההמשך, בחורף <a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%97\" title=\"תרל&quot;ח\">תרל\"ח</a>, תוך כדי מהלך כתיבתו: <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\". . ומוס\"פ מאמר חסידים ואנשי מעשה מאמר נפלא אשר אמר כ\"ק אאמו\"ר שליט\"א בחג הסוכות העבר ויקבלו עונג מאמר זה כי נפלא הוא\"</span>.\n</p><p>ובחודש <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%97\" title=\"תרל&quot;ח\">תרל\"ח</a> כותב אודותיו<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>: <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"וגם הוא מאמר עמוק מאוד בקבלה מראשו ועד גמירא, עמוק עמוק מי ימצאנה, וגם הלשון בקיצור נמרץ\"</span>.\n</p><p>באגרותיו של אדמו\"ר הרש\"ב הוא מתייחס כמה פעמים להמשך ולשליחת העתקים ממנו למקומות שונים, ואף מצווה להרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9C%D7%9E%D7%94_%D7%99%D7%A0%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"מאיר שלמה ינובסקי\">מאיר שלמה ינובסקי</a> (סבו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>) ש<span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"בימים הראשונים דחה\"פ הבע\"ל יתחיל ללמוד את הדרוש וככה הגדול וילמוג אותו בכ\"י איזה שעות, ולא יניחו באמצע כ\"א יגמור אותו בעז\"ה. ואם לימוד עם חתנו ש\"ב הר' שי'<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup> מה טוב<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>\"</span>.\n</p><p><a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> מפליא במעלת ההמשך ומדבר אודותיו בכמה הזדמנויות. הרבי התעכב לבאר את כינויו \"המשך הגדול\", שיש בו הפלאת הגדלות. אך עם כל זה אינו מגיע להפלאת הגדלות של <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%AA%D7%A8%D7%A1%22%D7%95\" class=\"mw-redirect\" title=\"המשך תרס&quot;ו\">המשך תרס\"ו</a>. הרבי השווה ביניהם, שהמשך תרס\"ו לגבי המשך \"וככה\" הוא כמו <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> לעומת <a href=\"/index.php/%D7%A0%D7%92%D7%9C%D7%94\" class=\"mw-redirect\" title=\"נגלה\">נגלה</a>. או אפילו כמו <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%A9%D7%91%D7%A2%D7%9C_%D7%A4%D7%94\" title=\"תורה שבעל פה\">תורה שבעל פה</a> לגבי <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%A9%D7%91%D7%9B%D7%AA%D7%91\" class=\"mw-redirect\" title=\"תורה שבכתב\">תורה שבכתב</a>. <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"המשך וככה הוא בסגנון של נגלה קבלה וחסידות, ובקיצור, ורק בהמשך תרס\"ו בא ה\"מעיין\" בהרחבה<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>\"</span>.\n</p><p>בשיחה אחרת<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup> ביאר, שעניינו של ההמשך קשור עם עניינו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a> - <a href=\"/index.php/%D7%9C%D7%9B%D7%AA%D7%97%D7%99%D7%9C%D7%94_%D7%90%D7%A8%D7%99%D7%91%D7%A2%D7%A8\" title=\"לכתחילה אריבער\">לכתחילה אריבער</a>. וזהו הטעם שהתחלת אמירתו הייתה ב<a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A4%D7%A1%D7%97\" class=\"mw-redirect\" title=\"חג הפסח\">חג הפסח</a> שעניינו קפיצה ודילוג. ובכלל, אמירת \"<a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשכים</a>\" זהו חידוש שהחל רק אצל אדמו\"ר המהר\"ש, ובאמצע שנות נשיאותו, שהדבר מדגיש עוד יותר שזה חידוש שלו הקשור לדרכו המיוחדת<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>. סדר חדש זה שהחל אצל אדמו\"ר המהר\"ש באמירת \"המשכים\" הוא גילוי של חסידות שלמעלה מ<a href=\"/index.php/%D7%A1%D7%93%D7%A8\" title=\"סדר\">סדר</a>. המאמרים לא קשורים דווקא לנושאי פרשיות השבוע או החגים שבהם נאמר המאמר, ואמירתו היא באופן של לכתחילה אריבער<sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\"><span class=\"cite-bracket\">&#91;</span>9<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>הרבי מחבב את ההמשך הזה מאוד, ומצטט פעמים רבות מדברי ההמשך אודות מעלת תשובה ומעשים טובים בעולם הזה מכל חיי העולם הבא, מחמת המעלה בתענוג הבורא על תענוג הנברא, ועוד שורה של נושאים יסודיים בתורת החסידות.\n</p><p>פעמים רבות ראו את הרבי בחג הסוכות נכנס לסוכתו וההמשך \"וככה\" בידו. ובשנים הראשונות, כשחסידים היו <a href=\"/index.php/%D7%91%D7%A8%D7%9B%D7%94_%D7%A2%D7%9C_%D7%94%D7%9C%D7%95%D7%9C%D7%91_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ברכה על הלולב של הרבי\">מברכים על הלולב של הרבי</a> בנוכחות הרבי עצמו בסוכתו האישית, היו רואים שהרבי לומד במשך זה. הרבה מאמרי חסידות של <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A1%D7%95%D7%9B%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג הסוכות\">חג הסוכות</a> מיוסדים על מאמרי ההמשך \"וככה\".\n</p>\n<h2><span id=\".D7.94.D7.93.D7.A4.D7.A1.D7.AA_.D7.94.D7.94.D7.9E.D7.A9.D7.9A\"></span><span class=\"mw-headline\" id=\"הדפסת_ההמשך\">הדפסת ההמשך</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;הדפסת ההמשך&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: הדפסת ההמשך\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ההמשך נדפס לראשונה בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%94\" title=\"תש&quot;ה\">תש\"ה</a> על ידי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי </a> שהיה ממונה על הדפסת ספרים <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a> באותה עת, מצילום כתב ידו של המעתיק הנודע ר' <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A1%D7%95%D7%A4%D7%A8\" title=\"שמואל סופר\">שמואל סופר</a>.\n</p><p>בפתח מהדורת תש\"ה נדפסה הקדשה נדפסה הקדשה על ידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a>, לעילוי נשמת אמו <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%A9%D7%98%D7%A2%D7%A8%D7%A0%D7%90_%D7%A9%D7%A8%D7%94\" class=\"mw-redirect\" title=\"הרבנית שטערנא שרה\">הרבנית שטערנא שרה</a><sup id=\"cite_ref-10\" class=\"reference\"><a href=\"#cite_note-10\"><span class=\"cite-bracket\">&#91;</span>10<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>במכתב כ\"ג טבת תש\"ה כותב הרבי<sup id=\"cite_ref-11\" class=\"reference\"><a href=\"#cite_note-11\"><span class=\"cite-bracket\">&#91;</span>11<span class=\"cite-bracket\">&#93;</span></a></sup>: <span class=\"hebrewQuotation\" style=\"font-size:120%;\">\"נמצא עתה בדפוס .. המשך וככה .. לאדמו\"ר מהר\"ש נ\"ע .. אלא שמפני תנאי הזמן איני יודע מתי יוגמר, תקותי במשך ב-ג חדשים\"</span>.\n</p><p>שנים רבות לאחר מכן, ב<a href=\"/index.php/%D7%99%D7%95%22%D7%93_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"יו&quot;ד שבט\">יו\"ד שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a>, הודפס מחדש ע\"י <a href=\"/index.php/%D7%9E%D7%A2%D7%A8%D7%9B%D7%AA_%D7%90%D7%95%D7%A6%D7%A8_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מערכת אוצר החסידים\">מערכת אוצר החסידים</a> באותיות מרובעות - ע\"פ הוראת הרבי<sup id=\"cite_ref-12\" class=\"reference\"><a href=\"#cite_note-12\"><span class=\"cite-bracket\">&#91;</span>12<span class=\"cite-bracket\">&#93;</span></a></sup>, ובה נוספו (בסוף הספר) ליקוט שיחות קודש ורשימות אודות ההמשך, וכן מאמר ד\"ה וככה והמשכו ד\"ה כימי צאתך<sup id=\"cite_ref-13\" class=\"reference\"><a href=\"#cite_note-13\"><span class=\"cite-bracket\">&#91;</span>13<span class=\"cite-bracket\">&#93;</span></a></sup> דשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a>, שנאמרו בקשר עם שנת המאה לההמשך ומיוסדים עליו. וכן בכמה מקומות שהי' נראה \"פליטת הקולמוס\" מוער על כך בשולי הדף.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94_-_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C\" title=\"לקוטי תורה - תורת שמואל\">לקוטי תורה - תורת שמואל</a></li>\n<li><a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95\" title=\"המשך מים רבים תרל&quot;ו\">המשך מים רבים תרל\"ו</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/images/1/1e/וככה_תרל%22ז_-_הוצאת_תשע%22ג.pdf\">וככה - תרל\"ז</a></b>, הוצאת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a> <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/images/8/8b/וככה_תרל%22ז_-_הוצאת_תש%22ה_(כת%22י).pdf\">וככה - תרל\"ז</a>, הוצאת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%94\" title=\"תש&quot;ה\">תש\"ה</a> (כת\"י) <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6