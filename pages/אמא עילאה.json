      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"infobox\" style=\"width:25%; border: 1px solid #E4DB77; background-color: #F6F4D5; margin-bottom: 0.5em; margin-right: 1em; padding: 0.2em; color: black; float: left; text-align: center; font-size: 85%; clear:right;\">\n\n<tbody><tr style=\"background:lightblue;\">\n<th style=\"background-color: #E4DB77;\"><font size=\"4\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9E%D7%95%D7%AA_%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA_%D7%91%D7%A8%D7%99%D7%90%D7%94_%D7%99%D7%A6%D7%99%D7%A8%D7%94_%D7%A2%D7%A9%D7%99%D7%94\" title=\"עולמות אצילות בריאה יצירה עשיה\">עולמות אבי\"ע</a></font>\n</th></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"עולם האצילות\">עולם האצילות</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%9B%D7%AA%D7%A8_%D7%A2%D7%9C%D7%99%D7%95%D7%9F\" title=\"כתר עליון\">כתר עליון</a> · <a href=\"/index.php/%D7%A2%D7%AA%D7%99%D7%A7_%D7%99%D7%95%D7%9E%D7%99%D7%9F\" title=\"עתיק יומין\">עתיק יומין</a> · <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%9A_%D7%90%D7%A0%D7%A4%D7%99%D7%9F\" title=\"אריך אנפין\">אריך אנפין</a> · <a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94_%D7%9E%D7%A7%D7%A0%D7%9F_%D7%91%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"אבא עילאה מקנן באצילות\">אבא עילאה מקנן באצילות</a> · <a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94\" title=\"אבא עילאה\">אבא עילאה</a> · <a class=\"mw-selflink selflink\">אמא עילאה</a> · <a href=\"/index.php/%D7%96%D7%A2%D7%99%D7%A8_%D7%90%D7%A0%D7%A4%D7%99%D7%9F\" title=\"זעיר אנפין\">זעיר אנפין</a> · <a href=\"/index.php/%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%93%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"מלכות דאצילות\">מלכות דאצילות</a> · <a href=\"/index.php/%D7%90%D7%93%D7%9D_%D7%94%D7%A2%D7%9C%D7%99%D7%95%D7%9F\" title=\"אדם העליון\">אדם העליון</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%9E%D7%9C_(%D7%91%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA)\" title=\"חשמל (בחסידות)\">חשמל</a> · <a href=\"/index.php/%D7%A4%D7%A8%D7%A1%D7%90\" title=\"פרסא\">פרסא</a>\n</td></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%91%D7%A8%D7%99%D7%90%D7%94\" title=\"עולם הבריאה\">עולם הבריאה</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php?title=%D7%90%D7%9E%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94_%D7%9E%D7%A7%D7%A0%D7%A0%D7%90_%D7%91%D7%91%D7%A8%D7%99%D7%90%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אמא עילאה מקננא בבריאה (הדף אינו קיים)\">אמא עילאה מקננא בבריאה</a> · <a href=\"/index.php/%D7%A9%D7%A8%D7%A4%D7%99%D7%9D\" title=\"שרפים\">שרפים</a> · <a href=\"/index.php/%D7%9E%D7%98%22%D7%98\" title=\"מט&quot;ט\">מט\"ט</a> · <a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%A7%D7%A8\" title=\"י&quot;ב בקר\">י\"ב בקר</a> · <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%91%D7%94\" title=\"מרכבה\">מרכבה</a>\n</td></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%99%D7%A6%D7%99%D7%A8%D7%94\" title=\"עולם היצירה\">עולם היצירה</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%9E%D7%9C%D7%90%D7%9B%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מלאכים\">מלאכים</a> · <a href=\"/index.php/%D7%97%D7%99%D7%95%D7%AA_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"חיות הקודש\">חיות הקודש</a> · <a href=\"/index.php/%D7%A1%D7%A0%D7%93%22%D7%9C\" class=\"mw-redirect\" title=\"סנד&quot;ל\">סנד\"ל</a>\n</td></tr>\n<tr>\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94\" title=\"עולם העשייה\">עולם העשייה</a>\n</font></th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94_%D7%94%D7%A8%D7%95%D7%97%D7%A0%D7%99\" class=\"mw-redirect\" title=\"עולם העשייה הרוחני\">עולם העשייה הרוחני</a> · <a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A0%D7%99%D7%9D\" title=\"אופנים\">אופנים</a> · <a href=\"/index.php?title=%D7%92%D7%9C%D7%92%D7%9C%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"גלגלים (הדף אינו קיים)\">גלגלים</a> · <a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94_%D7%94%D7%92%D7%A9%D7%9E%D7%99\" title=\"עולם העשייה הגשמי\">עולם העשייה הגשמי</a>\n</td></tr>\n</tbody></table>\n<p><b>אמא עילאה</b> הוא ה<a href=\"/index.php/%D7%A4%D7%A8%D7%A6%D7%95%D7%A3\" title=\"פרצוף\">פרצוף</a> של ספירת ה<a href=\"/index.php/%D7%91%D7%99%D7%A0%D7%94\" class=\"mw-redirect\" title=\"בינה\">בינה</a> של עולם ה<a href=\"/index.php/%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אצילות\">אצילות</a>. שספירת ה<a href=\"/index.php/%D7%91%D7%99%D7%A0%D7%94\" class=\"mw-redirect\" title=\"בינה\">בינה</a> כלולה מ<a href=\"/index.php/%D7%A2%D7%A9%D7%A8_%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA\" class=\"mw-redirect\" title=\"עשר ספירות\">עשר ספירות</a> וב<a href=\"/index.php/%D7%94%D7%AA%D7%9B%D7%9C%D7%9C%D7%95%D7%AA\" title=\"התכללות\">התכללותם</a> יחד קרויה בשם \"אמא עילאה\".\n</p><p><a class=\"mw-selflink selflink\">אמא עילאה</a> מקבלת את אורה מ<a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94\" title=\"אבא עילאה\">אבא עילאה</a>, <a href=\"/index.php/%D7%A1%D7%A4%D7%99%D7%A8%D7%AA_%D7%94%D7%97%D7%9B%D7%9E%D7%94\" title=\"ספירת החכמה\">ספירת החכמה</a> של עולם ה<a href=\"/index.php/%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"אצילות\">אצילות</a>, ויחד הם נקראים \"<a href=\"/index.php/%D7%AA%D7%A8%D7%99%D7%9F_%D7%A8%D7%99%D7%A2%D7%99%D7%9F_%D7%93%D7%9C%D7%90_%D7%9E%D7%AA%D7%A4%D7%A8%D7%A9%D7%99%D7%9F\" class=\"mw-redirect\" title=\"תרין ריעין דלא מתפרשין\">תרין ריעין דלא מתפרשין</a>\".\n</p><p>\"אמא עילאה\" נקרית בשם \"עילאה\" ביחס לספירת <a href=\"/index.php/%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%93%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"מלכות דאצילות\">מלכות דאצילות</a> הנקרית בשם \"<a href=\"/index.php/%D7%90%D7%9E%D7%90_%D7%AA%D7%AA%D7%90%D7%94\" title=\"אמא תתאה\">אמא תתאה</a>\". ומבואר ששני פרצופים אלו נקראים בשם \"אמא\", שאמא עילאה היא אם ביחס ל<a href=\"/index.php/%D7%96%D7%A2%D7%99%D7%A8_%D7%90%D7%A0%D7%A4%D7%99%D7%9F\" title=\"זעיר אנפין\">זעיר אנפין</a> ואמא תתאה היא בבחינת אם ל<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9E%D7%95%D7%AA_%D7%91%D7%99%22%D7%A2\" class=\"mw-redirect\" title=\"עולמות בי&quot;ע\">עולמות בי\"ע</a>. \n</p><p>אמא עילאה שורה בעולם ה<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%90%D7%94\" class=\"mw-redirect\" title=\"בריאה\">בריאה</a>, וכלשון <style data-mw-deduplicate=\"TemplateStyles:r805753\">@media(hover:none){.mw-parser-output .wpAbbreviation{position:relative;text-decoration:underline dotted;cursor:help}.mw-parser-output .wpAbbreviation:hover::after{background:#333;background:rgba(0,0,0,.8);border-radius:5px;top:26px;color:#fff;content:attr(title);left:50%;transform:translateX(-50%);padding:5px 15px;position:absolute;text-align:center;z-index:98;width:7em}.mw-parser-output .wpAbbreviation:hover::before{border:solid;border-color:#333 transparent;border-width:0 6px 6px 6px;top:20px;content:\"\";left:50%;transform:translateX(-50%);position:absolute;z-index:99}}</style><abbr title=\"תיקוני זוהר\" class=\"wpAbbreviation\"><a href=\"/index.php/%D7%96%D7%95%D7%94%D7%A8\" class=\"mw-redirect\" title=\"זוהר\">התיקונים</a></abbr>, \"<a href=\"/index.php/%D7%90%D7%9E%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94_%D7%9E%D7%A7%D7%A0%D7%A0%D7%90_%D7%91%D7%AA%D7%9C%D7%AA_%D7%A1%D7%A4%D7%99%D7%A8%D7%9F_%D7%91%D7%9B%D7%95%D7%A8%D7%A1%D7%99%D7%90\" class=\"mw-redirect\" title=\"אמא עילאה מקננא בתלת ספירן בכורסיא\">אמא עילאה מקננא בתלת ספירן בכורסיא</a>\".\n</p>\n<h2><span id=\".D7.A9.D7.95.D7.A8.D7.A9.D7.94\"></span><span class=\"mw-headline\" id=\"שורשה\">שורשה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9E%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;שורשה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9E%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: שורשה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>מקור ההמשכה של אבא ואמא הוא מדיקנא של <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%9A_%D7%90%D7%A0%D7%A4%D7%99%D7%9F\" title=\"אריך אנפין\">אריך אנפין</a>. ש<a href=\"/index.php/%D7%90%D7%91%D7%90_%D7%A2%D7%99%D7%9C%D7%90%D7%94\" title=\"אבא עילאה\">אבא עילאה</a> יונק ממזל השמיני, ואמא עילאה ממזל הי\"ג של <a href=\"/index.php/%D7%99%22%D7%92_%D7%AA%D7%99%D7%A7%D7%95%D7%A0%D7%99_%D7%93%D7%99%D7%A7%D7%A0%D7%90\" class=\"mw-redirect\" title=\"י&quot;ג תיקוני דיקנא\">י\"ג תיקוני דיקנא</a> שהוא מזל \"ונקה\". שענין מזל \"ונקה\" הוא מקור להמשכה בגלוי שבבחינת <a href=\"/index.php/%D7%91%D7%99%D7%A0%D7%94\" class=\"mw-redirect\" title=\"בינה\">בינה</a> מאין ליש ממש.\n</p>\n<!-- \nNewPP limit report\nCached time: 20260413193648\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.049 seconds\nReal time usage: 0.088 seconds\nPreprocessor visited node count: 53/1000000\nPost‐expand include size: 1662/2097152 bytes\nTemplate argument size: 73/2097152 bytes\nHighest expansion depth: 7/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 679/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5210112/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   75.712      1 -total\n 96.49%   73.055      1 תבנית:מונחון\n  9.18%    6.949      1 תבנית:קידוד\n  3.36%    2.543      1 תבנית:עולמות_אבי&quot;ע\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infop