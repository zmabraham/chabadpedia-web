span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A2\" title=\"תר&quot;ע\">תר\"ע</a> - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%93%D7%95%D7%93_%D7%91%D7%9C%D7%99%D7%A0%D7%95%D7%91\" title=\"שמואל דוד בלינוב\">שמואל דוד בלינוב</a>, <a href=\"/index.php/%D7%A9%D7%95%D7%97%D7%98\" title=\"שוחט\">שוחט</a> ומחנך חסידי מקהילת אנ\"ש ב<a href=\"/index.php/%D7%A4%D7%A8%D7%99%D7%96\" title=\"פריז\">פריז</a> שב<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%91\" title=\"תרצ&quot;ב\">תרצ\"ב</a> - הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%9E%D7%A8%D7%95%D7%96%D7%95%D7%91\" title=\"חיים שניאור זלמן מרוזוב\">חיים שניאור זלמן מרוזוב</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> קהילת חב\"ד ב<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"מונטריאול\">מונטריאול</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%98\" title=\"תשל&quot;ט\">תשל\"ט</a> - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%94%D7%9B%D7%98\" title=\"שניאור זלמן צבי הירש הכט\">שניאור זלמן צבי הירש הכט</a>, משלוחי הרבי ל<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תומכי תמימים מגדל העמק\">תומכי תמימים המקומית</a>, וחבר <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8_%D7%9E%D7%91%D7%95%D7%90%D7%A8\" title=\"מאמר מבואר\">מערכת 'מאמר מבואר'</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%98\" title=\"תרכ&quot;ט\">תרכ\"ט</a> - רבי <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%97%D7%90%D7%A0%D7%99%D7%9F\" title=\"מנחם נחום יצחק אייזיק חאנין\">מנחם נחום יצחק אייזיק חאנין</a>, מה<a href=\"/index.php/%D7%97%D7%95%D7%96%D7%A8\" title=\"חוזר\">חוזרים</a> של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%96\" title=\"תרל&quot;ז\">תרל\"ז</a> - אדמו\"ר רבי <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%91%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7)\" title=\"יוסף יצחק שניאורסון (בן אדמו&quot;ר הצמח צדק)\">יוסף יצחק שניאורסון</a> מאוורוטש, בנו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a>. מנוחתו כבוד בעיר <a href=\"/index.php/%D7%90%D7%95%D7%95%D7%A8%D7%95%D7%98%D7%A9\" class=\"mw-redirect\" title=\"אוורוטש\">אוורוטש</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> - הרב <a href=\"/index.php/%D7%A8%D7%90%D7%95%D7%91%D7%9F_%D7%A7%D7%9E%D7%99%D7%A0%D7%A6%D7%A7%D7%99\" title=\"ראובן קמינצקי\">ראובן קמינצקי</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> - הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%94%D7%99%D7%9C%D7%91%D7%99%D7%A5_(%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל הילביץ (רחובות) (הדף אינו קיים)\">מנחם מענדל הילביץ</a>, רב צבאי שפעל להפצת יהדות בקרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9C%D7%99_%D7%A6%D7%94%22%D7%9C\" class=\"mw-redirect\" title=\"חיילי צה&quot;ל\">חיילי צה\"ל</a>, ו<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A7%D7%95%D7%A8%D7%90\" title=\"בעל קורא\">בעל קורא</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA\" title=\"בית כנסת\">בית כנסת</a> <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%94\" title=\"תשע&quot;ה\">תשע\"ה</a> - הרב <a href=\"/index.php/%D7%A8%D7%90%D7%95%D7%91%D7%9F_%D7%A1%D7%99%D7%A8%D7%95%D7%98%D7%94\" title=\"ראובן סירוטה\">ראובן סירוטה</a>, חסיד תושב <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>, שעסק באפיית <a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מצות\">מצות</a>, וזכה לאפות את המצות ש<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> אכל ב<a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A4%D7%A1%D7%97\" class=\"mw-redirect\" title=\"חג הפסח\">חג הפסח</a></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ח בכסלו - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a> כותב: <a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94\" title=\"אהבה\">אהבה</a> דבחינת \"ועמך לא חפצתי\" (היינו) שלא לחפוץ שום דבר זולתו יתברך, ולא אפילו שמים וארץ שהם <a href=\"/index.php/%D7%92%D7%9F_%D7%A2%D7%93%D7%9F_%D7%A2%D7%9C%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"גן עדן עליון\">גן עדן עליון</a> ותחתון, כי רק ב<a href=\"/index.php/%D7%99%D7%95%22%D7%93\" class=\"mw-redirect\" title=\"יו&quot;ד\">יו\"ד</a> <a href=\"/index.php/%D7%A0%D7%91%D7%A8%D7%90\" title=\"נברא\">נברא</a> כו', אלא תהיה ה<a href=\"/index.php/%D7%90%D7%94%D7%91%D7%94\" title=\"אהבה\">אהבה</a> רק לו יתברך לבד, דהיינו ל<a href=\"/index.php/%D7%9E%D7%94%D7%95%D7%AA%D7%95_%D7%95%D7%A2%D7%A6%D7%9E%D7%95%D7%AA%D7%95\" class=\"mw-redirect\" title=\"מהותו ועצמותו\">מהותו ועצמותו</a> יתברך <a href=\"/index.php/%D7%9E%D7%9E%D7%A9\" class=\"mw-redirect\" title=\"ממש\">ממש</a>. וכך היה נשמע הלשון ממו\"ר נשמתו עדן (<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a>) ב<a href=\"/index.php/%D7%93%D7%91%D7%99%D7%A7%D7%95%D7%AA\" title=\"דביקות\">דביקותו</a>, שהיה אומר בזה הלשון:\n<p>\"איך וויל זע גאר ניסט, איך וויל ניט דיין <a href=\"/index.php/%D7%92%D7%9F_%D7%A2%D7%93%D7%9F\" title=\"גן עדן\">גן עדן</a> איך וויל ניט דיין <a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%91%D7%90\" title=\"עולם הבא\">עולם הבא</a> כו' איך וויל מער ניט אז דיך אליין\".\n</p><p><b>גוט יום טוב</b>\n</p><p>לשנה טובה ב<a href=\"/index.php/%D7%9C%D7%99%D7%9E%D7%95%D7%93_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"לימוד החסידות\">לימוד החסידות</a> ו<a href=\"/index.php/%D7%93%D7%A8%D7%9B%D7%99_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"דרכי החסידות\">דרכי החסידות</a> תכתבו ותחתמו. \n</p>\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: \"איני רוצה מאומה, איני רוצה את ה<a href=\"/index.php/%D7%92%D7%9F_%D7%A2%D7%93%D7%9F\" title=\"גן עדן\">גן עדן</a> שלך, איני רוצה את ה<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%91%D7%90\" title=\"עולם הבא\">עולם הבא</a> שלך כו', רצוני לא יותר מאשר אותך בלבד\".\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414052004\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.032 seconds\nReal time usage: 0.166 seconds\nPreprocessor visited node count: 93/1000000\nPost‐expand include size: 6569/2097152 bytes\nTemplate argument size: 499/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  117.505      1 -total\n 75.67%   88.920      1 תבנית:חודש_כסלו\n 35.67%   41.