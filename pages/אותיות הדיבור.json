ef=\"/index.php?title=%D7%A8%D7%9B%D7%99%D7%9C%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רכילות (הדף אינו קיים)\">רכילות</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%93%D7%91%D7%A8%D7%99%D7%9D_%D7%91%D7%98%D7%9C%D7%99%D7%9D\" title=\"דברים בטלים\">דברים בטלים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%A0%D7%90%D7%95%D7%9D\" title=\"תורת הנאום\">תורת הנאום</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A4%D7%94\" title=\"פה\">פה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A9%D7%9F\" title=\"שן\">שן</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%9C%D7%A9%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"לשון (הדף אינו קיים)\">לשון</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%92%D7%A8%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"גרון (הדף אינו קיים)\">גרון</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%A9%D7%A4%D7%AA%D7%99%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שפתיים (הדף אינו קיים)\">שפתיים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%97%D7%99%D7%9A\" title=\"חיך\">חיך</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">מתוך הספר ערכים בחסידות, על פי אגרת הקודש - סימן ה', תורה אור כא. א', תו\"ח ויצא כב. ד, ספר המאמרים תרנ\"ט ד\"ה יום טוב של ר\"ה, ד\"ה לולב וערבה, ספר המאמרים תרס\"א ד\"ה כבוד מלכותך, ספר המאמרים תרע\"ג ד\"ה והאבן הזאת</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%9C%D7%99%D7%A7%D7%95%D7%98%D7%99_%D7%90%D7%9E%D7%A8%D7%99%D7%9D_-_%D7%A4%D7%A8%D7%A7_%D7%9E%27\" title=\"ליקוטי אמרים - פרק מ&#39;\">ליקוטי אמרים - פרק מ'</a></span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%AA_%D7%94%D7%A7%D7%95%D7%93%D7%A9_-_%D7%A1%D7%99%D7%9E%D7%9F_%D7%94%27\" title=\"אגרת הקודש - סימן ה&#39;\">אגרת הקודש - סימן ה'</a></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413183835\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.125 seconds\nReal time usage: 0.879 seconds\nPreprocessor visited node count: 533/1000000\nPost‐expand include size: 11531/2097152 bytes\nTemplate argument size: 3602/2097152 bytes\nHighest expansion depth: 10/100\nExpensive parser function count: 3/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 1298/5000000 bytes\nLua time usage: 0.050/7 seconds\nLua virtual size: 5857280/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  754.923      1 -total\n 55.05%  415.550      3 תבנית:הערה\n 27.19%  205.278      1 תבנית:דיבור\n 25.25%  190.620      1 תבנית:ניווט_קבוצות\n  9.87%   74.522      1 תבנית:אות\n  7.80%   58.889      1 תבנית:הערות_שוליים\n  3.33%   25.159      1 תבנית:צבע_גופן\n  2.63%   19.826      3 תבנית:ש\n  2.62%  