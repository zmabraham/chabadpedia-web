    "pageid": 64764,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/31/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F.jpg/220px-%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"148\" class=\"mw-file-element\" srcset=\"/images/thumb/3/31/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F.jpg/330px-%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F.jpg 1.5x, /images/thumb/3/31/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F.jpg/440px-%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%95%D7%9E%D7%90%D7%99%D7%A8_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F.jpg 2x\" /></a><figcaption>הרב חיים אריה (משמאל) עם אחיו מאיר (מימין)</figcaption></figure>\n<p>הרב <b>חיים אריה זילברשטייין</b> (<a href=\"/index.php/%D7%AA%D7%A8%D7%93%22%D7%A2\" class=\"mw-redirect\" title=\"תרד&quot;ע\">תרד\"ע</a>-<a href=\"/index.php/%D7%98%22%D7%96_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"ט&quot;ז אדר\">ט\"ז אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a>) היה מנכבדי קהילת חב\"ד באנטוורפן, בלגיה, שמונה על ידי הרבי כ'בעל הבית' על המדינה.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%93%22%D7%A2\" class=\"mw-redirect\" title=\"תרד&quot;ע\">תרד\"ע</a> במרגרטן שברומניה לאביו ר' משה זילברשטיין ולאמו מרת לאה.\n</p><p>בצעירותו למד בישיבת 'נייטרא'.\n</p><p>עם סיומה של <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A9%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"מלחמת העולם השניה\">מלחמת העולם השניה</a> הגיע ל<a href=\"/index.php/%D7%91%D7%9C%D7%92%D7%99%D7%94\" title=\"בלגיה\">בלגיה</a> שם הצטרף לקבוצת הבחורים והאברכים שהסתופפו בצילו של הרב זלמן שניאורסון, בהם הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"אהרן מרדכי זילברשטרום\">אהרן מרדכי זילברשטרום</a> הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9E%D7%A9%D7%94_%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F\" title=\"דוד משה ליברמן\">דוד משה ליברמן</a>, הרב טייכטל והרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"נחום יעקובוביץ\">נחום יעקובוביץ</a>, ועוד.\n</p><p>לאחר נישואיו עם רעייתו שרה מאשע בת ר' דוד ופריידע, קבע את מגוריו בבלגיה ועסק לפרנסתו ביהלומים, ולצד זאת עסק בהפצת המעיינות בקרב הקהילה היהודית בעיר.\n</p><p>בדו\"ח של הרב <a href=\"/index.php/%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%95%D7%95%D7%9C%D7%A3\" title=\"אפרים וולף\">אפרים וולף</a> מביקור בבלגיה בשנת תשכ\"ח, מופיע שמו כאחד מהמתעסקים העיקריים ב<a href=\"/index.php/%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"אנטוורפן\">אנטוורפן</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A1%D7%95%D7%9B%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג הסוכות\">חג הסוכות</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a>, התקיימה ועידה של נציגי ה<a href=\"/index.php/%D7%94%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%9E%D7%90%D7%95%D7%97%D7%93%D7%95%D7%AA\" title=\"האומות המאוחדות\">או\"ם</a> שהתפרסה על פני שבוע שלם, שחל בדיוק בימי חג הסוכות, החל מהיום הראשון של החג, ועד לשמחת תורה. במהלך החג של אותה שנה, דיבר הרבי על כך שכאשר אומות העולם מתאספים, צריכים גם היהודים להתאסף יחדיו ולהוסיף בעניני תורה ומצוות על מנת לפעול על נציגי אומות העולם שלא יחליטו החלטות שעלולות להרע לבני ישראל.\n</p><p>ב<a href=\"/index.php/%D7%A9%D7%9E%D7%99%D7%A0%D7%99_%D7%A2%D7%A6%D7%A8%D7%AA\" title=\"שמיני עצרת\">שמיני עצרת</a> של אותה שנה בעת ה<a href=\"/index.php/%D7%94%D7%A7%D7%A4%D7%95%D7%AA\" title=\"הקפות\">הקפה</a> הרביעית, הקים הרבי <a href=\"/index.php/%D7%94%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%9E%D7%90%D7%95%D7%97%D7%93%D7%95%D7%AA#&quot;האו&quot;ם_החסידי&quot;\" title=\"האומות המאוחדות\">\"או\"ם\" משלו</a>, בו הפקיד נציג על כל מדינה, שהוא יהיה ה\"בעל הבית\" של אותה מדינה על פי תורה.\n</p><p>כאשר בחר הרבי ברב זילברשטיין שיהיה 'הבעל הבית' של מדינת בלגיה, אמר שאינו ראוי לכך כיון שאינו רב, והרבי הורה לו שאם כך - שיהפוך לרב, והוא מתכוון לכך ברצינות, ואכן מייד לאחר החג ניגש ללימוד <a href=\"/index.php/%D7%A1%D7%9E%D7%99%D7%9B%D7%94_%D7%9C%D7%A8%D7%91%D7%A0%D7%95%D7%AA\" title=\"סמיכה לרבנות\">סמיכה לרבנות</a> ונבחן והוכשר לרב<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>נפטר ב<a href=\"/index.php/%D7%98%22%D7%96_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"ט&quot;ז אדר\">ט\"ז אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, ר' <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%9E%D7%90%D7%99%D7%A8_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"שמואל מאיר זילברשטיין\">שמואל מאיר זילברשטיין</a></li>\n<li>חתנו, הרב יונתן בורשטיין - חסיד גור ו<a href=\"/index.php/%D7%9E%D7%A9%D7%9E%D7%A9_%D7%91%D7%A7%D7%95%D7%93%D7%A9\" title=\"משמש בקודש\">משמש בקודש</a> אצל האדמו\"רים <a href=\"/index.php/%D7%94%D7%9C%D7%91_%D7%A9%D7%9E%D7%97%D7%94\" class=\"mw-redirect\" title=\"הלב שמחה\">הלב שמחה</a> ו<a href=\"/index.php/%D7%94%D7%A4%D7%A0%D7%99_%D7%9E%D7%A0%D7%97%D7%9D\" class=\"mw-redirect\" title=\"הפני מנחם\">הפני מנחם</a></li>\n<li>בנו, הרב <a href=\"/index.php/%D7%99%D7%95%D7%90%D7%9C_%D7%96%D7%95%D7%A9%D7%90_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"יואל זושא זילברשטיין\">יואל זושא זילברשטיין</a> - משלוחי הרבי ב<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"מונטריאול\">מונטריאול</a>, אנגליה</li>\n<li>בנו ר' משה אהרון זילברשטיין - אנטוורפן, בלגיה</li>\n<li>בנו ר' אליהו יצחק זילברשטיין - נפטר ח' כסלו תש\"ע - לונדון, אנגליה</li>\n<li>בתו מרת מאטיל</li>\n<li>בתו מרת אסתר</li>\n<li>בתו מרת רבקה</li>\n<li>בתו מרת חנה מרים</li>\n<li>בתו מרת רחל</li></ul>\n<p><br />\n</p>\n<table class=\"mw-collapsible autocollapse\" style=\"border: 1px #aaaaaa solid; background-color: #f9f9f9; text-align: center; clear: both; width: 80%; margin: 0.5em auto;\" cellspacing=\"3\">\n<tbody><tr>\n<th style=\"background-color:#b0c4de; background:#b0c4de; padding-top: 0.1em; padding-bottom: 0.1em; text-align: center; color: black; font-weight: bold; font-size: 100%\"><b><a href=\"/index.php/%D7%94%D7%90%D7%95%22%D7%9D_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%99\" title=\"האו&quot;ם החסידי\">האו\"ם החסידי</a></b>\n</th></tr>\n<tr>\n<td style=\"padding-top: 3px; padding-bottom: 3px; background-color: #f9f9f9; font-size: 95%\">\n<table style=\"width: 98%; background-color: transparent; margin: auto; padding: 0; text-align: center;\" cellpadding=\"0\" cellspacing=\"0\">\n<tbody><tr>\n<td><a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%90%D7%91%D7%9C%D7%A1%D7%A7%D7%99\" title=\"זלמן טוביה אבלסקי\">זלמן טוביה אבלסקי</a> | <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%96%D7%93%D7%91%D7%90\" title=\"אברהם אזדבא\">אברהם אזדבא</a> | <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%90%D7%99%D7%99%D7%93%D7%9C%D7%9E%D7%9F\" title=\"שלום איידלמן\">שלום איידלמן</a> | <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%91%D7%95%D7%98%D7%A8%D7%A9%D7%95%D7%95%D7%99%D7%9C%D7%99\" title=\"יהודה בוטרשווילי\">יהודה בוטרשווילי</a> | <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%95%D7%9C%D7%93%D7%91%D7%A8%D7%92\" title=\"יוסף גולדברג\">יוסף גולדברג</a> | <a href=\"/index.php/%D7%A9%D7%9E%D7%A8%D7%99%D7%94%D7%95_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"שמריהו גוראריה\">שמריהו גוראריה</a> | <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%92%D7%95%D7%A8%D7%95%D7%93%D7%A6%D7%A7%D7%99\" title=\"בנימין אליהו גורודצקי\">בנימין אליהו גורודצקי</a> | <a href=\"/index.php/%D7%96%D7%9B%D7%A8%D7%99%D7%94_%D7%92%D7%95%D7%A8%D7%99\" title=\"זכריה גורי\">זכריה גורי</a> | <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%9C%D7%99%D7%A7\" title=\"אברהם יצחק גליק\">אברהם יצחק גליק</a> | <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%A0%D7%93%D7%9C\" title=\"יצחק הנדל\">יצחק הנדל</a> | <a href=\"/index.php/%D7%A8%D7%A4%D7%90%D7%9C_%D7%95%D7%99%D7%9C%D7%A9%D7%90%D7%A0%D7%A1%D7%A7%D7%99\" title=\"רפאל וילשאנסקי\">רפאל וילשאנסקי</a> | <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"יוסף וינברג\">יוסף וינברג</a> | <a class=\"mw-selflink selflink\">חיים אריה זילברשטיין</a> | <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%90%D7%99%D7%99%D7%96%D7%99%D7%A7_%D7%97%D7%95%D7%93%D7%A7%D7%95%D7%91\" class=\"mw-redirect\" title=\"חיים מרדכי אייזיק חודקוב\">חיים מרדכי אייזיק חודקוב</a> | <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%94%D7%99%D7%A8%D7%A9_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"צבי הירש חיטריק\">צבי הירש חיטריק</a> | <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%97%D7%A4%D7%A8\" title=\"שמואל חפר\">שמואל חפר</a> | <a href=\"/index.php/%D7%A8%D7%A4%D7%90%D7%9C_%D7%98%D7%95%D7%95%D7%99%D7%9C\" title=\"רפאל טוויל\">רפאל טוויל</a> | <a href=\"/index.php/%D7%99%D7%A6%