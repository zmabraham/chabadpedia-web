srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<p><br />\n</p>\n<div class=\"stub\" style=\"background-color:#FFFCFC; border-color:#CCCCCC; border-style:double; border-width:3px; clear:both; padding-top:4px; padding-bottom:4px; padding-right:7px; margin:0.5em 0 0.5em 0;vertical-align:middle;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/50px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" decoding=\"async\" width=\"50\" height=\"50\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/75px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 1.5x, /images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/100px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 2x\" /></a></span> &#160; ערך זה הוא <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8\" title=\"חב&quot;דפדיה:קצרמר\">קצרמר</a>&#160;בנושא <a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8_%D7%9E%D7%95%D7%A1%D7%93%D7%95%D7%AA_%D7%95%D7%90%D7%A8%D7%92%D7%95%D7%A0%D7%99%D7%9D\" title=\"קטגוריה:קצרמר מוסדות וארגונים\">מוסדות וארגונים</a>. אתם מוזמנים <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%A8%D7%95%D7%9B%D7%99%D7%9D_%D7%94%D7%91%D7%90%D7%99%D7%9D#כתיבה_בחב&quot;דפדיה\" title=\"חב&quot;דפדיה:ב