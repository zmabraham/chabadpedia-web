1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/3c/%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91.jpg/250px-%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91.jpg\" decoding=\"async\" width=\"250\" height=\"194\" class=\"mw-file-element\" srcset=\"/images/thumb/3/3c/%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91.jpg/375px-%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91.jpg 1.5x, /images/thumb/3/3c/%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91.jpg/500px-%D7%94%D7%A8%D7%91%D7%99_%D7%91%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91.jpg 2x\" /></a><figcaption>הרבי בתשעה באב</figcaption></figure>\n<p><b>ט' באב</b> (<b>תשעה באב</b>), הוא היום התשיעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">חודש מנחם אב</a> ובו נחרבו שני בתי המקדש, הראשון והשני, והוא יום <a href=\"/index.php/%D7%A6%D7%95%D7%9D\" class=\"mw-redirect\" title=\"צום\">צום</a>, תענית ואבל על חורבן הבית.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמט – <a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">עם ישראל</a> בכה על דברי ה<a href=\"/index.php/%D7%9E%D7%A8%D7%92%D7%9C%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מרגלים\">מרגלים</a> ונגזר שבני ישראל לא יכנסו לארץ.</li>\n<li>ג'של\"ח – <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" title=\"בית המקדש הראשון\">בית המקדש הראשון</a> נחרב על ידי ה<a href=\"/index.php/%D7%91%D7%91%D7%9C\" title=\"בבל\">בבלים</a>.</li>\n<li>ג'תתכ\"ח – חורבן <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9_%D7%94%D7%A9%D7%A0%D7%99\" title=\"בית המקדש השני\">בית המקדש השני</a> על ידי הרומאים.</li>\n<li>טורנוסרופוס הרשע חרש את שטח <a href=\"/index.php/%D7%94%D7%A8_%D7%94%D7%91%D7%99%D7%AA\" title=\"הר הבית\">הר הבית</a>.</li>\n<li>ג'תתצ\"ה – חורבן ביתר על ידי הרומאים – סיום מרד בר כוכבא ו-580 אלף יהודים, נרצחו. (יש אומרים בשנת ג'תת\"פ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>).</li>\n<li>ה'נ – גירוש יהודי <a href=\"/index.php/%D7%90%D7%A0%D7%92%D7%9C%D7%99%D7%94\" class=\"mw-redirect\" title=\"אנגליה\">אנגליה</a></li>\n<li>ה'רנ\"ב – גירוש יהודי ספרד בתקופת המלך פרננדו השני ואיזבלה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%94\" title=\"תקע&quot;ה\">תקע\"ה</a> – רבי <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%95%D7%A8%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יעקב יצחק הורביץ\">יעקב יצחק הורביץ</a> – ה'חוזה מלובלין', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> – רבי <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9D\" title=\"יצחק ניסים\">יצחק ניסים</a>, <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%95%D7%AA_%D7%94%D7%A8%D7%90%D7%A9%D7%99%D7%AA\" class=\"mw-redirect\" title=\"הרבנות הראשית\">הראשון לציון</a>, נפטר.</li></ul>\n<h3><span id=\".D7.A9.D7.95.D7.A0.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"שונות\">שונות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;שונות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: שונות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a> - <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש אב\">חודש אב</a> - בוצע <a href=\"/index.php/%D7%AA%D7%95%D7%9B%D7%A0%D7%99%D7%AA_%D7%94%D7%94%D7%AA%D7%A0%D7%AA%D7%A7%D7%95%D7%AA\" title=\"תוכנית ההתנתקות\">גירוש גוש קטיף</a> מיישובי גוש קטיף, בניגוד גמור לדעתו של הרבי בנושא <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%9E%D7%95%D7%AA_%D7%94%D7%90%D7%A8%D7%A5\" class=\"mw-redirect\" title=\"שלימות הארץ\">שלימות הארץ</a>. לאורך השנה פעלו חסידי חב\"ד בערוצים רבים על מנת לסכל את ביצוע התוכנית.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> – הרב <a href=\"/index.php/%D7%99%D7%A7%D7%95%D7%AA%D7%99%D7%90%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D_%D7%A8%D7%90%D7%A4\" title=\"יקותיאל מנחם ראפ\">יקותיאל מנחם ראפ</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> ומנהל בית חב\"ד בשדה התעופה JFK שב<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7_%D7%A1%D7%99%D7%98%D7%99\" title=\"ניו יורק סיטי\">ניו יורק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%98\" title=\"תש&quot;ט\">תש\"ט</a> – הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%A8%D7%92\" title=\"שמעון רוזנברג\">שמעון רוזנברג</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A2%D7%A4%D7%95%D7%9C%D7%94\" title=\"עפולה\">עפולה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A0%22%D7%95\" title=\"תקנ&quot;ו\">תקנ\"ו</a> – הרבנית <a href=\"/index.php/%D7%A8%D7%97%D7%9C_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" title=\"רחל (בת אדמו&quot;ר הזקן)\">רחל שיינעס</a> בת <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%9E%D7%9C%D7%99%D7%90%D7%93%D7%99_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" title=\"רבי שניאור זלמן מליאדי (אדמו&quot;ר הזקן)\">אדמו\"ר הזקן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> – הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9C%D7%99%D7%99%D7%91_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"ישראל לייב ליפשיץ\">ישראל לייב ליפשיץ</a>, מחשובי חסידי חב\"ד ברמת גן וחבר הנהלת ישיבת <a href=\"/index.php/%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" title=\"אחי תמימים תל אביב\">אחי תמימים תל אביב</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%9E%D7%95%D7%A6%27%D7%A7%D7%99%D7%9F\" title=\"יהודה לייב מוצ&#39;קין\">יהודה לייב מוצ'קין</a>, מזקני אנ\"ש ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> ומראשי ועד הבריחה ב<a href=\"/index.php?title=%D7%99%D7%A6%D7%99%D7%90%D7%94_%D7%9E%D7%A8%D7%95%D7%A1%D7%99%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יציאה מרוסיה (הדף אינו קיים)\">יציאה מרוסיה</a> .</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%99%D7%9E%D7%99_%D7%91%D7%99%D7%9F_%D7%94%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ימי בין המצרים\">ימי בין המצרים</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A2%D7%A0%D7%99%D7%AA_%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91\" title=\"תענית תשעה באב\">תענית תשעה באב</a></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראה <a rel=\"nofollow\" class=\"external text\" href=\"http://www.hebrewbooks.org/pdfpager.aspx?req=46817&amp;hilite=aad18c9d-3092-421c-8f77-050323ad3e42&amp;st=%u05d1%u05d9%u05ea%u05e8&amp;pgnum=183\">סדר הדורות</a></span>\n</li>\n</ol></div></div>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://chabad.co.il/?template=topic&amp;topic=140\">תשעה באב, הלכות ומנהגים, מאמרים וסיפורים</a> – <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C_(%D7%90%D7%AA%D7%A8)\" title=\"קישור חב&quot;ד בישראל\"><img alt=\"קישור חב&quot;ד בישראל\" src=\"/images/thumb/9/9e/%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg/60px-%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg\" decoding=\"async\" width=\"60\" height=\"12\" class=\"mw-file-element\" srcset=\"/images/thumb/9/9e/%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg/90px-%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg 1.5x, /images/thumb/9/9e/%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg/120px-%D7%97%D7%91%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C2.jpg 2x\" /></a></span> <span class=\"grayText\"><small>(הקישור אינו פעיל)</small></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/index.php?url=article_he&amp;id=55992\">דיני ומנהגי תשעה באב</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li>הרב יהודה לייב נחמנסון, <b><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/newvideo/video.php?id=3512\">הלכות ומנהגי תשעה באב</a></b> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://he.chabad.org/library/article_cdo/aid/6956664\">מדריך מעשי מפורט לתשעה באב</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר בית חב&quot;ד\"><img alt=\"קישור לאתר בית חב&quot;ד\" src=\"/images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/22px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG\" decoding=\"async\" width=\"22\" height=\"22\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/33px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG 1.5x, /images/thumb/d/d5/%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG/44px-%D7%90%D7%AA%D7%A8_%D7%91%D7%99%D7%AA_%D7%97%D7%91%D7%93.PNG 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://77012.blogspot.com/2025/07/blog-post_30.html\">הלכה למעשה: דיני ומנהגי תשעה באב שחל במוצאי שבת</a></b>, באתר '<a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\">לחלוחית גאולתית</a>' <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA_%D7%92%D7%90%D7%95%D7%9C%D7%AA%D7%99%D7%AA\" title=\"לחלוחית גאולתית\"><img src=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/27px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg\" decoding=\"async\" width=\"27\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/41px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 1.5x, /images/thumb/b/b9/%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg/54px-%27%D7%9C%D7%97%D7%9C%D7%95%D7%97%D7%99%D7%AA%27_%D7%A1%D7%9E%D7%9C.jpg 2x\" /></a></span></li></ul>\n<p><br />\n<br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ט' במנחם אב - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>ב<a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%94\" class=\"mw-redirect\" title=\"מנחה\">מנחה</a>: <a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%A9%D7%9E%D7%A2\" title=\"קריאת שמע\">קריאת שמע</a>, שיר של יום, \"אין-כאלוקינו\" וכל השיעורים השייכים ל<a href=\"/index.php/%D7%A9%D7%97%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"שחרית\">שחרית</a>, ואחר כך סדר <a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%AA_%D7%9E%D7%A0%D7%97%D7%94\" title=\"תפילת מנחה\">תפילת מנחה</a>. אין מברכין \"שעשה לי כל צרכי\" עד למחר</i>.\n<p><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדוני אבי מורי ורבי</a> היה לומד בכל שנה ושנה ב<a href=\"/index.php/%D7%AA%D7%A9%D7%A2%D7%94_%D7%91%D7%90%D7%91\" class=\"mw-redirect\" title=\"תשעה באב\">תשעה באב</a> איכה רבה וסוגית רב יוחנן דפרק הניזקין. בבוקר אחר אמירת הקינות - שהיה אומרם כולם - היה אומר איכה. היה עולה לתורה ל<a href=\"/index.php/%D7%94%D7%A4%D7%98%D7%A8%D7%94\" title=\"הפטרה\">מפטיר</a>, ולפעמים הן בשחרית הן במנחה.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414110528\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.118 seconds\nReal time usage: 1.777 seconds\nPreprocessor visited node count: 255/1000000\nPost‐expand include size: 7695/2097152 bytes\nTemplate argument size: 889/2097152 bytes\nHighest expansion depth: 8/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 570/5000000 bytes\nLua time usage: 0.030/7 seconds\nLua virtual size: 5619712/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00% 1163.465      1 -total\n 48.87%  568.549      1 תבנית:פירוש_נוסף\n 16.47%  191.598      1 תבנית:הערה\n  7.97%   92.786      1 תבנית:הערות_שוליים\n  6.15%   71.530      1 תבנית:חב&quot;ד_בישראל\n  5.64%   65.649      1 תבנית:חודש_אב\n  5.01%   58.347      1 תבנית:לוח_שנה\n  4.73%   55.039      1 תבנית:להיום_יום\n  4.04%   47.021      2 תבנית:אינפו\n  3.40%   39.603      1 תבנית:הערות_שוליים/מרחב_שם\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:13954-0!canonical and timestamp 20260414110528 and revision id 828829. Rendering was triggered because: page-view\n -->\n</div>"
