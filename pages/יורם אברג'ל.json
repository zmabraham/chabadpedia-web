D7%9E%D7%A0%D7%97%D7%9D_%D7%96%D7%99%D7%92%D7%9C%D7%91%D7%95%D7%99%D7%9D\" title=\"מנחם זיגלבוים\">מנחם זיגלבוים</a>, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/magazine/739166/\">בנו הרב חיים דוד אברג'יל: הקשר בין אבא הרב יורם אברג'יל לרבי ולספר התניא</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span>, כסלו <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/index.php?url=article_he&amp;id=19721\">ביקורו של הרב בבית חיינו</a></b> -<span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e