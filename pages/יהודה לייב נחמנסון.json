      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c5/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F.jpeg/250px-%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F.jpeg\" decoding=\"async\" width=\"250\" height=\"170\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c5/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F.jpeg/375px-%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F.jpeg 1.5x, /images/thumb/c/c5/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F.jpeg/500px-%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F.jpeg 2x\" /></a><figcaption>הרב יהודה לייב נחמנסון</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%9B%27%27%D7%93_%D7%98%D7%91%D7%AA_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/2c/%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%9B%27%27%D7%93_%D7%98%D7%91%D7%AA_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpeg/250px-%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%9B%27%27%D7%93_%D7%98%D7%91%D7%AA_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpeg\" decoding=\"async\" width=\"250\" height=\"141\" class=\"mw-file-element\" srcset=\"/images/thumb/2/2c/%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%9B%27%27%D7%93_%D7%98%D7%91%D7%AA_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpeg/375px-%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%9B%27%27%D7%93_%D7%98%D7%91%D7%AA_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpeg 1.5x, /images/thumb/2/2c/%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%9B%27%27%D7%93_%D7%98%D7%91%D7%AA_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpeg/500px-%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F_%D7%91%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99%D7%AA_%D7%9B%27%27%D7%93_%D7%98%D7%91%D7%AA_%D7%AA%D7%A9%D7%A4%27%27%D7%94.jpeg 2x\" /></a><figcaption>הרב יהודה לייב נחמנסון בהתוועדות חסידית. כ\"ד טבת תשפ\"ה</figcaption></figure>\n<p>הרב <b>יהודה לייב נחמנסון</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a>, 1977) הוא ראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D\" class=\"mw-redirect\" title=\"כולל אברכים\">כולל לדיינות</a> <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%93%D7%A8%D7%A9_%D7%9C%D7%94%D7%95%D7%A8%D7%90%D7%94_%D7%95%D7%9E%D7%A9%D7%A4%D7%98\" title=\"בית מדרש להוראה ומשפט\">'אור יעקב'</a> ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a>, ו<a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"מורה צדק\">מורה צדק</a> בקהילת חב\"ד בעיר, מחבר ספרים תורניים ומוסר שיעורי הלכה רבים.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%95_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"כ&quot;ו שבט\">כ\"ו שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a> לר' עזרא אבשלום מיכאלי וליהודית.\n</p><p>בצעירותו למד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A8%D7%99%D7%A1%D7%98%D7%95%D7%9F\" title=\"תומכי תמימים מוריסטון\">תומכי תמימים מוריסטון</a>.\n</p><p>לאחר נישואיו, התיישב בקהילת חב\"ד ב<a href=\"/index.php/%D7%A8%D7%97%D7%95%D7%91%D7%95%D7%AA\" title=\"רחובות\">רחובות</a> ולמד ב<a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%90%D7%91%D7%A8%D7%9B%D7%99%D7%9D_%27%D7%90%D7%95%D7%A8_%D7%99%D7%A2%D7%A7%D7%91_-_%D7%90%D7%95%D7%A8_%D7%96%D7%A8%D7%95%D7%A2%27\" class=\"mw-redirect\" title=\"כולל אברכים &#39;אור יעקב - אור זרוע&#39;\">כולל אברכים 'אור יעקב - אור זרוע'</a> של הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%90%D7%94%D7%A8%D7%9F\" class=\"mw-redirect\" title=\"מאיר אהרן\">מאיר אהרן</a>.\n</p><p>לאורך השנים פרסם ספרים רבים בהלכה עם דגש על הפן המעשי, וכן מוסר שיעורים רבים בנושאי הלכה ומנהג, וכן שיעורים בפרשת שבוע ובחסידות, שחלקם הגדול מפורסם באמצעי המדיה הדיגיטליים.\n</p>\n<h2><span id=\".D7.90.D7.AA.D7.A8_.D7.95.D7.90.D7.9C.D7.94_.D7.94.D7.9E.D7.A9.D7.A4.D7.98.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אתר_ואלה_המשפטים\">אתר ואלה המשפטים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;אתר ואלה המשפטים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: אתר ואלה המשפטים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9C%D7%95%D7%92%D7%95_%D7%94%D7%90%D7%AA%D7%A8.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e3/%D7%9C%D7%95%D7%92%D7%95_%D7%94%D7%90%D7%AA%D7%A8.png/220px-%D7%9C%D7%95%D7%92%D7%95_%D7%94%D7%90%D7%AA%D7%A8.png\" decoding=\"async\" width=\"220\" height=\"315\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e3/%D7%9C%D7%95%D7%92%D7%95_%D7%94%D7%90%D7%AA%D7%A8.png/330px-%D7%9C%D7%95%D7%92%D7%95_%D7%94%D7%90%D7%AA%D7%A8.png 1.5x, /images/thumb/e/e3/%D7%9C%D7%95%D7%92%D7%95_%D7%94%D7%90%D7%AA%D7%A8.png/440px-%D7%9C%D7%95%D7%92%D7%95_%D7%94%D7%90%D7%AA%D7%A8.png 2x\" /></a><figcaption>לוגו האתר</figcaption></figure>\n<p>האתר כולל שאלות ותשובות בהלכה, פסקי דין, שיעורים ועוד.\n</p><p>בנוסף האתר מציע מענה לשאלות הלכתיות, וכן שירותי דין תורה בדיני ממונות, משפחה ועוד.\n</p><p>האתר פועל במסגרת הארגון \"כולל דיינות הוראה ומשפט\", המעודד אברכים ללמוד ולקבל הכשרה והסמכה לדיינות, שהוקם על ידי <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%90%D7%94%D7%A8%D7%95%D7%9F\" title=\"מאיר אליהו אהרון\">הרב מאיר אהרן</a>.\n</p>\n<h3><span id=\".D7.A8.D7.91.D7.A0.D7.99_.D7.94.D7.9E.D7.9B.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"רבני_המכון\">רבני המכון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;רבני המכון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: רבני המכון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>הרב <a href=\"/index.php?title=%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אליהו יחזקאל (הדף אינו קיים)\">אליהו יחזקאל</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%9C%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"לוי יצחק הלל (הדף אינו קיים)\">לוי יצחק הלל</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%93%D7%A1%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמואל גדסי (הדף אינו קיים)\">שמואל גדסי</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%99%D7%95%D7%90%D7%9C_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יואל נחמנסון (הדף אינו קיים)\">יואל נחמנסון</a></li>\n<li>הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%92%D7%9C%D7%A8%D7%A0%D7%98%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם גלרנטר (הדף אינו קיים)\">מנחם גלרנטר</a></li></ul>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ספריו\">ספריו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;ספריו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: ספריו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>לב השבת</b> - עיונים בדברי אדמו\"ר הזקן בהלכות שבת, <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a> תשס\"ו</li>\n<li><b>דיני איטר</b> - הלכה למעשה בפועל לאיטר יד בדינים המצויים, אלול תשס\"ט</li>\n<li><b>צהר המשפט</b> - הלכות דיינים, טבת תשע\"א</li>\n<li><b>שו\"ת השלוחים</b> - חלק הראשון, תשע\"ד</li>\n<li><b>שיקדש עצמו</b> - הלכות והנהגות לבית היהודי - <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> תשע\"ה</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, הרב <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%9F_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F\" title=\"נחמן נחמנסון\">נחמן נחמנסון</a> - מחלוצי השליחות במזרח הרחוק ושליחו הראשון של הרבי להודו</li>\n<li>אחיו, הרב <a href=\"/index.php/%D7%90%D7%9C%D7%97%D7%A0%D7%9F_%D7%9E%D7%A9%D7%94_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F\" title=\"אלחנן משה נחמנסון\">אלחנן משה נחמנסון</a> - ראש כולל אברכים בלוד ומרבני מכון הלכה - חב\"ד</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A0%D7%97%D7%9E%D7%A0%D7%A1%D7%95%D7%9F&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://hamishpatim.co.il/\">אתר \"ואלה המשפטים\" בראשות הרב יהודה ליב נחמנסון שליט\"א שיעורים מרתקים בנושאים מגוונים, תשובות הלכתיות מעניינות ומחכימות</a></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://chabad.info/tag/הרב-יהודה-לייב-נחמנסון/\">שיעורים הלכתיים מאת הרב נחמנסון</a></b> <span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://halacha.co/?s=הרב+נחמנסון\">מאמרים שנכתבו על ידי הרב נחמנסון בהלכה</a> <span class=\"grayText\"><small>(הקישור אינו פעיל, ב' סיון תשפ\"ג)</small></span></li></ul>\n<!-- \nNewPP limit report\nCached time: 20260414093424\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.062 seconds\nReal time usage: 1.019 seconds\nPreprocessor visited node count: 58/1000000\nPost