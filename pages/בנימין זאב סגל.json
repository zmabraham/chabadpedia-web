    "pageid": 21190,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/26/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C.jpg/250px-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C.jpg\" decoding=\"async\" width=\"250\" height=\"246\" class=\"mw-file-element\" srcset=\"/images/2/26/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C.jpg 1.5x\" /></a><figcaption>ב<a href=\"/index.php/%D7%90%D7%99%D7%92%D7%95%D7%93_%D7%A6%D7%90%D7%A6%D7%90%D7%99_%D7%A8%D7%91%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F#כנסים_ופעולות\" title=\"איגוד צאצאי רבנו הזקן\">כינוס הצאצאים</a> תשע\"ב</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A1%D7%92%D7%9C_%D7%91%D7%9B%D7%95%D7%AA%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/9c/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A1%D7%92%D7%9C_%D7%91%D7%9B%D7%95%D7%AA%D7%9C.jpg/250px-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A1%D7%92%D7%9C_%D7%91%D7%9B%D7%95%D7%AA%D7%9C.jpg\" decoding=\"async\" width=\"250\" height=\"187\" class=\"mw-file-element\" srcset=\"/images/thumb/9/9c/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A1%D7%92%D7%9C_%D7%91%D7%9B%D7%95%D7%AA%D7%9C.jpg/375px-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A1%D7%92%D7%9C_%D7%91%D7%9B%D7%95%D7%AA%D7%9C.jpg 1.5x, /images/thumb/9/9c/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A1%D7%92%D7%9C_%D7%91%D7%9B%D7%95%D7%AA%D7%9C.jpg/500px-%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A1%D7%92%D7%9C_%D7%91%D7%9B%D7%95%D7%AA%D7%9C.jpg 2x\" /></a><figcaption>ב<a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" title=\"מבצע תפילין\">מבצע תפילין</a> ב<a href=\"/index.php/%D7%94%D7%9B%D7%95%D7%AA%D7%9C_%D7%94%D7%9E%D7%A2%D7%A8%D7%91%D7%99\" title=\"הכותל המערבי\">כותל המערבי</a></figcaption></figure>\n<p>הרב <b>בנימין זאב סגל</b> (מכונה <b>וועלוועל</b>, יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a>, 1944) הינו חסיד חב\"ד תושב <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> שכיהן כמשגיח בישיבת חוג חת\"ס ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק </a> וכן בראשות ישיבות חב\"ד '<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a>' ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, ו'<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים</a>' ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>, ו'<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"בית הר&quot;מ נחלת הר חב&quot;ד\">בית הר\"מ</a>' ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" title=\"קריית מלאכי\">קריית מלאכי</a>.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> ב<a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> להוריו <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A9%D7%9C%D7%95%D7%9D_%D7%A1%D7%92%D7%9C\" title=\"חיים שלום סגל\">חיים שלום סגל</a> ואשתו אסתר . \n</p><p>בצעירותו, למד בישיבת \"סלבודקה\", ובתקופת לימודיו במקום הצטרף לחבורת בחורים מבתים חסידיים שקיימו קביעות בלימוד ספרי חסידות ובראשם ספר ה<a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"תניא\">תניא</a>, (בין תלמידי החבורה - האחים הרבנים <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"משה הבלין\">משה</a> ו<a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"יוסף יצחק הבלין\">יוסף יצחק הבלין</a>). בהמשך עבר ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>. \n</p><p>לאחר נישואיו בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> עם רעייתו חנה ברכה, התיישב ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a> ושימש כמשגיח בישיבת חוג חתם סופר ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>. כעבור מספר שנים התמנה כראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a>, בתפקיד זה כיהן עד \n</p><p>בהמשך כיהן גם כראש ישיבת <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"בית הר&quot;מ\">בית הר\"מ</a> ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" title=\"קריית מלאכי\">קריית מלאכי</a> בין השנים <a href=\"/index.php/%D7%AA%D7%A9%D7%93%22%D7%9E\" title=\"תשד&quot;מ\">תשד\"מ</a>-<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>. \n</p><p>לקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a> החל לכהן כראש הישיבה הגדולה <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a>, תפקיד זה נשא עד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a>. \n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> עבר לגור ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> והחל לכהן במקביל גם כראש ה<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%A7%D7%98%D7%A0%D7%94_%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA\" title=\"ישיבה קטנה תורת אמת\">ישיבה קטנה תורת אמת</a>. בתפקיד זה נשא עד שנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"תש&quot;ע\">תש\"ע</a>. \n</p><p>משנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a> משמש כראש <a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C\" title=\"כולל\">כולל</a> שיסד. כיום מוסר שיעורים בישיבה גדולה בתורת אמת מספר פעמים בחודש.\n</p><p>לאחר פטירת רעייתו חנה ברכה (בי\"ח שבט תשפ\"ד), התחתן בשנית (בט\"ו מנחם אב אותה שנה) עם רעייתו לבית פרידמן, חיפה, ממשפחה מחסידי גור.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%96%D7%90%D7%91_%D7%A1%D7%92%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>בנו, הרב <a href=\"/index.php/%D7%A7%D7%9C%D7%9E%D7%9F_%D7%A1%D7%92%D7%9C\" title=\"קלמן סגל\">קלונימוס קלמן</a> - <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A4%D7%AA%D7%97_%D7%AA%D7%A7%D7%95%D7%95%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים פתח תקווה\">תומכי תמימים פתח תקווה</a> ושליח הרבי בכפר מעש.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A1%D7%92%D7%9C\" title=\"מנחם סגל\">מנחם מענדל</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ב<a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A7%D7%99%D7%9D\" title=\"אופקים\">אופקים</a>.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A1%D7%92%D7%9C\" title=\"אליהו סגל\">אליהו</a> - שליח הרבי בשכונת נעורים וקדמת ראשון ב<a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" title=\"ראשון לציון\">ראשון לציון</a> - זוגתו חנה (לבית הנדל מצפת) נפטרה בד' חשוון תשע\"ח והוא התחתן שוב בזוו\"ש .</li>\n<li>בנו, הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%9E%D7%94_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A1%D7%92%D7%9C_(%D7%97%D7%A8%D7%A7%D7%95%D7%91)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלמה יהודה סגל (חרקוב) (הדף אינו קיים)\">שלמה יהודה סגל (חרקוב)</a> - שליח הרבי בחרקוב.</li>\n<li>בנו, הרב חיים שלום - הרב הראשי ושליח הרבי לרפובליקת <a href=\"/index.php/%D7%9E%D7%9C%D7%98%D7%94\" title=\"מלטה\">מלטה</a>.</li>\n<li>בתו, שרה שפרה (נפטרה בכ\"ה מר חשון תשפ\"ד) אשת הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A6%D7%91%D7%99_%D7%A6%D7%99%D7%A8%D7%A7%D7%95%D7%A1\" title=\"יוסף צבי צירקוס\">יוסף צבי צירקוס</a> - <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li>בתו, שושנה בילא אשת הרב יוסף פינקוביץ - <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>.</li>\n<li>בתו, פנינה רילא אשת <a href=\"/index.php/%D7%90%D7%9C%D7%97%D7%A0%D7%9F_%D7%9B%D7%94%D7%9F_(%D7%A7%D7%A8%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99)\" class=\"mw-redirect\" title=\"אלחנן כהן (קרית מלאכי)\">הרב אלחנן ישראל כהן</a> - ר\"מ ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"תומכי תמימים קריית גת (גדולה)\">תומכי תמימים קריית גת</a> .</li>\n<li>בתו, זהבה אשת הר\"ר נתן לוין.</li>\n<li>בתו, רבקה אשת הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%A0%D7%95%D7%99%D7%94%D7%95%D7%99%D7%96%D7%A8\" title=\"יהושע נויהויזר\">יהושע נויהויזר</a> - ר\"מ ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים אור יהודה\">תומכי תמימים אור יהודה</a>.</li></ul>\n<!-- \nNewPP limit report\nCached time: 20260413090217\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.022 seconds\nReal time usage: 0.151 seconds\nPreprocessor visited node count: 48/1000000\nPost‐expand include size: 49/2097152 bytes\nTemplate argument size: 42/2097152 bytes\nHighest expansion depth: 3/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   34.731      1 תבנית:ה\n100.00%   34.731      1 -total\n-->\n