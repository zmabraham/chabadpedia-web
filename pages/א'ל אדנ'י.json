      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"infobox\" style=\"width:20%; border: 1px solid #E4DB77; background-color: #F6F4D5; margin-bottom: 0.5em; margin-right: 1em; padding: 0.2em; color: black; float: left; text-align: center; font-size: 85%; clear:right;\">\n\n<tbody><tr style=\"background:lightblue;\">\n<th style=\"background-color: #E4DB77;\"><font size=\"4\"><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%AA_%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"שמות הוי&quot;ה\">שמותיו של הקב\"ה</a></font>\n</th></tr>\n\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">7 שמות שאינם נמחקים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%94%D7%95%D7%99%22%D7%94_(%D7%A9%D7%9D)\" title=\"הוי&quot;ה (שם)\">הוי\"ה</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A0%22%D7%99\" title=\"אדנ&quot;י\">אדנ\"י</a> · <a href=\"/index.php/%D7%90%22%D7%9C\" title=\"א&quot;ל\">א\"ל</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%A7%D7%99%D7%9D\" title=\"אלקים\">אלהי\"ם</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%22%D7%94\" class=\"mw-redirect\" title=\"אלו&quot;ה\">אלו\"ה</a> · <a href=\"/index.php/%D7%A6%D7%91%D7%90%D7%95%22%D7%AA\" class=\"mw-redirect\" title=\"צבאו&quot;ת\">צבאו\"ת</a> · <a href=\"/index.php/%D7%A9%D7%93%22%D7%99\" class=\"mw-redirect\" title=\"שד&quot;י\">שד\"י</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\"><a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%AA_%D7%94%D7%95%D7%99%27_%D7%91%D7%9E%D7%99%D7%9C%D7%95%D7%90%D7%9D_(%D7%A2%22%D7%91_%D7%A1%22%D7%92_%D7%9E%22%D7%94_%D7%91%22%D7%9F)\" title=\"שמות הוי&#39; במילואם (ע&quot;ב ס&quot;ג מ&quot;ה ב&quot;ן)\">מילויים לשם הוי\"ה</a></font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A9%D7%9D_%D7%A2%22%D7%91\" title=\"שם ע&quot;ב\">שם ע\"ב</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%A1%22%D7%92\" title=\"שם ס&quot;ג\">שם ס\"ג</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%9E%22%D7%94\" title=\"שם מ&quot;ה\">שם מ\"ה</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%91%22%D7%9F\" title=\"שם ב&quot;ן\">שם ב\"ן</a>\n</td></tr>\n\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">שמות נוספים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%94%D7%99%22%D7%94\" title=\"אהי&quot;ה\">אהי\"ה</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%9E%22%D7%91\" title=\"שם מ&quot;ב\">שם מ\"ב</a> · <a href=\"/index.php/%D7%A9%D7%9D_%D7%A2%22%D7%91_(%D7%A2%22%D7%91_%D7%AA%D7%99%D7%91%D7%95%D7%AA)\" title=\"שם ע&quot;ב (ע&quot;ב תיבות)\">שם ע\"ב (ע\"ב תיבות)</a> · <a href=\"/index.php/%D7%90%D7%9B%D7%93%D7%98%22%D7%9D\" class=\"mw-redirect\" title=\"אכדט&quot;ם\">אכדט\"ם</a> · <a class=\"mw-selflink selflink\">א\"ל אדנ\"י</a> · <a href=\"/index.php/%D7%90%22%D7%9C_%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"א&quot;ל הוי&quot;ה\">א\"ל הוי\"ה</a> · <a href=\"/index.php/%D7%90%22%D7%9C_%D7%A9%D7%93%22%D7%99\" title=\"א&quot;ל שד&quot;י\">א\"ל שד\"י</a> · <a href=\"/index.php/%D7%90%D7%92%D7%9C%22%D7%90\" title=\"אגל&quot;א\">אגל\"א</a> · <a href=\"/index.php/%D7%99%22%D7%94\" title=\"י&quot;ה\">י\"ה</a> · <a href=\"/index.php/%D7%9E%D7%A6%D7%A4%22%D7%A5\" title=\"מצפ&quot;ץ\">מצפ\"ץ</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">כינויים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%A4%D7%95_%D7%A9%D7%9C_%D7%A2%D7%95%D7%9C%D7%9D\" title=\"אלופו של עולם\">אלופו של עולם</a> · <a href=\"/index.php/%D7%94%D7%A7%D7%93%D7%95%D7%A9_%D7%91%D7%A8%D7%95%D7%9A_%D7%94%D7%95%D7%90\" title=\"הקדוש ברוך הוא\">הקב\"ה</a> · <a href=\"/index.php/%D7%94%27_%D7%90%D7%97%D7%93\" class=\"mw-redirect\" title=\"ה&#39; אחד\">ה' אחד</a> · <a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_%D7%95%D7%9E%D7%94%D7%95%D7%AA\" title=\"עצמות ומהות\">עצמות ומהות</a> · <a href=\"/index.php/%D7%A7%D7%93%D7%9E%D7%95%D7%9F\" title=\"קדמון\">קדמון</a> · <a href=\"/index.php/%D7%90%D7%93%D7%95%D7%9F_(%D7%A9%D7%9D_%D7%94%27)\" title=\"אדון (שם ה&#39;)\">אדון</a> · <a href=\"/index.php/%D7%90%D7%93%D7%9D_%D7%94%D7%A2%D7%9C%D7%99%D7%95%D7%9F\" title=\"אדם העליון\">אדם העליון</a> · <a href=\"/index.php/%D7%9C%D7%90_%D7%90%D7%93%D7%9D\" title=\"לא אדם\">לא אדם</a> · <a href=\"/index.php/%D7%9E%D7%9C%D7%9A_%D7%9E%D7%9C%D7%9B%D7%99_%D7%94%D7%9E%D7%9C%D7%9B%D7%99%D7%9D\" title=\"מלך מלכי המלכים\">מלך מלכי המלכים</a> · <a href=\"/index.php/%D7%90%D7%95%D7%99%D7%91%D7%A2%D7%A8%D7%A9%D7%98%D7%A2%D7%A8\" title=\"אויבערשטער\">אויבערשטער</a> · <a href=\"/index.php?title=%D7%A9%D7%9C%D7%95%D7%9D_(%D7%A9%D7%9D)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלום (שם) (הדף אינו קיים)\">שלום</a> · <a href=\"/index.php?title=%D7%91%D7%95%D7%A8%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בורא (הדף אינו קיים)\">בורא</a>\n</td></tr></tbody></table>\n<p>שם <b>א\"ל אדנ\"י</b> ענינו הוא המשכה של שם <a href=\"/index.php/%D7%90%22%D7%9C\" title=\"א&quot;ל\">א\"ל</a>, שהוא תיקון הראשון מ<a href=\"/index.php/%D7%99%22%D7%92_%D7%AA%D7%99%D7%A7%D7%95%D7%A0%D7%99_%D7%93%D7%99%D7%A7%D7%A0%D7%90\" class=\"mw-redirect\" title=\"י&quot;ג תיקוני דיקנא\">י\"ג תיקוני דיקנא</a>, שנמשך ומתגלה ב<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%A2%D7%A9%D7%99%D7%99%D7%94\" title=\"עולם העשייה\">עולם העשייה</a> בשם <a href=\"/index.php/%D7%90%D7%93%D7%A0%22%D7%99\" title=\"אדנ&quot;י\">אדנ\"י</a> ונקרא בשם א\"ל אדנ\"י. ה<a href=\"/index.php/%D7%92%D7%99%D7%9E%D7%98%D7%A8%D7%99%D7%90\" class=\"mw-redirect\" title=\"גימטריא\">גימטריא</a> של א\"ל אדנ\"י היא צ\"ו שם זה מאיר בעולם העשייה לתשעים ושישה אלפים וכו'.\n</p><p>שם זה הוא אחד מן שלושת השמות \"<a href=\"/index.php/%D7%90%22%D7%9C_%D7%A9%D7%93%22%D7%99\" title=\"א&quot;ל שד&quot;י\">א\"ל שד\"י</a>\", \"<a href=\"/index.php/%D7%90%22%D7%9C_%D7%94%D7%95%D7%99%22%D7%94\" class=\"mw-redirect\" title=\"א&quot;ל הוי&quot;ה\">א\"ל הוי\"ה</a>\", \"א\"ל אדנ\"י\", שענינם הוא המשכה של שם א\"ל, שהוא התיקון הראשון מ<a href=\"/index.php/%D7%99%22%D7%92_%D7%AA%D7%99%D7%A7%D7%95%D7%A0%D7%99_%D7%93%D7%99%D7%A7%D7%A0%D7%90\" class=\"mw-redirect\" title=\"י&quot;ג תיקוני דיקנא\">י\"ג תיקוני דיקנא</a> אל עולמות <a href=\"/index.php/%D7%91%D7%99%22%D7%A2\" class=\"mw-redirect\" title=\"בי&quot;ע\">בי\"ע</a>. מבואר כי הענין שדווקא לעולמות הנפרדים נמשך מן שם א\"ל שבתיקוני דיקנא, שגבוה יותר מ<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"עולם האצילות\">עולם האצילות</a>, לפי שאדרבה, מכיוון שעולמות אלו הם בירידת המדריגה ביותר, משום כך צריך שיבוא להם השפע ממקום עליון ביותר. וזהו ענין \"<a href=\"/index.php/%D7%A0%D7%A2%D7%95%D7%A5_%D7%AA%D7%97%D7%99%D7%9C%D7%AA%D7%9F_%D7%91%D7%A1%D7%95%D7%A4%D7%9F\" class=\"mw-redirect\" title=\"נעוץ תחילתן בסופן\">נעוץ תחילתן בסופן</a>\".\n</p>\n<!-- \nNewPP limit report\nCached time: 20260413080407\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.011 seconds\nReal time usage: 0.101 seconds\nPreprocessor visited node count: 8/1000000\nPost‐expand include size: 1709/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 2/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   36.754      1 תבנית:שמות\n100.00%   36.754      1 -total\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:10067-0!canonical and timestamp 20260413080407 and revision id 812358. Rendering was triggered because: diff-page\n -->\n</div>"
