      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/93/%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99.jpeg/250px-%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99.jpeg\" decoding=\"async\" width=\"250\" height=\"177\" class=\"mw-file-element\" srcset=\"/images/thumb/9/93/%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99.jpeg/375px-%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99.jpeg 1.5x, /images/thumb/9/93/%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99.jpeg/500px-%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99.jpeg 2x\" /></a><figcaption>הרב יגאל ציפורי מקבל תעודת הוקרה מראש העיר קרית שמונה</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%A2%D7%9D_%D7%A9%D7%A8_%D7%94%D7%91%D7%99%D7%98%D7%97%D7%95%D7%9F_%D7%9C%D7%A9%D7%A2%D7%91%D7%A8_%D7%99%D7%95%D7%90%D7%91_%D7%92%D7%9C%D7%A0%D7%98.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1f/%D7%94%D7%A8%D7%91_%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%A2%D7%9D_%D7%A9%D7%A8_%D7%94%D7%91%D7%99%D7%98%D7%97%D7%95%D7%9F_%D7%9C%D7%A9%D7%A2%D7%91%D7%A8_%D7%99%D7%95%D7%90%D7%91_%D7%92%D7%9C%D7%A0%D7%98.jpg/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%A2%D7%9D_%D7%A9%D7%A8_%D7%94%D7%91%D7%99%D7%98%D7%97%D7%95%D7%9F_%D7%9C%D7%A9%D7%A2%D7%91%D7%A8_%D7%99%D7%95%D7%90%D7%91_%D7%92%D7%9C%D7%A0%D7%98.jpg\" decoding=\"async\" width=\"220\" height=\"186\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1f/%D7%94%D7%A8%D7%91_%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%A2%D7%9D_%D7%A9%D7%A8_%D7%94%D7%91%D7%99%D7%98%D7%97%D7%95%D7%9F_%D7%9C%D7%A9%D7%A2%D7%91%D7%A8_%D7%99%D7%95%D7%90%D7%91_%D7%92%D7%9C%D7%A0%D7%98.jpg/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%A2%D7%9D_%D7%A9%D7%A8_%D7%94%D7%91%D7%99%D7%98%D7%97%D7%95%D7%9F_%D7%9C%D7%A9%D7%A2%D7%91%D7%A8_%D7%99%D7%95%D7%90%D7%91_%D7%92%D7%9C%D7%A0%D7%98.jpg 1.5x, /images/thumb/1/1f/%D7%94%D7%A8%D7%91_%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%A2%D7%9D_%D7%A9%D7%A8_%D7%94%D7%91%D7%99%D7%98%D7%97%D7%95%D7%9F_%D7%9C%D7%A9%D7%A2%D7%91%D7%A8_%D7%99%D7%95%D7%90%D7%91_%D7%92%D7%9C%D7%A0%D7%98.jpg/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99_%D7%A2%D7%9D_%D7%A9%D7%A8_%D7%94%D7%91%D7%99%D7%98%D7%97%D7%95%D7%9F_%D7%9C%D7%A9%D7%A2%D7%91%D7%A8_%D7%99%D7%95%D7%90%D7%91_%D7%92%D7%9C%D7%A0%D7%98.jpg 2x\" /></a><figcaption>הרב יגאל ציפורי עם שר הביטחון לשעבר יואב גלנט.</figcaption></figure>\n<p>הרב <b>יגאל ציפורי</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%90\" title=\"תשכ&quot;א\">תשכ\"א</a>, 1961) הוא <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ומנהל <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%A9%D7%9E%D7%95%D7%A0%D7%94\" title=\"קריית שמונה\">קריית שמונה</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%98%D7%91%D7%A8%D7%99%D7%94\" title=\"טבריה\">טבריה</a> ב<a href=\"/index.php/%D7%9B%27_%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"כ&#39; ניסן\">כ' ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%90\" title=\"תשכ&quot;א\">תשכ\"א</a> לנדיר וכרמלית ציפורי, במשפחה שאינה שומרת תורה ומצוות. לאחר שירותו הצבאי התקרב לחב\"ד על ידי הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A8%D7%99%D7%99%D7%A6%D7%A1\" class=\"mw-redirect\" title=\"יעקב רייצס\">יעקב רייצס</a> מ<a href=\"/index.php?title=%D7%99%D7%A1%D7%95%D7%93_%D7%94%D7%9E%D7%A2%D7%9C%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יסוד המעלה (הדף אינו קיים)\">יסוד המעלה</a>. לאחר מכן נכנס ללמוד ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת\">ישיבת חסידי חב\"ד ליובאוויטש צפת</a>. לקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%95\" title=\"תשמ&quot;ו\">תשמ\"ו</a> נסע ללמוד ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ישיבת תומכי תמימים המרכזית\">ישיבת תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>לאחר נישואיו עם מרת אירית הצטרף אל שלוחי הרבי ופתח בית חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%A9%D7%9E%D7%95%D7%A0%D7%94\" title=\"קריית שמונה\">קריית שמונה</a>.\n</p><p>הבית חב\"ד שבראשותו מפעיל בין היתר בית תמחוי \"בית בתיה\" ומרכז מבקרים \"החוויה היהודית\" המיועד למטיילים מהארץ ומהעולם שמגיעים לטייל באיזור הצפון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בעת <a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%9C%D7%91%D7%A0%D7%95%D7%9F_%D7%94%D7%A9%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"מלחמת לבנון השניה\">מלחמת לבנון השניה</a> ניהל מערך של סיוע לתושבי העיר. לאחר המלחמה, במעמד ראשי הפדרציה היהודית UJA ו-UJC (הג'וינט העולמי והג'וינט של ניו-יורק), הוענק לו אות \"גיבור המלחמה בצפון\"<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>הרב ציפורי קיבל אותות כבוד מעיריית קריית שמונה ונבחר ב<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%95\" title=\"תשס&quot;ו\">תשס\"ו</a> ל\"איש השנה\" בעיר<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup> ובשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%96\" title=\"תשע&quot;ז\">תשע\"ז</a> הוועדה המארגת של עיריית קריית שמונה החליטה להעניק לרב ציפורי ולרעייתו את אות יקירי העיר כאות כבוד לרבי והוקרה לשלוחים על פעולתם.\n</p>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>חב\"ד במייל מגזין 18, שבוע פרשת וירא תשפ\"ד</li>\n<li>יוסף יצחק קפלן, <b>שליח תחת אש</b>, בתוך מוסף 'המהפכנים' <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"שבועון כפר חב&quot;ד\">שבועון כפר חב\"ד</a> חג הסוכות תשפ\"ה, (הודפס בתוך מגזין ב' של גיליון 2081 עמוד 96, <b>תפילה למשה</b>, עמוד 148) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\"><img src=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/60px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg\" decoding=\"async\" width=\"60\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/90px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 1.5x, /images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/120px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%92%D7%90%D7%9C_%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/news/264015/\">השליח בקרית שמונה: \"אות ההוקרה היא לרבי ולשלוחים\"</a> ב' באייר תשע\"ז <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/search/news?q=%D7%99%D7%92%D7%90%D7%9C+%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%99&amp;page=1\">תגית: הרב יגאל ציפורי</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95