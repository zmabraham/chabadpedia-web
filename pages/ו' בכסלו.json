an><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%97\" title=\"תקע&quot;ח\">תקע\"ח</a> (15/11/1817 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב לייב עמריך, מתלמידי רבי נתן אדלר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%97\" title=\"תשי&quot;ח\">תשי\"ח</a> (29/11/1957 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php?title=%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%99%D7%9B%D7%90%D7%9C_%D7%93%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%9E%D7%A0%D7%93%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חיים מיכאל דב וייסמנדל (הדף אינו קיים)\">חיים מיכאל דב וייסמנדל</a> <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, ראש ישיבת נייטרא ומחבר ספר 'מן המצר', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> (09/11/1994 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C_%D7%A9%D7%A8%D7%92%D7%90_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"יחזקאל שרגא ליפשיץ\">יחזקאל שרגא ליפשיץ</a> מ<a href=\"/index.php/%D7%A1%D7%98%D7%A8%D7%95%D7%A4%D7%A7%D7%95%D7%91\" class=\"mw-redirect\" title=\"סטרופקוב\">סטרופקוב</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%98\" title=\"תרפ&quot;ט\">תרפ\"ט</a> (19/11/1928 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בא בקישורי שידוכים עם הרבנית <a href=\"/index.php/%D7%97%D7%99%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%90_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%A9%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" class=\"mw-redirect\" title=\"חיה מושקא שניאורסון (אשת אדמו&quot;ר שליט&quot;א)\">חיה מושקא שניאורסון</a>, בתו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a>, בעיר <a href=\"/index.php/%D7%A8%D7%99%D7%92%D7%90\" class=\"mw-redirect\" title=\"ריגא\">ריגא</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a> (28/11/1976 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php?title=%D7%A9%D7%9C%D7%9E%D7%94_%D7%9C%D7%99%D7%A6%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלמה ליצמן (הדף אינו קיים)\">שלמה ליצמן</a>, ר\"מ ומשפיע בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D_(%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%A7%D7%98%D7%A0%D7%94)\" class=\"mw-redirect\" title=\"תורת אמת ירושלים (ישיבה קטנה)\">תורת אמת ירושלים</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%99%D7%AA%D7%A8_%D7%A2%D7%9C%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים ביתר עלית\">תומכי תמימים ביתר עלית</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%95%27_%D7%91%D7%9B%D7%A1%D7%9C%D7%95&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> (23/11/1990 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - נפטר הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%A8%D7%9C%D7%99%D7%A7&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל גרליק (הדף אינו קיים)\">מנחם מענדל גרליק</a>, מסר נפשו במבצע <a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%95\" title=\"יציאת רוסיה תש&quot;ו\">יציאת רוסיה תש\"ו</a>, ולאחר יציאתו מרוסיה פעל במבצעי הרבי עם חיילי <a href=\"/index.php/%D7%A6%D7%94%22%D7%9C\" title=\"צה&quot;ל\">צה\"ל</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ו' בכסלו - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> אמר: \"<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%A9%D7%9E%D7%A2_%D7%A9%D7%A2%D7%9C_%D7%94%D7%9E%D7%98%D7%94\" class=\"mw-redirect\" title=\"קריאת שמע שעל המטה\">קריאת שמע שעל המטה</a> איז, אין זעיר אנפין, ווי דער ווידוי וואס קודם צאת ה<a href=\"/index.php/%D7%A0%D7%A4%D7%A9\" title=\"נפש\">נפש</a> מה<a href=\"/index.php/%D7%92%D7%95%D7%A3\" class=\"mw-redirect\" title=\"גוף\">גוף</a>. נאר יעמאלט גייט מען שוין אינגאנצען אוועק פון יריד, און עס ענדיגט זיך שוין דער מסחר פון \"היום לעשותם\", און אין קריאת שמע שעל המטה פון יעדער נאכט האלט מען נאך אין מיטן יריד, און מען קען נאך אויפטאן\".\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%99%D7%99%D7%93%D7%99%D7%A9\" title=\"יידיש\">יידיש</a></b>: <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> אמר: \"<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%A9%D7%9E%D7%A2_%D7%A9%D7%A2%D7%9C_%D7%94%D7%9E%D7%98%D7%94\" class=\"mw-redirect\" title=\"קריאת שמע שעל המטה\">קריאת שמע שעל המטה</a> הוא, בזעיר אנפין הווידוי שאומרים קודם צאת ה<a href=\"/index.php/%D7%A0%D7%A4%D7%A9\" title=\"נפש\">נפש</a> מה<a href=\"/index.php/%D7%92%D7%95%D7%A3\" class=\"mw-redirect\" title=\"גוף\">גוף</a>. אלא שאז כבר הולכים לגמרי מהיריד ונגמרת העבודה של \"היום לעשותם\", ובקריאת שמע שעל המטה שבכל לילה, אוחזים עדיין באמצע היריד ואפשר עוד לפעול\".\n</p>\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראו באג\"ק אדמו\"ר מוהריי\"צ, חלק יז,(עמ' קלה. שם, עמ' קמג.) את אגרות קודשו אודות הרב וייסמנדל.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260413195250\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.041 seconds\nReal time usage: 0.076 seconds\nPreprocessor visited node count: 120/1000000\nPost‐expand include size: 6516/2097152 bytes\nTemplate argument size: 495/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 151/5000000 bytes\nLua time usage: 0.020/7 seconds\nLua virtual size: 5074944/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   58.049      1 -total\n 79.76%   46.300      1 תבנית:הערה\n 11.51%    6.680      1 תבנית:חודש_כסלו\n  8.33%    4.833      1 תבנית:להיום_יום\n  7.81%    4.534      1 תבנית:לוח_שנה\n  3.63%    2.106      1 תבנית:היום_יום/ו&#039;_כסלו\n  3.62%    2.102      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19813-0!canonical and timestamp 20260413195250 and revision id 583396. Rendering was triggered because: diff-page\n -->\n</div>"
