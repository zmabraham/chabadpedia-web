" title=\"כ&quot;ו באייר\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ז באייר\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ח באייר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%99%D7%99%D7%A8\" title=\"כ&quot;ט באייר\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ט&#39; באייר</b> הוא היום התשיעי\nבחודש השמיני<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי.\n</p><p>תאריך זה חל בתקופת ניסן&#160;והוא יכול לחול בימים&#160;ראשון, שלישי, רביעי ושישי.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php?title=%D7%A7%D7%A6%22%D7%98&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"קצ&quot;ט (הדף אינו קיים)\">קצ\"ט</a> – רבי אביגדור קרא, אב\"ד קהילת פראג ומחבר ספר 'הקנה הגדול', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%93\" title=\"תקצ&quot;ד\">תקצ\"ד</a> – החלו <a href=\"/index.php/%D7%A4%D7%A8%D7%A2%D7%95%D7%AA_%D7%AA%D7%A7%D7%A6%22%D7%93\" title=\"פרעות תקצ&quot;ד\">פרעות תקצ\"ד</a> בעיר <a href=\"/index.php/%D7%97%D7%91%D7%A8%D7%95%D7%9F\" title=\"חברון\">חברון</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%95\" title=\"תרס&quot;ו\">תרס\"ו</a> – רבי חיים פרידלנדר מליסקא, מחבר ספר 'טל חיים וברכה', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%95\" title=\"תרפ&quot;ו\">תרפ\"ו</a> – רבי משה הגר משאץ נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a> – רבי משה הגר, ראש ישיבת 'יחל ישראל' מסערט ויז'ניץ ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%93\" title=\"תקצ&quot;ד\">תקצ\"ד</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a> הוכנס ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%9E%D7%99%D7%9C%D7%94\" title=\"ברית מילה\">בריתו של אברהם אבינו</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%94\" title=\"תשל&quot;ה\">תשל\"ה</a>, הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%94%D7%A0%D7%93%D7%9C\" title=\"שמואל הנדל\">שמואל הנדל</a>, יו\"ר <a href=\"/index.php/%D7%9E%D7%98%D7%94_%D7%9E%D7%A9%D7%99%D7%97_%D7%91%D7%90%D7%A8%D7%94%22%D7%A7\" class=\"mw-redirect\" title=\"מטה משיח בארה&quot;ק\">מטה משיח בארה\"ק</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%27_%D7%91%D7%90%D7%99%D7%99%D7%A8&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> – הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9C%D7%95%D7%99%D7%9F\" title=\"ישראל לוין\">ישראל לוין</a> (נעוועלער), מפעילי חב\"ד הבולטים ב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%94%D7%A7%D7%95%D7%9E%D7%95%D7%A0%D7%99%D7%A1%D7%98%D7%99%D7%AA\" class=\"mw-redirect\" title=\"רוסיה הקומוניסטית\">רוסיה הקומוניסטית</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"תשכ&quot;ג\">תשכ\"ג</a> – הרב <a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%98%D7%95%D7%93%D7%A8%D7%95%D7%A1_%D7%90%D7%9C%D7%98%D7%94%D7%95%D7%99%D7%96\" title=\"פנחס טודרוס אלטהויז\">פנחס טודרוס אלטהויז</a>, מגדולי עסקני חב\"ד בארץ הקודש וממייסדי <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%93%22%D7%9E\" title=\"תשד&quot;מ\">תשד\"מ</a> – הרב <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F_%D7%A0%D7%9E%D7%A0%D7%95%D7%91\" title=\"ניסן נמנוב\">ניסן נמנוב</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> ב<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%94%D7%A7%D7%95%D7%9E%D7%95%D7%A0%D7%99%D7%A1%D7%98%D7%99%D7%AA\" class=\"mw-redirect\" title=\"רוסיה הקומוניסטית\">רוסיה הקומוניסטית</a> ולאחר מכן ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" title=\"תומכי תמימים ברינואה\">תומכי תמימים ברינואה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"תשס&quot;ה\">תשס\"ה</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%99%D7%95%D7%A0%D7%99%D7%A7\" title=\"דובער יוניק\">דובער יוניק</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%91%22%D7%A7\" class=\"mw-redirect\" title=\"משב&quot;ק\">משב\"ק</a> בביתו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A0%D7%9E%D7%A0%D7%95%D7%91\" title=\"משה נמנוב\">משה נמנוב</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ט' באייר - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>כד לעומר</i>\n<p>מורנו ה<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9D_%D7%98%D7%95%D7%91\" class=\"mw-redirect\" title=\"בעל שם טוב\">בעל שם טוב</a> אמר: כל דבר ודבר אשר האדם רואה או שומע, הוא הוראת הנהגה ב<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודת השם</a>. וזהו ענין העבודה, להבין ולהשכיל מכל דרך בעבודת השם.\n</p>\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השני\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260413202203\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.126 seconds\nReal time usage: 2.598 seconds\nPreprocessor visited node count: 358/1000000\nPost‐expand include size: 8438/2097152 bytes\nTemplate argument size: 837/2097152 bytes\nHighest expansion depth: 9/100\nExpensive