      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table cellpadding=\"2\" cellspacing=\"0\" style=\"float:left; clear:left; border:1px solid #aaa; background-color:#f9f9f9; width:200px; text-align:center;\">\n\n<tbody><tr>\n<th style=\"background:#9BCB65;\"><a href=\"/index.php/%D7%90%D7%99%D7%91%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"איברים\">איברי</a> <a href=\"/index.php/%D7%92%D7%95%D7%A3_%D7%94%D7%90%D7%93%D7%9D\" title=\"גוף האדם\">גוף</a> ה<a href=\"/index.php/%D7%90%D7%93%D7%9D_(%D7%9E%D7%99%D7%9F_%D7%94%D7%9E%D7%93%D7%91%D7%A8)\" title=\"אדם (מין המדבר)\">אדם</a>\n</th></tr>\n<tr>\n<th style=\"background:#BFD7FF;\">מושגים כלליים\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A8%D7%90%D7%A9\" title=\"ראש\">ראש</a> • <a href=\"/index.php/%D7%A4%D7%A0%D7%99%D7%9D\" title=\"פנים\">פנים</a> • <a href=\"/index.php/%D7%A0%D7%A9%D7%99%D7%9E%D7%94\" title=\"נשימה\">נשימה</a> • <a href=\"/index.php/%D7%93%D7%9D\" title=\"דם\">דם</a>  • <a href=\"/index.php/%D7%92%D7%99%D7%93%D7%99%D7%9D\" title=\"גידים\">גידים</a> • <a href=\"/index.php/%D7%95%D7%A8%D7%99%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ורידים\">ורידי הדם</a> • <a href=\"/index.php/%D7%A2%D7%95%D7%A8%D7%A7%D7%99%D7%9D\" class=\"mw-redirect\" title=\"עורקים\">עורקים</a> • <a href=\"/index.php/%D7%92%D7%99%D7%93%D7%99%D7%9D\" title=\"גידים\">עצבים</a> • <a href=\"/index.php/%D7%91%D7%A9%D7%A8_(%D7%A9%D7%A8%D7%99%D7%A8%D7%99%D7%9D)\" title=\"בשר (שרירים)\">בשר</a> • <a href=\"/index.php/%D7%A2%D7%A6%D7%9E%D7%95%D7%AA_(%D7%90%D7%99%D7%91%D7%A8%D7%99_%D7%94%D7%90%D7%93%D7%9D)\" title=\"עצמות (איברי האדם)\">עצמות</a> • <a href=\"/index.php/%D7%A2%D7%95%D7%A8\" title=\"עור\">עור</a> • <a href=\"/index.php/%D7%A9%D7%A2%D7%A8%D7%95%D7%AA_%D7%94%D7%A8%D7%90%D7%A9_%D7%95%D7%94%D7%96%D7%A7%D7%9F\" title=\"שערות הראש והזקן\">שערות הראש והזקן</a>\n</td></tr>\n<tr>\n<th style=\"background:#BFD7FF;\">איברי הראש\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%92%D7%9C%D7