ction=edit&amp;redlink=1\" class=\"new\" title=\"לחיים (איבר) (הדף אינו קיים)\">לחיים</a> • <a href=\"/index.php?title=%D7%A1%D7%A0%D7%98%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"סנטר (הדף אינו קיים)\">סנטר</a>\n</td></tr>\n<tr>\n<th style=\"background:#BFD7FF;\">איברי הגוף\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%97%D7%96%D7%94\" class=\"mw-redirect\" title=\"בית החזה\">בית החזה</a> • <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A9%D7%97%D7%99\" title=\"בית השחי\">בית השחי</a> • <a href=\"/index.php?title=%D7%91%D7%98%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בטן (הדף אינו קיים)\">בטן</a> • <a href=\"/index.php?title=%D7%98%D7%91%D7%95%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"טבור (הדף אינו קיים)\">טבור</a> • <a href=\"/index.php?title=%D7%90%D7%92%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אגן (הדף אינו קיים)\">אגן</a> • <a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a> • <a href=\"/index.php/%D7%A8%D7%99%D7%90%D7%94\" title=\"ריאה\">ריאות</a> • <a href=\"/index.php?title=%D7%9B%D7%9C%D7%99%D7%95%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כליות (הדף אינו קיים)\">כליות</a> • <a href=\"/index.php/%D7%9B%D7%99%D7%A1_%D7%94%D7%9E%D7%A8%D7%94\" class=\"mw-redirect\" title=\"כיס המרה\">כיס המרה</a> • <a href=\"/index.php/%D7%9B%D7%91%D7%93\" title=\"כבד\">כבד</a> • <a href=\"/index.php/%D7%A7%D7%99%D7%91%D7%94\" class=\"mw-redirect\" title=\"קיבה\">קיבה</a> • <a href=\"/index.php/%D7%90%D7%99%D7%91%D7%A8%D7%99_%D7%94%D7%A4%D7%A1%D7%95%D7%9C%D7%AA\" class=\"mw-redirect\" title=\"איברי הפסולת\">איברי הפסולת</a> • <a href=\"/index.php/%D7%90%D7%99%D7%91%D7%A8%D7%99_%D7%94%D7%94%D7%95%D7%9C%D7%93%D7%94\" class=\"mw-redirect\" title=\"איברי ההולדה\">איברי ההולדה</a> • <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%9E%D7%90_%D7%93%D7%92%D7%95%D7%A4%D7%90\" title=\"סיומא דגופא\">סיומא דגופא</a> • <a href=\"/index.php/%D7%99%D7%A1%D7%95%D7%93_%D7%93%D7%A0%D7%95%D7%A7%D7%91%D7%90\" title=\"יסוד דנוקבא\">יסוד דנוקבא</a>\n</td></tr>\n<tr>\n<th style=\"background:#BFD7FF;\">גפיים\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%9B%D7%AA%D7%A4%D7%99%D7%99%D7%9D\" class=\"mw-redirect\" title=\"כתפיים\">כתפיים</a> • <a href=\"/index.php/%D7%99%D7%93%D7%99%D7%99%D7%9D\" title=\"ידיים\">ידיים</a> • <a href=\"/index.php/%D7%A8%D7%92%D7%9C%D7%99%D7%99%D7%9D\" class=\"mw-redirect\" title=\"רגליים\">רגליים</a> • <a href=\"/index.php/%D7%A2%D7%A7%D7%91_(%D7%90%D7%99%D7%91%D7%A8)\" title=\"עקב (איבר)\">עקב</a> • <a class=\"mw-selflink selflink\">אצבעות</a> • <a href=\"/index.php/%D7%A6%D7%99%D7%A4%D7%95%D7%A8%D7%A0%D7%99%D7%99%D7%9D\" title=\"ציפורניים\">ציפורניים</a>\n</td></tr>\n<tr>\n<th style=\"background:#BFD7FF;\">ראו גם\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%A9%D7%A8_%D7%99%D7%A6%D7%A8\" class=\"mw-redirect\" title=\"אשר יצר\">אשר יצר</a> • <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%90%D7%95%D7%AA_%D7%95%D7%A8%D7%A4%D7%95%D7%90%D7%94\" title=\"בריאות ורפואה\">בריאות ורפואה</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%90%D7%93%D7%9D\" title=\"תבנית:אדם\">אדם - מין המדבר (תבנית)</a>\n</td></tr></tbody></table>\n<p><b>אצבעות</b> היד מגבילים את הכוח של היד להניע (כח התנועה).\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.A2.D7.A0.D7.99.D7.99.D7.A0.D7.9D\"></span><span class=\"mw-headline\" id=\"עניינם\">עניינם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A6%D7%91%D7%A2%D7%95%D7%AA&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;עניינם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A6%D7%91%D7%A2%D7%95%D7%AA&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: עניינם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>גם ביד עצמה, ללא אצבעות נמצא <a href=\"/index.php?title=%D7%9B%D7%95%D7%97_%D7%94%D7%AA%D7%A0%D7%95%D7%A2%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"כוח התנועה (הדף אינו קיים)\">כוח התנועה</a>, והיא יכולה לפעול דברים.\n</p><p>ואדרבה - ביד עצמה הכוח נמצא ביותר תקיפות מאשר באצבעות. מלאכות שדורשות מאמץ - כמו סבלות וחפירה - מתבצעות בהצלחה עם כף היד ללא אצבעות. האצבעות מחלישות יותר את כוח היד (על ידי שהן מחלקות את הכוח לעשר חלקים).\n</p><p>ולמרות כל זאת - האצבעות חשובות ביותר, דווקא בגלל שהם מחלישות את כוח היד, הם מנצלות ומתעלות את האנרגיה שלו. היד עצמה לא יכולה לפעול פעולות מוטוריות עדינות<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, ורק האצבעות יכולות<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\nאצבעות גם נמשלות ליתדות (לאטום האוזניים משמיעת דברים לא טובים)<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>\n</p>\n<h2><span id=\".D7.91.D7.A0.D7.9E.D7.A9.D7.9C_-_.D7.A2.D7.A9.D7.A8_.D7.94.D7.A1.D7.A4.D7.99.D7.A8.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"בנמשל_-_עשר_הספירות\">בנמשל - עשר הספירות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A6%D7%91%D7%A2%D7%95%D7%AA&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;בנמשל - עשר הספירות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A6%D7%91%D7%A2%D7%95%D7%AA&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: בנמשל - עשר הספירות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הנמשל בחסידות לאצבעות, הם <a href=\"/index.php/%D7%A2%D7%A9%D7%A8_%D7%94%D7%A1%D7%A4%D7%99%D7%A8%D7%95%D7%AA\" class=\"mw-redirect\" title=\"עשר הספירות\">עשר הספירות</a> שב<a href=\"/index.php/%D7%A2%D7%95%D7%9C%D7%9D_%D7%94%D7%90%D7%A6%D7%99%D7%9C%D7%95%D7%AA\" title=\"עולם האצילות\">עולם האצילות</a>. שעניינם להגביל, לתעל את אור אין סוף שלמעלה מאצילות ולהוריד אותו לעולמות <a href=\"/index.php/%D7%91%D7%99%22%D7%A2\" class=\"mw-redirect\" title=\"בי&quot;ע\">בי\"ע</a> - עד לעולם שלנו.\n</p><p>אמנם למעלה מאצילות האור יותר נעלה ופחות מוגבל, אבל דווקא לכן חשובות הספירות, כדי לברוא עולם מוגבל. \n</p>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A6%D7%91%D7%A2%D7%95%D7%AA&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A6%D7%91%D7%A2%D7%95%D7%AA&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>מאמר ד\"ה תקעו תרס\"א (ספר המאמרים תר\"ס-ג עמ' קס\"ח)</li>\n<li>מאמר ד\"ה ויולך תש\"ד (ספר המאמרים תש\"ד עמ' 181)</li></ul>\n<div class=\"stub\" style=\"background-color:#FFFCFC; border-color:#CCCCCC; border-style:double; border-width:3px; clear:both; padding-top:4px; padding-bottom:4px; padding-right:7px; margin:0.5em 0 0.5em 0;vertical-align:middle;\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/50px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png\" decoding=\"async\" width=\"50\" height=\"50\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/75px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 1.5x, /images/thumb/e/e6/%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png/100px-%D7%A1%D7%9E%D7%9C_%D7%97%D7%91%D7%93%D7%A4%D7%93%D7%99%D7%94.png 2x\" /></a></span> &#160; ערך זה הוא <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8\" title=\"חב&quot;דפדיה:קצרמר\">קצרמר</a>. אתם מוזמנים <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%91%D7%A8%D7%95%D7%9B%D7%99%D7%9D_%D7%94%D7%91%D7%90%D7%99%D7%9D#כתיבה_בחב&quot;דפדיה\" title=\"חב&quot;דפדיה:ברוכים הבאים\">לתרום</a> לחב\"דפדיה ו<b><span class=\"plainlinks\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php?title=%D7%90%D7%A6%D7%91%D7%A2%D7%95%D7%AA&amp;action=edit&amp;editintro=%D7%AA%D7%91%D7%A0%D7%99%D7%AA%3A%D7%A7%D7%A6%D7%A8%D7%9E%D7%A8%2F%D7%94%D7%A8%D7%97%D7%91%D7%94%2F%D7%9B%D7%9C%D7%9C%D7%99\">להרחיב אותו</a></span></b>.</div>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">כמו כתיבה וציור וכדו'.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">למרות האמור לעיל, דווקא כשמשתמשים בכף היד מתגלה הפנימיות של כח התנועה. העוצמות הפנימיות שלה.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">כתובות דף ו'</span>\n</li>\n</ol></div></div>\n<!-- \nNe