      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li><a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A0%D7%97%D7%95%D7%9D_%D7%9E%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%9C\" title=\"מנחם נחום מצ&#39;רנוביל\">מנחם נחום מצ'רנוביל</a>, מחבר הספר <a href=\"/index.php/%D7%9E%D7%90%D7%95%D7%A8_%D7%A2%D7%99%D7%A0%D7%99%D7%9D\" title=\"מאור עינים\">מאור עינים</a>.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%9E%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%9C\" title=\"מרדכי מצ&#39;רנוביל\">מרדכי מצ'רנוביל</a>, בנו של רבי מנחם נחום.</li>\n<li><a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%9E%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%9C\" title=\"אהרן מצ&#39;רנוביל\">אהרן מצ'רנוביל</a>, בנו של רבי מרדכי.</li>\n<li><a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"יעקב ישראל טברסקי\">יעקב ישראל טברסקי</a>, בנו של רבי מרדכי, האדמו\"ר מטשערקאס.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99_(%D7%94%D7%95%D7%A8%D7%A0%D7%A1%D7%98%D7%99%D7%99%D7%A4%D7%9C)\" title=\"מרדכי דב טברסקי (הורנסטייפל)\">מרדכי דב טברסקי</a>, האדמו\"ר מהורנסטייפל.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%93%D7%91_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99_(%D7%98%D7%95%D7%9E%D7%95%D7%A9%D7%A4%D7%95%D7%9C)\" class=\"mw-redirect\" title=\"מרדכי דב טברסקי (טומושפול)\">מרדכי דב טברסקי</a>, האדמו\"ר מטומושפול.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"משה חיים יהושע שניאורסון טברסקי\">משה חיים יהושע שניאורסון טברסקי</a>, האדמו\"ר מטומושפול.</li>\n<li><a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%94%D7%A2%D7%A9%D7%99%D7%9C_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"אברהם יהושע העשיל טברסקי\">אברהם יהושע העשיל טברסקי</a>, האדמו\"ר מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%9E%D7%97%D7%A0%D7%95%D7%91%D7%A7%D7%94\" class=\"mw-redirect\" title=\"חסידות מחנובקה\">מכנובקה</a>.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A9%D7%95%D7%9C%D7%9D_%D7%96%D7%95%D7%A1%D7%99%D7%90_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99_%D7%9E%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%9C\" class=\"mw-redirect\" title=\"משולם זוסיא טברסקי מצ&#39;רנוביל\">משולם זוסיא טברסקי</a>, האדמו\"ר מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A6%27%D7%A8%D7%A0%D7%95%D7%91%D7%99%D7%9C\" title=\"חסידות צ&#39;רנוביל\">צ'רנוביל</a>.</li>\n<li><a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A0%D7%97%D7%95%D7%9D_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" class=\"mw-redirect\" title=\"מנחם נחום טברסקי\">מנחם נחום טברסקי</a>, האדמו\"ר מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A8%D7%97%D7%9E%D7%A1%D7%98%D7%A8%D7%99%D7%95%D7%95%D7%A7%D7%90\" class=\"mw-redirect\" title=\"חסידות רחמסטריווקא\">רחמסטריווקא</a>.</li>\n<li><a href=\"/index.php/%D7%99%D7%95%D7%97%D7%A0%D7%9F_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"יוחנן טברסקי\">יוחנן טברסקי</a>, האדמו\"ר מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A8%D7%97%D7%9E%D7%A1%D7%98%D7%A8%D7%99%D7%95%D7%95%D7%A7%D7%90\" class=\"mw-redirect\" title=\"חסידות רחמסטריווקא\">רחמסטריווקא</a>.</li>\n<li><a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"ישראל מרדכי טברסקי\">ישראל מרדכי טברסקי</a>, האדמו\"ר מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A8%D7%97%D7%9E%D7%A1%D7%98%D7%A8%D7%99%D7%95%D7%95%D7%A7%D7%90\" class=\"mw-redirect\" title=\"חסידות רחמסטריווקא\">רחמסטריווקא</a>.</li>\n<li><a href=\"/index.php/%D7%97%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"חי יצחק טברסקי\">חי יצחק טברסקי</a>, האדמו\"ר מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A8%D7%97%D7%9E%D7%A1%D7%98%D7%A8%D7%99%D7%95%D7%95%D7%A7%D7%90\" class=\"mw-redirect\" title=\"חסידות רחמסטריווקא\">רחמסטריבקא</a>.</li>\n<li><a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%9F_%D7%99%D7%95%D7%A1%D7%A3_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"נחמן יוסף טברסקי\">נחמן יוסף טברסקי</a>, ר\"מ ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" class=\"mw-redirect\" title=\"תומכי תמימים אהלי תורה קראון הייטס\">תומכי תמימים אהלי תורה קראון הייטס</a>.</li>\n<li><a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"אברהם טברסקי\">אברהם טברסקי</a>, רופא ופסיכיאטר יהודי-חסידי מפורסם.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7