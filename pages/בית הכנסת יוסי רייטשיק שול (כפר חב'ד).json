    "pageid": 49108,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table cellpadding=\"4\" cellspacing=\"0\" width=\"250\" style=\"float: left; border: 1px solid #ccd2d9; margin: 0 1em 1em 0em; background: #f9f9f9; font-size: 85%;\">\n<tbody><tr>\n<th align=\"center\" colspan=\"2\" style=\"font-size: larger; background-color: #7dcdd1; color: #000000;\">רייטשיק שול\n</th></tr>\n<tr valign=\"top\">\n<td colspan=\"2\" align=\"center\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/66/%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C.jpeg/250px-%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C.jpeg\" decoding=\"async\" width=\"250\" height=\"141\" class=\"mw-file-element\" srcset=\"/images/thumb/6/66/%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C.jpeg/375px-%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C.jpeg 1.5x, /images/thumb/6/66/%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C.jpeg/500px-%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C.jpeg 2x\" /></a></span><br />בית הכנסת יוסי רייטשיק שול\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">עיר</span></b>\n</td>\n<td><a href=\"/index.php/%D7%A9%D7%9B%D7%95%D7%A0%D7%AA_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"שכונת לוי יצחק (כפר חב&quot;ד)\">שכונת לוי יצחק א'</a>, <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">מדינה</span></b>\n</td>\n<td><a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a>\n</td></tr>\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">תאריך יסוד</span></b>\n</td>\n<td><a href=\"/index.php/%D7%99%22%D7%92_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"י&quot;ג שבט\">י\"ג שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a>\n</td></tr>\n\n\n\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"גבאי\">גבאי</a> גשמי</span></b>\n</td>\n<td>ר' אבי מלכא, ר'צבי אברמוביץ', ר' מוטי פרידמן\n</td></tr>\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%94%D7%95%D7%A8%D7%90%D7%94\" title=\"מורה הוראה\">רב</a> בית הכנסת</span></b>\n</td>\n<td>הרב <a href=\"/index.php/%D7%90%D7%A9%D7%A8_%D7%90%D7%99%D7%99%D7%96%D7%A0%D7%91%D7%9A\" title=\"אשר אייזנבך\">אשר אייזנבך</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בית הכנסת</span></b>\n</td>\n<td>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A7%D7%98%D7%9F\" class=\"mw-redirect\" title=\"יעקב קטן\">יעקב קטן</a>\n</td></tr>\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">מספר מתפללים</span> </b>\n</td>\n<td>כ-250 מקומות ישיבה\n</td></tr>\n\n\n<tr>\n<td colspan=\"2\" style=\"text-align: center; border-top: solid 1px #708090; background-color: #E0E0F0; padding: 0.2em1em 0.2em 0; font-size: 100%;\"><b>ראו גם</b>\n</td></tr>\n<tr>\n<td colspan=\"2\" style=\"border-top: solid 1px #aaaaaa; padding: 0.4em 0 0.4em 0; text-align: center;\" align=\"center\"><a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%91%D7%AA%D7%99_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%91%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"קטגוריה:בתי כנסת בכפר חב&quot;ד\">בתי כנסת בכפר חב\"ד</a>\n</td></tr></tbody></table>\n<p><b>בית הכנסת יוסי רייטשיק שול</b> הוא מבתי הכנסת הגדולים ב<a href=\"/index.php/%D7%A9%D7%9B%D7%95%D7%A0%D7%AA_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7\" class=\"mw-redirect\" title=\"שכונת לוי יצחק\">שכונת לוי יצחק</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>. בית הכנסת נקרא על שם ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7\" title=\"יוסף יצחק רייטשיק\">יוסף יצחק רייטשיק</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.99.D7.A1.D7.98.D7.95.D7.A8.D7.99.D7.94\"></span><span class=\"mw-headline\" id=\"היסטוריה\">היסטוריה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;היסטוריה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: היסטוריה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_2.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c5/%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_2.jpg/250px-%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_2.jpg\" decoding=\"async\" width=\"250\" height=\"133\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c5/%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_2.jpg/375px-%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_2.jpg 1.5x, /images/thumb/c/c5/%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_2.jpg/500px-%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_2.jpg 2x\" /></a><figcaption>בית הכנסת לקראת סיום הבנייה</figcaption></figure>\n<p>ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7\" title=\"יוסף יצחק רייטשיק\">יוסף יצחק רייטשיק</a> שעל שמו נקרא בית הכנסת היה מהאנשים הפעילים ביותר ב<a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"צעירי אגודת חב&quot;ד בישראל\">צעירי אגודת חב\"ד בישראל</a>, ומיד כשנפטר ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7\" title=\"יוסף יצחק רייטשיק\">יוסף יצחק רייטשיק</a> ב<a href=\"/index.php/%D7%9B%22%D7%90_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"כ&quot;א אלול\">כ\"א אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a>, הנהלת <a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"צעירי אגודת חב&quot;ד בישראל\">צא\"ח</a> שחפצו כבר זמן רב לבנות משרדים חדשים העלו הצעה לבנות בניין משרדים ענק ומפואר על שמו של ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7\" title=\"יוסף יצחק רייטשיק\">יוסף יצחק רייטשיק</a>, ואף העלו כבר תכניות. אך לאחר זמן מה התכניות נגנזו, הזמן בו נפטר ר' רייטשיק היה זמן בו \"בתי הכנסת לצעירים\" צברו תאוצה ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> ובכל חודש בממוצע התבשרו על עוד בית כנסת שקם. לכן ההחלטה הסופית הייתה לבנות בית כנסת לצעירים גדול ומפואר במקום בניין המשרדים ש<a href=\"/index.php/%D7%A6%D7%A2%D7%99%D7%A8%D7%99_%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%91%22%D7%93_%D7%91%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"צעירי אגודת חב&quot;ד בישראל\">צעירי אגודת חב\"ד</a> רצו לבנות לזכרו.\n</p><p>ב<a href=\"/index.php/%D7%97%27_%D7%91%D7%90%D7%91\" class=\"mw-redirect\" title=\"ח&#39; באב\">ח' באב</a>, <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> הכריז <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ועד כפר חב&quot;ד\">ועד כפר חב\"ד</a> בראשות ר' <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"בנימין ליפשיץ\">בנימין ליפשיץ</a> באופן רשמי על הקמת בית הכנסת, ונתן את האישורים הסופיים לבניתו. \n</p><p>ב<a href=\"/index.php/%D7%9B%22%D7%90_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"כ&quot;א אלול\">כ\"א אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a>, שנת השנה לפטירתו של הרב רייטשיק התקיים מעמד הנחת אבן הפינה לבית הכנסת החדש<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%99%D7%90%D7%A8%D7%A6%D7%99%D7%99%D7%98\" title=\"יארצייט\">יארצייט</a> השלישי של הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7\" title=\"יוסף יצחק רייטשיק\">יוסף יצחק רייטשיק</a> ב<a href=\"/index.php/%D7%9B%22%D7%90_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"כ&quot;א אלול\">כ\"א אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> נערכה התוועדות של ידידי הרב רייטשיק ומשפחתו לציון היארציט שלו בבית כנסת ההולך ונבנה, ולמתוועדים נערך אף סיור בתוך בית הכנסת. \n</p><p>ב<a href=\"/index.php/%D7%99%22%D7%92_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"י&quot;ג שבט\">י\"ג שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> נחנכו ה<a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94\" title=\"מקווה\">מקווה</a> ו<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> במעמד חנוכת הבית אדיר, בתוך כך אף בוצעה הכנסת ספר תורה לבית הכנסת החדש בנוכחות רבנים ואישי ציבור<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>כיום בית הכנסת יוסי רייטשיק שול הוא מבתי הכנסת הגדולים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> וב<a href=\"/index.php/%D7%A9%D7%9B%D7%95%D7%A0%D7%AA_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7\" class=\"mw-redirect\" title=\"שכונת לוי יצחק\">שכונת לוי יצחק</a> והוא משמש כבית כנסת לצעירים.\n</p>\n<h2><span id=\".D7.9E.D7.91.D7.A0.D7.94_.D7.91.D7.99.D7.AA_.D7.94.D7.9B.D7.A0.D7.A1.D7.AA\"></span><span class=\"mw-headline\" id=\"מבנה_בית_הכנסת\">מבנה בית הכנסת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;מבנה בית הכנסת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: מבנה בית הכנסת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%95%D7%9C%D7%9D_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c3/%D7%90%D7%95%D7%9C%D7%9D_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7.jpg/250px-%D7%90%D7%95%D7%9C%D7%9D_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7.jpg\" decoding=\"async\" width=\"250\" height=\"166\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c3/%D7%90%D7%95%D7%9C%D7%9D_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7.jpg/375px-%D7%90%D7%95%D7%9C%D7%9D_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7.jpg 1.5x, /images/thumb/c/c3/%D7%90%D7%95%D7%9C%D7%9D_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7.jpg/500px-%D7%90%D7%95%D7%9C%D7%9D_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7.jpg 2x\" /></a><figcaption>פנים אולם בית הכנסת (בחנוכת הבית)</figcaption></figure>\n<p>בית הכנסת מתפרס לגובה של שתי קומות, כאשר כנהוג ב<a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> הקומה השנייה משמשת כ<a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%AA_%D7%A0%D7%A9%D7%99%D7%9D\" class=\"mw-redirect\" title=\"עזרת נשים\">עזרת נשים</a>, והקומה התחתונה כעזרת הגברים. בקומה התחתונה יש את אולם <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA\" title=\"בית כנסת\">בית הכנסת</a>, שתי חדרים המשמשים כ<a href=\"/index.php/%D7%97%D7%93%D7%A8_%D7%A9%D7%A0%D7%99\" class=\"mw-redirect\" title=\"חדר שני\">חדר שני</a>, מטבח קטן, ו<a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94\" title=\"מקווה\">מקווה</a> מפואר<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>. בית הכנסת מוקף בגינה מטופחת ויפה אשר נערכים בה לעיתים <a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"התוועדות\">התוועדויות</a> למתפללי בית הכנסת, וגם פעילויות ל<a href=\"/index.php/%D7%99%D7%9C%D7%93%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ילדים\">ילדים</a>.\n</p><p>בית הכנסת בנוי בצדו החיצוני בסגנון אדריכלי מיוחד מאוד, כאשר הוא בנוי מכלך מיני בליטות שבולטות ממנו דבר היוצר מחזה מאוד יפה, חלונות בית הכנסת הם חלונות רחבים כמו שכתוב ב<a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A\" title=\"שולחן ערוך\">שולחן ערוך</a> שחלונות בית הכנסת צרכים להיות רחבים כדי שאדם יוכל לכוון ליבו לשמים. החלונות גם הם בנויים בצורה ייחודית. ארון הקודש מתפרס לגובה של למעלה מחמישה מטר ומבנהו מזכיר את מבנה <a href=\"/index.php/%D7%A7%D7%95%D7%93%D7%A9_%D7%94%D7%A7%D7%95%D7%93%D7%A9%D7%99%D7%9D\" title=\"קודש הקודשים\">קודש הקודשים</a> שב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9\" title=\"בית המקדש\">בית המקדש</a>. הבימה בנויה כנהוג במרכז בית הכנסת, הבימה יוצרה בהזמנה אישית והוקבעה לבית הכנסת עוד בזמן בו החלו את בנייתו. באולם בית הכנסת מפוזרים כשלוש שורות של ספסלים שאליהם מחוברים כיסאות, כאשר הספסלים משמשים בו בעת כשולחן ליושבים מאחורה.\n</p>\n<ul><li>מטבח בית הכנסת ממוקם בצדו הפנימי של בית הכנסת.</li></ul>\n<p>בקיר הלובי של בית הכנסת יש לוחות זכוכית שמספרות את סיפור חייו של איש החסד ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7\" title=\"יוסף יצחק רייטשיק\">יוסף יצחק רייטשיק</a>. כמו כן ממוקם בבית הכנסת <a href=\"/index.php/%D7%9E%D7%A7%D7%95%D7%95%D7%94_%D7%98%D7%94%D7%A8%D7%94\" class=\"mw-redirect\" title=\"מקווה טהרה\">מקווה טהרה</a> מפואר, בבור הטבילה שולבו אבנים ממקווה ש<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> טבל בו, המקווה פתוח בכל ימות השבוע.\nבבית הכנסת יש למעלה מ200 מקומות ישיבה<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup> והוא הבית כנסת השני בגודלו ב<a href=\"/index.php/%D7%A9%D7%9B%D7%95%D7%A0%D7%AA_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7\" class=\"mw-redirect\" title=\"שכונת לוי יצחק\">שכונת לוי יצחק</a> (אחרי <a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בית הכנסת ישראל אריה לייב (הדף אינו קיים)\">בית הכנסת ישראל אריה לייב</a>) ומהגדולים שבבתי הכנסת ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.\n</p>\n<h3><span id=\".D7.94.D7.A4.D7.A2.D7.99.D7.9C.D7.95.D7.99.D7.95.D7.AA_.D7.9C.D7.99.D7.9C.D7.93.D7.99.D7.9D_.D7.91.D7.91.D7.99.D7.AA_.D7.94.D7.9B.D7.A0.D7.A1.D7.AA\"></span><span class=\"mw-headline\" id=\"הפעילויות_לילדים_בבית_הכנסת\">הפעילויות לילדים בבית הכנסת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;הפעילויות לילדים בבית הכנסת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: הפעילויות לילדים בבית הכנסת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>בשבתות מתקיימת בבית הכנסת פעילות צ\"ה מושקעת.\nובחגים יוצאים המתפללים ל'מבצעים' במחנה צריפין ובמרכז הרפואי 'שמיר' (אסף הרופא), את הפעילות מארגן ר' <a href=\"/index.php?title=%D7%A9%D7%99_%D7%A8%D7%A4%D7%90%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שי רפאל (הדף אינו קיים)\">שי רפאל</a><sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.90.D7.99.D7.A9.D7.99.D7.9D_.D7.91.D7.91.D7.99.D7.AA_.D7.94.D7.9B.D7.A0.D7.A1.D7.AA\"></span><span class=\"mw-headline\" id=\"אישים_בבית_הכנסת\">אישים בבית הכנסת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;אישים בבית הכנסת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%99%D7%95%D7%A1%D7%99_%D7%A8%D7%99%D7%99%D7%98%D7%A9%D7%99%D7%A7_%D7%A9%D7%95%D7%9C_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: אישים בבית הכנסת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<dl><dt>תפקידים בבית הכנסת</dt></dl>\n<p><b><a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a></b>: הרב <a href=\"/index.php/%D7%90%D7%A9%D7%A8_%D7%90%D7%99%D7%99%D7%96%D7%A0%D7%91%D7%9A\" title=\"אשר אייזנבך\">אשר אייזנבך</a>.\n</p>\n<dl><dt>גבאים</dt>\n<dd></dd></dl>\n<ul><li>ר' אבי מלכא.</li>\n<li>ר' צבי אברמוביץ'.</li>\n<li>ר' מוטי פרידמן.</li></ul>\n<dl><dt><a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a></dt>\n<dd>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A7%D7%98%D7%9F\" class=\"mw-redirect\" title=\"יעקב קטן\">יעקב קטן</a><sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>.</dd></dl>\n<dl><dt>אישים בולטים 