0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ד במנחם אב\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ה במנחם אב\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ו במנחם אב\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ז במנחם אב\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ח במנחם אב\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"כ&quot;ט במנחם אב\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" title=\"ל&#39; במנחם אב\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ד' באב</b> הוא היום הרביעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">חודש מנחם אב</a> והיום השבעה עשר מ<a href=\"/index.php/%D7%99%D7%9E%D7%99_%D7%91%D7%99%D7%9F_%D7%94%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ימי בין המצרים\">ימי בין המצרים</a> (הרביעי ב\"תשעת הימים\").\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%99%D7%A9%D7%A9%D7%9B%D7%A8\" title=\"יששכר\">יששכר</a> בן <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91\" class=\"mw-redirect\" title=\"יעקב\">יעקב</a> ו<a href=\"/index.php/%D7%9C%D7%90%D7%94\" class=\"mw-redirect\" title=\"לאה\">לאה</a>, נולד.</li>\n<li>ה'תנ\"ו - רבי <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%91%D7%9F_%D7%A2%D7%98%D7%A8\" title=\"חיים בן עטר\">חיים בן עטר</a> -בעל האור החיים הקדוש, נולד.</li>\n<li>ג'תי\"ג – ה<a href=\"/index.php/%D7%9B%D7%A1%D7%A3\" title=\"כסף\">כסף</a>, ה<a href=\"/index.php/%D7%96%D7%94%D7%91\" title=\"זהב\">זהב</a> והכלים של <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9E%D7%A7%D7%93%D7%A9\" title=\"בית המקדש\">בית המקדש</a>, נשקלו בפקודת <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%90_%D7%94%D7%A1%D7%95%D7%A4%D7%A8\" title=\"עזרא הסופר\">עזרא הסופר</a>.</li>\n<li>ה'ש\"פ – רבי <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%A2%D7%96%D7%A8%D7%99%D7%94_%D7%9E%D7%A4%D7%90%D7%A0%D7%95\" title=\"מנחם עזריה מפאנו\">מנחם עזריה מפאנו</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> – רבי <a href=\"/index.php/%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%9D\" class=\"mw-redirect\" title=\"בן ציון הלברשטם\">בן ציון הלברשטם</a> מ<a href=\"/index.php/%D7%91%D7%90%D7%91%D7%95%D7%91\" class=\"mw-redirect\" title=\"באבוב\">באבוב</a>, מחבר ספר 'קדושת ציון', נהרג על <a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9_%D7%94%27\" class=\"mw-redirect\" title=\"קידוש ה&#39;\">קידוש ה'</a>.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> – הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%97%D7%96%D7%9F\" title=\"אהרן חזן\">אהרן חזן</a>, מחסידי חב\"ד שעסקו בשמירת הגחלת היהודית ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> במשך עשרות שנים.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> - הרב <a href=\"/index.php/%D7%A8%D7%90%D7%95%D7%91%D7%9F_%D7%94%D7%9C%D7%9E%D7%9F\" title=\"ראובן הלמן\">ראובן הלמן</a> שהיה מחשובי אנ\"ש בכפר חב\"ד ואב משפחה חב\"די ענפה שעבר חיים סוערים.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> - הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%97%D7%A6%D7%A8%D7%A0%D7%95%D7%91\" title=\"אריה לייב חצרנוב\">אריה לייב חצרנוב</a> מאנ\"ש בירושלים ובעל מסירות נפש</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%93%27_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%99%D7%9E%D7%99_%D7%91%D7%99%D7%9F_%D7%94%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ימי בין המצרים\">ימי בין המצרים</a></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ד' במנחם-אב - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>מיט דער גרעסטער הארעוואניע קען מען ניט פארדינען קיין איין סענט מעהר וויפיל השי\"ת האט אפגעשטעלט, אז דער און דער מענש זאל פארדינען. מען בעדארף טאן וויפיל עס איז נויטיג, אבער מען מוז געדיינקען, אז די גאנצע ארבעט, איז מער ניט ווי א טפל, דער עיקר איז די ברכה פון השי\"ת, און די ברכה פארדינט מען ווען מען איז א ערליכער איד: <a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%94\" title=\"תפילה\">תפילה</a> ב<a href=\"/index.php?title=%D7%A6%D7%99%D7%91%D7%95%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ציבור (הדף אינו קיים)\">ציבור</a>, שמירת <a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבת</a> בהידור <a href=\"/index.php/%D7%9B%D7%A9%D7%A8\" class=\"mw-redirect\" title=\"כשר\">כשרות</a> בהשגחה גדולה, <a href=\"/index.php/%D7%97%D7%99%D7%A0%D7%95%D7%9A\" title=\"חינוך\">חינוך</a> ה<a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בנים (הדף אינו קיים)\">בנים</a> בא <a href=\"/index.php/%D7%9E%D7%9C%D7%9E%D7%93_%D7%AA%D7%99%D7%A0%D7%95%D7%A7%D7%95%D7%AA\" title=\"מלמד תינוקות\">מלמדים</a> ערליכע אידען.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: ביגיעה הגדולה ביותר אי אפשר להשיג סנט אחד יותר מכמה שהשם-יתברך הקציב, שהאדם הזה והזה ירוויח. צריך לעשות כמה שנחוץ, אבל חייבים לזכור, שכל העבודה, הוא לא יותר מטפל, העיקר הוא הברכה של השם-יתברך, ואת הברכה מרוויחים כשמתנהגים ביראת שמים: <a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%94\" title=\"תפילה\">תפילה</a> ב<a href=\"/index.php?title=%D7%A6%D7%99%D7%91%D7%95%D7%A8&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ציבור (הדף אינו קיים)\">ציבור</a>, שמירת <a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבת</a> בהידור <a href=\"/index.php/%D7%9B%D7%A9%D7%A8%D7%95%D7%AA\" title=\"כשרות\">כשרות</a> בהשגחה גדולה, <a href=\"/index.php/%D7%97%D7%99%D7%A0%D7%95%D7%9A\" title=\"חינוך\">חינוך</a> ה<a href=\"/index.php?title=%D7%91%D7%A0%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בנים (הדף אינו קיים)\">בנים</a> אצל <a href=\"/index.php/%D7%9E%D7%9C%D7%9E%D7%93_%D7%AA%D7%99%D7%A0%D7%95%D7%A7%D7%95%D7%AA\" title=\"מלמד תינוקות\">מלמדים</a> יראי שמים.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413110136\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.032 seconds\nReal time usage: 0.458 seconds\nPreprocessor visited node count: 94/1000000\nPost‐expand include size: 7500/2097152 bytes\nTemplate argument size: 660/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  247.644      1 -total\n 54.76%  135.611      1 תבנית:להיום_יום\n 45.17%  111.850      1 תבנית:חודש_אב\n 36.47%   90.319      1 תבנית:היום_יום/ד&#039;_מנחם-אב\n 30.57%   75.697      1 תבנית:לוח_שנה\n 14.26%   35.314      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:18257-0!canonical and timestamp 20260413110136 and revision id 839176. Rendering was triggered because: diff-page\n -->\n</div>"
