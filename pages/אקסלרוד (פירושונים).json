    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>ОћОљОЮ ОћОфОЏОЋОЋОаОфОЮ Ою...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93_(%D7%94%D7%A1%D7%95%D7%A4%D7%A8)\" class=\"mw-redirect\" title=\"ОъОЕОћ ОљОДОАОюОеОЋОЊ (ОћОАОЋОцОе)\">ОъОЕОћ ОљОДОАОюОеОЋОЊ (ОћОАОЋОцОе)</a> - ОћОъОДОЉОю ОћОЕОюОЎОЕОЎ ОЕОю <a href=\"/index.php/%D7%9B%D7%AA%D7%91_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"ОЏОфОЉ ОљОЊОъОЋ&quot;Ое ОћОќОДОЪ\">ОЏОфОЉ ОљОЊОъОЋ\"Ое ОћОќОДОЪ</a> ОъОљОф ОќОЋОаОЊОю ОћОАОЋОцОе ОЕОДОЎОЉОю ОъОљОф <a href=\"/index.php/%D7%A8%D7%90%D7%95%D7%91%D7%9F_%D7%94%D7%A1%D7%95%D7%A4%D7%A8\" title=\"ОеОљОЋОЉОЪ ОћОАОЋОцОе\">ОеОљОЋОЉОЪ ОћОАОЋОцОе</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%A9%D7%9C%D7%9E%D7%94_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"ОљОћОеОЪ ОЕОюОъОћ ОљОДОАОюОеОЋОЊ\">ОљОћОеОЪ ОЕОюОъОћ ОљОДОАОюОеОЋОЊ</a> - ОъОеОљОЕОЋОаОЎ ОЌОАОЎОЊОЎ ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ОљОеОдОЋОф ОћОЉОеОЎОф\">ОљОеОдОЋОф ОћОЉОеОЎОф</a> ОЕОЕОЎОъОЕ ОЏОЕОюОЎОЌ ОћОеОЉОЎ ОћОеОЎОЎ\"Од ОЉ<a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ОаОЎОЋ ОЎОЋОеОД\">ОаОЎОЋ ОЎОЋОеОД</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"ОљОЉОеОћОЮ ОљОюОЎОћОЋ ОљОДОАОюОеОЋОЊ\">ОљОЉОеОћОЮ ОљОюОЎОћОЋ ОљОДОАОюОеОЋОЊ</a> - ОеОЉ ОћОбОЎОе <a href=\"/index.php/%D7%91%D7%95%D7%9C%D7%98%D7%99%D7%9E%D7%95%D7%A8\" title=\"ОЉОЋОюОўОЎОъОЋОе\">ОЉОЋОюОўОЎОъОЋОе</a>, ОЋОъОЌОЕОЋОЉОЎ ОеОЉОаОЎ ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"ОљОеОдОЋОф ОћОЉОеОЎОф\">ОљОеОдОЋОф ОћОЉОеОЎОф</a>.</li></ul>\n<hr />\n<ul><li>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"ОъОЕОћ ОљОДОАОюОеОЋОЊ\">ОъОЕОћ ОљОДОАОюОеОЋОЊ</a> - ОеОЉ ОЉ<a href=\"/index.php/%D7%96%27%D7%9C%D7%95%D7%91%D7%99%D7%9F\" title=\"Оќ&#39;ОюОЋОЉОЎОЪ\">Оќ'ОюОЋОЉОЎОЪ</a> ОЋОъОеОЉОаОЎ ОЌОЉ\"ОЊ ОћОЉОЋОюОўОЎОЮ ОЕОъОАОеОЋ ОаОцОЕОЮ ОбОю ОћОЎОћОЊОЋОф ОЉ<a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%94%D7%A1%D7%95%D7%91%D7%99%D7%99%D7%98%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ОеОЋОАОЎОћ ОћОАОЋОЉОЎОЎОўОЎОф\">ОеОЋОАОЎОћ ОћОАОЋОЉОЎОЎОўОЎОф</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%92%D7%93%D7%9C%D7%99%D7%94%D7%95_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" class=\"mw-redirect\" title=\"ОњОЊОюОЎОћОЋ ОљОДОАОюОеОЋОЊ\">ОњОЊОюОЎОћОЋ ОљОДОАОюОеОЋОЊ</a> - ОеОЉ ОДОћОЎОюОф ОЌОЉ\"ОЊ ОЋОЉОбОЉОе ОљОЉ ОЉОЎОф ОћОЊОЎОЪ ОЉ<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"ОЌОЎОцОћ\">ОЌОЎОцОћ</a>, ОЋОеОљОЕ ОЎОЕОЎОЉОф ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%91%D7%90%D7%A8_%D7%A9%D7%91%D7%A2\" title=\"ОЉОљОе ОЕОЉОб\">ОЉОљОе ОЕОЉОб</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%90%D7%9C%D7%99%D7%A6%D7%95%D7%A8_-_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"ОЎОћОЋОЊОћ ОљОеОЎОћ ОюОЎОЎОЉ ОљОюОЎОдОЋОе - ОљОДОАОюОеОЋОЊ\">ОЎОћОЋОЊОћ ОљОеОЎОћ ОюОЎОЎОЉ ОљОюОЎОдОЋОе - ОљОДОАОюОеОЋОЊ</a> - ОеОЉ ОдОЉОљОЎ ОЉ<a href=\"/index.php/%D7%A6%D7%94%22%D7%9C\" title=\"ОдОћ&quot;Ою\">ОдОћ\"Ою</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93_(%D7%A2%D7%AA%D7%9C%D7%99%D7%AA)\" title=\"ОъОЕОћ ОљОДОАОюОеОЋОЊ (ОбОфОюОЎОф)\">ОъОЕОћ ОљОДОАОюОеОЋОЊ</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"ОЕОюОЎОЌ\">ОЕОюОЎОЌ</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a> ОЉОбОфОюОЎОф.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" class=\"mw-redirect\" title=\"ОЉОаОЎОъОЎОЪ ОљОДОАОюОеОЋОЊ\">ОЉОаОЎОъОЎОЪ ОљОДОАОюОеОЋОЊ</a> - ОъОЕОюОЋОЌОЎ ОћОеОЉОЎ Ою<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A4%D7%A8%D7%99%D7%96\" class=\"mw-redirect\" title=\"ОЉОЎОф ОюОЎОЋОЉОљОЋОЋОЎОўОЕ ОцОеОЎОќ\">ОЉОЎОф ОюОЎОЋОЉОљОЋОЋОЎОўОЕ ОцОеОЎОќ</a> - <a href=\"/index.php/%D7%A4%D7%AA%D7%97_%D7%AA%D7%A7%D7%95%D7%95%D7%94\" title=\"ОцОфОЌ ОфОДОЋОЋОћ\">ОцОфОЌ ОфОДОЋОЋОћ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%A9%D7%90%D7%95%D7%9C_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"ОЕОљОЋОю ОљОДОАОюОеОЋОЊ\">ОЕОљОЋОю ОљОДОАОюОеОЋОЊ</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"ОЕОюОЎОЌ\">ОЕОюОЎОЌ</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a> ОЉОњОЉОбОф ОљОЋОюОњОћ (ОћОњОљОЋОюОћ) <a href=\"/index.php/%D7%97%D7%93%D7%A8%D7%94\" title=\"ОЌОЊОеОћ\">ОЉОЌОЊОеОћ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" class=\"mw-redirect\" title=\"ОЎОдОЌОД ОљОћОеОЋОЪ ОљОДОАОюОеОЋОЊ\">ОЎОдОЌОД ОљОћОеОЋОЪ ОљОДОАОюОеОЋОЊ</a> - ОеОљОЕ ОЎОЕОЎОЉОф <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%94%D7%91%D7%95%D7%9B%D7%A8%D7%99%D7%9D_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"ОЎОЕОЎОЉОф ОћОЉОЋОЏОеОЎОЮ (ОДОўОаОћ)\">ОЎОЕОЎОЉОф ОћОЉОЋОЏОеОЎОЮ (ОДОўОаОћ)</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%93%D7%91_%D7%90%D7%A7%D7%A1%D7%9C%D7%A8%D7%95%D7%93\" title=\"ОЊОЉ ОљОДОАОюОеОЋОЊ\">ОЊОЉ ОљОДОАОюОеОЋОЊ</a> - <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"ОЕОюОЎОЌ\">ОЕОюОЎОЌ</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a> ОЉ<a href=\"/index.php/%D7%A6%27%D7%A8%D7%A7%D7%90%D7%A1%D7%99\" title=\"Од&#39;ОеОДОљОАОЎ\">Од'ОеОДОљОАОЎ</a>, <a href=\"/index.php/%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" title=\"ОљОЋОДОеОљОЎОаОћ\">О