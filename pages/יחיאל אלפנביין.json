    "pageid": 64648,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/ca/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F.jpg/200px-%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F.jpg\" decoding=\"async\" width=\"200\" height=\"227\" class=\"mw-file-element\" srcset=\"/images/thumb/c/ca/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F.jpg/300px-%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F.jpg 1.5x, /images/c/ca/%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F.jpg 2x\" /></a><figcaption>הרב יחיאל אלפנביין</figcaption></figure>\n<p>הרב <b>יחיאל אלפנביין</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a>) הינו משגיח בחסידות בוקר וחבר צוות ההנהלה הרוחנית והגשמית <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים קריית גת (קטנה)\">בישיבה קטנה תומכי תמימים בקרית גת</a> .\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a> ב<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a> לרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F\" title=\"ישראל יהודה אלפנביין\">ישראל יהודה</a> ומרת חנה אלפנביין.\n</p><p>בצעירותו למד בישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים בנתניה</a> ו<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"תומכי תמימים אור יהודה (גדולה)\">באור יהודה</a>. בשנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> נסע ללמוד במסגרת <a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">שנת ה'קבוצה'</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" title=\"תומכי תמימים המרכזית 770\">ישיבה המרכזית ב-770</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a> התחתן עם הגב' חנה, בת הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%94%D7%91%D7%A8\" title=\"משה דובער הבר\">משה דובער הבר</a>, והתגורר ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>. \n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> החל לשמש כמשגיח ל<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים קריית גת (קטנה)\">ישיבה קטנה תומכי תמימים קריית גת</a>, ובעקבות כך עבר להתגורר ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"קריית גת\">עיר</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> יזם אירוע התרמה נרחב לטובת פיתוח הישיבה<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, שכלל בניית <a href=\"/index.php/%D7%96%D7%90%D7%9C\" title=\"זאל\">זאל</a> חדש וגדול. כתוצאה מכך, הוא הצטרף לצוות ההנהלה הגשמית של הישיבה. \n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> החל לנהל את מחלקת הבוגרים בישיבה.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו ר' <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F\" title=\"שניאור זלמן אלפנביין\">שניאור זלמן אלפנביין</a> - ביתר עלית</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/old/files/0.33451045104_6321280.pdf\">תשורה מחתונת הרב יחיאל וחנה אלפנביין <span typeof=\"mw:File\"></span></a><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></li></ul>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%