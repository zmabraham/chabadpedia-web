    "pageid": 37514,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/24/%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8.jpg/250px-%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8.jpg\" decoding=\"async\" width=\"250\" height=\"188\" class=\"mw-file-element\" srcset=\"/images/thumb/2/24/%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8.jpg/375px-%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8.jpg 1.5x, /images/thumb/2/24/%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8.jpg/500px-%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8.jpg 2x\" /></a><figcaption>הרב אלעד קנטור</figcaption></figure>\n<p>הרב <b>אלעד שלמה קנטור</b> (מפורסם בשם העט: <b>אוהד בר סלע,</b> יליד <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a>), הינו מנהל <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%94%D7%94%D7%A4%D7%A6%D7%94_%D7%9E%D7%9E%D7%A9\" title=\"מרכז ההפצה ממש\">ממש - מרכז חב\"ד  להפצת אור הגאולה</a> , סופר חסידי, ועסקן הפועל רבות להפצת <a href=\"/index.php/%D7%91%D7%A9%D7%95%D7%A8%D7%AA_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"בשורת הגאולה\">בשורת הגאולה</a> והנפקת חומרי עזר לפרסום והפצה.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%A4%D7%AA%D7%97_%D7%AA%D7%A7%D7%95%D7%95%D7%94\" title=\"פתח תקווה\">פתח תקווה</a> ב<a href=\"/index.php/%D7%99%22%D7%98_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"י&quot;ט שבט\">י\"ט שבט</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> לאביו ר' דוד ולויטה יוכבד.\n</p><p>בצעירותו למד במוסדות חב\"ד , ובעקבות כך למד בישיבה גדולה בצפת.  בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%90\" title=\"תשס&quot;א\">תשס\"א</a> נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>בזמן לימודיו ב'קבוצה', ייסד את מכון ההוצאה לאור '<a href=\"/index.php/%D7%9E%D7%9E%D7%A9_-_%D7%9E%D7%A8%D7%9B%D7%96_%D7%94%D7%94%D7%A4%D7%A6%D7%94_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ממש - מרכז ההפצה בארץ הקודש\">ממש</a>' עם עוד מספר בחורים, יזם את הדפסת הסדרה <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_-_%D7%A4%D7%99%D7%A2%D7%A0%D7%95%D7%97%D7%99%D7%9D\" class=\"mw-redirect\" title=\"דבר מלכות - פיענוחים\">דבר מלכות - פיענוחים</a> ואף נמנה על צוות העריכה.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> הקים את משרדי המכון ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a> והחל להפעיל מערך מסודר של הוצאה לאור המתרכז בהנפקת חומרים איכותיים לפעילים העוסקים בהפצת בשורת הגאולה כמו - עלוני הסברה לחגים, ספרים, מוצרי משיח, מוצרים וחוברות צביעה לגני ילדים באופן שהכל חדור בעניין העיקרי - קבלת פני משיח.\n</p><p>לאורך השנים פרסם טורים שונים ב<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> ובאתר הגאולה תחת שם העט אוהד בר סלע.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%93\" title=\"תשע&quot;ד\">תשע\"ד</a> יזם קמפיין פרסום ארצי תחת הסלוגן '<a href=\"/index.php/%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"משיח\">משיח</a> - עוד מעשה קטן והוא כאן', ובשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%95\" title=\"תשע&quot;ו\">תשע\"ו</a> יזם פרוייקט המשך של פרסום הקמפיין על מוניות ואמצעי תחבורה ציבוריים.\n</p><p>בשנת תשפ\"ב יזם קמפיין ארצי ענק המתפרס על כל ארץ הקודש לרגל 120 שנה להולדת כ\"ק אדמו\"ר מלך המשיח שליט\"א הושכר 120 מוניות שירות שפרסמו בכל ארץ הקודש את השלטים\n</p><p>הרב קנטור מתגורר ב<a href=\"/index.php/%D7%91%D7%AA_%D7%99%D7%9D\" title=\"בת ים\">בת ים</a>.\n</p>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.9D_.D7.91.D7.A2.D7.A8.D7.99.D7.9B.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ספרים_בעריכתו\">ספרים בעריכתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ספרים בעריכתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ספרים בעריכתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_-_%D7%A4%D7%99%D7%A2%D7%A0%D7%95%D7%97%D7%99%D7%9D\" class=\"mw-redirect\" title=\"דבר מלכות - פיענוחים\">דבר מלכות - פיענוחים</a></b> (עורך שותף)</li>\n<li><b>משיח - תמונות ורגעים</b> (עורך שותף)</li>\n<li><b>החלום המופלא</b> (עורך שותף)</li>\n<li><b>קומיקס של התקשרות</b> (עורך שותף)</li>\n<li><b>החייל סיפורו של תמים</b> (הביא לדפוס)</li>\n<li><b>הלמדן כבשונו של תמים</b> (הביא לדפוס)</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, <a href=\"/index.php/%D7%92%D7%99%D7%90_%D7%91%D7%A6%D7%9C%D7%90%D7%9C_%D7%A7%D7%A0%D7%98%D7%95%D7%A8\" title=\"גיא בצלאל קנטור\">גיא בצלאל קנטור</a> - יוזם ומפיק פרוייקטים חב\"דיים, הפיק את מספר קלטות וסרטים חסידיים לילדים סופר מרצה ואיש הגות</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.94_.D7.A2.D7.95.D7.93\"></span><span class=\"mw-headline\" id=\"ראה_עוד\">ראה עוד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;ראה עוד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: ראה עוד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%9E%D7%9E%22%D7%A9\" class=\"mw-redirect\" title=\"מכון ממ&quot;ש\">מכון ממ\"ש</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%9C%D7%A2%D7%93_%D7%A7%D7%A0%D7%98%D7%95%D7%A8&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://www.hageula.com/tag/?term=%D7%90%D7%95%D7%94%D7%93%20%D7%91%D7%A8%20%D7%A1%D7%9C%D7%A2\">תגית אוהד בר סלע</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר הגאולה\"><img alt=\"קישור לאתר הגאולה\" src=\"/images/thumb/b/b3/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_%D7%90%D7%AA%D7%A8_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%97%D7%93%D7%A9.jpg/50px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_%D7%90%D7%AA%D7%A8_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%97%D7%93%D7%A9.jpg\" decoding=\"async\" width=\"50\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/b/b3/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_%D7%90%D7%AA%D7%A8_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%97%D7%93%D7%A9.jpg/75px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_%D7%90%D7%AA%D7%A8_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%97%D7%93%D7%A9.jpg 1.5x, /images/thumb/b/b3/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_%D7%90%D7%AA%D7%A8_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%97%D7%93%D7%A9.jpg/100px-%D7%A1%D7%9E%D7%