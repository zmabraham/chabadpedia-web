      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5.png\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e2/%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5.png/220px-%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5.png\" decoding=\"async\" width=\"220\" height=\"304\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e2/%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5.png/330px-%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5.png 1.5x, /images/thumb/e/e2/%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5.png/440px-%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5.png 2x\" /></a><figcaption>הרב גורביץ</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/9a/%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg/220px-%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg\" decoding=\"async\" width=\"220\" height=\"163\" class=\"mw-file-element\" srcset=\"/images/thumb/9/9a/%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg/330px-%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg 1.5x, /images/thumb/9/9a/%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg/440px-%D7%9C%D7%91_%D7%9C%D7%91%D7%99%D7%99%D7%91_%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%90%D7%99%D7%A1%D7%9C%D7%9D_%D7%A7%D7%A8%D7%99%D7%9E%D7%95%D7%91.jpeg 2x\" /></a><figcaption>הרב אבא דוד גורביץ שליח ורב הראשי של אוזבקיסטן, לב לבייב יו\"ר אור אבנר וקונגרס יהודי בוכרה, ונשיא אוזבקיסטן איסלם קרימוב</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_-_%D7%9E%D7%A6%D7%95%D7%AA.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/61/%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_-_%D7%9E%D7%A6%D7%95%D7%AA.jpg/220px-%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_-_%D7%9E%D7%A6%D7%95%D7%AA.jpg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/6/61/%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_-_%D7%9E%D7%A6%D7%95%D7%AA.jpg/330px-%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_-_%D7%9E%D7%A6%D7%95%D7%AA.jpg 1.5x, /images/thumb/6/61/%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_-_%D7%9E%D7%A6%D7%95%D7%AA.jpg/440px-%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_-_%D7%9E%D7%A6%D7%95%D7%AA.jpg 2x\" /></a><figcaption>הרב גורביץ מפקח על חלוקת ה<a href=\"/index.php/%D7%9E%D7%A6%D7%94\" title=\"מצה\">מצות</a> באוזבקיסטן</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_1.jpg\" class=\"mw-file-description\"><img src=\"/images/c/c9/%D7%94%D7%A8%D7%91_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_1.jpg\" decoding=\"async\" width=\"133\" height=\"181\" class=\"mw-file-element\" /></a><figcaption></figcaption></figure>\n<p>הרב <b>אבא דוד גורביץ</b> (<a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כ&quot;ח בכסלו\">כ\"ח בכסלו</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%96\" title=\"תרצ&quot;ז\">תרצ\"ז</a>-<a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%A9%D7%91%D7%98\" title=\"ט&quot;ז בשבט\">ט\"ז בשבט</a> <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%94\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;ה\">ה'תשפ\"ה</a>) היה <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> למדינת <a href=\"/index.php/%D7%90%D7%95%D7%96%D7%91%D7%A7%D7%99%D7%A1%D7%98%D7%9F\" title=\"אוזבקיסטן\">אוזבקיסטן</a> והרב הראשי של אסיה התיכונה.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הרב אבא דוד גורביץ, נולד ב<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>, <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כ&quot;ח בכסלו\">כ\"ח בכסלו</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%96\" title=\"תרצ&quot;ז\">תרצ\"ז</a> לרב <a href=\"/index.php?title=%D7%A8%D7%A4%D7%90%D7%9C_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רפאל דובער גורביץ (הדף אינו קיים)\">רפאל דובער גורביץ</a>. בילדותו, המשפחה נמלטה בזמן ה<a href=\"/index.php/%D7%A9%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"שואה\">שואה</a> והגיעה ל<a href=\"/index.php/%D7%A1%D7%9E%D7%A8%D7%A7%D7%A0%D7%93\" title=\"סמרקנד\">סמרקנד</a>. למד במחתרת בסמרקנד אצל החסיד ר' <a href=\"/index.php/%D7%91%D7%A2%D7%A8%D7%A7%27%D7%94_%D7%97%D7%9F\" class=\"mw-redirect\" title=\"בערק&#39;ה חן\">בערק'ה חן</a>.\n</p><p>התחתן עם גב' מלכה וגרו ב<a href=\"/index.php/%D7%9C%D7%91%D7%95%D7%91\" title=\"לבוב\">לבוב</a> וב<a href=\"/index.php/%D7%98%D7%A9%D7%A7%D7%A0%D7%98\" title=\"טשקנט\">טשקנט</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%97\" title=\"תשכ&quot;ח\">תשכ\"ח</a> זכה לאתר את המצבות של אדמו\"ר <a href=\"/index.php/%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"הצמח צדק\">הצמח צדק</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"הרבי המהר&quot;ש\">הרבי המהר\"ש</a> ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>, ולהקים סביבם גדר אחרי ההרס שהותירו הנאצים במקום, תוך חירוף נפש.\n</p><p>יצא מ<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a> בגל העלייה של שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a>, התיישב ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a> ולימד ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%94%D7%91%D7%95%D7%9B%D7%A8%D7%99%D7%9D\" title=\"ישיבת הבוכרים\">ישיבת הבוכרים</a>, לאחר מספר שנים עבר ל<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> ועסק בסת\"ם. בשנת תש\"נ יצא בשליחות הרבי לטשקנט בירת <a href=\"/index.php/%D7%90%D7%95%D7%96%D7%91%D7%A7%D7%99%D7%A1%D7%98%D7%9F\" title=\"אוזבקיסטן\">אוזבקיסטן</a>.\n</p>\n<h2><span id=\".D7.A9.D7.9C.D7.99.D7.97_.D7.91.D7.90.D7.A1.D7.99.D7.94_.D7.94.D7.AA.D7.99.D7.9B.D7.95.D7.A0.D7.94\"></span><span class=\"mw-headline\" id=\"שליח_באסיה_התיכונה\">שליח באסיה התיכונה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;שליח באסיה התיכונה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: שליח באסיה התיכונה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הרב גורביץ פעל רבות במקום שליחותו ב<a href=\"/index.php/%D7%98%D7%A9%D7%A7%D7%A0%D7%98\" title=\"טשקנט\">טשקנט</a>, ויהודים רבים השתתפו בפעילויותיו. מדי שנה קיים סדר ציבורי בהשתתפות מאות מיהודי המקום,<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> והקים במקום בית ספר יהודי \"בית מנחם\".<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>\n</p><p>עוד בטרם נפילתו המוחלטת של הקומוניזם בברית המועצות, כאשר ניבטו הזרעים הראשונים של ה'פרסטרויקה', שב לטשקנט אחד מבניה לשעבר, הרב אבא דוד גורביץ, ב<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97%D7%95%D7%AA\" title=\"שליחות\">שליחות</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>, כדי לשמר ולהעצים את החיים היהודיים בעיר. עם הזמן התמנה לשליח ולרבה הראשי של אסיה התיכונה.\n</p>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%98%D7%A9%D7%A7%D7%A0%D7%98.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f1/%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%98%D7%A9%D7%A7%D7%A0%D7%98.jpeg/220px-%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%98%D7%A9%D7%A7%D7%A0%D7%98.jpeg\" decoding=\"async\" width=\"220\" height=\"165\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f1/%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%98%D7%A9%D7%A7%D7%A0%D7%98.jpeg/330px-%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%98%D7%A9%D7%A7%D7%A0%D7%98.jpeg 1.5x, /images/thumb/f/f1/%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%98%D7%A9%D7%A7%D7%A0%D7%98.jpeg/440px-%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_%D7%98%D7%A9%D7%A7%D7%A0%D7%98.jpeg 2x\" /></a><figcaption>השליח הרב גורביץ עם בני קהילתו</figcaption></figure>\n<p>בשנים הבאות, הגיעו לטשקנט שלוחים נוספים של הרבי שסייעו לשליח הראשי, ובהם נכדים לעסקני חב\"ד שפעלו בעיר בשנות המלחמה בתנאי מחתרת.\n</p><p>במאמר באתר חב\"ד און ליין תועדה פעילותו במדינות אסיה התיכונה:\nבמשך שנות שליחותו נסע לכל רחבי אסיה התיכונה הכוללת חמש מדינות: <a href=\"/index.php/%D7%90%D7%95%D7%96%D7%91%D7%A7%D7%99%D7%A1%D7%98%D7%9F\" title=\"אוזבקיסטן\">אוזבקיסטן</a>, <a href=\"/index.php/%D7%A7%D7%96%D7%97%D7%A1%D7%98%D7%9F\" title=\"קזחסטן\">קזחסטן</a>, טג'קיסטן, טורקמניסטן וקריגזיה, ובכל מדינה ומדינה ובכל עיר ועיר, אשר שם נמצאים יהודים, פעל בהתאם לאפשרויות והצרכים, מחלוקת זוגות תפילין, לולבים ומצות, ועד הפעלת תמימים-שלוחים לתקופות קצרות וממושכות. גם השליח הראשי לקזחסטן הרב <a href=\"/index.php/%D7%A9%D7%99%D7%99%D7%A2_%D7%9B%D7%94%D7%9F\" class=\"mw-redirect\" title=\"שייע כהן\">שייע כהן</a>, עבר דרך טשקנט כאשר יצא לשליחות בשנת תשנ\"ד, ולאחר חניית ביניים שארכה מספר ימים, נסע עם הרב גורביץ ל<a href=\"/index.php/%D7%90%D7%9C%D7%9E%D7%90_%D7%90%D7%98%D7%90\" title=\"אלמא אטא\">אלמא אטא</a>, שם סייע בעדו להניח את יסודות השליחות.<sup id=\"cite_ref-הרב_גורביץ_-_שליח_בכל_תנאי_ובכל_מצב_3-0\" class=\"reference\"><a href=\"#cite_note-הרב_גורביץ_-_שליח_בכל_תנאי_ובכל_מצב-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>\n</p>\n<h2><span id=\".D7.A7.D7.A9.D7.A8.D7.99.D7.9D_.D7.A2.D7.9D_.D7.A8.D7.91.D7.A0.D7.99.D7.9D_.D7.95.D7.90.D7.99.D7.A9.D7.99_.D7.A6.D7.99.D7.91.D7.95.D7.A8_.D7.91.D7.9B.D7.99.D7.A8.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קשרים_עם_רבנים_ואישי_ציבור_בכירים\">קשרים עם רבנים ואישי ציבור בכירים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;קשרים עם רבנים ואישי ציבור בכירים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: קשרים עם רבנים ואישי ציבור בכירים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>במהלך השנים היו לרב גורביץ קשרים ידידותיים עם ארגונים מקומיים וארגוני חוץ, כמו לדוגמא ארגון <a href=\"/index.php?title=%D7%94%D7%92%27%D7%95%D7%99%D7%A0%D7%98&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"הג&#39;וינט (הדף אינו קיים)\">הג'וינט</a>, אשר העניק סיוע רב ליהודי אוזבקיסטן בשיתוף פעולה עם הרב גורביץ. ובהשגחה פרטית מסובב הסיבות, שלח לטשקנט שני פקידי ג'וינט וותיקים ומנוסים מר סטנלי אברמוביץ והרב ישראל שיף, שניהם עוד זכו לפעול בשנות הי' עם שליח הרבי ב<a href=\"/index.php/%D7%9E%D7%A8%D7%95%D7%A7%D7%95\" title=\"מרוקו\">מרוקו</a> הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%9E%D7%98%D7%95%D7%A1%D7%95%D7%91\" title=\"שלמה מטוסוב\">שלמה מטוסוב</a> ובעידוד הרבי, ולאחר עשרות שנים, התגלגלו לטשקנט ופעלו עם חב\"ד במדינה מוסלמית אחרת.\n</p><p>במקביל היו לו קשרים חשובים עם רבנים בכירים אשר פעלו בתחומים שונים באיזורים בהם הרב גורביץ פעל בשליחות הרבי. לדוגמא, בנושאים הלכתיים מורכבים היה בקשר עם הרב <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%99%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%A7%D7%99%D7%9F\" title=\"עזריאל חייקין\">עזריאל חייקין</a> שליט\"א שנחשב פוסק של השלוחים ב<a href=\"/index.php/%D7%97%D7%91%D7%A8_%D7%94%D7%A2%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"חבר העמים\">חבר העמים</a>, וכך גם היה בקשר רצוף עם רבנים בכירים מבית הדין הגדול של הרבנות הראשית בישראל, הפועל ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> והללו פעלו בתחום הגיטין, ומהם שביקרו בטשקנט, כמו הראשון לציון הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%9E%D7%A9%D7%94_%D7%A2%D7%9E%D7%90%D7%A8\" title=\"שלמה משה עמאר\">שלמה משה עמאר</a> שליט\"א, ומצד שני היו גם ביקורים של חברי כנסת ישראלים, ובו בזמן התפתחה קבוצת גבירים מקומית, אשר הרב גורביץ יצר איתם קשר קרוב כל כך, עד שהם הרגישו חלק מהשליחות, והזרימו תרומות וקשרים כחלק מהשגרה.<sup id=\"cite_ref-הרב_גורביץ_-_שליח_בכל_תנאי_ובכל_מצב_3-1\" class=\"reference\"><a href=\"#cite_note-הרב_גורביץ_-_שליח_בכל_תנאי_ובכל_מצב-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>\n</p>\n<h3><span id=\".D7.92.D7.99.D7.A8.D7.95.D7.A9\"></span><span class=\"mw-headline\" id=\"גירוש\">גירוש</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;גירוש&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: גירוש\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a>, לאחר סדרת התנכלויות לרב<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup> גורש הרב מהמדינה לאחר שהויזה שלו לא הוארכה,.<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup><sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup> מאז גירושו הוא שלח שליחים למדינה לחזק את הפעילות היהודית במקום.<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup> ב<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> מינתה הקהילה את השליח הרב דוד אברהם קולטון לרב הקהילה.<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup> ולאחר זמן קצר גורש אף הוא. וכיום בטשקנט השליח הרב חיים שייקביץ מנהל את פעילות חב\"ד.\n</p><p>בשנים האחרונות היה גר ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>.\n</p><p>הרב גורביץ חתם על <a href=\"/index.php/%D7%A4%D7%A1%D7%A7_%D7%94%D7%93%D7%99%D7%9F_%D7%A9%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%95%D7%90_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"פסק הדין שהרבי הוא מלך המשיח\">פסק הדין שהרבי הוא מלך המשיח</a>.\n</p><p>לאחר תקופה קצרה של מחלה נפטר ב<a href=\"/index.php/%D7%98%22%D7%96_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"ט&quot;ז שבט\">ט\"ז שבט</a> <a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%D7%A4%22%D7%94\" class=\"mw-redirect\" title=\"ה&#39;תשפ&quot;ה\">ה'תשפ\"ה</a>, הלוויתו יצאה בו ביום והוא נטמן בבית החיים ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" title=\"קריית מלאכי\">קריית מלאכי</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אביו, הרב <a href=\"/index.php?title=%D7%A8%D7%A4%D7%90%D7%9C_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"רפאל דובער גורביץ (הדף אינו קיים)\">רפאל דובער גורביץ</a> - נפטר ו' מנחם אב תשמ\"ז. - הוגלה ל<a href=\"/index.php/%D7%A1%D7%99%D7%91%D7%99%D7%A8\" title=\"סיביר\">סיביר</a> ביחד עם ר' <a href=\"/index.php/%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%95%D7%98%D7%A8%D7%A4%D7%90%D7%A1\" class=\"mw-redirect\" title=\"מענדל פוטרפאס\">מענדל פוטרפאס</a></li>\n<li>אמו, מרת שרה אסתר גורביץ - נפטרה י\"ח תשרי תשל\"ז</li>\n<li>אחיו, הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"שמואל גורביץ (כפר חב&quot;ד)\">שמואל גורביץ</a> ע\"ה, מנהל ה<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94\" title=\"תלמוד תורה\">תלמוד תורה</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a></li>\n<li>אחיו, הרב אברהם גורביץ - נפטר ט' ניסן תשס\"א - כפר חב\"ד</li>\n<li>בנו, הרב ברוך גורביץ, שליח ב<a href=\"/index.php/%D7%A9%D7%99%D7%A7%D7%92%D7%95\" title=\"שיקגו\">שיקגו</a></li>\n<li>בנו, הרב יוסף יצחק גורביץ, שליח הרבי ב<a href=\"/index.php/%D7%9C%D7%95%D7%A1_%D7%90%D7%A0%D7%92%27%D7%9C%D7%A1\" title=\"לוס אנג&#39;לס\">לוס אנג'לס</a></li>\n<li>בתו, ברכה רעיית הרב <a href=\"/index.php?title=%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A9%D7%9C%D7%9E%D7%94_%D7%92%D7%90%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אברהם שלמה גאנזבורג (הדף אינו קיים)\">אברהם שלמה גאנזבורג</a>, <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a></li>\n<li>נכדתו רעיית הרב <a href=\"/index.php/%D7%A9%D7%A8%D7%92%D7%90_%D7%A7%D7%A8%D7%95%D7%9E%D7%91%D7%99\" title=\"שרגא קרומבי\">שרגא קרומבי</a></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p><b>חייל-גנרל בשירות הרבי</b>, שבועון בית משיח, גיליון 1448   <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 2x\" /></a></span>\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%91%D7%90_%D7%93%D7%95%D7%93_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/bdh/1181413/\">אבל בחב\"ד: השליח הרב אבא דוד גורביץ ע\"ה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/#!g=1&amp;url=article&amp;id=38991\">נאלצתי לעזוב את מקום שליחותי ראיון</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/#!g=1&amp;url=article&amp;id=30412\">יומן טיסה: מבצע תפילין בגובה 36,000 רגל</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" w