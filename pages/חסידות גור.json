%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%9C%D7%A2%D7%9C%D7%95%D7%91\" title=\"חסידות לעלוב\">לעלוב</a> • <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%98%D7%A8%D7%95%D7%A4%D7%A7%D7%95%D7%91\" title=\"חסידות סטרופקוב\">סטרופקוב</a> • <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A8%D7%90%D7%93%D7%96%D7%99%D7%9F\" class=\"mw-redirect\" title=\"חסידות ראדזין\">ראדזין</a> • <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%91%D7%99%D7%90%D7%9C%D7%90\" title=\"חסידות ביאלא\">ביאלא</a> • <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A4%D7%A9%D7%99%D7%A1%D7%97%D7%90\" class=\"mw-redirect\" title=\"חסידות פשיסחא\">פשיסחא</a> • <a href=\"/index.php?title=%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%90%D7%95%D7%96%27%D7%A8%D7%95%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חסידות אוז&#39;רוב (הדף אינו קיים)\">אוז'רוב</a>\n</td></tr>\n\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">חצרות <a href=\"/index.php/%D7%94%D7%95%D7%A0%D7%92%D7%A8%D7%99%D7%94\" title=\"הונגריה\">הונגריה</a> ו<a href=\"/index.php/%D7%A8%D7%95%D7%9E%D7%A0%D7%99%D7%94\" title=\"רומניה\">רומניה</a></font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%95%D7%99%D7%96%27%D7%A0%D7%99%D7%A5\" title=\"חסידות ויז&#39;ניץ\">ויז'ניץ</a> • <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%90%D7%98%D7%9E%D7%A8\" title=\"חסידות סאטמר\">סאטמאר</a> • <a href=\"/index.php?title=%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%A4%D7%99%D7%A0%D7%A7%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חסידות ספינקא (הדף אינו קיים)\">ספינקא</a> • <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A2%D7%A8%D7%9C%D7%95%D7%99\" title=\"חסידות ערלוי\">ערלוי</a> • <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A4%D7%90%D7%A4%D7%90\" title=\"חסידות פאפא\">פאפא</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #EAE395;\"><font size=\"2\">חצרות <a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a> ו<a href=\"/index.php/%D7%9E%D7%A8%D7%95%D7%A7%D7%95\" title=\"מרוקו\">מרוקו</a></font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A9%D7%95%D7%9E%D7%A8%D7%99_%D7%90%D7%9E%D7%95%D7%A0%D7%99%D7%9D\" title=\"חסידות שומרי אמונים\">שומרי אמונים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%90%D7%A9%D7%9C%D7%92\" title=\"חסידות אשלג\">אשלג</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%A9%D7%95%D7%A9%D7%9C%D7%AA_%D7%90%D7%91%D7%95%D7%97%D7%A6%D7%99%D7%A8%D7%90\" class=\"mw-redirect\" title=\"שושלת אבוחצירא\">אבוחצירא</a>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">שם משפחתו האמיתי היה רוטנברג. בשנת <a href=\"/index.php/%D7%AA%D7%A8%D7%99%22%D7%90\" title=\"תרי&quot;א\">תרי\"א</a> גזרה מלכות <a href=\"/index.php/%D7%A4%D7%95%D7%9C%D7%99%D7%9F\" title=\"פולין\">פולין</a>, כי על כל היהודים לגזור את פיאותיהם וזקנם, ולהוריד מהם את מלבושיהם המיוחדים. פקידי הממשלה רצו לתפוס את החידושי הרי\"ם כדי להסיר ממנו את פיאותיו וזקנו. הוא הסתתר, ובאותה תקופה הוא שינה את שם משפחתו לשם אלתר.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">המוזכרים בהרחבה באגרות קודש אדמו\"ר הרש\"ב, עיין שם במפתח שמות אנשים בסוף חלק ג.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414030811\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.075 seconds\nReal time usage: 0.834 seconds\nPreprocessor visited node count: 157/1000000\nPost‐expand include size: 3926/2097152 bytes\nTemplate argument size: 0/2097152 bytes\nHighest expansion depth: 6/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 1254/5000000 bytes\nLua time usage: 0.030/7 seconds\nLua virtual size: 5476352/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  498.249      1 -total\n 75.04%  373.896      2 תבנית:הערה\n 15.34%   76.432      1 תבנית:הערות_שוליים\n  9.53%   47.500      1 תבנית:חצרות\n  4.11%   20.467      4 תבנית:רווח\n  2.79%   13.911      1 תבנית:הערות_שוליים/מרחב_שם\n  1.53%    7.622      1 תבנית:ש\n  1.47%    7.340      2 תבנית:*\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:13179-0!canonical and timestamp 20260414030811 and revision id 826222. Rendering was triggered because: page-view\n -->\n</div>"
