%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ו בתמוז\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ז בתמוז\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ח בתמוז\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ט בתמוז\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>א' בתמוז</b> (<a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a>) הוא היום הראשון ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב' אלפים ר' (לרוב הדעות) – נולד <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%94%D7%A6%D7%93%D7%99%D7%A7\" title=\"יוסף הצדיק\">יוסף הצדיק</a> בן <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"יעקב אבינו\">יעקב אבינו</a>.</li>\n<li>ב'ש\"ט – הסתלק <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%94%D7%A6%D7%93%D7%99%D7%A7\" title=\"יוסף הצדיק\">יוסף הצדיק</a>, בגיל מאה ועשר. מנוחתו כבוד ב<a href=\"/index.php?title=%D7%A9%D7%9B%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שכם (הדף אינו קיים)\">שכם</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A4%22%D7%92\" title=\"תקפ&quot;ג\">תקפ\"ג</a> – נסתלק רבי <a href=\"/index.php?title=%D7%A7%D7%9C%D7%95%D7%A0%D7%99%D7%9E%D7%95%D7%A1_%D7%A7%D7%9C%D7%9E%D7%9F_%D7%90%D7%A4%D7%A9%D7%98%D7%99%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"קלונימוס קלמן אפשטיין (הדף אינו קיים)\">קלונימוס קלמן אפשטיין</a> מ<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%A7%D7%90\" class=\"mw-redirect\" title=\"קראקא\">קראקא</a> (מחבר ספר 'מאור ושמש'), ומנוחתו כבוד בקראקא.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A1%22%D7%94\" title=\"תרס&quot;ה\">תרס\"ה</a> – נסתלק רבי <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%94%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%90%D7%9D\" title=\"שלמה הלברשטאם\">שלמה הלברשטאם</a>, מייסד <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%91%D7%90%D7%91%D7%95%D7%91\" title=\"חסידות באבוב\">חסידות באבוב</a>.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> מסכים ומברך על הקמת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A8%D7%99%D7%A0%D7%95%D7%90%D7%94\" title=\"תומכי תמימים ברינואה\">תומכי תמימים ברינואה</a></li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9E%22%D7%98\" title=\"תרמ&quot;ט\">תרמ\"ט</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A1%D7%99%D7%9E%D7%A4%D7%A1%D7%95%D7%9F\" title=\"אליהו סימפסון\">אליהו סימפסון</a>, <a href=\"/index.php/%D7%97%D7%95%D7%96%D7%A8\" title=\"חוזר\">חוזר</a> אצל <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"הרבי הרש&quot;ב\">הרבי הרש\"ב</a>, <a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"גבאי\">גבאי</a> אצל <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a>, מהנהלת <a href=\"/index.php/%D7%90%D7%92%D7%95%D7%93%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" class=\"mw-redirect\" title=\"אגודת חסידי חב&quot;ד בארצות הברית\">אגודת חסידי חב\"ד בארצות הברית</a> ו<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" class=\"mw-redirect\" title=\"ישיבת תומכי תמימים המרכזית 770\">ישיבת תומכי תמימים המרכזית 770</a>, סבו של הבחור ה<a href=\"/index.php/%D7%AA%D7%9E%D7%99%D7%9D\" title=\"תמים\">תמים</a> <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%92%D7%95%D7%9C%D7%93%D7%9E%D7%9F\" title=\"אברהם אליעזר גולדמן\">אברהם אליעזר גולדמן</a> הי\"ד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%94\" title=\"תרפ&quot;ה\">תרפ\"ה</a> – ר' <a href=\"/index.php/%D7%A0%D7%AA%D7%9F_%D7%A7%D7%A8%D7%A4%D7%99%D7%9C_%D7%A7%D7%95%D7%91%D7%9C%D7%A0%D7%95%D7%91_(%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7)\" title=\"נתן קרפיל קובלנוב (בני ברק)\">נתן קרפיל קובלנוב</a>, רופא חסידי מאסורי 'תיק 206', ובאחרית ימיו מנכבדי קהילת חב\"ד ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a> – הרב <a href=\"/index.php/%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99\" title=\"שבתי סלבטיצקי\">שבתי סלבטיצקי</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> באנטוורפן שבבלגיה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%93%D7%95%D7%93_%D7%90%D7%99%D7%99%D7%96%D7%A0%D7%91%D7%A8%D7%92\" title=\"משה דוד אייזנברג\">משה דוד אייזנברג</a>, מנהל <a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"תלמוד תורה מגדל העמק\">תלמוד תורה מגדל העמק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%9C\" title=\"תש&quot;ל\">תש\"ל</a> - הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9E%D7%95%D7%A0%D7%93%D7%A9%D7%99%D7%99%D7%9F\" title=\"דוד מונדשיין\">דוד מונדשיין,</a>משלוחי הרבי ב<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a> שברוסיה, מנכ\"ל ארגון החינוך העולמי <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%90%D7%91%D7%A0%D7%A8\" title=\"אור אבנר\">אור אבנר</a> וחבר הנהלת איגוד הקהילות היהודיות ברוסיה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%90%D7%99%D7%A8_%D7%A7%D7%95%D7%91%D7%99%D7%98%D7%A9%D7%A2%D7%A7\" title=\"יעקב מאיר קוביטשעק\">יעקב מאיר קוביטשעק</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> ו<a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> בסרטוב, <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> – ר' <a href=\"/index.php/%D7%A9%D7%9E%D7%A8%D7%99%D7%94%D7%95_%D7%96%D7%9C%D7%9E%D7%9F_%D7%99%D7%A4%D7%94\" title=\"שמריהו זלמן יפה\">שמריהו זלמן יפה</a>, עסקן ציבורי חסיד חב\"ד שחי בתקופתם של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> ו<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> ועמד בראש ועד הקהילה החב\"דית ב<a href=\"/index.php/%D7%93%D7%99%D7%A1%D7%A0%D7%90\" title=\"דיסנא\">דיסנא</a>. נרצח על ידי הנאצים ימ\"ש.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"תשכ&quot;ב\">תשכ\"ב</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%94%D7%9C%D7%9E%D7%9F\" title=\"דוד הלמן\">דוד הלמן</a>, רוקח חסיד חב\"ד ששהה בשליחות <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a> בברן, <a href=\"/index.php/%D7%A9%D7%95%D7%95%D7%99%D7%99%D7%A5\" title=\"שווייץ\">שווייץ</a> ולאחר מכן <a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"גבאי\">גבאי</a> בבית הכנסת חב\"ד ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" class=\"mw-redirect\" title=\"תל אביב\">תל אביב</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"תשע&quot;ג\">תשע\"ג</a> – הרב <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%A4%D7%95%D7%92%D7%9C%D7%9E%D7%9F\" title=\"צבי יהודה פוגלמן\">צבי יהודה פוגלמן</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a> ו<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> לווסטר מסצ'וסטס.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - א' בתמוז - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i><a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a></i>.\n<p><a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A0%D7%A4%D7%A9\" class=\"mw-redirect\" title=\"מסירת נפש\">מסירת נפש</a> הראויה לבני תורה הוא כדרשת רז\"ל \"אדם כי ימות באהל\", להמית את כל ה<a href=\"/index.php/%D7%AA%D7%A2%D7%A0%D7%95%D7%92\" title=\"תענוג\">תענוגים</a> בעניני עולם. כי אפילו דברים קלי הערך בתענוגי עולם, מונעים המה מלהיות מסור ונתון באהלה של <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414024421\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.062 seconds\nReal time usage: 0.084 seconds\nPreprocessor visited node count: 118/1000000\nPost‐expand include size: 5609/2097152 bytes\nTemplate argument size: 698/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   14.594      1 -total\n 61.28%    8.943      1 תבנית:חודש_תמוז\n 37.73%    5.506      1 תבנית:לוח_שנה_חסר\n 37.54%    5.478      1 תבנית:להיום_יום\n 16.91%    2.468      1 תבנית:היום_יום/א&#039;_תמוז\n 15.31%    2.235      1 תבנית:כתב_קטן\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:17035-0!canonical and timestamp 20260414024421 and revision id 841004. Rendering was triggered because: api-parse\n -->\n</div>"
