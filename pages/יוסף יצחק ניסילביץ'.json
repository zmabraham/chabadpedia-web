    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/6b/%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5.jpg/250px-%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6b/%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5.jpg/375px-%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5.jpg 1.5x, /images/thumb/6/6b/%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5.jpg/500px-%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5.jpg 2x\" /></a><figcaption>ОћОеОЉ ОЎОЋОАОБ ОЎОдОЌОД ОаОЎОАОюОЉОЎОЦ' (ОфОЕОц\"ОЊ)</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5_%D7%AA%D7%A9%D7%A4%22%D7%91.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/9/99/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5_%D7%AA%D7%A9%D7%A4%22%D7%91.jpeg/250px-%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5_%D7%AA%D7%A9%D7%A4%22%D7%91.jpeg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/9/99/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5_%D7%AA%D7%A9%D7%A4%22%D7%91.jpeg/375px-%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5_%D7%AA%D7%A9%D7%A4%22%D7%91.jpeg 1.5x, /images/thumb/9/99/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5_%D7%AA%D7%A9%D7%A4%22%D7%91.jpeg/500px-%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5_%D7%AA%D7%A9%D7%A4%22%D7%91.jpeg 2x\" /></a><figcaption>ОћОеОЉ ОаОЎОАОЎОюОЉОЎОЦ' ОъОфОЋОЋОбОЊ ОЉ-770. ОљОЎОЎОе ОфОЕОц\"ОЉ</figcaption></figure>\n<p>ОћОеОЉ <b>ОЎОЋОАОБ ОЎОдОЌОД ОаОЎОАОЎОюОЉОЎОЦ'</b> (ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%97%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ОЌ&#39; ОЉОфОъОЋОќ\">ОЌ' ОЉОфОъОЋОќ</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"ОфОЕОю&quot;Ољ\">ОфОЕОю\"Ољ</a>, 1971) ОћОЋОљ ОъОаОћОю ОљОеОњОЋОЪ <a href=\"/index.php/%D7%97%D7%9E%22%D7%94\" class=\"mw-redirect\" title=\"ОЌОъ&quot;Оћ\">ОЌОъ\"Оћ</a> ОЋ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉ<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОаОЌОюОф ОћОе ОЌОЉ&quot;ОЊ\">ОаОЌОюОф ОћОе ОЌОЉ\"ОЊ</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОфОЋОюОЊОЋОф_ОЌОЎОЎОЮ\">ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОаОЌОюОф ОћОе ОЌОЉ&quot;ОЊ\">ОаОЌОюОф ОћОе ОЌОЉ\"ОЊ</a> ОюОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27\" title=\"ОъОЕОћ ОаОЎОАОюОЉОЎОЦ&#39;\">ОъОЕОћ ОаОЎОАОюОЉОЎОЦ'</a> ОЋОюОъОљОеОб (ОюОъОЕОцОЌОф ОъОюОљОЏОЋОЋОАОДОЎ).\n</p><p>ОЉОЉОЌОеОЋОфОЋ ОюОъОЊ ОЉОЎОЕОЎОЉОЋОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЋОЊ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОюОЋОЊ</a> ОЋ<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОЏОцОе ОЌОЉ&quot;ОЊ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОЏОцОе ОЌОЉ\"ОЊ</a>.\n</p><p>ОюОДОеОљОф ОЕОаОф <a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"ОфОаОЕ&quot;Ољ\">ОфОаОЕ\"Ољ</a>, ОаОАОб ОюОюОъОЋОЊ ОЉ<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_770\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф 770\">ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф 770</a> ОЉОъОАОњОеОф ОЕОаОф Оћ'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"ОДОЉОЋОдОћ\">ОДОЉОЋОдОћ</a>'.\n</p><p>ОюОљОЌОе ОаОЎОЕОЋОљОЎОЋ ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"ОфОЕОа&quot;Оћ\">ОфОЕОа\"Оћ</a> ОбОЮ ОеОЌОю ОЉОфОЋ ОЕОю ОћОеОЉ <a href=\"/index.php/%D7%93%D7%91_%D7%98%D7%99%D7%99%D7%9B%D7%9E%D7%9F\" title=\"ОЊОЉ ОўОЎОЎОЏОъОЪ\">ОЊОЉ ОўОЎОЎОЏОъОЪ</a> ОъОеОЉОаОЎ ОЌОЉ\"ОЊ ОЉ<a href=\"/index.php/%D7%98%D7%91%D7%A8%D7%99%D7%94\" title=\"ОўОЉОеОЎОћ\">ОўОЉОеОЎОћ</a>, ОДОЉОб ОљОф ОъОДОЋОЮ ОъОњОЋОеОЎОЋ ОЉ<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОаОЌОюОф ОћОе ОЌОЉ&quot;ОЊ\">ОаОЌОюОф ОћОе ОЌОЉ\"ОЊ</a> ОЋОћОЌОю ОюОюОъОЋОЊ ОЉОЏОЋОюОю ОћОъОДОЋОъОЎ, ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"ОфОЕОа&quot;ОЋ\">ОфОЕОа\"ОЋ</a> ОъОЋОаОћ ОюОЕОъОЕ ОЏОъОЋОеОћ ОЉОфОюОъОЋОЊ ОфОЋОеОћ ОЌОЉ\"ОЊ ОћОъОДОЋОъОЎ, ОЋОъОАОцОе ОЕОаОЎОЮ ОюОљОЌОе ОъОЏОЪ ОћОфОъОаОћ ОЏ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОаОЌОюОф ОћОе ОЌОЉ&quot;ОЊ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОаОЌОюОф ОћОе ОЌОЉ\"ОЊ</a>.\n</p>\n<h3><span id=\".D7.A4.D7.A2.D7.95.D7.9C.D7.95.D7.AA.D7.99.D7.95_.D7.95.D7.AA.D7.A4.D7.A7.D7.99.D7.93.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ОцОбОЋОюОЋОфОЎОЋ_ОЋОфОцОДОЎОЊОЎОЋ\">ОцОбОЋОюОЋОфОЎОЋ ОЋОфОцОДОЎОЊОЎОЋ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОцОбОЋОюОЋОфОЎОЋ ОЋОфОцОДОЎОЊОЎОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОцОбОЋОюОЋОфОЎОЋ ОЋОфОцОДОЎОЊОЎОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"ОфОЕОА&quot;ОЌ\">ОфОЕОА\"ОЌ</a> ОћОЌОю ОюОбОАОЋОД ОЉОћОцОдОф ОАОцОе ОћОфОаОЎОљ ОюОаОЕОЎОЮ ОЋОЎОюОЊОЎОЮ ОЉОћОЋОеОљОф ОљОЉОЎОЋ, ОЉОъОАОњОеОф ОљОеОњОЋОЪ <a href=\"/index.php/%D7%90%D7%97%D7%93%D7%95%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%91%D7%94%D7%A4%D7%A6%D7%AA_%D7%94%D7%9E%D7%A2%D7%99%D7%A0%D7%95%D7%AA\" title=\"ОљОЌОЊОЋОф ОЎОЕОеОљОю ОЉОћОцОдОф ОћОъОбОЎОаОЋОф\">ОљОЌОЊОЋОф ОЎОЕОеОљОю ОЉОћОцОдОф ОћОъОбОЎОаОЋОф</a>, ОЋОћОЋОдОЎОљ ОъОАОцОе ОАОцОеОЎОЮ ОћОъОЉОљОеОЎОЮ ОљОф ОАОцОе ОћОфОаОЎОљ ОюОЎОюОЊОЎОЮ ОЋОћОЌОю ОюОъОАОЋОе ОЕОЎОбОЋОеОЎОЮ ОЉОЕОцОћ ОДОюОћ ОЉОАОцОе ОћОфОаОЎОљ ОюОаОЕОЎОЮ.\n</p><p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"ОфОЕОб&quot;Ољ\">ОфОЕОб\"Ољ</a> ОюОљОЌОе ОцОўОЎОеОф ОљОЉОЎОЋ ОъОЋОаОћ ОЏОъОъОЕОЎОџ ОЊОеОЏОЋ ОЏОъОаОћОю ОљОеОњОЋОЪ <a href=\"/index.php/%D7%97%D7%9E%22%D7%94\" class=\"mw-redirect\" title=\"ОЌОъ&quot;Оћ\">ОЌОъ\"Оћ</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ОЋОћОеОЉ ОаОЎОАОюОЉОЎОЦ' ОцОЋОбОю ОЉОфОцОДОЎОЊ ОќОћ ОЉОћОдОюОЌОћ ОеОЉОћ ОЋОъОцОбОЎОю ОљОф <b>ОЉОаОЎОЎОЪ ОЌОъ\"Оћ</b> ОћОЏОЋОюОю ОЉОфОЋОЏОЋ ОЉОЎОф ОћОЏОаОАОф ОЋОъОДОЋОЋОћ ОЌОЉ\"ОЊ, ОљОЋОюОЮ ОљОЎОеОЋОбОЎОЮ, ОъОбОЋОаОЋОф ОЎОЋОЮ, ОъОеОЏОќОЎ ОъОцОњОЕ ОЋОъОЕОеОЊОЎ ОћОљОеОњОЋОЪ.\n</p><p>ОЉОЎОЪ ОћОЎОфОе ОћОеОЉ ОаОЎОАОЎОюОЉОЎОЦ' ОъОЋОЏОе ОЏОЉОбОю ОюОЕОЋОЪ ОдОЌОћ ОЋОЉОеОЋОеОћ ОЋОъОЕОъОЕ ОЏОъОЕОцОЎОб ОљОЋОеОЌ ОЉОЉОфОЎ ОЌОЉ\"ОЊ ОЋОЉОДОћОЎОюОЋОф ОљОа\"ОЕ ОЋОЉОЎОЕОЎОЉОЋОф ОЌОЉ\"ОЊ, ОћОфОЋОЋОбОЊОЋОЎОЋОфОЎОЋ ОћОАОЋОЌОцОЋОф ОЋОъОеОфОДОЋОф ОљОюОЎОћОЮ ОаОъОЕОЏОЎОЮ ОљОаОЕОЎОЮ ОеОЉОЎОЮ ОЋОЉОћОЮ ОћОЋОљ ОъОАОцОе ОАОЎОцОЋОеОЎОЮ ОъОеОЉОћ ОюОАОцОе ОљОф ОАОЎОцОЋОеОЎ ОћОњОЉОЋОеОћ ОЕОю ОљОЉОЎОЋ ОЉОъОћОюОџ ОЕОюОЎОЌОЋОфОЋ ОЉОеОЋОАОЎОћ.\n</p>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%99%D7%A6_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/fd/%D7%99%D7%99%D7%A6_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27.jpg/250px-%D7%99%D7%99%D7%A6_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/f/fd/%D7%99%D7%99%D7%A6_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27.jpg/375px-%D7%99%D7%99%D7%A6_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27.jpg 1.5x, /images/thumb/f/fd/%D7%99%D7%99%D7%A6_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27.jpg/500px-%D7%99%D7%99%D7%A6_%D7%A0%D7%99%D7%A1%D7%9C%D7%91%D7%99%D7%A5%27.jpg 2x\" /></a><figcaption>ОћОеОЉ ОЎОЋОАОБ ОЎОдОЌОД ОаОЎОАОюОЉОЎОЦ'</figcaption></figure>\n<p>ОЉОаОЋОАОБ ОћОеОЉ ОаОЎОАОюОЉОЎОЦ' ОъОфОЋОЋОбОЊ ОњОЮ ОбОЮ ОаОЕОЎОЮ ОЋОъОДОЋОеОЉОЎОЮ, ОЋОъОЋОАОе ОЕОЎОбОЋОеОЎ ОфОаОЎОљ ОеОЉОЎОЮ ОюОаОЕОЎОЮ ОЋОћОЋОљ ОъОЏОћОЪ ОЏОъОЕОцОЎОб ОЉ<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%90%D7%95%D7%A8_%D7%97%D7%99%D7%94\" title=\"ОъОЏОЋОЪ ОљОЋОе ОЌОЎОћ\">ОъОЏОЋОЪ ОљОЋОе ОЌОЎОћ</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> ОЉОЎОеОЋОЕОюОЎОЮ.\n</p><p>ОЎОЊОЋОб ОЏ<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%AA%D7%A4%D7%99%D7%9C%D7%94\" class=\"mw-redirect\" title=\"ОЉОбОю ОфОцОЎОюОћ\">ОЉОбОю ОфОцОЎОюОћ</a> ОъОЎОЋОЌОЊ ОћОбОЋОЉОе ОюОцОаОЎ ОћОфОЎОЉОћ ОЉОеОњОЕ ОеОЉ ОЋОъОЕОюОЉ ОЉОфОцОЎОюОфОЋ ОаОЎОњОЋОаОЎ ОЌОЉ\"ОЊ ОеОЉОЎОЮ. ОбОЋОЉОе ОюОцОаОЎ ОћОфОцОЎОюОћ ОЉОДОЉОЎОбОЋОф ОЉОЉОЎОф ОћОЏОаОАОф ОЕОю ОЌОъ\"Оћ ОЉОаОЌОюОф ОћОе ОЌОЉ\"ОЊ ОЋОеОЉОЎОЮ ОЉОљОЎОЮ ОюОћОЕОфОфОБ ОЉОфОцОЎОюОЋОф ОъОЎОЋОЌОЊОЋОф ОљОюОЋ. \nОЉОЉОЎОф ОћОЏОаОАОф ОъОДОћОюОф ОЎОюОЊОЎОЮ ОћОъОюОЋОЋОћ ОљОф ОћОфОцОЎОюОЋОф, ОћОеОЉ ОаОЎОАОЎОюОЉОЎОЦ ОЊОЋОњОю ОЉОъОЋОЊОю ОќОћ ОЋОЌОцОЦ ОЉОћОфОцОЕОўОЋОфОЋ ОЉОДОеОЉ ОДОћОЎОюОЋОф ОЌОЉ\"ОЊ <sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\nОЏОъОЋ ОЏОЪ, ОъОЋОќОъОЪ ОцОбОъОЎОЮ ОеОЉОЋОф <a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ОћОфОЋОЋОбОЊОЋОф\">ОюОћОфОЋОЋОбОЊ</a> ОЉОЎОЕОЎОЉОЋОф ОЉОеОЌОЉОЎ <a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОљОеОЦ ОћОДОЋОЊОЕ\">ОљОеОЦ ОћОДОЋОЊОЕ</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ОъОЕОцОЌОфОЋ\">ОъОЕОцОЌОфОЋ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОъОЕОцОЌОфОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОъОЕОцОЌОфОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ОЌОфОаОЋ, Ое' ОЌОЎОЎОЮ ОЕОљОеОБ - ОъОаОћОю ОњОЕОъОЎ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОЉОЎОф ОЕОъОЕ (ОДОўОаОћ)\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОЉОЎОф ОЕОъОЕ</a></li>\n<li>ОЌОфОаОЋ, ОћОеОЉ <a href=\"/index.php?title=%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%94%D7%A8%D7%A9%D7%95%D7%A7%D7%95%D7%91%D7%99%D7%A5_(%D7%90%D7%95%D7%A4%D7%A7%D7%99%D7%9D)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОъОбОЋОЪ ОћОеОЕОЋОДОЋОЉОЎОЦ (ОљОЋОцОДОЎОЮ) (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЕОъОбОЋОЪ ОћОеОЕОДОЋОЉОЎОЦ</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"ОЕОюОЎОЌ\">ОЕОюОЎОЌ</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a> ОЉ<a href=\"/index.php/%D7%90%D7%95%D7%A4%D7%A7%D7%99%D7%9D\" title=\"ОљОЋОцОДОЎОЮ\">ОљОЋОцОДОЎОЮ</a>, ОаОцОўОе ОЉ<a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%9C%D7%95%D7%9C\" title=\"ОЏ&quot;ОЋ ОЉОљОюОЋОю\">ОЏ\"ОЋ ОЉОљОюОЋОю</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"ОфОЕОц&quot;Оњ\">ОфОЕОц\"Оњ</a><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li>ОЉОаОЋ, Ое' ОЕОаОЎОљОЋОе ОќОюОъОЪ ОаОЎОАОЎОюОЉОЎОЦ' - ОъОаОћОю ОцОаОЎОъОЎОЎОћ ОЉ<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%A7%D7%98%D7%A0%D7%94_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОћ ОДОўОаОћ ОЌОАОЎОЊОЎ ОЌОЉ&quot;ОЊ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ ОдОцОф\">ОЎОЕОЎОЉОћ ОДОўОаОћ ОЌОАОЎОЊОЎ ОЌОЉ\"ОЊ ОюОЎОЋОЉОљОЋОЋОЎОўОЕ ОдОцОф</a>.</li>\n<li>ОЉОаОЋ, Ое' ОъОаОЌОЮ ОъОбОаОЊОю ОаОЎОАОЎОюОЉОЎОЦ' - ОцОфОЌ ОфОДОЋОЋОћ.</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"ОюОДОеОЎОљОћ_ОаОЋОАОцОф\">ОюОДОеОЎОљОћ ОаОЋОАОцОф</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;veaction=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОюОДОеОЎОљОћ ОаОЋОАОцОф&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A0%D7%99%D7%A1%D7%99%D7%9C%D7%91%D7%99%D7%A5%27&amp;action=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОюОДОеОЎОљОћ ОаОЋОАОцОф\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ОъОаОЌОЮ ОќОЎОюОњОЉОЋОЎОЮ,&#160;РђЈ<b>ОъОю