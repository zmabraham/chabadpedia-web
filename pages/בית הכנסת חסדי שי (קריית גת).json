  "parse": {
    "title": "ОЉОЎОф ОћОЏОаОАОф ОЌОАОЊОЎ ОЕОЎ (ОДОеОЎОЎОф ОњОф)",
    "pageid": 88693,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table cellpadding=\"4\" cellspacing=\"0\" width=\"250\" style=\"float: left; border: 1px solid #ccd2d9; margin: 0 1em 1em 0em; background: #f9f9f9; font-size: 85%;\">\n<tbody><tr>\n<th align=\"center\" colspan=\"2\" style=\"font-size: larger; background-color: #7dcdd1; color: #000000;\">ОЌОАОЊОЎ ОЕОЎ\n</th></tr>\n<tr valign=\"top\">\n<td colspan=\"2\" align=\"center\"><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/cc/%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92.jpg/250px-%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92.jpg\" decoding=\"async\" width=\"250\" height=\"188\" class=\"mw-file-element\" srcset=\"/images/thumb/c/cc/%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92.jpg/375px-%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92.jpg 1.5x, /images/thumb/c/cc/%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92.jpg/500px-%D7%A7%D7%A8%D7%99%D7%90%D7%AA_%D7%9E%D7%92%D7%99%D7%9C%D7%94_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92.jpg 2x\" /></a></span><br />ОДОеОЎОљОф ОћОъОњОЎОюОћ ОЉОЉОЎОф ОћОЏОаОАОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"ОфОЕОц&quot;Оћ\">ОфОЕОц\"Оћ</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">ОбОЎОе</span></b>\n</td>\n<td><a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"ОДОеОЎОЎОф ОњОф\">ОДОеОЎОЎОф ОњОф</a>\n</td></tr>\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">ОъОЎОЎОАОЊ ОЉОЎОф ОћОЏОаОАОф</span></b>\n</td>\n<td>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"ОъОЕОћ ОћОЉОюОЎОЪ\">ОъОЕОћ ОћОЉОюОЎОЪ</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\">ОфОљОеОЎОџ ОЎОАОЋОЊ</span></b>\n</td>\n<td>ОАОЉОЎОЉОЋОф <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"ОфОЕ&quot;Об\">ОфОЕ\"Об</a>\n</td></tr>\n\n\n\n\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"ОњОЉОљОЎ\">ОњОЉОљОЎ</a> ОњОЕОъОЎ</span></b>\n</td>\n<td>ОћОеОЉ ОЕОаОЎОљОЋОе ОъОъОЋ\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"ОњОЉОљОЎ\">ОњОЉОљОЎ</a> ОеОЋОЌОаОЎ</span></b>\n</td>\n<td>ОћОеОЉ <a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%9C%D7%99%D7%A9%D7%91%D7%99%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЎОдОЌОД ОљОюОЎОЕОЉОЎОЦ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЎОдОЌОД ОљОюОЎОЕОЉОЎОЦ</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%94%D7%95%D7%A8%D7%90%D7%94\" title=\"ОъОЋОеОћ ОћОЋОеОљОћ\">ОеОЉ</a> ОЉОЎОф ОћОЏОаОАОф</span></b>\n</td>\n<td>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"ОъОЕОћ ОћОЉОюОЎОЪ\">ОъОЕОћ ОћОЉОюОЎОЪ</a>\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉОЎОф ОћОЏОаОАОф</span></b>\n</td>\n<td>ОћОеОЉ ОъОљОЎОе ОљОЎОЎОќОЪ\n</td></tr>\n<tr valign=\"top\">\n<td><b><span style=\"white-space: nowrap;\"><a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A7%D7%95%D7%A8%D7%90\" title=\"ОЉОбОю ОДОЋОеОљ\">ОЉОбОю ОДОЋОеОљ</a> ОЉОЉОЎОф ОћОЏОаОАОф</span></b>\n</td>\n<td>ОћОеОЉ ОюОЋОЎ ОъОЋОЕОДОЋОЉОЎОЦ\n</td></tr>\n\n\n\n\n\n<tr>\n<td colspan=\"2\" style=\"border-top: solid 1px #aaaaaa; padding: 0.4em 0 0.4em 0; text-align: center;\" align=\"center\"><a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%9E%D7%95%D7%A1%D7%93%D7%95%D7%AA_%D7%95%D7%90%D7%A8%D7%92%D7%95%D7%A0%D7%99%D7%9D_%D7%91%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"ОДОўОњОЋОеОЎОћ:ОъОЋОАОЊОЋОф ОЋОљОеОњОЋОаОЎОЮ ОЉОДОеОЎОЎОф ОњОф\">ОъОЋОАОЊОЋОф ОЋОљОеОњОЋОаОЎОЮ ОЉОДОеОЎОЎОф ОњОф</a>\n</td></tr></tbody></table>\n<p><b>ОЉОЎОф ОћОЏОаОАОф ОЌОАОЊОЎ ОЕОЎ</b> ОћОЋОљ ОЉОЎОф ОЏОаОАОф ОЌОЉ\"ОЊОЎ ОЉ<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"ОДОеОЎОЎОф ОњОф\">ОДОеОЎОЎОф ОњОф</a>, ОЕОЕОЎОъОЕ ОЉОбОЉОе ОЏ<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"ОЉОЎОф ОЌОЉ&quot;ОЊ\">ОЉОЎОф ОЌОЉ\"ОЊ</a> ОюОбОЋОюОЎ <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ОЉОеОЎОф ОћОъОЋОбОдОЋОф\">ОЉОеОЎОф ОћОъОЋОбОдОЋОф</a>, ОЋОЏОЎОЋОЮ ОцОЋОбОю ОЏОъОеОЏОќ ОфОцОЎОюОћ ОЋОюОЎОъОЋОЊ ОбОЉОЋОе <a href=\"/index.php/%D7%90%D7%A0%22%D7%A9\" class=\"mw-redirect\" title=\"ОљОа&quot;ОЕ\">ОљОа\"ОЕ</a> ОЋОдОЋОЋОф Оћ<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" class=\"mw-redirect mw-disambig\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОДОеОЎОЎОф ОњОф\">ОЎОЕОЎОЉОћ</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.99.D7.A1.D7.98.D7.95.D7.A8.D7.99.D7.94\"></span><span class=\"mw-headline\" id=\"ОћОЎОАОўОЋОеОЎОћ\">ОћОЎОАОўОЋОеОЎОћ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОћОЎОАОўОЋОеОЎОћ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОћОЎОАОўОЋОеОЎОћ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92_%D7%9B..png\" class=\"mw-file-description\"><img src=\"/images/thumb/c/cf/%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92_%D7%9B..png/250px-%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92_%D7%9B..png\" decoding=\"async\" width=\"250\" height=\"187\" class=\"mw-file-element\" srcset=\"/images/thumb/c/cf/%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92_%D7%9B..png/375px-%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92_%D7%9B..png 1.5x, /images/thumb/c/cf/%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92_%D7%9B..png/500px-%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_%D7%A7%22%D7%92_%D7%9B..png 2x\" /></a><figcaption>ОеОЌОЉОф ОћОЏОаОЎОАОћ ОюОЉОЎОф ОћОЏОаОАОф (ОъОЕОъОљОю, ОъОфОЌОф ОюОЉОаОЎОЎОЪ ОћОЎОЕОЎОЉОћ)</figcaption></figure>\n<p>ОЉОЎОф ОћОЏОаОАОф ОћОЋОДОЮ ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A2\" title=\"ОфОЕ&quot;Об\">ОфОЕОА\"ОЋ</a> ОбОю ОЎОЊОЎ ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"ОъОЕОћ ОћОЉОюОЎОЪ\">ОъОЕОћ ОћОЉОюОЎОЪ</a> ОЋОћОеОЉ <a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%9C%D7%99%D7%A9%D7%91%D7%99%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЎОдОЌОД ОљОюОЎОЕОЉОЎОЦ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЎОдОЌОД ОљОюОЎОЕОЉОЎОЦ</a> ОЏОЉОЎОф ОЏОаОАОф ОЋ<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"ОЉОЎОф ОЌОЉ&quot;ОЊ\">ОЉОЎОф ОЌОЉ\"ОЊ</a> ОюОбОЋОюОЎ <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ОЉОеОЎОф ОћОъОЋОбОдОЋОф\">ОЉОеОЎОф ОћОъОЋОбОдОЋОф</a>, ОЋОаОДОеОљ ОбОю ОЕОЮ ОћОЉОЌОЋОе <b>ОЕОюОъОћ ОЎОЋОАОБ ОЕОюОЋОЮ</b> ОЕОаОцОўОе ОЉОдОбОЎОеОЋОфОЋ. ОћОъОДОЋОЮ ОЕОЎОъОЕ ОЏОъОеОЏОќ ОДОћОЎОюОфОЎ ОбОЉОЋОе ОЏ-30 ОќОДОаОЎОЮ ОЕОаОћОаОЋ ОъОцОбОЎОюОЋОф ОбОаОцОћ ОЕОЏОюОюОћ ОюОЎОъОЋОЊОЎ ОЎОћОЊОЋОф, ОљОеОЋОЌОЋОф ОЌОъОЋОф ОъОЊОЎ ОЎОЋОЮ, ОЋОљОЎОеОЋОбОЎОЮ ОЌОњОЎОњОЎОЎОЮ ОЏОъОЋ <a href=\"/index.php/%D7%AA%D7%94%D7%9C%D7%95%D7%9B%D7%AA_%D7%9C%22%D7%92_%D7%91%D7%A2%D7%95%D7%9E%D7%A8\" title=\"ОфОћОюОЋОЏОф Ою&quot;Оњ ОЉОбОЋОъОе\">ОфОћОюОЋОЏОф Ою\"Оњ ОЉОбОЋОъОе</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, ОДОЋОаОдОеОў <a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9B%D7%94\" title=\"ОЌОаОЋОЏОћ\">ОЌОаОЋОЏОћ</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> ОЋОбОЋОЊ.\n</p><p>ОЉОъОћОюОџ <a href=\"/index.php/%D7%9E%D7%92%D7%A4%D7%AA_%D7%94%D7%A7%D7%95%D7%A8%D7%95%D7%A0%D7%94\" class=\"mw-redirect\" title=\"ОъОњОцОф ОћОДОЋОеОЋОаОћ\">ОъОњОцОф ОћОДОЋОеОЋОаОћ</a>, ОЏОљОЕОе ОћОќОДОаОЎОЮ ОЕОћОЎОЋОЋ ОљОф ОеОЋОЉ ОћОъОфОцОюОюОЎОЮ ОаОљОюОдОЋ ОюОћОцОАОЎОД ОюОћОњОЎОб ОъОфОЋОџ ОЌОЕОЕ ОюОЉОеОЎОљОЋОфОЮ ОбОДОЉ ОњОЎОюОЮ, ОћОфОбОЋОеОе ОдОЋОеОџ ОюОњОЎОЎОА ОъОаОЎОЎОЪ ОЌОЊОЕ ОбОю ОъОаОф ОюОДОЎОЎОЮ ОфОцОЎОюОЋОф. ОюОљОЌОе ОћОДОЋОеОЋОаОћ, ОЉОЎОф ОћОЏОаОАОф ОбОЉОе ОфОћОюОЎОџ ОЕОЎОДОЋОЮ ОбОю ОЎОЊОЎ ОдОЎОЉОЋОе <a href=\"/index.php/%D7%90%D7%A0%22%D7%A9\" class=\"mw-redirect\" title=\"ОљОа&quot;ОЕ\">ОљОа\"ОЕ</a> ОЕОћОЌОю ОюОЉОАОАОЋ ОъОЌОЊОЕ.\n</p><p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"ОфОЕОц&quot;ОЊ\">ОфОЕОц\"ОЊ</a> ОћОЌОю ОюОЏОћОЪ ОЏОњОЉОљОЎ ОћОеОЉ ОЎОбОДОЉ ОЎОЋОАОБ ОеОАОДОЎОЪ, ОЕОцОбОю ОюОЌОЎОќОЋОД ОћОъОДОЋОЮ. ОюОљОЌОе ОъОЏОЪ, ОЉОАОЉОЎОЉОЋОф ОЌОЋОЊОЕ <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"ОфОъОЋОќ\">ОфОъОЋОќ</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"ОфОЕОц&quot;Оћ\">ОфОЕОц\"Оћ</a>, ОаОЏОаОА ОюОфОцОДОЎОЊ ОћОњОЉОљОЎ, ОЕОаОЎОљОЋОе ОъОъОЋ, ОЋОћОъОЕОЎОџ ОљОф ОцОЎОфОЋОЌ ОљОф ОћОъОДОЋОЮ ОЉОдОЋОеОћ ОъОеОЕОЎОъОћ: ОћОеОЌОЉОћ ОъОЕОъОбОЋОфОЎОф ОЕОю ОћОћОфОЋОЋОбОЊОЋОЎОЋОф ОЋОЕОЎОцОЋОе ОЌОќОЋОф ОЉОЎОф ОћОЏОаОАОф.\n</p><p>ОЉОЕОаОЎОЮ <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"ОфОЕОц&quot;Оњ\">ОфОЕОц\"Оњ</a> ОЋ<a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"ОфОЕОц&quot;ОЊ\">ОфОЕОц\"ОЊ</a> ОћОфОДОЎОЎОЮ ОЉОъОДОЋОЮ ОЏОЋОюОю ОљОЉОеОЏОЎОЮ <b>'ОљОЋОћОю ОЕОъОбОЋОЪ'</b> ОъОўОбОЮ Оћ<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОДОеОЎОЎОф ОњОф (ОњОЊОЋОюОћ)\">ОЎОЕОЎОЉОћ</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A4.D7.A2.D7.99.D7.9C.D7.95.D7.AA_.D7.91.D7.99.D7.AA_.D7.94.D7.9B.D7.A0.D7.A1.D7.AA\"></span><span class=\"mw-headline\" id=\"ОцОбОЎОюОЋОф_ОЉОЎОф_ОћОЏОаОАОф\">ОцОбОЎОюОЋОф ОЉОЎОф ОћОЏОаОАОф</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОцОбОЎОюОЋОф ОЉОЎОф ОћОЏОаОАОф&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОцОбОЎОюОЋОф ОЉОЎОф ОћОЏОаОАОф\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОЉОЎОф ОћОЏОаОАОф ОъОфОљОцОЎОЎОЪ ОЏОЉОЎОф ОЏОаОАОф ОЌОАОЎОЊОЎ, ОЋОъОЕОъОЕ ОЏОъОеОЏОќ ОбОЉОЋОе ОДОћОю ОљОа\"ОЕ ОЋОдОЋОЋОф ОћОЎОЕОЎОЉОћ, ОћОъОЕОцОЎОбОЎОЮ ОЋОћОфОъОЎОъОЎОЮ. \n</p><p>ОъОфОДОЎОЎОъОЋОф ОЉОЋ ОъОЊОЎ ОЎОЋОЮ: <a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%AA_%D7%A9%D7%97%D7%A8%D7%99%D7%AA\" title=\"ОфОцОЎОюОф ОЕОЌОеОЎОф\">ОфОцОЎОюОф ОЕОЌОеОЎОф</a>, <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%94\" class=\"mw-redirect\" title=\"ОъОаОЌОћ\">ОъОаОЌОћ</a> ОЋ<a href=\"/index.php/%D7%A2%D7%A8%D7%91%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ОбОеОЉОЎОф\">ОбОеОЉОЎОф</a>.\n</p><p><a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%AA_%D7%A9%D7%97%D7%A8%D7%99%D7%AA_%D7%A9%D7%9C_%D7%A9%D7%91%D7%AA\" class=\"mw-redirect\" title=\"ОфОцОЎОюОф ОЕОЌОеОЎОф ОЕОю ОЕОЉОф\">ОфОцОЎОюОф ОЕОЌОеОЎОф</a> ОЉ<a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"ОЕОЉОф\">ОЕОЉОф</a> ОъОфОЌОЎОюОћ ОАОЉОЎОЉ ОћОЕОбОћ 10:30, ОЊОЉОе ОћОъОљОцОЕОе ОќОъОЪ ОеОЉ <a href=\"/index.php/%D7%9C%D7%99%D7%9E%D7%95%D7%93_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ОюОЎОъОЋОЊ ОћОЌОАОЎОЊОЋОф\">ОюОюОЎОъОЋОЊ ОЌОАОЎОЊОЋОф ОюОцОаОЎ ОћОфОцОЎОюОћ</a>. \n</p><p>ОъОЊОЎ ОЕОЉОф ОЉОЉОЋОДОе, ОюОљОЌОе ОћОфОцОЎОюОћ, ОъОфОДОЎОЎОъОф ОЉОъОДОЋОЮ ОћОфОЋОЋОбОЊОЋОф ОбОЮ ОћОеОЉ ОћОЉОюОЎОЪ ОЋОЏОЪ ОЕОљОе ОћОъОфОцОюОюОЎОЮ ОЕОеОЉОЎОЮ ОъОћОЮ ОЉОбОдОъОЮ ОъОЕОцОЎОбОЎОЮ.\n</p><p>ОЉОЉОЎОф ОћОЏОаОАОф ОДОЎОЎОъОф ОћОДОцОЊОћ ОњОЊОЋОюОћ ОбОю ОљОЎ ОЊОЎОЉОЋОе ОЉОфОцОЎОюОћ, ОЏОцОЎ ОЕОЏОЋОфОЉ <a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%9E%D7%9C%D7%99%D7%90%D7%93%D7%99_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" title=\"ОеОЉОЎ ОЕОаОЎОљОЋОе ОќОюОъОЪ ОъОюОЎОљОЊОЎ (ОљОЊОъОЋ&quot;Ое ОћОќОДОЪ)\">ОљОЊОъОЋ\"Ое ОћОќОДОЪ</a>, ОЋОћОЋОљ ОъОЕОъОЕ ОъОДОЋОЮ ОюОфОцОЎОюОћ ОЋОюОЎОъОЋОЊ ОфОЋОеОћ ОЉОљОЋОЋОЎОеОћ ОЌОАОЎОЊОЎОф ОъОЎОЋОЌОЊОф.\n</p>\n<h2><span id=\".D7.9E.D7.91.D7.A0.D7.94_.D7.91.D7.99.D7.AA_.D7.94.D7.9B.D7.A0.D7.A1.D7.AA\"></span><span class=\"mw-headline\" id=\"ОъОЉОаОћ_ОЉОЎОф_ОћОЏОаОАОф\">ОъОЉОаОћ ОЉОЎОф ОћОЏОаОАОф</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОъОЉОаОћ ОЉОЎОф ОћОЏОаОАОф&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОъОЉОаОћ ОЉОЎОф ОћОЏОаОАОф\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОЉОЎОф ОћОЏОаОАОф ОъОъОЋОДОЮ ОъОфОЌОф ОюОъОЉОаОћ Оћ<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОДОеОЎОЎОф ОњОф (ОДОўОаОћ)\">ОЎОЕОЎОЉОћ</a>, ОЉОЏОаОЎОАОћ ОюОЉОЎОф ОћОЏОаОАОф ОаОъОдОљ ОЌОЊОе ОДОцОћ ОДОўОЪ, ОЋОЉОЋ ОъОЋОдОбОЎОЮ ОЏОЎОЉОЋОЊОЎОЮ ОЋОЕОфОЎОЎОћ ОюОаОЋОЌОЎОЋОф ОћОъОфОцОюОюОЎОЮ.\n</p><p>ОЉОЕОЉОфОЋОф ОДОЎОЎОъОф <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA#ОбОќОеОф_ОаОЕОЎОЮ\" title=\"ОЉОЎОф ОЏОаОАОф\">ОбОќОеОф ОаОЕОЎОЮ</a> ОњОЊОЋОюОћ ОЋОъОеОЋОЋОЌОф.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ОеОљОЋ_ОњОЮ\">ОеОљОЋ ОњОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;veaction=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОеОљОЋ ОњОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%A1%D7%93%D7%99_%D7%A9%D7%99_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)&amp;action=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОеОљОЋ ОњОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA_%D7%97%D7%91%22%D7%93_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"ОЉОЎОф ОЏОаОАОф ОЌОЉ&quot;ОЊ ОћОъОеОЏОќОЎ ОДОеОЎОЎОф ОњОф\">ОЉОЎОф ОЏОаОАОф ОЌОЉ\"ОЊ ОћОъОеОЏОќОЎ ОДОеОЎОЎОф ОњОф</a></li>\n<li><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%A9%D7%A2%D7%A8%D7%99_%D7%92%D7%90%D7%95%D7%9C%D7%94_-_770_(%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA)\" title=\"ОЉОЎОф ОћОЏОаОАОф ОЕОбОеОЎ ОњОљОЋОюОћ - 770 (ОДОеОЎОЎОф ОњОф)\">ОЉОЎОф ОћОЏОаОАОф ОЕОбОеОЎ ОњОљОЋОюОћ - 770</a></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/news/165600\">ОћОЋОЕОбОаОљ ОеОЉОљ ОЋОћОДОцОЋОф ОЕОаОЎОЋОф ОЉОЉОЎОф ОћОЏОаОАОф</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"ОЌОЉ&quot;ОЊ ОљОЋОЪ ОюОЎОЎОЪ\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D