    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%9E%D7%AA%D7%95%D7%A2%D7%93_%D7%91%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%A1%D7%9C%D7%95_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/5/58/%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%9E%D7%AA%D7%95%D7%A2%D7%93_%D7%91%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%A1%D7%9C%D7%95_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg/220px-%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%9E%D7%AA%D7%95%D7%A2%D7%93_%D7%91%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%A1%D7%9C%D7%95_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/5/58/%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%9E%D7%AA%D7%95%D7%A2%D7%93_%D7%91%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%A1%D7%9C%D7%95_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg/330px-%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%9E%D7%AA%D7%95%D7%A2%D7%93_%D7%91%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%A1%D7%9C%D7%95_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg 1.5x, /images/thumb/5/58/%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%9E%D7%AA%D7%95%D7%A2%D7%93_%D7%91%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%A1%D7%9C%D7%95_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg/440px-%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%9E%D7%AA%D7%95%D7%A2%D7%93_%D7%91%D7%91%D7%99%D7%AA_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9B%D7%A1%D7%9C%D7%95_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg 2x\" /></a><figcaption>ОћОеОЉ ОњОЋОеОюОЎОД ОъОфОЋОЋОбОЊ ОЉОЉОЎОф ОћОЏОаОАОф ОЉОЎОф ОъОаОЌОЮ ОЉОЏОцОе ОЌОЉ\"ОЊ (ОфОЕОц\"ОЊ)</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%AA%D7%A9%D7%A4%22%D7%93_.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/ac/%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%AA%D7%A9%D7%A4%22%D7%93_.jpg/220px-%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%AA%D7%A9%D7%A4%22%D7%93_.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/a/ac/%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%AA%D7%A9%D7%A4%22%D7%93_.jpg/330px-%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%AA%D7%A9%D7%A4%22%D7%93_.jpg 1.5x, /images/thumb/a/ac/%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%AA%D7%A9%D7%A4%22%D7%93_.jpg/440px-%D7%94%D7%A8%D7%91_%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_%D7%AA%D7%A9%D7%A4%22%D7%93_.jpg 2x\" /></a><figcaption>ОћОеОЉ ОњОЋОеОюОЎОД ОъОфОцОюОю (ОфОЕОц\"ОЊ)</figcaption></figure>\n<p>ОћОеОЉ <b>ОќОЋОЕОљ (ОљОюОЏОАОаОЊОе ОќОЋОАОъОЪ) ОњОЋОеОюОЎОД</b> (ОЎОюОЎОЊ ОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"ОфОЕОю&quot;ОЉ\">ОфОЕОю\"ОЉ</a>) ОћОЎОаОЋ ОъОЕОцОЎОб ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОЋОе ОЎОћОЋОЊОћ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОЋОе ОЎОћОЋОЊОћ</a>, ОЋОЌОЉОе ОЉОдОЋОЋОф <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОф ОљОћОюОЎ ОфОъОЎОъОЎОЮ\">ОЎОЕОЎОЉОф ОљОћОюОЎ ОфОъОЎОъОЎОЮ</a> ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>. ОћОЎОћ ОъОЕОюОЋОЌОЎ ОћОеОЉОЎ ОЉ<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"ОъОЋОАОДОЉОћ\">ОъОЋОАОДОЉОћ</a>, ОЋОъОЕОцОЎОб ОеОљОЕОЎ ОЉ<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОъОЋОАОДОЉОћ\">ОАОаОЎОБ ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОДОЋОъОЎ (ОЎОЕОЎОЉОћ ОњОЊОЋОюОћ)</a>. \n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОфОЋОюОЊОЋОф_ОЌОЎОЎОЮ\">ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%AA_%D7%9E%D7%9C%D7%90%D7%9B%D7%99\" class=\"mw-redirect\" title=\"ОДОеОЎОф ОъОюОљОЏОЎ\">ОДОеОЎОф ОъОюОљОЏОЎ</a> ОюОеОЉ <a href=\"/index.php/%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%9E%D7%A0%D7%A9%D7%94_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7\" title=\"ОъОеОЊОЏОЎ ОъОаОЕОћ ОњОЋОеОюОЎОД\">ОъОеОЊОЏОЎ ОъОаОЕОћ ОњОЋОеОюОЎОД</a> ОЋОюОфОъОеОћ ОљОЎОўОљ ОЉОфОЋ ОЕОю ОћОЌОАОЎОЊ Ое' <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%90%D7%95%D7%A8%D7%99_%D7%A0%D7%AA%D7%9F_%D7%A0%D7%98%D7%A2_%D7%91%D7%A8%D7%9B%D7%94%D7%9F\" title=\"ОЕОюОЋОЮ ОљОЋОеОЎ ОаОфОЪ ОаОўОб ОЉОеОЏОћОЪ\">ОЕОюОЋОЮ ОљОЋОеОЎ ОаОфОЪ ОаОўОб ОЉОеОЏОћОЪ</a>, ОќОъОЪ ОДОдОе ОюОљОЌОе ОбОюОЎОЎОфОЮ ОюОљОеОЦ ОћОДОЋОЊОЕ ОъОбОЉОе Ою<a href=\"/index.php/%D7%9E%D7%A1%D7%9A_%D7%94%D7%91%D7%A8%D7%96%D7%9C\" class=\"mw-redirect\" title=\"ОъОАОџ ОћОЉОеОќОю\">ОъОАОџ ОћОЉОеОќОю</a>.\n</p><p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%91\" title=\"ОфОЕОа&quot;ОЉ\">ОфОЕОа\"ОЉ</a> ОюОъОЊ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф</a> ОЉ-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> ОЉОъОАОњОеОф ОЕОаОф Оћ'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"ОДОЉОЋОдОћ\">ОДОЉОЋОдОћ</a>'.\n</p><p>ОЉОћОњОЎОбОЋ ОюОњОЎОю ОЌОфОЋОаОћ, ОаОЎОЕОљ ОбОЮ ОеОбОЎОЎОфОЋ ОдОЎОцОЋОеОћ, ОЉОф ОћОЌОАОЎОЊ ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%95%D7%95%D7%A8%D7%96%D7%95%D7%91\" title=\"ОъОљОЎОе ОЋОЋОеОќОЋОЉ\">ОъОљОЎОе ОЋОЋОеОќОЋОЉ</a>, ОЋОћОдОўОеОБ ОюОдОЋОЋОф ОћОЌОЎОаОЋОЏОЎ ОЕОю ОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОъОЋОАОДОЉОћ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОъОЋОАОДОЉОћ</a> (ОЎОЕОЎОЉОћ ОњОЊОЋОюОћ) ОЋОЉОћ ОЕОЎОъОЕ ОЉОфОцОДОЎОЊ ОъОЕОцОЎОб ОеОљОЕОЎ.\n</p><p>ОЉОъОДОЉОЎОю ОюОцОбОЎОюОЋОфОЋ ОЉОЎОЕОЎОЉОћ, ОЕОЎОъОЕ ОЏОЌОюОД ОъОЕОюОЋОЌОЎ ОћОеОЉОЎ ОЉОбОЎОе ОъОЋОАОДОЉОћ, ОЋОћОЎОћ ОЕОЋОфОБ ОюОЎОЋОќОъОЋОф ОћОДОћОЎОюОфОЎОЋОф ОЕОю ОћОДОћОЎОюОћ ОћОЌОЉ\"ОЊОЎОф ОЉОбОЎОе.\n</p><p>ОАОЎОЎОб ОЉОбОеОЎОЏОф ОћОАОцОе <a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_-_%D7%94%D7%A2%D7%99%D7%99%D7%A8%D7%94_%D7%A9%D7%9C_%D7%97%D7%91%22%D7%93_(%D7%A1%D7%A4%D7%A8)\" class=\"mw-redirect\" title=\"ОюОЎОЋОЉОљОЋОЋОЎОўОЕ - ОћОбОЎОЎОеОћ ОЕОю ОЌОЉ&quot;ОЊ (ОАОцОе)\">ОюОЎОЋОЉОљОЋОЋОЎОўОЕ - ОћОбОЎОЎОеОћ ОЕОю ОЌОЉ\"ОЊ</a>.\n</p><p>ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"ОфОЕОц&quot;Ољ\">ОфОЕОц\"Ољ</a> ОбОюОћ Ою<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОљОеОЦ ОћОДОЋОЊОЕ\">ОљОеОЦ ОћОДОЋОЊОЕ</a> ОЋОћОфОЎОЎОЕОЉ ОЉ<a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" title=\"ОљОЋОе ОЎОћОЋОЊОћ\">ОљОЋОе ОЎОћОЋОЊОћ</a>.\n</p>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_2.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/2/25/%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_2.jpg/250px-%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_2.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/2/25/%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_2.jpg/375px-%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_2.jpg 1.5x, /images/thumb/2/25/%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_2.jpg/500px-%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7_2.jpg 2x\" /></a><figcaption>ОћОеОЉ ОњОЋОеОюОЎОД</figcaption></figure>\n<p>ОъОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"ОфОЕОц&quot;ОЉ\">ОфОЕОц\"ОЉ</a> ОъОЕОъОЕ ОЏ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОЋОе ОЎОћОЋОЊОћ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОЋОе ОЎОћОЋОЊОћ</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ОъОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"ОфОЕОц&quot;Оњ\">ОфОЕОц\"Оњ</a> ОъОЕОъОЕ ОЏ<a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"Ое&quot;Оъ\">Ое\"Оъ</a> ОЉОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ <a href=\"/index.php/%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ОљОћОюОЎ ОфОъОЎОъОЎОЮ\">ОљОћОюОЎ ОфОъОЎОъОЎОЮ</a> <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>.\n</p><p>ОћОеОЉ ОњОЋОеОюОЎОД ОћОЋОљ ОњОЮ ОдОЎОЎОе ОъОДОдОЋОбОЎ.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ОъОЕОцОЌОфОЋ\">ОъОЕОцОЌОфОЋ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОъОЕОцОЌОфОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОъОЕОцОЌОфОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ОЌОфОаОЋ, ОћОеОЉ <a href=\"/index.php?title=%D7%A9%D7%9E%D7%A2%D7%99%D7%94_%D7%99%D7%94%D7%95%D7%93%D7%90_%D7%9C%D7%99%D7%99%D7%91_%D7%9E%D7%A8%D7%99%D7%A0%D7%95%D7%91%D7%A1%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЕОъОбОЎОћ ОЎОћОЋОЊОљ ОюОЎОЎОЉ ОъОеОЎОаОЋОЉОАОДОЎ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЕОъОбОЎОћ ОЎОћОЋОЊОљ ОюОЎОЎОЉ ОъОеОЎОаОЋОЉОАОДОЎ</a> - ОъОЕОцОЎОб ОЉОЎОЕОЎОЉОћ ОњОЊОЋОюОћ <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%AA_%D7%92%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОДОеОЎОф ОњОф (ОњОЊОЋОюОћ)\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОДОеОЎОф ОњОф</a>.</li>\n<li>ОЉОаОЋ, Ое' ОъОаОЌОЮ ОъОбОаОЊОю ОњОЋОеОюОЎОД, ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЎОЕОЋОЉ <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9F_%D7%9E%D7%95%D7%A8%D7%94\" title=\"ОљОюОЋОЪ ОъОЋОеОћ\">ОљОюОЋОЪ ОъОЋОеОћ</a>.</li>\n<li>ОЌОфОаОЋ, Ое' <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%92%D7%A8%D7%95%D7%96%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОъОаОЌОЮ ОњОеОЋОќОъОЪ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОъОаОЌОЮ ОњОеОЋОќОъОЪ</a> - ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОбОЎОе <a href=\"/index.php?title=%D7%96%D7%9C%D7%A6%D7%91%D7%95%D7%A8%D7%92&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОќОюОдОЉОЋОеОњ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОќОюОдОЉОЋОеОњ</a> <a href=\"/index.php/%D7%90%D7%95%D7%A1%D7%98%D7%A8%D7%99%D7%94\" title=\"ОљОЋОАОўОеОЎОћ\">ОљОЋОАОўОеОЎОћ</a></li>\n<li>ОЌОфОаОЋ, Ое' ОљОюОЎОћОЋ ОЕОЋОЌОў, ОъОЕОњОЎОЌ ОЉ<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A8%22%D7%9E_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЉОЎОф ОћОе&quot;Оъ ОаОЌОюОф ОћОе ОЌОЉ&quot;ОЊ\">ОЎОЕОЎОЉОф ОЉОЎОф ОћОе\"Оъ ОаОЌОюОф ОћОе ОЌОЉ\"ОЊ</a></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"ОюОДОеОЎОљОћ_ОаОЋОАОцОф\">ОюОДОеОЎОљОћ ОаОЋОАОцОф</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОюОДОеОЎОљОћ ОаОЋОАОцОф&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОюОДОеОЎОљОћ ОаОЋОАОцОф\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>ОћОЎОАОЋОЊОЋОф ОЕОЎОћОцОЏОЋ ОљОф ОћОЎОюОЊОЎОЮ ОюОаОеОЋОф ОюОћОљОЎОе</b>, ОЕОЉОЋОбОЋОЪ ОЏОцОе ОЌОЉ\"ОЊ ОњОюОЎОЋОЪ 1936 ОбОъОЋОЊ 25</li></ul>\n<ul><li>ОЎОЕОеОљОю ОљОюОцОеОЋОЉОЎОЦ,&#160;РђЈ<b>ОЕОЎОЕОЎОЮ ОЎОъОЎ ОЕОъОЌОћ</b>, ОЕОЉОЋОбОЋОЪ ОЏОцОе ОЌОЉ\"ОЊ, ОњОЎОюОЎОЋОЪ 2046 ОбОъОЋОЊ 40 (ОфОЕОц\"ОЊ) <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ (ОЕОЉОЋОбОЋОЪ)\"><img src=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/45px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg\" decoding=\"async\" width=\"45\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/68px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 1.5x, /images/thumb/1/1c/%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg/90px-%D7%9C%D7%95%D7%92%D7%95_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОДОЎОЕОЋОеОЎОЮ_ОЌОЎОдОЋОаОЎОЎОЮ\">ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;veaction=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%D7%95%D7%A9%D7%90_%D7%92%D7%95%D7%A8%D7%9C%D7%99%D7%A7&amp;action=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-edit