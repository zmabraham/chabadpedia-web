      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C._%D7%A6%D7%99%D7%9C%D7%95%D7%9D_%D7%A9%D7%95%D7%A7%D7%99_%D7%9C%D7%A8%D7%A8.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/eb/%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C._%D7%A6%D7%99%D7%9C%D7%95%D7%9D_%D7%A9%D7%95%D7%A7%D7%99_%D7%9C%D7%A8%D7%A8.jpeg/220px-%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C._%D7%A6%D7%99%D7%9C%D7%95%D7%9D_%D7%A9%D7%95%D7%A7%D7%99_%D7%9C%D7%A8%D7%A8.jpeg\" decoding=\"async\" width=\"220\" height=\"146\" class=\"mw-file-element\" srcset=\"/images/thumb/e/eb/%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C._%D7%A6%D7%99%D7%9C%D7%95%D7%9D_%D7%A9%D7%95%D7%A7%D7%99_%D7%9C%D7%A8%D7%A8.jpeg/330px-%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C._%D7%A6%D7%99%D7%9C%D7%95%D7%9D_%D7%A9%D7%95%D7%A7%D7%99_%D7%9C%D7%A8%D7%A8.jpeg 1.5x, /images/thumb/e/eb/%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C._%D7%A6%D7%99%D7%9C%D7%95%D7%9D_%D7%A9%D7%95%D7%A7%D7%99_%D7%9C%D7%A8%D7%A8.jpeg/440px-%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C._%D7%A6%D7%99%D7%9C%D7%95%D7%9D_%D7%A9%D7%95%D7%A7%D7%99_%D7%9C%D7%A8%D7%A8.jpeg 2x\" /></a><figcaption>תמונה זו מוצגת בחב\"דפדיה בשימוש הוגן, נשמח להחליפה בתמונה חופשית.</figcaption></figure>\n<p>רבי <b>ישעיה יעקב פורטוגל</b> (<a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ו באדר\">כ\"ו באדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a> 9 במרץ 1956– <a href=\"/index.php/%D7%94%27_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ה&#39; אלול\">ה' אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a>, 7 בספטמבר 2024) היה האדמו\"ר השלישי מ<a href=\"/index.php?title=%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"חסידות סקולען (הדף אינו קיים)\">חסידות סקולען</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php?title=%D7%91%D7%95%D7%A7%D7%A8%D7%A9%D7%98&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בוקרשט (הדף אינו קיים)\">בוקרשט</a> לרבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C\" title=\"ישראל אברהם פורטוגל\">ישראל אברהם</a> ולרייזל.\n</p><p>בבחרותו למד בישיבת <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%A1%D7%90%D7%98%D7%9E%D7%A8\" title=\"חסידות סאטמר\">חסידות סאטמר</a>, ובישיבת תפארת ישראל - רוז'ין ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.\n</p><p>התחתן עם סילקא, בת הרב מאיר גרינוולד אב\"ד טעטש.\n</p><p>אחרי פטירת חמיו החורג ב<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%92\" title=\"תשנ&quot;ג\">תשנ\"ג</a> מונה הרב פורטוגל לרב הקהילה במונטריאול.\n</p><p>לאחר פטירת אביו ב<a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%90%D7%93%D7%A8_%D7%91%27\" class=\"mw-redirect\" title=\"כ&quot;ו באדר ב&#39;\">כ\"ו באדר ב'</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> מונה למלא את מקומו באדמו\"רות מסקולען.\n</p><p>ב<a href=\"/index.php/%D7%9E%D7%95%D7%A6%D7%90%D7%99_%D7%A9%D7%91%D7%AA\" title=\"מוצאי שבת\">מוצאי שבת</a> <a href=\"/index.php/%D7%A4%D7%A8%D7%A9%D7%AA_%D7%A9%D7%95%D7%A4%D7%98%D7%99%D7%9D\" title=\"פרשת שופטים\">פרשת שופטים</a>, <a href=\"/index.php/%D7%94%27_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ה&#39; אלול\">ה' אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a>, לאחר מחלה, נפטר<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A7.D7.A9.D7.A8.D7.99.D7.95_.D7.A2.D7.9D_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"קשריו_עם_חב&quot;ד\">קשריו עם חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;קשריו עם חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: קשריו עם חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>כילד השתתף ב<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"התוועדות של הרבי\">התוועדות של הרבי</a> ב<a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%AA_%D7%AA%D7%95%D7%A8%D7%94\" title=\"שמחת תורה\">שמחת תורה</a><sup id=\"cite_ref-וידאו_דבר_מלכות_משיח_2-0\" class=\"reference\"><a href=\"#cite_note-וידאו_דבר_מלכות_משיח-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%9E%D7%A1%D7%90%D7%98%D7%9E%D7%A8_%D7%9E%D7%94%D7%A8%27%27%D7%90,_%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F,_%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%91%D7%91%D7%99%D7%AA_%D7%97%D7%91%27%D7%93.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/4/41/%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%9E%D7%A1%D7%90%D7%98%D7%9E%D7%A8_%D7%9E%D7%94%D7%A8%27%27%D7%90%2C_%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F%2C_%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%91%D7%91%D7%99%D7%AA_%D7%97%D7%91%27%D7%93.jpg/220px-%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%9E%D7%A1%D7%90%D7%98%D7%9E%D7%A8_%D7%9E%D7%94%D7%A8%27%27%D7%90%2C_%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%