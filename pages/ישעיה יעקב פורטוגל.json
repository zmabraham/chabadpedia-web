%94%D7%A8%27%27%D7%90%2C_%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F%2C_%D7%94%D7%90%D7%93%D7%9E%D7%95%27%27%D7%A8_%D7%A8%D7%91%D7%99_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%91%D7%91%D7%99%D7%AA_%D7%97%D7%91%27%D7%93.jpg 2x\" /></a><figcaption>רבי <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%98%D7%99%D7%99%D7%98%D7%9C%D7%91%D7%95%D7%99%D7%9D\" title=\"אהרן טייטלבוים\">אהרן טייטלבוים</a> האדמו\"ר מסאטמר, רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%A8%D7%98%D7%99%D7%92%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ישראל אברהם פרטיגול\">ישראל אברהם</a> האדמו\"ר מסקולען, ורבי ישעיה יעקב האדמו\"ר מסקולען בבית חב\"ד בפאלם ספרינג</figcaption></figure>\n<p>ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">חודש טבת</a> באחת משנות הס' ביקר עם אביו הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%A8%D7%98%D7%99%D7%92%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ישראל אברהם פרטיגול\">ישראל אברהם פרטיגול</a> בבית חב\"ד בפאלם ספרינג, ונועד עם הרב <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%98%D7%99%D7%99%D7%98%D7%9C%D7%91%D7%95%D7%99%D7%9D\" title=\"אהרן טייטלבוים\">אהרן טייטלבוים</a> ששהה במקום<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%94%D7%A8%27%27%D7%99_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A2%D7%9C%D7%A1%D7%A7%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/e/e0/%D7%9E%D7%94%D7%A8%27%27%D7%99_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A2%D7%9C%D7%A1%D7%A7%D7%99.jpg/250px-%D7%9E%D7%94%D7%A8%27%27%D7%99_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A2%D7%9C%D7%A1%D7%A7%D7%99.jpg\" decoding=\"async\" width=\"250\" height=\"140\" class=\"mw-file-element\" srcset=\"/images/thumb/e/e0/%D7%9E%D7%94%D7%A8%27%27%D7%99_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A2%D7%9C%D7%A1%D7%A7%D7%99.jpg/375px-%D7%9E%D7%94%D7%A8%27%27%D7%99_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A2%D7%9C%D7%A1%D7%A7%D7%99.jpg 1.5x, /images/thumb/e/e0/%D7%9E%D7%94%D7%A8%27%27%D7%99_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A2%D7%9C%D7%A1%D7%A7%D7%99.jpg/500px-%D7%9E%D7%94%D7%A8%27%27%D7%99_%D7%9E%D7%A1%D7%A7%D7%95%D7%9C%D7%A2%D7%9F_%D7%A2%D7%9D_%D7%94%D7%A8%D7%91_%D7%90%D7%91%D7%A2%D7%9C%D7%A1%D7%A7%D7%99.jpg 2x\" /></a><figcaption>הרב פורטוגל עם הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%90%D7%91%D7%9C%D7%A1%D7%A7%D7%99\" title=\"זלמן טוביה אבלסקי\">זלמן טוביה אבלסקי</a></figcaption></figure>\n<p>בשנים <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> ו<a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a>, במהלך ביקוריו ב<a href=\"/index.php/%D7%9E%D7%95%D7%9C%D7%93%D7%95%D7%91%D7%94\" title=\"מולדובה\">מולדובה</a> יחד עם אביו רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%A8%D7%98%D7%99%D7%92%D7%95%D7%9C\" class=\"mw-redirect\" title=\"ישראל אברהם פרטיגול\">ישראל אברהם</a>, ביקר במוסדות חב\"ד ב<a href=\"/index.php/%D7%A7%D7%99%D7%A9%D7%99%D7%A0%D7%91\" title=\"קישינב\">קישינב</a> ו<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"התוועדות\">התוועד</a> עם <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> ורבה הראשי של מולדובה הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%98%D7%95%D7%91%D7%99%D7%94_%D7%90%D7%91%D7%9C%D7%A1%D7%A7%D7%99\" title=\"זלמן טוביה אבלסקי\">זלמן טוביה אבלסקי</a><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>לאחר פטירת אביו רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C\" title=\"ישראל אברהם פורטוגל\">ישראל אברהם</a> משלחת חב\"דית שמנתה את הרבנים <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%91%D7%A8%D7%95%D7%99%D7%9F\" title=\"יוסף ישעיה ברוין\">יוסף ישעיה ברוין</a>, <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%92%D7%A8%D7%95%D7%A0%D7%A8\" title=\"יהודה לייב גרונר\">יהודה לייב גרונר</a>, <a href=\"/index.php/%D7%97%D7%A0%D7%99%D7%A0%D7%90_%D7%A9%D7%A4%D7%A2%D7%A8%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"חנינא שפערלין\">חנינא שפערלין</a>, <a href=\"/index.php?title=%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A1%D7%9C%D7%95%D7%95%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אליהו סלווין (הדף אינו קיים)\">אליהו סלווין</a>, ו<a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A7%D7%A8%D7%90%D7%95%D7%A1\" title=\"שמואל קראוס\">שמואל קראוס</a> <a href=\"/index.php/%D7%A0%D7%99%D7%97%D7%95%D7%9D_%D7%90%D7%91%D7%9C%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ניחום אבלים\">ניחמה אותו</a><sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> קיבל את הרב <a href=\"/index.php?title=%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A2%D7%96%D7%92%D7%90%D7%95%D7%95%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מנחם מענדל עזגאווי (הדף אינו קיים)\">מנחם מענדל עזגאווי</a> לפגישה במעונו, הרב עזגאווי העניק לו את הספר <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_-_%D7%97%D7%99%D7%93%D7%95%D7%A9%D7%99%D7%9D_%D7%95%D7%91%D7%99%D7%90%D7%95%D7%A8%D7%99%D7%9D_%D7%91%D7%94%D7%9C%D7%9B%D7%95%D7%AA_%D7%9E%D7%9C%D7%9B%D7%99%D7%9D\" title=\"דבר מלכות - חידושים וביאורים בהלכות מלכים\">דבר מלכות - חידושים וביאורים בהלכות מלכים</a>, וסקר בפניו את רצונו של הרבי ללמוד ענייני גאולה ומשיח ואת הספר, הרב פורטוגל התעניין במקורות הספר ושיבח את הספר, הוא התבטא שלימוד תורתו של הרבי יזרז את הגאולה<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>הרב עזגאווי סיפר על יחידותו של סביו של הרב פורטוגל עם הרבי. הרב פורטוגל סיפר על השתתפותו בהתוועדות של הרבי ב<a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%AA_%D7%AA%D7%95%D7%A8%D7%94\" title=\"שמחת תורה\">שמחת תורה</a> בתור ילד, הוא תיאר את עידודו של הרבי לשירת הקהל ואת מחיאות הכפיים של הרבי. בסיום המפגש הביע הרב פורטוגל את משאלת ליבו לבוא הגאולה ובירך את הרב עזגאווי להצלחה<sup id=\"cite_ref-וידאו_דבר_מלכות_משיח_2-1\" class=\"reference\"><a href=\"#cite_note-וידאו_דבר_מלכות_משיח-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>לאחר פטירתו משלחת חב\"דית שמנתה את הרבנים <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%91%D7%A8%D7%95%D7%99%D7%9F\" title=\"יוסף ישעיה ברוין\">יוסף ישעיה ברוין</a>, <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%9F_%D7%A9%D7%A4%D7%99%D7%A8%D7%90\" title=\"נחמן שפירא\">נחמן שפירא</a>, <a href=\"/index.php/%D7%97%D7%A0%D7%99%D7%A0%D7%90_%D7%A9%D7%A4%D7%A2%D7%A8%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"חנינא שפערלין\">חנינא שפערלין</a>, ו<a href=\"/index.php?title=%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%A1%D7%9C%D7%95%D7%95%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אליהו סלווין (הדף אינו קיים)\">אליהו סלווין</a>\n<a href=\"/index.php/%D7%A0%D7%99%D7%97%D7%95%D7%9D_%D7%90%D7%91%D7%9C%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ניחום אבלים\">ניחמה את בניו</a><sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>, בנו הרב אהרן מאיר והרב ברוין שוחחו על מעצרם של סביהם רבי <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%96%D7%95%D7%A1%D7%99%D7%90_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C\" title=\"אליעזר זוסיא פורטוגל\">אליעזר זוסיא</a> ורבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C\" title=\"ישראל אברהם פורטוגל\">ישראל אברהם</a> ועל מועד שחרורם<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%A2%D7%99%D7%94_%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>לרב פורטוגל 8 ילדים, בהם:\n</p>\n<ul><li>בנו, הרב אהרן מאיר פורטוגל, ממשיך דרכו באדמו\"רות סקולען.</li>\n<li>בתו, שיינא רחל, נשואה לרב מרדכי דב בעק, הרב מטאלמיטש במונסי.</li>\n<li>בתו, הינדא טשיפא, נשואה לרב יואל מוסקוביץ', רב קהילת מאור הגולה במונטריאול.</li>\n<li>בנו, הרב אליעזר זוסיא, נשוי ליוכבד.</li>\n<li>בתו, אסתר פריידא, נשואה לרב יוסף משה דוב אונסדורפר.</li>\n<li>בתו, מאטיל לאה, נשואה לרב דוד פרידמן, ראש כולל מאור ישראל סקולען (ווילימסבורג).</li>\n<li>בתו, זיסל, נשואה לרב מנחם נחום טוורסקי.</li>\n<li>בתו הנשואה לרב יעקב מנחם מנדל בריעף, ראש הכולל סקולען (בורו פארק).</li></ul>\n<table class=\"toccolours\" border=\"1\" cellspacing=\"0\" cellpadding=\"4\" style=\"clear:both; width:90%; border-collapse:collapse; margin:0 auto 0 auto; text-align:center;\">\n\n<tbody><tr>\n<td width=\"30%\"><b>הקודם</b>:<br /><b>האדמו\"ר רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A4%D7%95%D7%A8%D7%98%D7%95%D7%92%D7%9C\" title=\"ישראל אברהם פורטוגל\">ישראל אברהם פורטוגל</a></b>\n</td>\n<td width=\"40%\"><b>אדמו\"רי <a href=\"/index.php?title=%D7%A1%D7%A7%D7%95%D7%9C%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"סקולן (הדף אינו קיים)\">סקולן</a></b> <br /><a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a> - <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a>\n</td>\n<td width=\"30%\"><b>הבא</b>:<br /><b>האדמו\"ר רבי אהרן מאיר פורטוגל, האדמו\"ר רבי אליעזר זוסיא פורטוגל (בלינדן)</b>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\"><b><a rel=\"nofollow\" class=\"external text\" href=\"http://col.org.il/news/164679\">אבל בעולם החסידות: בניו יורק נפטר האדמו\"ר מסקולען זצ\"ל</a></b> - באתר <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span> ה' אלול תשפ\"ד</span>\n</li>\n<li id=\"cite_note-וידאו_דבר_מלכות_משיח-2\"><span class=\"mw-cite-backlink\">^ <sup><a href=\"#cite_ref-וידאו_דבר_מלכות_משיח_2-0\">1</a></sup> <sup><a href=\"#cite_ref-וידאו_דבר_מלכות_משיח_2-1\">2</a></sup></span> <span class=\"reference-text\">וידאו 'פרסום ראשון הסקולנר רבי זצוק\"ל עם הספר דבר מלכות ופגישות מרתקות עם הרבי' בערוץ היוטיוב DVAR MALCHUS HILCHOS MOSHIACH דבר מלכות משיח.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">תמונות מהביקור ב[ivelt.com/forum/viewtopic.php?t=71210&amp;start=150 אשכול התמונות - כ\"ק אדמו\"ר ר' ישעי' יעקב מסקולען זצ\"ל] באתר אידישע וועלט פארומס עמודה 7.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/magazine/1130903/\">השפעתו החבד\"ית של הרב זלמן אבעלסקי עם חצר סקולען</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/crown_heights/469138/\">משלחת חב\"דית בניחום אבלים בבית האדמו\"ר מסקולען ע\"ה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">תמלול השיחה: כשהציג בפניו הרב עזגאווי <a href=\"/index.php/%D7%A7%D7%95%D7%9C_%D7%A7%D7%95%D7%A8%D7%90\" title=\"קול קורא\">קול קורא</a> של רבנים ללימוד בספר התבטא: \"ס'איז א זיכערע א גוטע זאכן: [=אלו ודאי דברים טובים]\". \"ס'איז א גוואלדיגע זאך, (וואס) מ'לערנט (וואס) דער רבי האט געזאגט, (וועט) זיכער מזרז זיין די גאולה, ס'איז גוואלדיגע זאך\" [= זהו דבר נפלא, שלומדים את תורת הרבי, בוודאי יזרז את הגאולה, זה הוא דבר נפלא] הצלחה רבה, יישר כח, מצליח זיין [=תצליחו], ביאת משיח צדקנו, אלץ וואס דער רבי האט געזאגט [= כל מה שהרבי אמר].</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">וידאו שִׁבְעָה דְּנֶחֱמְתָּא • אצל כ\"ק האדמורי\"ם מסקולען שליט\"א דקה: 8:26 בערוץ היוטיוב\nסקולען skulen. <a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php/קובץ:ניחום_אבלים_סקולען.jpg\">תמונות</a> <a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/index.php/קובץ:ניחום_אבלים_סקולען_2.jpg\">מהמעמד</a> בכתבה <a rel=\"nofollow\" class=\"external text\" href=\"https://ahblicklive.com/post.php?u_id=jYRxbcI64L50ON2WDP0&amp;archive=1&amp;allowed_categories=1\">עוד רבנים רבים אצל ניחום אבלים על כ\"ק אדמו\"ר מהר\"יי מסקולען זצ\"ל</a> באתר AhBlickLive.com <span typeof=\"mw:File\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%AA%D7%9E%D7%95%D7%A0%D7%94\" title=\"קובץ תמונה\"><img alt=\"קובץ תמונה\" src=\"/images/thumb/2/28/Picture_icon_BLACK.svg.png/20px-Picture_icon_BLACK.svg.png\" decoding=\"async\" width=\"20\" height=\"18\" class=\"mw-file-element\" srcset=\"/images/thumb/2/28/Picture_icon_BLACK.svg.png/30px-Picture_icon_BLACK.svg.png 1.5x, /images/thumb/2/28/Picture_icon_BLACK.svg.png/40px-Picture_icon_BLACK.svg.png 2x\" /></a></span></span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">דקה: 10:56 בוידאו שבהערה הקודמת</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414094646\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.102 seconds\nReal time usage: 0.264 seconds\nPreprocessor visited node count: 381/1000000\nPost‐expand include size: 2385/2097152 bytes\nTemplate argument size: 591/2097152 bytes\nHighest expansion depth: 6/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 7838/5000000 bytes\nLua time usage: 0.070/7 seconds\nLua virtual size: 5750784/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  218.868 