      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><p><b>האם התכוונתם ל...</b><br />\n</p>\n<div class=\"nodisambig\">\n<ul><li>הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" class=\"mw-redirect\" title=\"שניאור זלמן אלפרוביץ&#39;\">שניאור זלמן אלפרוביץ'</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%97%D7%A8%D7%A7%D7%95%D7%91\" title=\"תומכי תמימים חרקוב\">תומכי תמימים חרקוב</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%A9%D7%94_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"חיים משה אלפרוביץ&#39;\">חיים משה אלפרוביץ'</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ברמת גן.</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"שלום דובער אלפרוביץ&#39;\">שלום דובער אלפרוביץ'</a> - משלוחי הרבי בניו הייבן ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת תומכי תמימים המקומית.</li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%95%D7%9C%D7%9D_%D7%96%D7%95%D7%A9%D7%90_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"משולם זושא אלפרוביץ&#39;\">משולם זושא אלפרוביץ'</a> - מהשלוחים לארץ הקודש, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ראשי בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"תומכי תמימים קריית גת (גדולה)\">תומכי תמימים קריית גת (גדולה)</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יוסף יצחק אלפרוביץ\">יוסף יצחק אלפרוביץ</a> - משלוחי הרבי בוורמונט, אנגליה, ומחבר הספר <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%94%D7%AA%D7%A4%D7%9C%D7%94\" title=\"אור התפלה\">אור התפלה</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A8%D7%97%D7%9E%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"ירחמיאל אלפרוביץ&#39;\">ירחמיאל אלפרוביץ'</a> - מזקני חסידי חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%96%D7%9C%D7%9E%D7%9F_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5\" title=\"שלמה זלמן אלפרוביץ\">שלמה זלמן אלפרוביץ</a> - ראש מכון לימוד <a href=\"/index.php/%D7%A1%D7%AA%22%D7%9D\" class=\"mw-redirect\" title=\"סת&quot;ם\">סת\"ם</a> ב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%94%D7%91%D7%95%D7%9B%D7%A8%D7%99%D7%9D\" title=\"ישיבת הבוכרים\">ישיבת הבוכרים</a>, <a href=\"/index.php/%D7%92%D7%91%D7%90%D7%99\" title=\"גבאי\">גבאי</a> ומוסר שיעורים ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_%D7%91%27\" title=\"כפר חב&quot;ד ב&#39;\">כפר חב\"ד ב'</a>, <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9E%D7%95%D7%A2%D7%94\" title=\"בעל שמועה\">ובעל שמועה</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%9C%D7%99%D7%A4%D7%90_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5\" class=\"mw-redirect\" title=\"יוסף ליפא אלפרוביץ\">יוסף ליפא אלפרוביץ</a> - פעיל <a href=\"/index.php/%D7%94%D7%A4%D7%A6%D7%AA_%D7%94%D7%9E%D7%A2%D7%99%D7%99%D7%A0%D7%95%D7%AA\" class=\"mw-redirect\" title=\"הפצת המעיינות\">הפצת המעיינות</a> בשכונת מאה שערים ומחנך בחיידר <a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA\" class=\"mw-redirect\" title=\"תלמוד תורה תורת אמת\">תלמוד תורה תורת אמת</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A7%D7%95%D7%AA%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5\" title=\"יקותיאל אלפרוביץ\">יקותיאל אלפרוביץ</a> - מחנך ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תלמוד תורה נחלת הר חב&quot;ד\">תלמוד תורה נחלת הר חב\"ד</a>, <a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%A9%D7%9E%D7%95%D7%A2%D7%94\" title=\"בעל שמועה\">בעל שמועה</a> ו<a href=\"/index.php/%D7%91%D7%A2%D7%9C_%D7%9E%D7%A0%D7%92%D7%9F\" title=\"בעל מנגן\">בעל מנגן</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%A2%D7%95%D7%96%D7%A8_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"עוזר אלפרוביץ&#39;\">עוזר אלפרוביץ'</a> - משפיע ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"מנחם מענדל אלפרוביץ (כפר חב&quot;ד)\">מנחם מענדל אלפרוביץ (כפר חב\"ד)</a> - משפיע ב<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תלמוד תורה כפר חב&quot;ד\">תלמוד תורה כפר חב\"ד</a> ושליח בכפר-חב\"ד.</li>\n<li>הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5_(%D7%9E%D7%95%D7%94%D7%99%D7%9C%D7%91)\" class=\"mw-redirect\" title=\"מנחם מענדל אלפרוביץ (מוהילב)\">מנחם מענדל אלפרוביץ</a> - שליח הרבי במוהילב <a href=\"/index.php/%D7%91%D7%9C%D7%90%D7%A8%D7%95%D7%A1\" title=\"בלארוס\">בלארוס</a>.</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%A9%D7%94_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27_(%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F)\" title=\"חיים משה אלפרוביץ&#39; (ראשון לציון)\">חיים משה אלפרוביץ' (ראשון לציון)</a> - שליח הרבי בשכונת אברמוביץ ומשולש ז'בוטינסקי בראשון לציון, משפיע בישיבת תומכי תמימים ראשון לציון ובישיבת אוהלי מנחם מענדל בכפר חב\"ד.</li></ul>\n</div>\n<table class=\"plainlinks dmbox dmbox-disambig\" style=\"width: 100%; margin-top: 10px; border-top: 1px solid #aaa;\">\n\n<tbody><tr>\n<td style=\"vertical-align: top; padding-top: 0.6em;\"><figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Disambig_RTL.svg\" class=\"mw-file-description\" title=\"פירושונים\"><img alt=\"פירושונים\" src=\"/images/thumb/b/bc/Disambig_RTL.svg/40px-Disambig_RTL.svg.png\" decoding=\"async\" width=\"40\" height=\"31\" class=\"mw-file-element\" srcset=\"/images/thumb/b/bc/Disambig_RTL.svg/60px-Disambig_RTL.svg.png 1.5x, /images/thumb/b/bc/Disambig_RTL.svg/80px-Disambig_RTL.svg.png 2x\" /></a><figcaption>פירושונים</figcaption></figure> </td><td class=\"mbox-text\" style=\"padding: 0.25em 0.4em\"> זהו דף <a href=\"/index.php/%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94:%D7%A4%D7%99%D7%A8%D7%95%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"חב&quot;דפדיה:פירושונים\">פירושונים</a>, שמטרתו להבחין בין ערכים שונים בעלי שם דומה.\n<div class=\"checkty-ignore\">\n<p><span typeof=\"mw:File\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:Gnome-searchtool.svg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/1e/Gnome-searchtool.svg/21px-Gnome-searchtool.svg.png\" decoding=\"async\" width=\"21\" height=\"21\" class=\"mw-file-element\" srcset=\"/images/thumb/1/1e/Gnome-searchtool.svg/32px-Gnome-searchtool.svg.png 1.5x, /images/thumb/1/1e/Gnome-searchtool.svg/42px-Gnome-searchtool.svg.png 2x\" /></a></span> אם לא מצאתם ברשימת הפירושונים את הערך שהתכוונתם אליו, נסו:\n</p>\n<ul><li><a href=\"/index.php/%D7%9E%D7%99%D7%95%D7%97%D7%93:%D7%93%D7%A4%D7%99%D7%9D_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C%D7%99%D7%9D_%D7%91/%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"מיוחד:דפים המתחילים ב/אלפרוביץ&#39;\">דפים ששמם מתחיל ב”אלפרוביץ&#39;“</a></li>\n<li><a h