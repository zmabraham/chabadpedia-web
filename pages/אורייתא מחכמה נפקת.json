%AA%D7%95%D7%A8%D7%AA%D7%95_%D7%A9%D7%9C_%D7%9E%D7%A9%D7%99%D7%97\" title=\"תורתו של משיח\">תורתו של משיח</a> • <a href=\"/index.php?title=%D7%90%D7%97%D7%93%D7%95%D7%AA_%D7%91%D7%AA%D7%95%D7%A8%D7%94&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אחדות בתורה (הדף אינו קיים)\">אחדות בתורה</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\">אישים\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%97%D7%96%22%D7%9C\" title=\"חז&quot;ל\">חז\"ל</a> • <a href=\"/index.php/%D7%AA%D7%A0%D7%90%D7%99%D7%9D\" title=\"תנאים\">תנאים</a> • <a href=\"/index.php/%D7%90%D7%9E%D7%95%D7%A8%D7%90%D7%99%D7%9D\" title=\"אמוראים\">אמוראים</a> • <a href=\"/index.php/%D7%92%D7%90%D7%95%D7%A0%D7%99%D7%9D\" title=\"גאונים\">גאונים</a> • <a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%95%D7%A0%D7%99%D7%9D\" title=\"ראשונים\">ראשונים</a> • <a href=\"/index.php/%D7%90%D7%97%D7%A8%D7%95%D7%A0%D7%99%D7%9D\" title=\"אחרונים\">אחרונים</a> • <a href=\"/index.php?title=%D7%A4%D7%95%D7%A1%D7%A7%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"פוסקים (הדף אינו קיים)\">פוסקים</a> • <a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%99%D7%93_%D7%97%D7%9B%D7%9D\" title=\"תלמיד חכם\">תלמיד חכם</a> • <a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> • <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%9E%D7%AA%D7%99%D7%91%D7%AA%D7%90\" title=\"ראש מתיבתא\">ראש מתיבתא</a> • <a href=\"/index.php/%D7%9E%D7%9C%D7%9E%D7%93_%D7%AA%D7%99%D7%A0%D7%95%D7%A7%D7%95%D7%AA\" title=\"מלמד תינוקות\">מלמד תינוקות</a> • <a href=\"/index.php/%D7%A0%D7%A9%D7%99%D7%90_%D7%94%D7%93%D7%95%D7%A8\" title=\"נשיא הדור\">נשיא הדור</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\">לימוד\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%91%D7%A8%D7%9B%D7%AA_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" title=\"ברכת התורה\">ברכת