      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%22%D7%99_%D7%94%D7%91%D7%9C%D7%99%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/79/%D7%99%22%D7%99_%D7%94%D7%91%D7%9C%D7%99%D7%9F.jpg/220px-%D7%99%22%D7%99_%D7%94%D7%91%D7%9C%D7%99%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/7/79/%D7%99%22%D7%99_%D7%94%D7%91%D7%9C%D7%99%D7%9F.jpg/330px-%D7%99%22%D7%99_%D7%94%D7%91%D7%9C%D7%99%D7%9F.jpg 1.5x, /images/thumb/7/79/%D7%99%22%D7%99_%D7%94%D7%91%D7%9C%D7%99%D7%9F.jpg/440px-%D7%99%22%D7%99_%D7%94%D7%91%D7%9C%D7%99%D7%9F.jpg 2x\" /></a><figcaption>הרב הבלין</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F_%D7%A4%27%27%D7%93.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/0/09/%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F_%D7%A4%27%27%D7%93.jpg/220px-%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F_%D7%A4%27%27%D7%93.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/0/09/%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F_%D7%A4%27%27%D7%93.jpg/330px-%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F_%D7%A4%27%27%D7%93.jpg 1.5x, /images/thumb/0/09/%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F_%D7%A4%27%27%D7%93.jpg/440px-%D7%A8%27_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F_%D7%A4%27%27%D7%93.jpg 2x\" /></a><figcaption>הרב יוסף יצחק הבלין נואם במעמד סיום הרמב\"ם (תשפ\"ד)</figcaption></figure>\n<p>הרב <b>יוסף יצחק הבלין</b> (יליד שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a>, 1951) הינו רב קהילת חב\"ד בשכונת <a href=\"/index.php/%D7%A8%D7%9E%D7%AA_%D7%A9%D7%9C%D7%9E%D7%94_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"רמת שלמה (ירושלים)\">רמת שלמה</a> שב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> וראש מכון <a href=\"/index.php/%D7%94%D7%99%D7%9B%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D\" title=\"היכל מנחם\">היכל מנחם</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%9B%22%D7%97_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"כ&quot;ח טבת\">כ\"ח טבת</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%90\" title=\"תשי&quot;א\">תשי\"א</a> ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a> לרב <a href=\"/index.php/%D7%93%D7%95%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"דוב אליעזר הבלין\">דוב אליעזר הבלין</a> ולעלקא. סבו, היה הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%96%D7%9C%D7%9E%D7%9F_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"שלמה זלמן הבלין\">שלמה זלמן הבלין</a>, ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a> בעיר.\n</p><p>בבחרותו למד בישיבת מיר, שם היה מחשובי הבחורים וממקורביו של ראש הישיבה הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%A4%D7%A8%D7%A6%D7%95%D7%91%D7%99%D7%A5%27\" title=\"נחום פרצוביץ&#39;\">נחום פרצוביץ'</a>, בישיבה הוא התקרב לחסידות בלימוד <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a> בקבוצות של שיעורים בישיבה. במשך תקופה שימש איש הקשר בין הרבי לבין ה<a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%A4%D7%A8%D7%A6%D7%95%D7%91%D7%99%D7%A5%27\" title=\"נחום פרצוביץ&#39;\">רב נחום פרצוביץ</a>'<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בהגיעו לגיל חתונה, נישא בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"תשל&quot;ב\">תשל\"ב</a> עם רעייתו מרת עדינה בת המשגיח בישיבת קמניץ, הרב משה אהרן שטרן, ולאחר חתונתו למד ב<a href=\"/index.php/%D7%9B%D7%95%D7%9C%D7%9C_%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect mw-disambig\" title=\"כולל צמח צדק\">כולל צמח צדק</a> בירושלים העתיקה והיה מעורכי קובץ <a href=\"/index.php/%D7%99%D7%92%D7%93%D7%99%D7%9C_%D7%AA%D7%95%D7%A8%D7%94_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"יגדיל תורה (ירושלים)\">יגדיל תורה</a> שיצא לאור על ידי הכולל.\n</p><p>במשך תקופה כיהן כר\"מ בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA\" class=\"mw-redirect\" title=\"תורת אמת\">תורת אמת</a> בירושלים.\n</p><p>בשנת תשמ\"ח היה שותף בייסוד ספריה תורנית בשכונת גאולה בירושלים לעילוי נשמת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%97%D7%99%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%90\" class=\"mw-redirect\" title=\"הרבנית חיה מושקא\">הרבנית חיה מושקא</a> יחד עם הנגיד ר' <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%95%D7%98%D7%A0%D7%99%D7%A7\" title=\"יוסף יצחק גוטניק\">יוסף יצחק גוטניק</a>, הספריה קיבלה לימים את השם \"<a href=\"/index.php/%D7%94%D7%99%D7%9B%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D\" title=\"היכל מנחם\">היכל מנחם</a>\" <a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, וכיום משמש כעורך ראשי של מכון ההוצאה לאור של הספרים היוצאים לאור על ידי היכל מנחם.\n</p><p>לאחר שהוקמה שכונת <a href=\"/index.php/%D7%A8%D7%9E%D7%AA_%D7%A9%D7%9C%D7%9E%D7%94\" title=\"רמת שלמה\">רמת שלמה</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a>, פעל רבות בביסוס הקהילה שם, ולאחר שנערכו בחירות בינו לבין הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%95%D7%A4%D7%9F\" title=\"יוסף יצחק אופן\">יוסף יצחק אופן</a> מי יהיה רב הקהילה ומי המשפיע, נבחר ברוב קולות לרבנות הקהילה בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%96\" title=\"תשנ&quot;ז\">תשנ\"ז</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> יזם את בניית <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> חב\"ד בשכונה במודל <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.\n</p><p>הרב הבלין הקים את סמינר 'שושנת ירושלים' לבנות מחוץ לארץ בשכונת <a href=\"/index.php/%D7%A8%D7%9E%D7%AA_%D7%A9%D7%9C%D7%9E%D7%94\" title=\"רמת שלמה\">רמת שלמה</a>.\n</p>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.9D_.D7.91.D7.A2.D7.A8.D7.99.D7.9B.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ספרים_בעריכתו\">ספרים בעריכתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ספרים בעריכתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ספרים בעריכתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>הליכות מנחם</b> - מנהגים והנהגות כ\"ק אדמו\"ר מליובאוויטש, תמוז תשפ\"ג<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup></li>\n<li><b>שולחן מנחם</b> - פסקים הלכתיים מתורתו של הרבי</li>\n<li><b>שערי גאולה</b> - ליקוט שיחות כ\"ק אדמו\"ר בענייני משיח וגאולה</li>\n<li><b>שערי המועדים</b> - הלכות בסיסיות בכל מועדי השנה</li>\n<li><b>שערי צדקה</b> - ליקוט תורת הרבי בענייני צדקה</li>\n<li><b>שערי אמונה</b> - ליקוט תורת הרבי בנושאי אמונה</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h4><span id=\".D7.90.D7.97.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"אחיו\">אחיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;אחיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: אחיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h4>\n<ul><li>אחיו, הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"משה הבלין\">משה הבלין</a> - רב העיר <a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" title=\"קריית גת\">קריית גת</a> וראש המוסדות, חבר <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"בית דין רבני חב&quot;ד בארץ הקודש\">בית דין רבני חב\"ד בארץ הקודש</a>.</li>\n<li>אחיו, הרב <a href=\"/index.php?title=%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%90%D7%94%D7%A8%D7%9F_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שמואל אהרן הבלין (הדף אינו קיים)\">שמואל אהרן הבלין</a> - רב קהילת יבנה בס. פאולו, ברזיל.</li>\n<li>אחיו, הרב שלמה זלמן הבלין - ראש המכון התורני \"דרך אליעזר\", <a href=\"/index.php/%D7%94%D7%A8_%D7%A0%D7%95%D7%A3\" class=\"mw-redirect\" title=\"הר נוף\">הר נוף</a>, ירושלים.</li></ul>\n<h4><span id=\".D7.99.D7.9C.D7.93.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ילדיו\">ילדיו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;ילדיו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: ילדיו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h4>\n<ul><li>בנו, הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"שניאור זלמן הבלין\">שניאור זלמן הבלין</a> - שליח הרבי ורב העיר דרזדן, גרמניה.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"שמואל הבלין\">שמואל הבלין</a> - שליח הרבי ורב העיר ברמן, גרמניה.</li>\n<li>בנו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%94%D7%91%D7%9C%D7%99%D7%9F\" title=\"מנחם מענדל הבלין\">מנחם מענדל הבלין</a> - מרבני <a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%94%D7%91%D7%99%D7%A0%D7%A0%D7%99\" title=\"מכון הבינני\">מכון הבינני</a> שעל ידי <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A8%D7%91%D7%A0%D7%99_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"בית דין רבני חב&quot;ד\">בית דין רבני חב\"ד</a>.</li>\n<li>בנו, הרב אברהם ברוך הבלין - ממנהלי <a href=\"/index.php/%D7%94%D7%99%D7%9B%D7%9C_%D7%9E%D7%A0%D7%97%D7%9D\" title=\"היכל מנחם\">מכון היכל מנחם</a> להפצת המעיינות.</li></ul>\n<h4><span id=\".D7.97.D7.AA.D7.A0.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"חתניו\">חתניו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;חתניו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%94%D7%91%D7%9C%D7%99%D7%9F&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: חתניו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h4>\n<ul><li>חתנו, הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%92%D7%95%D7%9C%D7%93%D7%A9%D7%9E%D7%99%D7%93\" title=\"יעקב גולדשמיד\">יעקב גולדשמיד</a> - מראשי ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"תומכי תמימים כפר חב&quot;ד\">תומכי תמימים כפר חב\"ד</a>.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%96%D7%95%D7%A9%D7%90_%D7%95%D7%95%D7%9C%D7%A3\" title=\"זושא וולף\">זושא וולף</a> - סופר חסידי, ומנהל סניף חברת המדיה <a href=\"/index.php/Jem\" class=\"mw-redirect\" title=\"Jem\">jem</a> בארץ הקודש.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%92%D7%95%D7%A4%D7%99%D7%9F\" title=\"שמעון גופין\">שמעון גופין</a> - <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a>, רב <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> 'גבעת ליובאוויטש' ומנהל מכון ההוצאה לאור של ספרי אביו הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%92%D7%95%D7%A4%D7%99%D7%9F\" title=\"זלמן גופין\">זלמן גופין</a>.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A9%D7%9B%D7%A8_%D7%A9%D7%9C%D7%9E%D7%94_%D7%91%D7%99%D7%A1%D7%98%D7%A8%D7%99%D7%A6%D7%A7%D7%99\" title=\"יששכר שלמה ביסטריצקי\">יששכר שלמה ביסטריצקי</a> - שליח הרבי ורב העיר המבורג, <a href=\"/index.php/%D7%92%D7%A8%D7%9E%D7%A0%D7%99%D7%94\" title=\"גרמניה\">גרמניה</a>.</li>\n<li>חתנו, הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%91%D7%99%D7%99%D7%98%D7%A9\" title=\"דוד בייטש\">דוד בייטש</a> - משפיע בישיבות תומכי תמימים לוד וכפר חב\"ד.</li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><spa