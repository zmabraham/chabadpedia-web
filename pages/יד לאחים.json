    "pageid": 2485,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Frameless\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D.jpg\" class=\"mw-file-description\" title=\"הסמל הישן של הארגון\"><img alt=\"הסמל הישן של הארגון\" src=\"/images/a/a0/%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D.jpg\" decoding=\"async\" width=\"150\" height=\"202\" class=\"mw-file-element\" /></a><figcaption>הסמל הישן של הארגון</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9C%D7%95%D7%92%D7%95_%D7%97%D7%93%D7%A9_%D7%A9%D7%9C_%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D.png\" class=\"mw-file-description\"><img src=\"/images/thumb/5/50/%D7%9C%D7%95%D7%92%D7%95_%D7%97%D7%93%D7%A9_%D7%A9%D7%9C_%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D.png/220px-%D7%9C%D7%95%D7%92%D7%95_%D7%97%D7%93%D7%A9_%D7%A9%D7%9C_%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D.png\" decoding=\"async\" width=\"220\" height=\"67\" class=\"mw-file-element\" srcset=\"/images/5/50/%D7%9C%D7%95%D7%92%D7%95_%D7%97%D7%93%D7%A9_%D7%A9%D7%9C_%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D.png 1.5x\" /></a><figcaption>יד לאחים</figcaption></figure>\n<figure class=\"mw-default-size\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90PictureFileName.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/74/%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90PictureFileName.jpg/220px-%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90PictureFileName.jpg\" decoding=\"async\" width=\"220\" height=\"220\" class=\"mw-file-element\" srcset=\"/images/thumb/7/74/%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90PictureFileName.jpg/330px-%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90PictureFileName.jpg 1.5x, /images/7/74/%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90PictureFileName.jpg 2x\" /></a><figcaption>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90\" title=\"יעקב לנדא\">יעקב לנדא</a>, רבה של <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a> נואם בכנס פעילים של \"יד לאחים\" ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%A9%D7%9E%D7%95%D7%A0%D7%94\" title=\"קריית שמונה\">קריית שמונה</a></figcaption></figure>\n<p><b>יד לאחים</b> הוא ארגון הפועל למען <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%9D\" class=\"mw-redirect\" title=\"שלימות העם\">שלימות עם ישראל</a>, בעיקר על ידי לחימה בטמיעה והתבוללות.\n</p><p>פעילי הארגון מטפלים בחילוץ נשים וילדים יהודים מכפרים ערביים ושיקום חייהם, מצילים נפשות מציפורני המיסיון ועוסקים בהכוונה חינוכית ובהסברה.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.A7.D7.9E.D7.AA_.D7.94.D7.90.D7.A8.D7.92.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"הקמת_הארגון\">הקמת הארגון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;הקמת הארגון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: הקמת הארגון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הארגון נוסד בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a> (1950) על ידי קבוצת פעילים בלתי מפלגתיים חלקם חסידי <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a>, חלקם ליטאים וחלק חסידי גור, בעקבות ניסיונות 'חינוך מחדש' לעולים החדשים, על מנת לסייע לעולים חדשים בשלבי ההתאקלמות הראשונים בארץ לקבל חינוך דתי. הארגון הוקם כתגובת נגד לפעולות הממשלה החילונית שהעבירה את העולים למחנות עולים חילוניים.\n</p><p>את הארגון הקים הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"שלום דובער ליפשיץ\">שלום דובער ליפשיץ</a> יחד עם הרבנים <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9C%D7%A0%D7%93%D7%90\" title=\"יעקב לנדא\">יעקב לנדא</a>, <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%9C%D7%99%D7%99%D7%91%D7%95%D7%91\" title=\"ישראל לייבוב\">ישראל לייבוב</a>, <a href=\"/index.php?title=%D7%A9%D7%9C%D7%9E%D7%94_%D7%A0%D7%97_%D7%A7%D7%A8%D7%95%D7%9C&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלמה נח קרול (הדף אינו קיים)\">שלמה נח קרול</a> ויחיאל יעקובוביץ', בברכתם של כל גדולי ישראל, וביניהם <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a>.\n</p>\n<h2><span id=\".D7.AA.D7.97.D7.95.D7.9E.D7.99_.D7.94.D7.A4.D7.A2.D7.99.D7.9C.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"תחומי_הפעילות\">תחומי הפעילות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;תחומי הפעילות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: תחומי הפעילות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.9C.D7.97.D7.99.D7.9E.D7.94_.D7.91.D7.9E.D7.99.D7.A1.D7.99.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"לחימה_במיסיון\">לחימה במיסיון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;לחימה במיסיון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: לחימה במיסיון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>בהמשך, הופנתה הפעילות לטיפול בבעיות נוספות קשות ומורכבות יותר, אחת המרכזיות שבהן היא, מאבק בשליחי המיסיון הנוצרי. אחר שהתברר כי בארץ פועלות כמעט באין מפריע, כמאה קהילות מיסיונריות וכתות שונות, המתוקצבות היטב ומציעות למשפחות במצוקה עזרה כספית וכדומה. המאבק בהם הפך לאחת המשימות העיקריות של הארגון. מנהל האגף ללחימה במיסיון: <a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9B%D7%98%D7%9E%D7%9F\" title=\"חנוך גכטמן\">חנוך גכטמן</a>.\n</p>\n<h3><span id=\".D7.9C.D7.97.D7.99.D7.9E.D7.94_.D7.95.D7.94.D7.A6.D7.9C.D7.94_.D7.9E.D7.94.D7.AA.D7.91.D7.95.D7.9C.D7.9C.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"לחימה_והצלה_מהתבוללות\">לחימה והצלה מהתבוללות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לחימה והצלה מהתבוללות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לחימה והצלה מהתבוללות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>נושא נוסף ומרכזי בו עוסק 'יד לאחים' הוא מאבק בטמיעה. מדובר בתופעה הולכת ומתרחבת של נערות ונשים, שיוצאות, ובהרבה מקרים אף מתחתנות, עם ערבים ובני מיעוטים אחרים. למשרדי הארגון מגיעות כ-500 קריאות בשנה ודיווחים על מקרים מסוג זה. המחלקה להצלה מטמיעה פועלת בדרכים שונות, לעיתים מסוכנות, להצלת אותן נערות ונשים, כשלפעמים יש צורך בחילוץ מכפרים עוינים ושיכון בדירות מסתור. מנהל האגף ללחימה והצלה מהתבוללות: <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A9%D7%9C%D7%9E%D7%94_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"שמואל שלמה ליפשיץ\">שמואל שלמה ליפשיץ</a>.\n</p>\n<h3><span id=\".D7.A4.D7.A2.D7.99.D7.9C.D7.95.D7.AA_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"פעילות_נוספת\">פעילות נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;פעילות נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: פעילות נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>ב'יד לאחים' קיימות גם מחלקות נוספות למטרות אלו של הצלת יהודים מטמיעה: המחלקה לקליטה רוחנית לעולי חבר העמים ומחלקה לרישום ילדים למוסדות תורניים ועוד\n</p>\n<h3><span id=\".D7.94.D7.92.D7.A8.D7.9C.D7.AA_.D7.99.D7.93_.D7.9C.D7.90.D7.97.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הגרלת_יד_לאחים\">הגרלת יד לאחים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;הגרלת יד לאחים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: הגרלת יד לאחים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>כל שנה לפני חג השבועות, ביד לאחים עורכים הגרלה על ספר תורה מהודר.\nהזוכה בספר בוחר בין ספר תורה ספרדי לאשכנזי.\n</p><p>כל המצטרפים להגרלה מקבלים ללא עלות פיסת בד מספר התורה הידועה כסגולה לשמירה והגנה<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.90.D7.95.D7.A4.D7.99_.D7.94.D7.90.D7.A8.D7.92.D7.95.D7.9F\"></span><span class=\"mw-headline\" id=\"אופי_הארגון\">אופי הארגון</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;אופי הארגון&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: אופי הארגון\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>יד לאחים נחשב כארגון דתי - כללי ואף פעילים בו גם כאלה שאינם <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסידי</a> <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a>, ולכן אינו פועל בשם חב\"ד באופן רשמי, אך קיימת הוראת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> לפיה יד לאחים יכול לפעול בשמו, כל עוד אין הדבר עלול להזיק לפעילות הארגון.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%98\" title=\"תשמ&quot;ט\">תשמ\"ט</a> בזמן המחלוקת והפילוגים בציבור החרדי, ביוזמת חלק מרבני הליטאים, הכריזו אותם רבנים שכיון שבראש הארגון עומד חסיד חב\"ד (הרב ליפשיץ), יש להתנתק מן הארגון. במקום זה הם הקימו ארגון ליטאי מתחרה בשם לב לאחים. מסופר שכאשר מזכיר הארגון שהיה ליטאי, ביקר אצל הרבי ושאל למה כאלה דברים קורים ללא הצדקה, הרבי לימד זכות על ראש ישיבה באמריקה שדחף לפילוג, בכך שהייתה לו נגיעה אישית, כי אחד מתורמיו איים שלא יתרום אם ראש הישיבה לא יצא נגד <a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> לאחר פטירתו של הרב שלום דוב ליפשיץ, מונו להנהלת הארגון בניו.\n</p>\n<h2><span id=\".D7.91.D7.A2.D7.95.D7.9C.D7.9D\"></span><span class=\"mw-headline\" id=\"בעולם\">בעולם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=8\" title=\"עריכת פסקה: &quot;בעולם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=8\" title=\"עריכת קוד המקור של הפרק: בעולם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>יד לאחים התפתח גם לעולם ולתחומים שונים משרדים בארצות הברית, הולנד ועוד...\n</p>\n<h2><span id=\".D7.A1.D7.A4.D7.A8.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ספרים\">ספרים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=9\" title=\"עריכת פסקה: &quot;ספרים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=9\" title=\"עריכת קוד המקור של הפרק: ספרים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>הארגון הוציא ספרים על מנת להגביר המודעות בציבור:\n</p>\n<ul><li>עלילות הפעילים - קומיקס המתאר את שנותיו הראשונות של הארגון,</li></ul>\n<p>בשנים האחרונות הארגון הודיע על כוונתו להוציא ספר המתאר את תולדות ופועלי הארגון, הספר בשלבי הכננה לדפוס מתקדמים נכון לשנת תשפ\"ו\n</p>\n<h2><span id=\".D7.94.D7.90.D7.A8.D7.92.D7.95.D7.9F_.D7.9B.D7.99.D7.95.D7.9D\"></span><span class=\"mw-headline\" id=\"הארגון_כיום\">הארגון כיום</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=10\" title=\"עריכת פסקה: &quot;הארגון כיום&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=10\" title=\"עריכת קוד המקור של הפרק: הארגון כיום\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A9%D7%9C%D7%9E%D7%94_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"שמואל שלמה ליפשיץ\">שמואל ליפשיץ</a> - מנהל הארגון.</li>\n<li><a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%A8%D7%99%D7%96%D7%9C\" class=\"mw-redirect\" title=\"שלמה ריזל\">שלמה ריזל</a> - דובר הארגון.</li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%A0%D7%95%D7%9A_%D7%92%D7%9B%D7%98%D7%9E%D7%9F\" title=\"חנוך גכטמן\">חנוך גכטמן</a> - ראש האגף ללחימה במסיון.</li>\n<li><a href=\"/index.php/%D7%91%D7%A0%D7%99%D7%9E%D7%99%D7%9F_%D7%A7%D7%9C%D7%95%D7%92%D7%A8\" title=\"בנימין קלוגר\">בנימין קלוגר</a> - סגן ראש האגף ללחימה במסיון.</li></ul>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=11\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=11\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"שלום דובער ליפשיץ\">שלום דובער ליפשיץ</a></li>\n<li><a href=\"/index.php/%D7%A7%D7%98%D7%92%D7%95%D7%A8%D7%99%D7%94:%D7%A4%D7%A2%D7%99%D7%9C%D7%99_%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D\" title=\"קטגוריה:פעילי יד לאחים\">קטגוריה: פעילי יד לאחים</a></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=12\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=12\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>היד הארוכה מגיעה למדינות ערביות עוינות</b>, שבועון בית משיח י\"ג סיון תש\"פ עמוד 14</li>\n<li><b>הגאולה מן הכפר</b>, שלמה מן, שבועון <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\"> כפר חב\"ד</a> מס' 1955 ע' 130-133.</li>\n<li>ראיון עם ר' מנחם כהן, מראשוני ה\"פעילים\": \"הרבי פקח לי את העיניים\". כפר חב\"ד, גליון 1979, ערב סוכות תשפ\"ג, עמ' 62 ואילך.</li>\n<li><b>המאבק על הנפש</b>, שבועון כפר חב\"ד גליון 1976 עמוד 72</li>\n<li><b>חוד החנית במאבק במיסיון</b>, מתוך <a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"שבועון בית משיח\">שבועון בית משיח</a> גיליון 138 ערב <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג השבועות\">חג השבועות</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%96\" title=\"תשנ&quot;ז\">תשנ\"ז</a>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;veaction=edit&amp;section=13\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%93_%D7%9C%D7%90%D7%97%D7%99%D7%9D&amp;action=edit&amp;section=13\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"http://www.yadleachim.co.il/#\">אתר יד לאחים</a></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"http://old2.ih.chabad.info/index.php?t=2202095&amp;url=article_he&amp;id=64946\">הרב עובדיה יוסף</a><span typeof=\"mw:File\"><span><img src=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/16px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png\" decoding=\"async\" width=\"16\" height=\"11\" class=\"mw-file-element\" srcset=\"/images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/24px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 1.5x, /images/thumb/d/d6/%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg/32px-%D7%A1%D7%9E%D7%9C_%D7%95%D7%99%D7%93%D7%99%D7%90%D7%95_%D7%9E%D7%97%D7%95%D7%93%D7%A9_5.svg.png 2x\" /></span></span> - דברי הספד על הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%99%D7%A4%D7%A9%D7%99%D7%A5\" title=\"שלום דובער ליפשיץ\">שלום דובער ליפשיץ</a> וקריאה לתמיכה בארגון \"יד לאחים\" <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/magazine/601834/\">פעילות יד לאחים במדינות מוסלמיות עוינות</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"קישור לשבועון בית משיח\"><img alt=\"קישור לשבועון בית משיח\" src=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/60px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png\" decoding=\"async\" width=\"60\" height=\"13\" class=\"mw-file-element\" srcset=\"/images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/90px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png 1.5x, /images/thumb/0/03/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%9C%D7%9C%D7%90_%D7%A8%D7%A7%D7%A2.png/120px-%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97_%D7%