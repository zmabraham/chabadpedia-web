      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%A4%27%27%D7%91.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/8b/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%A4%27%27%D7%91.jpg/250px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%A4%27%27%D7%91.jpg\" decoding=\"async\" width=\"250\" height=\"167\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8b/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%A4%27%27%D7%91.jpg/375px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%A4%27%27%D7%91.jpg 1.5x, /images/thumb/8/8b/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%A4%27%27%D7%91.jpg/500px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%A4%27%27%D7%91.jpg 2x\" /></a><figcaption>ОћОеОЉ ОЕОЋОЋОеОЦ (ОфОЕОц\"ОЉ)</figcaption></figure>\n<figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f6/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA.jpg/250px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA.jpg\" decoding=\"async\" width=\"250\" height=\"131\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f6/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA.jpg/375px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA.jpg 1.5x, /images/thumb/f/f6/%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA.jpg/500px-%D7%94%D7%A8%D7%91_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5_%D7%91%D7%9E%D7%A1%D7%99%D7%A8%D7%AA_%D7%A9%D7%99%D7%A2%D7%95%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA.jpg 2x\" /></a><figcaption>ОћОеОЉ ОЕОЋОЋОеОЦ ОЉОъОАОЎОеОф ОЕОЎОбОЋОеОЋ ОћОЕОЉОЋОбОЎ ОЉОЌОАОЎОЊОЋОф ОЉОЎОЕОЎОЉОф ОЏОАОљ ОеОЌОъОЎОЮ (ОъОфОЋОџ ОфОЋОЏОаОЎОф ОЋОЎОЊОљОЋ ОЕОю ОљОеОњОЋОЪ <a href=\"/index.php/%D7%9E%D7%A8%D7%9B%D7%96_%D7%90%D7%AA%22%D7%94_%D7%91%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"ОъОеОЏОќ ОљОф&quot;Оћ ОЉОљОеОЦ ОћОДОЋОЊОЕ\">ОъОеОЏОќ ОљОф\"Оћ ОЉОљОеОЦ ОћОДОЋОЊОЕ</a>) (ОфОЕОб\"Оќ)</figcaption></figure>\n<p>ОћОеОЉ <b>ОЎОЋОАОБ ОЎОдОЌОД ОЕОЋОЋОеОЦ</b> (ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%91%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ОЉ&#39; ОЉОфОъОЋОќ\">ОЉ' ОЉОфОъОЋОќ</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"ОфОЕОъ&quot;Ољ\">ОфОЕОъ\"Ољ</a>, 4 ОЉОЎОЋОюОЎ 1981) ОћОЎОаОЋ ОљОЎОЕ ОЌОЎОаОЋОџ ОћОъОЕОъОЕ ОЏОаОЋОЕОљ ОЋОаОЋОфОЪ ОЉОАОЊОеОЎ ОЌОАОЎОЊОЋОф, ОњОЎОеОАОљ, ОЋОњОљОЋОюОћ ОЋОъОЕОЎОЌ ОЉОЎОЕОЎОЉОЋОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОЋОе ОЎОћОЋОЊОћ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОљОЋОе ОЎОћОЋОЊОћ</a>, ОЉОбОЉОе ОЕОЎОъОЕ ОЏОе\"Оъ ОЉОаОњОюОћ ОЋОЏОъОЕОњОЎОЌ.\n</p>\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОфОЋОюОЊОЋОф_ОЌОЎОЎОЮ\">ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"ОЉОаОЎ ОЉОеОД\">ОЉОаОЎ ОЉОеОД</a> ОюОе' ОњОеОЕОЋОЪ ОќОљОЉ<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> ОЋОюОЕОЋОЕОаОћ ОеОЎОЎОќОю, ОЉОЎОюОЊОЋОфОЋ ОюОъОЊ ОЉ<a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%AA%D7%95%D7%A8%D7%94\" title=\"ОфОюОъОЋОЊ ОфОЋОеОћ\">ОфОюОъОЋОЊ ОфОЋОеОћ</a> ОЕОю <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%91%D7%A2%D7%9C%D7%96%D7%90\" class=\"mw-redirect\" title=\"ОЌОАОЎОЊОЋОф ОЉОбОюОќОљ\">ОЌОАОЎОЊОЋОф ОЉОбОюОќОљ</a> ОЉОбОЎОе.\n</p><p>ОЏОаОбОе ОюОъОЊ ОЉОЎОЕОЎОЉОћ ОДОўОаОћ ОЕОю ОЌОАОЎОЊОЋОф ОЉОбОюОќОљ ОЉОбОЎОе <a href=\"/index.php/%D7%90%D7%A9%D7%93%D7%95%D7%93\" title=\"ОљОЕОЊОЋОЊ\">ОљОЕОЊОЋОЊ</a>, ОЉОћОЕОцОбОф ОљОЌОЎОЋ ОћОњОЊОЋОю ОћОеОЉ <a href=\"/index.php?title=%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%A9%D7%95%D7%95%D7%A8%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОљОћОеОЋОЪ ОЕОЋОЋОеОЦ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОљОћОеОЋОЪ</a> ОЋОЉОбОДОЉОЋОф <a href=\"/index.php/%D7%9B%D7%AA%D7%99%D7%91%D7%94_%D7%9C%D7%A8%D7%91%D7%99_%D7%91%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ОЏОфОЎОЉОћ ОюОеОЉОЎ ОЉОљОњОеОЋОф ОДОЋОЊОЕ\">ОъОбОаОћ ОЕОДОЎОЉОю ОъОћОеОЉОЎ ОЉОљОњОеОЋОф ОДОЋОЊОЕ</a> ОЉОЋ ОћОЋОеОћ ОюОЋ ОћОеОЉОЎ ОюОбОЉОЋОе ОюОюОъОЋОЊ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ</a> ОбОюОћ ОюОюОъОЋОЊ ОЉ<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%94_%D7%92%D7%93%D7%95%D7%9C%D7%94\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОћ ОњОЊОЋОюОћ\">ОЎОЕОЎОЉОћ ОњОЊОЋОюОћ</a> ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОъОњОЊОю ОћОбОъОД\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОъОњОЊОю ОћОбОъОД</a>.\n</p><p>ОћОЌОю Оъ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"ОЌОЋОЊОЕ ОфОЕОеОЎ\">ОЌОЋОЊОЕ ОфОЕОеОЎ</a> <a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"ОфОЕ&quot;ОА\">ОфОЕ\"ОА</a> ОЕОћОћ ОЉ-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> ОбОЊ ОюОЕОаОф Оћ<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"ОДОЉОЋОдОћ\">ОДОЉОЋОдОћ</a> ОЕОюОЋ ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"ОфОЕОА&quot;ОЉ\">ОфОЕОА\"ОЉ</a> ОЋОюОљОЌОеОЎОћ ОаОЕОљОе ОЕОЮ ОбОЊ ОюОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%94\" title=\"ОфОЕОА&quot;Оћ\">ОфОЕОА\"Оћ</a>, ОЏОЕОЉОљОъОдОб ОЎОдОљ ОюОъОАОцОе ОЌОЋОЊОЕОЎОЮ ОЉОЕОюОЎОЌОЋОф ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%9E%D7%AA_%D7%90%D7%91%D7%99%D7%91\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОеОъОф ОљОЉОЎОЉ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОеОъОф ОљОЉОЎОЉ</a>.\n</p><p>ОЉОъОћОюОџ ОЕОаОЋОф ОюОЎОъОЋОЊОЎОЋ ОЉ-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> ОаОъОаОћ ОбОю ОъОЕОфОфОцОЎ ОЕОЎОбОЋОеОЎОЋ ОЕОю Ое' <a href=\"/index.php/%D7%99%D7%95%D7%90%D7%9C_%D7%9B%D7%94%D7%9F\" title=\"ОЎОЋОљОю ОЏОћОЪ\">ОЎОЋОљОю ОЏОћОЪ</a>, ОЏОфОЉ ОћОбОеОЋОф ОЋОЌОЎОЊОЋОЕОЎОЮ ОЉ<a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5_%D7%94%D7%A2%D7%A8%D7%95%D7%AA_%D7%95%D7%91%D7%99%D7%90%D7%95%D7%A8%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ОДОЋОЉОЦ ОћОбОеОЋОф ОЋОЉОЎОљОЋОеОЎОЮ\">ОДОЋОЉОЦ ОћОбОеОЋОф ОЋОЉОЎОљОЋОеОЎОЮ</a> ОЕОю <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA_-_770\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф - 770\">ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОъОеОЏОќОЎОф - 770</a>, ОЋОЏОЎОћОЪ ОЏОЌОЉОе ОљОеОњОЋОЪ <a href=\"/index.php/%D7%90%D7%AA%22%D7%94_%D7%94%D7%A2%D7%95%D7%9C%D7%9E%D7%99\" class=\"mw-redirect\" title=\"ОљОф&quot;Оћ ОћОбОЋОюОъОЎ\">ОљОф\"Оћ ОћОбОЋОюОъОЎ</a>.\n</p><p>ОюОљОЌОе ОаОЎОЕОЋОљОЎОЋ ОбОЮ ОъОеОф ОаОЌОъОћ ОЊОЎОаОћ ОЉОфОЋ ОЕОю ОћОеОЉ <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%94%D7%9C%D7%A4%D7%A8%D7%99%D7%9F_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_%D7%91%27)\" class=\"mw-redirect\" title=\"ОљОћОеОЪ ОћОюОцОеОЎОЪ (ОЏОцОе ОЌОЉ&quot;ОЊ ОЉ&#39;)\">ОљОћОеОЪ ОћОюОцОеОЎОЪ (ОЏОцОе ОЌОЉ\"ОЊ ОЉ')</a> ОћОфОњОЋОеОеОЋ ОћОќОЋОњ ОъОАОцОе ОЌОЋОЊОЕОЎОЮ ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_%D7%91%27\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ ОЉ&#39;\">ОЏОцОе ОЌОЉ\"ОЊ ОЉ'</a>, ОЏОЕОЏОфОЉОЋ ОюОеОЉОЎ ОбОю ОеОдОЋОаОЮ ОюОдОљОф Ою<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97%D7%95%D7%AA\" title=\"ОЕОюОЎОЌОЋОф\">ОЕОюОЎОЌОЋОф</a> <a href=\"/index.php/%D7%9B%D7%AA%D7%99%D7%91%D7%94_%D7%9C%D7%A8%D7%91%D7%99_%D7%91%D7%90%D7%9E%D7%A6%D7%A2%D7%95%D7%AA_%D7%94%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9\" title=\"ОЏОфОЎОЉОћ ОюОеОЉОЎ ОЉОљОъОдОбОЋОф ОћОљОњОеОЋОф ОДОЋОЊОЕ\">ОДОЎОЉОюОЋ ОъОбОаОћ ОЉОљОњОеОЋОф ОДОЋОЊОЕ</a> ОћОъОбОЋОЊОЊ ОљОЎОЋОЕ ОъОЕОеОћ ОЌОЎОаОЋОЏОЎОф ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ</a>, ОЉОбОДОЉОЋОф ОЏОџ ОћОЮ ОбОЉОеОЋ ОюОњОЋОе ОЉОбОЎОе ОбОЎОе <a href=\"/index.php/%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94\" title=\"ОљОЋОе ОЎОћОЋОЊОћ\">ОљОЋОе ОЎОћОЋОЊОћ</a> ОЕОЮ ОћОЌОю ОюОЕОъОЕ ОћОеОЉ ОЕОЋОЋОеОЦ ОЏ<a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"Ое&quot;Оъ\">Ое\"Оъ</a> ОЉОаОњОюОћ ОЋ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОћОДОўОаОћ ОЉОбОЎОе (ОћОЎОћ ОќОћ ОќОъОЪ ОДОдОе ОюОљОЌОе ОцОфОЎОЌОф ОћОЎОЕОЎОЉОћ), ОеОбОЎОЎОфОЋ ОћОЌОюОћ ОюОЕОъОЕ ОЏОъОЌОаОЏОф ОЉОЉОЎОф ОАОцОе ОЌОЉ\"ОЊ ОюОЉОаОЋОф ОЉОбОЎОе.\n</p><p>ОЉОћОъОЕОџ ОћОъОЎОе ОљОф ОфОцОДОЎОЊ ОћОъОЕОцОЎОб ОЉОЎОЕОЎОЉОћ ОДОўОаОћ ОЋОъОЋОаОћ ОюОЕОъОЕ ОЏ<a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"ОъОЕОњОЎОЌ\">ОъОЕОњОЎОЌ</a> ОЉОАОЊОеОЎ ОЌОАОЎОЊОЋОф ОЉОЎОЕОЎОЉОћ ОћОњОЊОЋОюОћ ОЉОбОЎОе, ОЏОбОЉОЋОе ОфОДОЋОцОф ОЕОаОЎОЮ ОъОАОЋОЎОЎОъОф ОЌОЊОю ОъОюОЕОъОЕ ОЏОе\"Оъ ОЉОЎОЕОЎОЉОћ ОДОўОаОћ. ОюОДОеОљОф ОЕОаОф ОћОюОЎОъОЋОЊОЎОЮ <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"ОфОЕОц&quot;ОЊ\">ОфОЕОц\"ОЊ</a> ОЌОЊОю ОъОюОЕОъОЕ ОЏОъОЕОњОЎОЌ ОЉОЎОЕОЎОЉОћ ОњОЊОЋОюОћ ОЋОЉОъОДОЋОЮ ОќОљОф ОъОЋОаОћ ОюОЕОъОЕ ОЏОаОЋ\"Оа ОЉОАОЊОеОЎ ОЌОАОЎОЊОЋОф ОЉОЋОДОе, ОЉОфОцОДОЎОЊ ОќОћ ОаОЋОЕОљ ОЏОЎОЋОЮ ОќОљОф ОюОдОЊ ОфОцОДОЎОЊ ОаОЋ\"Оа ОЉОАОЊОеОЎ ОњОЎОеОАОљ ОЋ<a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"ОњОљОЋОюОћ ОЋОъОЕОЎОЌ\">ОњОљОЋОюОћ ОЋОъОЕОЎОЌ</a> ОЉОЎОЕОЎОЉОћ ОДОўОаОћ.\n</p><p>ОъОЎОЊОЎ ОЕОаОћ ОъОЕОъОЕ ОЏОаОдОЎОњ ОћОЎОЕОЎОЉОћ ОћОњОЊОЋОюОћ (ОЎОЌОЊ ОбОЮ ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%94%D7%9C%D7%9C_(%D7%90%D7%95%D7%A8_%D7%99%D7%94%D7%95%D7%93%D7%94)\" title=\"ОъОЕОћ ОћОюОю (ОљОЋОе ОЎОћОЋОЊОћ)\">ОъОЕОћ ОћОюОю</a>) ОЉОћОфОЋОЋОбОЊОЋОЎОЋОф <a href=\"/index.php/%D7%90%D7%AA%22%D7%94_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99_770#ОЕОЉОфОЋОф_ОљОЌОЊОЋОф\" title=\"ОљОф&quot;Оћ ОћОъОеОЏОќОЎ 770\">ОЕОЉОф ОЕОЏОЋОюОћ ОъОЕОЎОЌ</a>.\n</p><p>ОъОЋОАОе ОЕОЎОбОЋОе <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ОЌОАОЎОЊОЋОф\">ОЌОАОЎОЊОЋОф</a> ОЕОЉОЋОбОЎ ОЉОЎОЕОЎОЉОф ОЏОАОљ ОеОЌОъОЎОЮ ОЉ<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"ОЉОаОЎ ОЉОеОД\">ОЉОаОЎ ОЉОеОД</a>.\n</p><p>ОюОеОЉ ОЕОЋОЋОеОЦ ОЋОюОеОбОЎОЎОфОЋ ОЕОюОЋОЕОћ ОбОЕОе ОЎОюОЊОЎОЮ.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ОъОЕОцОЌОфОЋ\">ОъОЕОцОЌОфОЋ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОъОЕОцОЌОфОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%95%D7%95%D7%A8%D7%A5&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОъОЕОцОЌОфОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ОљОЌОЎОЋ, ОћОеОЉ <a href=\"/index.php?title=%D7%90%D7%94%D7%A8%D7%9F_%D7%A9%D7%95%D7%95%D7%A8%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОљОћОеОЪ ОЕОЋОЋОеОЦ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОљОћОеОЪ ОЕОЋОЋОеОЦ</a> - ОеОљОЕ ОЏОЋОюОю ОЉОДОеОЎОф <a href=\"/index.php/%D7%A6%D7%90%D7%A0%D7%96\" class=\"mw-redirect\" title=\"ОдОљОаОќ\">ОдОљОаОќ</a> ОЉ<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"ОаОфОаОЎОћ\">ОаОфОаОЎОћ</a> ОЋ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉОДОбОъОц ОњОЪ ОЎОЕОеОљОю ОЉОаОЎ ОћОЎОЕОЎОЉОЋОф ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%90%D7%94%D7%9C%D7%99_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ОљОћОюОЎ ОъОаОЌОЮ ОъОбОаОЊОю ОюОЎОЋОЉОљОЋОЋОЎОўОЕ\">ОљОћОюОЎ ОъОаОЌОЮ ОъОбОаОЊОю ОюОЎОЋОЉОљОЋОЋОЎОўОЕ</a> ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a>.</li>\n<li>ОћОеОЉ ОЎОбОДОЉ ОЕОЋОЋОеОЦ - <a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"ОъОњОЊОю ОћОбОъОД\">ОъОњОЊОю ОћОбОъОД</a>.</li>\n<li>ОћОеОЉ ОЎОћОЋОЕОб ОЕОЋОЋОеОЦ - <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A9%D7%9E%D7%A9\" title=\"ОЉОЎОф ОЕОъОЕ\">ОЉОЎОф ОЕОъОЕ</a>.</li>\n<li>ОљОЌОЋОфОЋ, ОцОаОЎОаОћ ОЊОЎОЎОўОЕ - <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%A7%D7%9C%D7%99%D7%9F\" title=\"ОЉОеОЋОДОюОЎОЪ\">ОЉОеОЋОДОюОЎОЪ</a>.</li>\n<li>ОњОЎОАОЋ, ОћОеОЉ ОЕОаОЎОљОЋОе ОќОюОъОЪ ОЋОЎОюОћОюОЮ - <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"ОЉОаОЎ ОЉОеОД\">ОЉОаОЎ ОЉОеОД</a>.</li>\n<li>ОњОЎОАОЋ, ОћОеОЉ <a href=\"/index.php/%D7%91%D7%9F_%D7%A6%D7%99%D7%95%D7%9F_%D7%A4%D7%A8%D7%99%D7%A9%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"ОЉОЪ ОдОЎОЋОЪ ОцОеОЎОЕОъОЪ\">ОЉОЪ ОдОЎОЋОЪ ОцОеОЎОЕОъОЪ</a> - ОъОЕОцОЎОб ОЉ<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ\">ОЎОЕОЎОЉОф ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ</a>, ОЋОЌОЉОе ОъОбОеОЏОф <a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%AA_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"ОЕОЎОЌОф ОћОњОљОЋОюОћ\">ОЕОЎОЌОф ОћОњОљОЋОюОћ</a> ОЋ<a href=\"/index.php/%D7%A2%D7%99%D7%AA%D7%95%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" class=\"mw-redirect\" title=\"ОбОЎОфОЋОЪ ОћОњОљОЋОюОћ\">ОбОЎОфОЋОЪ ОћОњОљОЋОюОћ</a>.</li>\n<li>ОњОЎОАОЋ, ОћОеОЉ ОъОЕОћ ОдОЉОЎ ОћОюОцОеОЎОЪ - <a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" title=\"ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ\">ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ</a>.</li>\n<li>ОњОЎОАОЋ,ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%94%D7%9C%D7%A4%D7%A8%D7%99%D7%9F\" title=\"ОъОаОЌОЮ ОъОбОаОЊОю ОћОюОцОеОЎОЪ\">ОъОаОЌОЮ ОъОбОаОЊОю ОћОюОцОеОЎОЪ</a> - <a href=\"/index.php/%D7%A0%D7%95%22%D7%A0\" class=\"mw-redirect\" title=\"ОаОЋ&quot;Оа\">ОаОЋ\"Оа</a> ОЉ<a href=\"/index.php/%D7%97%D7%97%22%D7%9C_%D7%A6%D7%A4%D7%AA\" class=\"mw-redirect\" title=\"ОЌОЌ&quot;Ою ОдОцОф\">ОЌОЌ\"Ою ОдОцОф</a>.</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОћОбОеОЋОф_ОЕОЋОюОЎОЎОЮ\">ОћОбОеОЋОф ОЕОЋОюОЎОЎОЮ</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ОаОцОўОе ОЉ<a href=\"/index.php/%D7%91%27_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"ОЉ&#39; ОЕОЉОў\">ОЉ' ОЕОЉОў</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%92\" title=\"ОфОЕОб&quot;Оњ\">ОфОЕОб\"Оњ</a> <a rel=\"nofollow\" class=\"external text\" href=\"https://old2.ih.chabad.info/#!g=1&amp;url=article&amp;id=74077\">ОЎОЊОЎОбОћ ОбОю ОцОўОЎОеОфОЋ</a> ОЉОљОфОе <a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"ОЌОЉ&quot;ОЊ ОљОЎОаОцОЋ\">ОЌОЉ\"ОЊ ОљОЎОаОцОЋ</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414071716\nCache expiry: 86400\nReduced expiry: false\nComplications: []\nCPU time usage: 0.072 seconds\nReal time usage: 0.173 seconds\