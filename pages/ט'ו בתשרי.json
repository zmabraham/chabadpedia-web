/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ז בתשרי\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ח בתשרי\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"כ&quot;ט בתשרי\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%AA%D7%A9%D7%A8%D7%99\" title=\"ל&#39; בתשרי\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>ט&#34;ו בתשרי</b> הוא היום החמישה עשר\nבחודש הראשון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;והיום הראשון של <a href=\"/index.php/%D7%97%D7%92_%D7%94%D7%A1%D7%95%D7%9B%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חג הסוכות\">חג הסוכות</a>.\n</p><p>תאריך זה חל בתקופת תשרי&#160;והוא יכול לחול בימים&#160;שני, שלישי, חמישי ושבת.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'רנ\"ז (-1504 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - נולדו ל<a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"יצחק אבינו\">יצחק אבינו</a> ו<a href=\"/index.php/%D7%A8%D7%91%D7%A7%D7%94_%D7%90%D7%9E%D7%A0%D7%95\" title=\"רבקה אמנו\">רבקה אמנו</a> אחים תאומים <a href=\"/index.php/%D7%A2%D7%A9%D7%95\" class=\"mw-redirect\" title=\"עשו\">עשו</a> ו<a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91\" class=\"mw-redirect\" title=\"יעקב\">יעקב</a> אבינו.</li>\n<li>ב'רנ\"ז (-1504 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">לפנה\"ס</a>) - <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%91%D7%99%D7%A0%D7%95\" title=\"יעקב אבינו\">יעקב אבינו</a>, נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%94\" title=\"תרנ&quot;ה\">תרנ\"ה</a> (15/10/1894 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי מרדכי לייפר מ<a href=\"/index.php/%D7%A0%D7%93%D7%91%D7%95%D7%A8%D7%A0%D7%94\" class=\"mw-redirect\" title=\"נדבורנה\">נדבורנה</a>, נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%95\" title=\"תרפ&quot;ו\">תרפ\"ו</a> (03/10/1925 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php?title=%D7%9E%D7%90%D7%99%D7%A8_%D7%90%D7%A8%D7%99%D7%A7&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאיר אריק (הדף אינו קיים)\">מאיר אריק</a>, מחבר הספרים 'אמרי יושר' ו'טל תורה', נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> (02/10/2001 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי יהודה הכהן רבין, רבם של קהילת יהודי <a href=\"/index.php/%D7%91%D7%95%D7%9B%D7%A8%D7%94\" class=\"mw-redirect\" title=\"בוכרה\">בוכרה</a> ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a>, נפטר.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> (27/09/2007 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%90%D7%9C%D7%A7%D7%A0%D7%94_%D7%A9%D7%A4%D7%99%D7%A8%D7%90\" class=\"mw-redirect\" title=\"אברהם אלקנה שפירא\">אברהם אלקנה שפירא</a>, ראש ישיבת 'מרכז הרב' ו<a href=\"/index.php/%D7%94%D7%A8%D7%91_%D7%94%D7%A8%D7%90%D7%A9%D7%99_%D7%9C%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"הרב הראשי לישראל\">הרב הראשי לישראל</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%90\" title=\"תרע&quot;א\">תרע\"א</a> (18/10/1910 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A8%D7%91%D7%A7%D7%99%D7%9F\" class=\"mw-redirect\" title=\"שניאור זלמן רבקין\">שניאור זלמן רבקין</a>, מתושביה הוותיקים של <a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> שנמנה על מייסדי הכפר.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%98%22%D7%95_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%94\" title=\"תרצ&quot;ה\">תרצ\"ה</a> (24/09/1934 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%92%D7%99%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92_(%D7%97%D7%AA%D7%9F_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9)\" class=\"mw-redirect\" title=\"משה לייב גינזבורג (חתן אדמו&quot;ר המהר&quot;ש)\">משה לייב גינזבורג</a>, חתן <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%98\" title=\"תשנ&quot;ט\">תשנ\"ט</a> (05/10/1998 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - ר' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%91%D7%99%D7%99%D7%98%D7%A9\" title=\"משה בייטש\">משה בייטש</a>, <a href=\"/index.php/%D7%A9%D7%95%D7%97%D7%98\" title=\"שוחט\">שוחט</a> חב\"די שנמנה על ראשוני המתיישבים ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%97\" title=\"תשס&quot;ח\">תשס\"ח</a> (27/09/2007 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%91%D7%95%D7%92%D7%A8%D7%93\" title=\"שמואל בוגרד\">שמואל בוגרד</a>, רב ושוחט ב<a href=\"/index.php/%D7%94%D7%A8%D7%A6%D7%9C%D7%99%D7%94\" title=\"הרצליה\">הרצליה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> - הרב <a href=\"/index.php/%D7%9C%D7%99%D7%A4%D7%90_%D7%A7%D7%9C%D7%99%D7%99%D7%9F\" title=\"ליפא קליין\">ליפא קליין</a> - זקן חסידי חב\"ד ב<a href=\"/index.php/%D7%A0%D7%97%D7%9C%D7%AA_%D7%94%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"נחלת הר חב&quot;ד\">נחלת הר חב\"ד</a>, משומרי הגחלת החסידית ב<a href=\"/index.php/%D7%98%D7%A9%D7%A7%D7%A0%D7%98\" title=\"טשקנט\">טשקנט</a>, ממייסדי <a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%94%D7%91%D7%95%D7%9B%D7%A8%D7%99%D7%9D\" title=\"ישיבת הבוכרים\">ישיבת הבוכרים 'אור שמחה'</a> ומזכיר הישיבה למעלה מיובל שנים.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ט\"ו בתשרי - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>כשנותנים ה<a href=\"/index.php/%D7%90%D7%A8%D7%91%D7%A2%D7%AA_%D7%94%D7%9E%D7%99%D7%A0%D7%99%D7%9D\" title=\"ארבעת המינים\">ד' מינים</a> לאחר לברך עליהם אומרים בפירוש שהוא במתנה על מנת להחזיר, ובפרט ביום ראשון, והוא תועלת לנותן ולמקבל. הורה <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אבי</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> שיתחילו <a href=\"/index.php/%D7%91%D7%A8%D7%9B%D7%94\" title=\"ברכה\">ברכת</a> <a href=\"/index.php/%D7%A9%D7%94%D7%97%D7%99%D7%99%D7%A0%D7%95\" class=\"mw-redirect\" title=\"שהחיינו\">שהחיינו</a> כשה<a href=\"/index.php/%D7%9C%D7%95%D7%9C%D7%91\" title=\"לולב\">לולב</a> בידו אחת וה<a href=\"/index.php/%D7%90%D7%AA%D7%A8%D7%95%D7%92\" title=\"אתרוג\">אתרוג</a> בשניה. הפסוקים \"כי אמרתי\" גו' - רק ב<a href=\"/index.php/%D7%94%D7%95%D7%A9%D7%A2%D7%A0%D7%90_%D7%A8%D7%91%D7%90\" class=\"mw-redirect\" title=\"הושענא רבא\">הושענא רבא</a>. גם ביום מברכים לישב ב<a href=\"/index.php/%D7%A1%D7%95%D7%9B%D7%94\" class=\"mw-redirect\" title=\"סוכה\">סוכה</a> אחר <a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9\" title=\"קידוש\">קידוש</a> ולא אחר המוציא.</i>\n<p>ההנהגה בעת <a href=\"/index.php/%D7%91%D7%A8%D7%9B%D7%AA_%D7%9B%D7%94%D7%A0%D7%99%D7%9D\" title=\"ברכת כהנים\">ברכת כהנים</a> (כנזכר לעיל יום ב' דחג ה<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%AA\" title=\"שבועות\">שבועות</a>) אנו יודעים על ידי זה ש<a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a> היה לוקח את ה<a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"צמח צדק\">צמח צדק</a>, קודם חתונתו, תחת <a href=\"/index.php/%D7%98%D7%9C%D7%99%D7%AA\" title=\"טלית\">טליתו</a> לנשיאת כפים.\n</p>\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השביעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260414080112\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.110 seconds\nReal time usage: 1.026 seconds\nPreprocessor visited node count: 377/1000000\nPost‐expand include size: 9063/2097152 bytes\nTemplate argument size: 761/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 4/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 151/5000000 bytes\nLua time usage: 0.080/7 seconds\nLua virtual size: 6123520/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  936.417      1 -total\n 97.66%  914.475      1 תבנית:פתיח_יום\n 27.80%  260.290      5 תבנית:מילה_אחרונה\n 17.89%  167.497      1 תבנית:הערה\n 10.29%   96.329      2 תבנית:מילה_ראשונה\n  6.04%   56.574      1 תבנית:הסר_מילה_ראשונה\n  2.48%   23.230      1 תבנית:חודש_תשרי\n  2.32%   21.747      1 תבנית:להיום_יום\n  1.79%   16.778      3 תבנית:רווח\n  1.69%   15.811      1 תבנית:לוח_שנה\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:19191-0!canonical and timestamp 20260414080112 and revision id 841322. Rendering was triggered because: page-view\n -->\n</div>"
