9%D7%94%D7%95%D7%93%D7%99\" class=\"mw-redirect\" title=\"יהודי\">יהודי</a> <a href=\"/index.php/%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"רוסיה\">רוסיה</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%98\" title=\"תרפ&quot;ט\">תרפ\"ט</a> – פורצים '<a href=\"/index.php/%D7%9E%D7%90%D7%95%D7%A8%D7%A2%D7%95%D7%AA_%D7%AA%D7%A8%D7%A4%22%D7%98\" class=\"mw-redirect\" title=\"מאורעות תרפ&quot;ט\">מאורעות תרפ\"ט</a>' ב<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"ארץ ישראל\">ארץ ישראל</a></li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%98\" title=\"תרל&quot;ט\">תרל\"ט</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> קיבל לידיו את תעודת הפטור הרשמית מהצבא הרוסי</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A2\" title=\"תר&quot;ע\">תר\"ע</a> – הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A2%D7%95%D7%9F_%D7%91%D7%9F-%D7%A6%D7%99%D7%95%D7%9F_%D7%90%D7%99%D7%99%D7%96%D7%A0%D7%91%D7%9A\" title=\"שמעון בן-ציון אייזנבך\">שמעון בן-ציון אייזנבך</a>, מחשובי חסידי חב\"ד בשכונת מאה שערים ובית ישראל ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>. נהרג על קידוש השם מפגז ירדני ב<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A2%D7%A6%D7%9E%D7%90%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מלחמת העצמאות\">מלחמת העצמאות</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%90\" title=\"תרפ&quot;א\">תרפ\"א</a> – פרופסור <a href=\"/index.php/%D7%A8%D7%90%D7%95%D7%91%D7%9F_%D7%A4%D7%95%D7%99%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"ראובן פוירשטיין\">ראובן פוירשטיין</a> פסיכולוג ופדגוג ישראלי, וידיד חב\"ד. ייסד שיטה חינוכית בהוראה, והקים את מרכז פוירשטיין לקידום כושר הלמידה. שיטתו זכתה לספרים ומחקרים רבים, ולהתייחסויות מהרבי</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%9E%D7%9C%D7%9A_%D7%A6%D7%95%D7%95%D7%99%D7%91%D7%9C\" title=\"אלימלך צוויבל\">אלימלך צוויבל</a>, <a href=\"/index.php/%D7%97%D7%95%D7%96%D7%A8\" title=\"חוזר\">חוזר</a> ו<a href=\"/index.php/%D7%94%D7%A0%D7%97%D7%94\" title=\"הנחה\">מניח</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9E%D7%95%D7%A8%D7%99%D7%A1%D7%98%D7%95%D7%9F\" title=\"תומכי תמימים מוריסטון\">תומכי תמימים מוריסטון</a>, חבר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%A8%D7%91%D7%A0%D7%99_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ועד רבני ליובאוויטש\">ועד רבני ליובאוויטש</a>, <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9C%D7%94%D7%A4%D7%A6%D7%AA_%D7%A9%D7%99%D7%97%D7%95%D7%AA\" title=\"ועד להפצת שיחות\">ועד להפצת שיחות</a>, ו<a href=\"/index.php/%D7%9E%D7%9B%D7%95%D7%9F_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%9E%D7%91%D7%95%D7%90%D7%A8%D7%AA\" title=\"מכון חסידות מבוארת\">מכון חסידות מבוארת</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%96\" title=\"תשל&quot;ז\">תשל\"ז</a> – העיתונאי החב\"די הרב <a href=\"/index.php/%D7%9E%D7%AA%D7%99_%D7%98%D7%95%D7%9B%D7%A4%D7%9C%D7%93\" title=\"מתי טוכפלד\">מתי טוכפלד</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%90\" title=\"תרצ&quot;א\">תרצ\"א</a> – התמים <a href=\"/index.php/%D7%A9%D7%9E%D7%97%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%A8%D7%95%D7%9D\" title=\"שמחה זילברשטרום\">שמחה זילברשטרום</a>, מדריך ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%A1%D7%A4%D7%A8_%D7%9C%D7%9E%D7%9C%D7%90%D7%9B%D7%94\" class=\"mw-redirect\" title=\"בית הספר למלאכה\">בית הספר למלאכה</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> ש<a href=\"/index.php/%D7%A8%D7%A6%D7%97_%D7%99%D7%93_%D7%94%D7%97%D7%9E%D7%A9%D7%94\" class=\"mw-redirect\" title=\"רצח יד החמשה\">נרצח על ידי המחבלים</a></li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%96_%D7%91%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%93\" title=\"תרפ&quot;ד\">תרפ\"ד</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%91%D7%99%D7%97%D7%95%D7%91%D7%A1%D7%A7%D7%99\" title=\"חיים אליעזר ביחובסקי\">חיים אליעזר ביחובסקי</a> מ<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93-%D7%A7%D7%90%D7%A4%D7%95%D7%A1%D7%98\" class=\"mw-redirect\" title=\"חסידי חב&quot;ד-קאפוסט\">חסידי חב\"ד-קאפוסט</a> שעסק ב<a href=\"/index.php/%D7%94%D7%95%D7%A6%D7%90%D7%94_%D7%9C%D7%90%D7%95%D7%A8\" title=\"הוצאה לאור\">הוצאה לאור</a> של ספרי <a href=\"/index.php/%D7%A8%D7%91%D7%95%D7%AA%D7%99%D7%A0%D7%95_%D7%A0%D7%A9%D7%99%D7%90%D7%99%D7%A0%D7%95\" class=\"mw-redirect\" title=\"רבותינו נשיאינו\">רבותינו נשיאינו</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%97\" title=\"תרפ&quot;ח\">תרפ\"ח</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%9C%D7%95%D7%9D\" title=\"משה רוזנבלום\">משה רוזנבלום</a>, מזכיר ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"תומכי תמימים ליובאוויטש\">תומכי תמימים ליובאוויטש</a> עורך עיתון <a href=\"/index.php/%D7%94%D7%90%D7%97_(%D7%A2%D7%99%D7%AA%D7%95%D7%9F_%D7%99%D7%9C%D7%93%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"האח (עיתון ילדים)\">האח</a>, ומנהל ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%95%D7%A1%D7%98%D7%95%D7%91\" title=\"תומכי תמימים רוסטוב\">תומכי תמימים רוסטוב</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%91\" title=\"תש&quot;ב\">תש\"ב</a> – הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A1%D7%9C%D7%95%D7%A0%D7%99%D7%9D\" class=\"mw-redirect\" title=\"מנחם יוסף יהודה לייב סלונים\">מנחם יוסף יהודה לייב סלונים</a>, ממייסדי הקהילה החב\"דית ב<a href=\"/index.php/%D7%99%D7%A4%D7%95\" class=\"mw-redirect\" title=\"יפו\">יפו</a>, סוחר ואיש חסד</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%92\" title=\"תשמ&quot;ג\">תשמ\"ג</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A9%D7%9C%D7%95%D7%9D_%D7%A1%D7%92%D7%9C\" title=\"חיים שלום סגל\">חיים שלום סגל</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA\" title=\"בית כנסת\">בית הכנסת</a> חב\"ד בשכונת 'נחלאות' ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a></li>\n<li>תשמ\"ג – הרב <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%9F_%D7%93%D7%91_%D7%95%D7%95%D7%99%D7%9B%D7%A0%D7%99%D7%9F\" title=\"נחמן דב וויכנין\">נחמן דב וויכנין</a>, <a href=\"/index.php/%D7%A9%D7%95%D7%97%D7%98\" title=\"שוחט\">שוחט</a> ו<a href=\"/index.php/%D7%A9%D7%93%22%D7%A8\" class=\"mw-redirect\" title=\"שד&quot;ר\">שד\"ר</a> מחסידי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A4\" title=\"תש&quot;פ\">תש\"פ</a> – הרב <a href=\"/index.php/%D7%A2%D7%93%D7%99%D7%9F_%D7%90%D7%91%D7%9F_%D7%99%D7%A9%D7%A8%D7%90%D7%9C-%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%96%D7%9C%D7%A5\" class=\"mw-redirect\" title=\"עדין אבן ישראל-שטיינזלץ\">עדין אבן ישראל-שטיינזלץ</a>, מחבר ביאור התלמוד – <a href=\"/index.php/%D7%AA%D7%9C%D7%9E%D7%95%D7%93_%D7%A9%D7%98%D7%99%D7%99%D7%A0%D7%96%D7%9C%D7%A5\" title=\"תלמוד שטיינזלץ\">תלמוד שטיינזלץ</a></li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a> - הרב <a href=\"/index.php/%D7%96%D7%91%D7%95%D7%9C%D7%95%D7%9F_%D7%9E%D7%95%D7%A9%D7%99%D7%90%D7%A9%D7%95%D7%99%D7%9C%D7%99\" class=\"mw-redirect\" title=\"זבולון מושיאשוילי\">זבולון מושיאשוילי</a>, שחקן וקומיקאי שחזר בתשובה</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ז במנחם אב - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a> ביאר מה שמיחסים <a href=\"/index.php/%D7%90%D7%A9\" class=\"mw-redirect\" title=\"אש\">אש</a> ל<a href=\"/index.php/%D7%A4%D7%A0%D7%99%D7%9E%D7%99%D7%95%D7%AA_%D7%94%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פנימיות התורה\">פנימיות התורה</a>, לפי שהיא הנותנת <a href=\"/index.php/%D7%97%D7%99%D7%95%D7%AA\" class=\"mw-redirect\" title=\"חיות\">חיות</a> ב<a href=\"/index.php/%D7%92%D7%9C%D7%99%D7%90_%D7%A9%D7%91%D7%AA%D7%95%D7%A8%D7%94\" class=\"mw-redirect\" title=\"גליא שבתורה\">גליא שבתורה</a>: אז ער לערענט א <a href=\"/index.php/%D7%94%D7%9C%D7%9B%D7%94\" title=\"הלכה\">הלכה</a> און ווייס אז די זעלבע הלכה וועט ער לערנען נאך א מאה ועשרים שנה אין <a href=\"/index.php/%D7%92%D7%9F_%D7%A2%D7%93%D7%9F\" title=\"גן עדן\">גן עדן</a> גיט עס אריין א פייערעל (כשהוא לומד הלכה ויודע שאותה הלכה הוא ילמד לאחר מאה ועשרים שנה בגן עדן זה מכניס אש).\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש החמישי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">לשיטת ה<a href=\"/index.php/%D7%A8%D7%9E%D7%91%22%D7%9F\" title=\"רמב&quot;ן\">רמב\"ן</a></span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413224444\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.116 seconds\nReal time usage: 1.477 seconds\nPreprocessor visited node count: 469/1000000\nPost‐expand include size: 9030/2097152 bytes\nTemplate argument size: 864/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 782/5000000 bytes\nLua time usage: 0.080/7 seconds\nLua virtual size: 6156288/52428800 bytes\nLua es