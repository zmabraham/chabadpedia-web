    "pageid": 5876,
    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/a/af/%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99.jpg/250px-%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99.jpg\" decoding=\"async\" width=\"250\" height=\"166\" class=\"mw-file-element\" srcset=\"/images/a/af/%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99.jpg 1.5x\" /></a><figcaption>השליח הרב סלבטיצקי</figcaption></figure>\n<p><b>אנטוורפן</b> הינה העיר השניה בגודלה במדינת בלגיה, בה שוכנת הקהילה היהודית השנייה בגודלה בבלגיה (לאחר <a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%A1%D7%9C\" title=\"בריסל\">בריסל</a>), ואחת הגדולות, החשובות והותיקות באירופה. לפני <a href=\"/index.php/%D7%A9%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"שואה\">מלחמת העולם השנייה</a> מנתה הקהילה כ-55 אלף איש, וכיום היא מונה מעל 20 אלף, חלק ניכר מחברי הקהילה נמנים עם חברי הקהילה החרדית הוותיקה בעיר. הקהילה היא אחת מן הקהילות המאורגנות והוותיקות, שעדיין מתנהלת בסגנון \"שטעטל\" עתיק. הנהלת הקהילה נבחרת בבחירות כלליות. \n</p><p>רבים מן היהודים מתגוררים בשכונה גדולה סמוך למרכז העיר, בה ניתן לראות שלטים, חנויות וכרזות ב<a href=\"/index.php/%D7%A2%D7%91%D7%A8%D7%99%D7%AA\" title=\"עברית\">עברית</a> וב<a href=\"/index.php/%D7%99%D7%99%D7%93%D7%99%D7%A9\" title=\"יידיש\">יידיש</a>. חלק גדול מיהודי העיר עוסקים במסחר ובעיבוד יהלומים. בעיר בתי עסק רבים העוסקים בתעשיית היהלומים.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.9E.D7.95.D7.A1.D7.93.D7.95.D7.AA_.D7.97.D7.91.22.D7.93_.D7.91.D7.A2.D7.99.D7.A8\"></span><span class=\"mw-headline\" id=\"מוסדות_חב&quot;ד_בעיר\">מוסדות חב\"ד בעיר</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;מוסדות חב&quot;ד בעיר&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: מוסדות חב&quot;ד בעיר\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בעיר פועל <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%9B%D7%A0%D7%A1%D7%AA\" title=\"בית כנסת\">בית כנסת</a> חב\"ד גדול ומפואר שנוסד על ידי הרב יעקב צבי הולצמן שנשלח לעיר על ידי הרבי בסוף שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%96\" title=\"תשכ&quot;ז\">תשכ\"ז</a> ועבר למקום יותר גדול ב<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> שמנוהל כיום על ידי ה<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> הנודע ה<a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> <a href=\"/index.php/%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99\" title=\"שבתי סלבטיצקי\">שבתאי סלבטיצקי</a> בו מתקיימים תפילות כל ימי השבוע, שיעורים והתוועדויות רבים.\n</p><p>במקביל אליו פועלים במבנה <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"תומכי תמימים אנטוורפן\">ישיבת חב\"ד</a>, מכון סמיכה - חב\"ד, וחנות יודאיקה חב\"ד. \n</p><p>במכון ה<a href=\"/index.php/%D7%A1%D7%9E%D7%99%D7%9B%D7%94\" class=\"mw-redirect\" title=\"סמיכה\">סמיכה</a> הפועל במקום, מוסמכים מדי שנה כ-15 בחורים העוברים מסלול לימודים של דיינות והוראה, שבתור ראש הישיבה וראש המכון משמש הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%98%D7%91%D7%A8%D7%93%D7%95%D7%91%D7%99%D7%A5%27\" title=\"מנחם מענדל טברדוביץ&#39;\">מנחם מענדל טברדוביץ'</a>, חתנו של שליח הרבי בעיר, הרב שבתאי סלבטיצקי.\n</p><p>בשנת תשע\"ה נפתחה במקום <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F\" title=\"תומכי תמימים אנטוורפן\">ישיבה קטנה לילדי השלוחים מאירופה</a> על ידי הרב מנחם מענדל טבדרוביץ. נכון לשנת תשע\"ז מונה הישיבה כ-50 תמימים בצוות הישיבה חברים הרבנים יעקב גוראריה והרב שבתאי סלבטיצקי.\n</p>\n<h2><span id=\".D7.94.D7.A9.D7.9C.D7.95.D7.97.D7.99.D7.9D_.D7.94.D7.9E.D7.A7.D7.95.D7.9E.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"השלוחים_המקומיים\">השלוחים המקומיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;השלוחים המקומיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: השלוחים המקומיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>השליח הראשי בבלגיה הוא ה<a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> <a href=\"/index.php/%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99\" title=\"שבתי סלבטיצקי\">שבתי סלבטיצקי</a> שנשלח על ידי הרבי בסוף שנות הלמ\"דים.\nלצידו של הרב סלביטצקי, פועלים בעיר הרב מענדי גורארי' והרב <a href=\"/index.php?title=%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יוסף יצחק סלבטיצקי (הדף אינו קיים)\">יוסף יצחק סלבטיצקי</a> המשמש כיד ימינו של אביו. בפרברי העיר פועל הרב מנחם הרץ.\n</p><p>בשנים שלפני זה פעלו שם הרב סעדיה ליברוב שנשלח לעיר על ידי הרבי בשנת תשי\"ח שנקרא על ידי הרבי הבא-כח לבלגיא ועסק רבות בהפצת המעיינות והשאיר רושם עמוק עד היום.\n</p><p>בסוף שנת תשכ\"ז נשלח הרב יעקב צבי הולצמן שי' (משב\"ק בשנים תשי\"ד-תש\"כ) על ידי הרבי לאנטוורפן כשהרבי אומר לו שהוא יעסוק עם הגברים ולאשתו אמר שתעסוק עם הנשים.\n</p><p>כמה שבועות אחרי הגיעו לעיר פתח ביהכ\"נ חב\"ד הראשון בעיר ובשנות הלמד פתח קעמפ. כן הדפיס את ה<a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"תניא\">תניא</a> ברחבי בלגיא.\n</p>\n<h2><span id=\".D7.A8.D7.91.D7.A0.D7.99.D7.9D_.D7.91.D7.90.D7.A0.D7.98.D7.95.D7.95.D7.A8.D7.A4.D7.9F\"></span><span class=\"mw-headline\" id=\"רבנים_באנטוורפן\">רבנים באנטוורפן</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;רבנים באנטוורפן&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: רבנים באנטוורפן\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>במשך שנים רבות כיהן הגאון הרב הלל מדליה (בנו של הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%A8%D7%99%D7%94%D7%95_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%9E%D7%93%D7%9C%D7%99%D7%94\" title=\"שמריהו יהודה לייב מדליה\">שמריהו יהודה לייב מדליה</a>) כרב קהילת שומרי הדת באנטוורפן. הרב מדליה היה מקורב מאד לחב\"ד, ואף נכנס כמה פעמים ל<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> אצל הרבי. כמה שנים לאחר פטירת הרב מדליה בשנת תש\"מ נקרא לכהן במקומו הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9E%D7%A9%D7%94_%D7%9C%D7%99%D7%91%D7%A8%D7%9E%D7%9F\" title=\"דוד משה ליברמן\">דוד משה ליברמן</a> שכיהן שם ברבנותו עד לפטירתו בשנת תשפ\"ב (חתנו של הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"יהודה חיטריק\">יהודה חיטריק</a>).\n</p>\n<h2><span id=\".D7.97.D7.A1.D7.99.D7.93.D7.99.D7.9D_.D7.91.D7.90.D7.A0.D7.98.D7.95.D7.95.D7.A8.D7.A4.D7.9F\"></span><span class=\"mw-headline\" id=\"חסידים_באנטוורפן\">חסידים באנטוורפן</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;חסידים באנטוורפן&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%D7%A0%D7%98%D7%95%D7%95%D7%A8%D7%A4%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: חסידים באנטוורפן\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%97%D7%99%D7%98%D7%A8%D7%99%D7%A7\" title=\"יהודה חיטריק\">יהודה חיטריק</a> - פעל שם משנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> עד לשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a>, שאז עבר ל<a href=\"/index.php/%D7%9E%D7%95%D7%A0%D7%98%D7%A8%D7%99%D7%90%D7%95%D7%9C\" title=\"מונטריאול\">מונטריאול</a> שבקנדה</li>\n<li>הרב <a href=\"/index.php/%D7%A1%D7%A2%D7%93%D7%99%D7%94_%D7%9C%D7%99%D7%91%D7%A8%D7%95%D7%91\" title=\"סעדיה ליברוב\">סעדיה ליברוב</a> - לאחר שעזב את <a href=\"/index.php/%D7%9E%D7%A8%D7%95%D7%A7%D7%95\" title=\"מרוקו\">מרוקו</a> התיישב על פי הוראת <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> באנטוורפן שם פעל עד לפטירתו בחודש <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%93\" class=\"mw-redirect\" title=\"תשמ&quot;ד\">תשמ\"ד</a></li>\n<li>הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%9E%D7%A9%D7%94_%D7%99%D7%95%D7%A0%D7%99%D7%A7\" title=\"דוד אליהו משה יוניק\">דוד אליהו משה יוניק</a> (אחיו של הרב <a href=\"/index.php/%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%99%D7%95%D7%A0%D7%99%D7%A7\" title=\"דובער יוניק\">דובער יוניק</a>) - שימש כ<a href=\"/index.php/%D7%A9%D7%95%22%D7%91\" class=\"mw-redirect\" title=\"שו&quot;ב\">שו\"ב</a> ומוהל עד לפטירותו ב<a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%93\" title=\"תשנ&quot;ד\">תשנ\"ד</a></li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A6%D7%91%D7%99_%D7%94%D7%95%D7%9C%D7%A6%D7%9E%D7%9F\" title=\"יעקב צבי הולצמן\">יעקב צבי הולצמן</a> שנשלח על ידי הרבי בשלהי תשכ\"ז והיה שם מעל 30 שנה. בסוף ימיו גר ב<a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a></li>\n<li>הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%90%D7%A8%D7%99%D7%94_%D7%96%D7%99%D7%9C%D7%91%D7%A8%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"חיים אריה זילברשטיין\">חיים אריה זילברשטיין</a> - מאוחר יותר עבר ל<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, נפטר ב<a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%93\" title=\"תשס&quot;ד\">תשס\"ד</a></li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A7%D7%A8%D7%90%D7%95%D7%A1\" title=\"שמואל קראוס\">שמואל קראוס</a> - גר באנטוורפן במשך כמה שנים, כיום משמש כמזכיר ה<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%93%D7%99%D7%9F_%D7%A6%D7%93%D7%A7_%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"בית דין צדק קראון הייטס\">בית דין צדק</a> בשכונת <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a></li>\n<li>הרב <a href=\"/index.php/%D7%A9%D7%91%D7%AA%D7%99_%D7%A1%D7%9C%D7%91%D7%98%D7%99%D7%A6%D7%A7%D7%99\" title=\"שבתי סלבטיצקי\">שבתי סלבטיצקי</a> - השליח הראשי בעיר</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A\" class=\"mw-redirect\" title=\"יעקב פרידריך\">יעקב פרידריך</a>.- מוותיקי ומנכבדי קהילת חב\"ד באנטוורפן</li>\n<li>הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A1%D7%A4%D7%99%D7%98%D7%A6%D7%A7%D7%99\" title=\"יעקב ספיטצקי\">יעקב ספיטצקי</a>. - שליח בבלגיה ליותר משלושים שנה. כעת גר בירושלים ופועל כשליח לסטודנטים מחו\"ל</li>\n<li>הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%A2%D7%A7%D7%95%D7%91%D7%95%D7%91%D7%99%D7%A5%27\" title=\"נחום אברהם יעקובוביץ&#39;\">נחום אברהם יעקובוביץ'</a> - מוותיקי ומנכבדי קהילת חב\"ד באנטוורפן</li></ul>\n<p><br />\n</p>\n<table class=\"mw-collapsible autocollapse\" style=\"border: 1px #aaaaaa solid; background-color: #f9f9f9; text-align: center; clear: both; width: 75%; margin: 0.5em auto;\" cellspacing=\"3\">\n<tbody><tr>\n<th style=\"background-color:#b0c4de; background:#b0c4de; padding-top: 0.1em; padding-bottom: 0.1em; text-align: center; color: black; font-weight: bold; font-size: 100%\">ערים מרכזיות ב<a href=\"/index.php/%D7%90%D7%99%D7%A8%D7%95%D7%A4%D7%94\" title=\"אירופה\">אירופה</a>\n</th></tr>\n<tr>\n<td style=\"padding-top: 3px; padding-bottom: 3px; background-color: #f9f9f9; font-size: 95%\">\n<table style=\"width: 98%; background-color: transparent; margin: auto; padding: 0; text-align: center;\" cellpadding=\"0\" cellspacing=\"0\">\n<tbody><tr>\n<td><a href=\"/index.php/%D7%A4%D7%A8%D7%99%D7%96\" title=\"פריז\">פריז</a> · <a href=\"/index.php/%D7%A7%D7%99%D7%99%D7%91\" title=\"קייב\">קייב</a> · <a href=\"/index.php?title=%D7%A4%D7%A8%D7%90%D7%92&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"פראג (הדף אינו קיים)\">פראג</a> · <a href=\"/index.php/%D7%90%D7%AA%D7%95%D7%A0%D7%94\" title=\"אתונה\">אתונה</a> · <a href=\"/index.php/%D7%9C%D7%95%D7%A0%D7%93%D7%95%D7%9F\" title=\"לונדון\">לונדון</a> · <a class=\"mw-selflink selflink\">אנטוורפן</a> · <a href=\"/index.php/%D7%A8%D7%95%D7%9E%D7%90\" title=\"רומא\">רומא</a> · <a href=\"/index.php/%D7%A8%D7%99%D7%92%D7%94\" title=\"ריגה\">ריגה</a> · <a href=\"/index.php/%D7%95%D7%A8%D7%A9%D7%94\" title=\"ורשה\">ורשה</a> · <a href=\"/index.php/%D7%91%D7%A8%D7%9C%D7%99%D7%9F\" title=\"ברלין\">ברלין</a> · <a href=\"/index.php/%D7%95%D7%99%D7%A0%D7%94\" class=\"mw-redirect\" title=\"וינה\">וינה</a> · <a href=\"/index.php?title=%D7%91%D7%95%D7%93%D7%A4%D7%A1%D7%98&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"בודפסט (הדף אינו קיים)\">בודפסט</a>\n</td></tr></tbody></table>\n</td></tr>\n<tr>\n<td style=\"background-color: #F2F3F4; font-size: 95%;\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%A8%D7%95%D7%A1%D7%99%D7%94\" title=\"תבנית:עיירות ברוסיה\">עיירות ברוסיה</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%90%D7%95%D7%A7%D7%A8%D7%90%D7%99%D7%A0%D7%94\" class=\"mw-redirect\" title=\"תבנית:עיירות באוקראינה\">עיירות באוקראינה</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%9C%D7%99%D7%98%D7%90\" title=\"תבנית:עיירות בליטא\">עיירות בליטא</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%9C%D7%98%D7%91%D7%99%D7%94\" title=\"תבנית:עיירות בלטביה\">עיירות בלטביה</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%A8%D7%99%D7%9D_%D7%91%D7%A4%D7%95%D7%9C%D7%99%D7%9F\" title=\"תבנית:ערים בפולין\">ערים בפולין</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%99%D7%99%D7%A8%D7%95%D7%AA_%D7%91%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"תבנית:עיירות בצרפת\">עיירות בצרפת</a> • <a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%A2%D7%A8%D7%99%D7%9D_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA\" title=\"תבנית:ערים בארצות הברית\">ערים בארצות הברית</a>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413183614\nCache expiry: 86400\nReduced expiry: false\nComplicat