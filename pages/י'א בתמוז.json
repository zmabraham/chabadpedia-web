הוא היום האחד עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>שמ\"ה – רבי יצחק חיות, אב\"ד פראג. מחבר הספרים 'פחד יצחק', 'שיח יצחק', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A6%22%D7%90\" title=\"תקצ&quot;א\">תקצ\"א</a> – רבי צבי הירש סאפרין מזידיטשויב. מחבר ספר 'עטרת צבי', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> – רבי <a href=\"/index.php?title=%D7%90%D7%9C%D7%97%D7%A0%D7%9F_%D7%91%D7%95%D7%A0%D7%9D_%D7%95%D7%A1%D7%A8%D7%9E%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אלחנן בונם וסרמן (הדף אינו קיים)\">אלחנן בונם וסרמן</a>, ראש ישיבת אוהל תורה ברנוביץ'. מחבר ספר 'קובץ שיעורים', נרצח על <a href=\"/index.php/%D7%A7%D7%99%D7%93%D7%95%D7%A9_%D7%94%D7%A9%D7%9D\" title=\"קידוש השם\">קידוש השם</a> בידי הנאצים ימ\"ש.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%90\" title=\"תרנ&quot;א\">תרנ\"א</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> החל להניח <a href=\"/index.php/%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" class=\"mw-redirect\" title=\"תפילין\">תפילין</a>, בהיותו בן 11 שנים<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>..</li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A2%22%D7%97\" title=\"תרע&quot;ח\">תרע\"ח</a> – הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A9%D7%98%D7%A8%D7%9F\" title=\"חיים שטרן\">חיים שטרן</a>, רב <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA\" class=\"mw-redirect\" title=\"בית הכנסת\">בית הכנסת</a> חב\"ד בשכונת הר נוף ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>, וחבר וועדת הבנין של ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%96\" title=\"תרצ&quot;ז\">תרצ\"ז</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%91%D7%A2%D7%A8_%D7%92%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" title=\"שלום בער גנזבורג\">שלום בער גנזבורג</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%9E%D7%A9_%D7%91%D7%A7%D7%95%D7%93%D7%A9\" title=\"משמש בקודש\">משמש בקודש</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA%D7%95_%D7%94%D7%A4%D7%A8%D7%98%D7%99_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ביתו הפרטי של הרבי\">ביתו הפרטי</a> של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"תשכ&quot;ג\">תשכ\"ג</a> – הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%91%D7%9C%D7%95%D7%9E%D7%A0%D7%A4%D7%9C%D7%93\" title=\"שניאור זלמן בלומנפלד\">שניאור זלמן בלומענפעלד</a>, שליח הרבי למדינת <a href=\"/index.php?title=%D7%A4%D7%A8%D7%95&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"פרו (הדף אינו קיים)\">פרו</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%91\" title=\"תרפ&quot;ב\">תרפ\"ב</a> – הרב <a href=\"/index.php/%D7%92%D7%93%D7%9C%D7%99%D7%94_%D7%97%D7%A8%D7%99%D7%98%D7%95%D7%A0%D7%95%D7%91\" class=\"mw-redirect\" title=\"גדליה חריטונוב\">גדליה חריטונוב</a> (קארף), מחשובי חסידי חב\"ד בניקולייב.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%95\" title=\"תרצ&quot;ו\">תרצ\"ו</a> – הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A1%D7%9C%D7%95%D7%A0%D7%99%D7%9D\" title=\"שניאור זלמן סלונים\">שניאור זלמן סלונים</a>, נין ל<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%90\" title=\"תש&quot;א\">תש\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A6%D7%99%D7%A8%D7%9C%D7%A1%D7%95%D7%9F\" title=\"יהודה לייב צירלסון\">יהודה לייב צירלסון</a>, <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסיד</a> <a href=\"/index.php/%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"חב&quot;ד\">חב\"ד</a> ו<a href=\"/index.php/%D7%90%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"אב&quot;ד\">אב\"ד</a> קישנב, נרצח.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%97\" title=\"תש&quot;ח\">תש\"ח</a> – זלמן דוד לנדא, נינו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a> (נכדם של הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%95%D7%97%D7%99%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%90_%D7%94%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" class=\"mw-redirect\" title=\"משה וחיה מושקא הורנשטיין\">משה וחיה מושקא הורנשטיין</a>), נהרג ב<a href=\"/index.php/%D7%9E%D7%9C%D7%97%D7%9E%D7%AA_%D7%94%D7%A9%D7%97%D7%A8%D7%95%D7%A8\" title=\"מלחמת השחרור\">מלחמת השחרור</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%A8%D7%92\" title=\"שלמה רוזנברג\">שלמה רוזנברג</a>, מייסד ומנהל ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"תומכי תמימים בני ברק\">תומכי תמימים בני ברק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%97\" title=\"תשע&quot;ח\">תשע\"ח</a> - הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%92%D7%A8%D7%91%D7%A8%D7%A6%27%D7%99%D7%A7\" title=\"שלמה יהודה גרברצ&#39;יק\">שלמה יהודה גרברצ'יק</a> חבר בוועדת החינוך של כפר חב\"ד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%A7%D7%90%D7%A8%D7%A3\" title=\"אברהם קארף\">אברהם קארף</a>, שליח הרבי במשך ששים וארבע שנים למדינת <a href=\"/index.php/%D7%A4%D7%9C%D7%95%D7%A8%D7%99%D7%93%D7%94\" title=\"פלורידה\">פלורידה</a>, מהשלוחים שהרבי שלח בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%96\" title=\"תשט&quot;ז\">תשט\"ז</a> ל<a href=\"/index.php/%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"ארץ הקודש\">ארץ הקודש</a>.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"א בתמוז - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ב<a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"תניא\">תניא</a> דפוס זאלקווי שנת <a href=\"/index.php/%D7%AA%D7%A7%D7%9E%22%D7%91\" title=\"תקמ&quot;ב\">מבש\"ר</a> טו\"ב, נדפסה <a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%AA_%D7%94%D7%AA%D7%A9%D7%95%D7%91%D7%94\" title=\"אגרת התשובה\">אגרת התשובה</a> מהדורא קמא, ולא נחלקה לפרקים, גם יש כמה שנוים בתוכן האגרת.\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">כיון שבאותה שנה י\"ב תמוז חל בשבת, הוקדמה הנחת התפילין ליום שישי. ראו בהרחבה במדור 'רגעים בליובאוויטש', שבועון בית משיח 1267 עמוד 38.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260413224942\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.057 seconds\nReal time usage: 0.100 seconds\nPreprocessor visited node count: 129/1000000\nPost‐expand include size: 5555/2097152 bytes\nTemplate argument size: 783/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 151/5000000 bytes\nLua time usage: 0.010/7 seconds\nLua virtual s