      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg\" class=\"mw-file-description\"><img src=\"/images/thumb/6/68/%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg/220px-%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/6/68/%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg/330px-%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg 1.5x, /images/thumb/6/68/%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg/440px-%D7%94%D7%A8%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%AA%D7%A9%D7%A4%27%27%D7%93.jpeg 2x\" /></a><figcaption>הרב וייסגלס נואם בארוע בישיבת תומכי תמימים ראשון לציון (תשפ\"ד)</figcaption></figure>\n<figure class=\"mw-default-size mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%A8%D7%90%D7%A9%D7%95%D7%9F.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f3/%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%A8%D7%90%D7%A9%D7%95%D7%9F.jpg/220px-%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%A8%D7%90%D7%A9%D7%95%D7%9F.jpg\" decoding=\"async\" width=\"220\" height=\"147\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f3/%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%A8%D7%90%D7%A9%D7%95%D7%9F.jpg/330px-%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%A8%D7%90%D7%A9%D7%95%D7%9F.jpg 1.5x, /images/thumb/f/f3/%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%A8%D7%90%D7%A9%D7%95%D7%9F.jpg/440px-%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1_%D7%A8%D7%90%D7%A9%D7%95%D7%9F.jpg 2x\" /></a><figcaption>הרב וייסגלס נואם בארוע התוועדות של <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"האגודה למען הגאולה האמיתית והשלימה\">האגודה למען הגאולה האמיתית והשלימה</a> (תשפ\"ג)</figcaption></figure>\n<p>הרב <b>יהודה ליב וייסגלס</b> (נולד ב<a href=\"/index.php/%D7%9B%22%D7%91_%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"כ&quot;ב אדר\">כ\"ב אדר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a>, 11 במרץ 1988) הוא מנהל תוכניות הלימוד של סדרי <a href=\"/index.php/%D7%92%D7%9E%D7%A8%D7%90\" class=\"mw-redirect\" title=\"גמרא\">גמרא</a> למיגרס, <a href=\"/index.php/%D7%A9%D7%95%D7%9C%D7%97%D7%9F_%D7%A2%D7%A8%D7%95%D7%9A_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F)\" class=\"mw-redirect\" title=\"שולחן ערוך (אדמו&quot;ר הזקן)\">שולחן ערוך</a>, ו<a href=\"/index.php/%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%95%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"גאולה ומשיח\">גאולה ומשיח</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"תומכי תמימים ראשון לציון (גדולה)\">תומכי תמימים ראשון לציון</a>, <a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"מורה צדק\">מורה צדק</a> ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" class=\"mw-redirect\" title=\"בית הכנסת המרכזי (כפר חב&quot;ד)\">בית הכנסת המרכזי</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a> ועורך תורני. לשעבר <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> בישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A2%D7%9E%D7%A0%D7%95%D7%90%D7%9C\" title=\"תומכי תמימים עמנואל\">תומכי תמימים עמנואל</a> ו<a href=\"/index.php/%D7%93%D7%A8%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"דרכי תמימים\">דרכי תמימים</a>, ור\"מ, <a href=\"/index.php/%D7%A0%D7%95%D7%A9%D7%90_%D7%95%D7%A0%D7%95%D7%AA%D7%9F\" title=\"נושא ונותן\">נושא ונותן</a>, ו<a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים ראשון לציון (קטנה)\">תומכי תמימים ראשון לציון</a>. \n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"תולדות_חיים\">תולדות חיים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;תולדות חיים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: תולדות חיים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>נולד ב<a href=\"/index.php/%D7%A7%D7%A8%D7%99%D7%AA_%D7%90%D7%AA%D7%90\" class=\"mw-redirect\" title=\"קרית אתא\">קרית אתא</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%97\" title=\"תשמ&quot;ח\">תשמ\"ח</a> לרב <a href=\"/index.php?title=%D7%99%D7%A6%D7%97%D7%A7_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יצחק וייסגלס (הדף אינו קיים)\">יצחק וייסגלס</a> אחראי תיפעולי בעמותת ארוחה חמה ומנהל מטבח ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%AA_%D7%90%D7%AA%D7%90\" class=\"mw-redirect\" title=\"תומכי תמימים קרית אתא\">תומכי תמימים קרית אתא</a>.\n</p><p>בבחורתו למד בישיבות <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9C%D7%95%D7%93\" title=\"תומכי תמימים לוד\">תומכי תמימים לוד</a>, <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%A7%D7%A8%D7%99%D7%95%D7%AA\" title=\"תומכי תמימים הקריות\">תומכי תמימים הקריות</a>, וב<a href=\"/index.php/%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%A1%D7%99%D7%93%D7%99_%D7%97%D7%91%22%D7%93_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9_%D7%A6%D7%A4%D7%AA_(%D7%92%D7%93%D7%95%D7%9C%D7%94)\" title=\"ישיבת חסידי חב&quot;ד ליובאוויטש צפת (גדולה)\">ישיבת חסידי חב\"ד ליובאוויטש צפת</a>.\n</p><p>לקראת שנת הלימודים <a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%98\" title=\"תשס&quot;ט\">תשס\"ט</a> נסע ללמוד בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99%D7%AA\" class=\"mw-redirect\" title=\"תומכי תמימים המרכזית\">תומכי תמימים המרכזית</a> בחצר הרבי ב-<a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a> במסגרת שנת ה'<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>'.\n</p><p>לאחר שנת הקבוצה שימש כשליח בישיבת חב\"ד אחוזה חיפה<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ב<a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%90\" title=\"תשע&quot;א\">תשע\"א</a> התחתן עם שפרה ביתו של הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A4%D7%99%D7%99%D7%91%D7%99%D7%A9_%D7%92%D7%99%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" class=\"mw-redirect\" title=\"יצחק פייביש גינזבורג\">יצחק גינזבורג</a><sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> וקבע את מגוריו בכפר חב\"ד בסמיכות למקום מגורי חמיו.\n</p><p>שימש כר\"מ בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A2%D7%9E%D7%A0%D7%95%D7%90%D7%9C\" title=\"תומכי תמימים עמנואל\">תומכי תמימים עמנואל</a><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>. לאחר מכן שימש תקופת קצרה כר\"מ בישיבת <a href=\"/index.php/%D7%93%D7%A8%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"דרכי תמימים\">דרכי תמימים</a>, בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> התמנה כר\"מ ומשיב בסדרי נגלה לעיון ולמיגרס ב<a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F_(%D7%A7%D7%98%D7%A0%D7%94)\" title=\"תומכי תמימים ראשון לציון (קטנה)\">ישיבה קטנה תומכי תמימים ראשון לציון</a>, בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> התמנה  כמשגיח בסדרי חסידות ערב.\n</p><p>לצד עבודתו כר\"מ משמש כעורך תורני, הוא כותב בקביעות את המדורים פנימיות המנהגים ודברי ימי החסידות בעלון <a href=\"/index.php/%D7%A4%D7%A0%D7%99%D7%9E%D7%99%D7%95%D7%AA_(%D7%92%D7%99%D7%9C%D7%99%D7%95%D7%9F)\" title=\"פנימיות (גיליון)\">פנימיות</a>, בנוסף משתתף במיזמי כתיבה שונים<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>, בין היתר גם בעבור <a href=\"/index.php/%D7%94%D7%95%D7%A6%D7%90%D7%AA_%D7%9E%D7%A2%D7%99%D7%99%D7%A0%D7%95%D7%AA%D7%99%D7%9A\" title=\"הוצאת מעיינותיך\">הוצאת מעיינותיך</a> של הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A9%D7%99%D7%9C%D7%AA\" title=\"משה שילת\">משה שילת</a>. \n</p><p>משמש כ<a href=\"/index.php/%D7%9E%D7%95%D7%A8%D7%94_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"מורה צדק\">מורה צדק</a> <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%94%D7%9B%D7%A0%D7%A1%D7%AA_%D7%94%D7%9E%D7%A8%D7%9B%D7%96%D7%99_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" class=\"mw-redirect\" title=\"בית הכנסת המרכזי (כפר חב&quot;ד)\">בית הכנסת המרכזי</a> בכפר חב\"ד, בנוסף מעביר בו שיעורי תורה קבועים וכן מתוועד לעיתים קרובות ביומא דפגרא. לעיתים מוזמן למסור שיעורים ולהרצות בפורמים קהילתיים שונים<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> החלו להתפרסם פרקים מתוך ספר בעריכתו של שיעורי חמיו הרב גינזבורג המבאר את תורתו של רבי <a href=\"/index.php/%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"לוי יצחק שניאורסון\">לוי יצחק שניאורסון</a>, אביו של הרבי, על <a href=\"/index.php/%D7%A1%D7%A4%D7%A8_%D7%94%D7%AA%D7%A0%D7%99%D7%90\" title=\"ספר התניא\">ספר התניא</a>.\n</p><p>החל מ<a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%94\" title=\"תשפ&quot;ה\">תשפ\"ה</a> כותב את מדור 'מגלים את הגאולה' בעלון <a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%AA_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"שיחת הגאולה\">שיחת הגאולה</a><sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>לקראת שנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a>, עם סגירתה של הישיבה קטנה תומכי תמימים ראשון לציון, עבר לשמש כמנהל תוכניות הלימוד של סדרי גמרא למיגרס, שולחן ערוך (אדמו\"ר הזקן), וגאולה ומשיח בישיבה הגדולה תומכי תמימים ראשון לציון<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.9B.D7.95.D7.AA.D7.A8.D7.99.D7.9D_.D7.91.D7.A2.D7.A8.D7.99.D7.9B.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"כותרים_בעריכתו\">כותרים בעריכתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;כותרים בעריכתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: כותרים בעריכתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>נשמתא דאורייתא לש\"ס</b> (עורך שותף) (ג' כרכים), ביאורי תורת החסידות לתלמוד בבלי. הוצאת <a href=\"/index.php/%D7%9E%D7%A2%D7%99%D7%99%D7%A0%D7%95%D7%AA%D7%99%D7%9A\" class=\"mw-redirect\" title=\"מעיינותיך\">מעיינותיך</a>, תשפ\"ג - תשפ\"ד<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>.</li>\n<li><b>המאורות הגדולים</b> (חבר בצוות העריכה)<sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\"><span class=\"cite-bracket\">&#91;</span>9<span class=\"cite-bracket\">&#93;</span></a></sup>.</li></ul>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"משפחתו\">משפחתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;משפחתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: משפחתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>אחיו, הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%A7%D7%99%D7%9D_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1\" title=\"אליקים וייסגלס\">אליקים וייסגלס</a> מאנ\"ש ב<a href=\"/index.php/%D7%9E%D7%92%D7%93%D7%9C_%D7%94%D7%A2%D7%9E%D7%A7\" title=\"מגדל העמק\">מגדל העמק</a>.</li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%99%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" title=\"חיים יוסף גינזבורג\">חיים יוסף גינזבורג</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%A9%D7%99_%D7%94%D7%A8%D7%9E%D7%AA%D7%99\" title=\"שי הרמתי\">שי הרמתי</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F_(%D7%A4%D7%AA%D7%97_%D7%AA%D7%A7%D7%95%D7%95%D7%94)\" title=\"מנחם מענדל פרידמן (פתח תקווה)\">מנחם מענדל פרידמן (פתח תקווה)</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A0%D7%97%D7%A9%D7%95%D7%9F\" title=\"מנחם מענדל נחשון\">מנחם מענדל נחשון</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%94%D7%A0%D7%93%D7%9C\" title=\"מנחם מענדל הנדל\">מנחם מענדל הנדל</a></li>\n<li>גיסו, הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%91%D7%A8%D7%95%D7%9A_%D7%91%D7%9C%D7%95%D7%9A\" title=\"אריה ברוך בלוך\">אריה ברוך בלוך</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%91_%D7%95%D7%99%D7%99%D7%A1%D7%92%D7%9C%D7%A1&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>תגית: <a rel=\"nofollow\" class=\"external text\" href=\"https://www.hageula.com/authors/98.htm\"><b>הרב יהודה ויסגלס</b></a> מאמריו של הרב ויסגלס ב<a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%AA_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94\" title=\"שיחת הגאולה\">שיחת הגאולה</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר הגאולה\"><img alt=\"קישור לאתר הגאולה\" src=\"/images/thumb/b/b3/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_%D7%90%D7%AA%D7%A8_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%97%D7%93%D7%A9.jpg/50px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_%D7%90%D7%AA%D7%A8_%D7%94%D7%92%D7%90%D7%95%D7