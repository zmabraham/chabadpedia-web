- תשנ&quot;ג\">בורא ניב שפתיים תשמ\"ח</a>  <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%97%D7%95%D7%93%D7%A9_%D7%94%D7%96%D7%94_%D7%AA%D7%A9%D7%9E%22%D7%96\" title=\"החודש הזה תשמ&quot;ז\">החודש הזה תשמ\"ז</a>  <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%90%D7%A0%D7%9B%D7%99_%D7%94%27_%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%9A_%D7%AA%D7%A9%D7%9E%22%D7%98\" title=\"אנכי ה&#39; אלוקיך תשמ&quot;ט\">אנכי ה' אלוקיך תשמ\"ט</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%95%D7%99%D7%94%D7%99_%D7%97%D7%99%D7%99_%D7%A9%D7%A8%D7%94_%D7%AA%D7%A0%D7%A9%E2%80%9D%D7%90\" class=\"mw-redirect\" title=\"ויהי חיי שרה תנש”א\">ויהי חיי שרה תנש”א</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9E%D7%A8%D7%92%D7%9C%D7%90_%D7%91%D7%A4%D7%95%D7%9E%D7%99%D7%94_%D7%93%D7%A8%D7%91%D7%90_(%D7%9E%D7%90%D7%9E%D7%A8_%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA)\" class=\"mw-redirect\" title=\"מרגלא בפומיה דרבא (מאמר חסידות)\">מרגלא בפומיה דרבא תשמ\"ו</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #33cccc;\"><font size=\"2\"><a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשכים</a></font>\n</th></tr>\n<tr>\n<td><a class=\"mw-selflink selflink\">המשך מים רבים תרל\"ו</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%94%D7%97%D7%A8%D7%99%D7%9D\" title=\"המשך והחרים\">המשך והחרים</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96\" title=\"המשך וככה תרל&quot;ז\">המשך וככה תרל\"ז</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%A9%D7%9E%D7%97_%D7%AA%D7%A9%D7%9E%D7%97_%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"המשך שמח תשמח תרנ&quot;ז\">המשך שמח תשמח תרנ\"ז</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%A8%D7%A0%22%D7%98\" class=\"mw-redirect\" title=\"המשך רנ&quot;ט\">המשך רנ\"ט</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%99%D7%95%D7%9D_%D7%98%D7%95%D7%91_%D7%A9%D7%9C_%D7%A8%D7%90%D7%A9_%D7%94%D7%A9%D7%A0%D7%94_%D7%AA%D7%A8%D7%A1%22%D7%95\" title=\"המשך יום טוב של ראש השנה תרס&quot;ו\">המשך תרס\"ו</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%A9%D7%A2%D7%94_%D7%A9%D7%94%D7%A7%D7%93%D7%99%D7%9E%D7%95_%D7%AA%D7%A2%D7%A8%22%D7%91\" title=\"בשעה שהקדימו תער&quot;ב\">המשך תער\"ב</a> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%AA%D7%A9%D7%A8%D7%99_%D7%AA%D7%A9%D7%9B%22%D7%92\" title=\"המשך תשרי תשכ&quot;ג\">המשך תשרי תשכ\"ג</a>\n</td></tr>\n<tr style=\"background:lightblue;\">\n<th style=\"background-color: #33cccc;\"><font size=\"2\">מושגים</font>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A0%D7%99%D7%92%D7%95%D7%9F_%D7%94%D7%9B%D7%A0%D7%94_%D7%9C%D7%9E%D7%90%D7%9E%D7%A8\" class=\"mw-redirect\" title=\"ניגון הכנה למאמר\">ניגון הכנה למאמר</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C\" title=\"דיבור המתחיל\">דיבור המתחיל</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php?title=%D7%99%D7%90%D7%99%D7%A8_%D7%A0%D7%AA%D7%99%D7%91_(%D7%9E%D7%95%D7%A9%D7%92)&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יאיר נתיב (מושג) (הדף אינו קיים)\">יאיר נתיב</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%99%D7%9B%D7%9C%D7%90%D7%9A\" title=\"ביכלאך\">ביכלאך</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%91%D7%9C%D7%AA%D7%99_%D7%9E%D7%95%D7%92%D7%94\" title=\"בלתי מוגה\">בלתי מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%9E%D7%95%D7%92%D7%94\" title=\"מוגה\">מוגה</a> <span style=\"white-space:nowrap; font-weight:bold;\">&#160;•&#160;</span> <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשך</a>\n</td></tr>\n</tbody></table>\n<figure typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%D7%95.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/7/79/%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%D7%95.jpg/250px-%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%D7%95.jpg\" decoding=\"async\" width=\"250\" height=\"321\" class=\"mw-file-element\" srcset=\"/images/thumb/7/79/%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%D7%95.jpg/375px-%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%D7%95.jpg 1.5x, /images/thumb/7/79/%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%D7%95.jpg/500px-%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%D7%95.jpg 2x\" /></a><figcaption>ההוצאה החדשה של המשך 'מים רבים' (לקוטי תורה - תורת שמואל תרל\"ו ח\"א)</figcaption></figure>\n<p><b>המשך מים רבים - <a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%95\" title=\"תרל&quot;ו\">תרל\"ו</a></b> הוא <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A\" title=\"המשך\">המשך</a> מאמרי חסידות שנאמר ע\"י <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a> בשנת תרל\"ו, למשך רוב חדשי השנה. נחשב לאחד מ'ההמשכים' הידועים ב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a> בכלל, ובמאמרי אדמו\"ר המהר\"ש בפרט.\n</p><p>נדפס לראשונה בהוצאת <a href=\"/index.php/%D7%A7%D7%94%22%D7%AA\" class=\"mw-redirect\" title=\"קה&quot;ת\">קה\"ת</a> ע\"י <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a> בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a>, באותיות מרובעות<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, כ\"לקוטי תורה תורת שמואל - שער שלישי\".\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.94.D7.9E.D7.90.D7.9E.D7.A8.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"המאמרים\">המאמרים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;המאמרים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: המאמרים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>בהכנת ההמשך לדפוס השתמש הרבי בשלושה כתבי יד, ובעיקר בכת\"י ר' <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%A1%D7%95%D7%A4%D7%A8\" title=\"שמואל סופר\">שמואל סופר</a>, שהיה ראש המעתיקים ב<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a> שנים רבות<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>לאורך ההמשך הוסיף הרבי (באופן נדיר) מראי מקומות, ואף כו\"כ הערות תוכן לגבי מקומם של מארז\"ל אחדים<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ההמשך מכיל ר\"ב (202) פרקים. בכל כתבי היד מופיע שלמאמר יש קצ\"ט פרקים. וכלשון אדמו\"ר הרש\"ב: \"בשנת [תר]ל\"ו אמר מאמר מים רבים לא יוכלו לכבות אהבה כו' והתחיל אותו בפ' נח וסיים אותו פ' פנחס, והוא מחזיק קצ\"ט סעי', ויש בו מוסר וחסידות ומעט קבלה. וגם הלשון הוא באורך ורוחב. וסעי' קל\"א מתחיל מענין פסח ומצה...\"<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>. אך בכת\"י ר' שמואל סופר נמצאו עוד ארבעה סעיפים (כותב הרבי ב\"הערת המו\"ל\" לפרק קצט: \"ד' הפרקים קצ\"ט-רב, לא מצאתים אלא בכת\"י א', בהעתקת הר\"ש סופר\").\n</p><p>אדמו\"ר הרש\"ב כתב ביאור על המאמר הראשון, ו<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> כתב כשהדפיס את הביאור הזה ב<a href=\"/index.php/%D7%94%D7%AA%D7%9E%D7%99%D7%9D_(%D7%95%D7%A8%D7%A9%D7%94)\" title=\"התמים (ורשה)\">קובץ התמים ווארשא</a>, כי \"הוא הביאור הראשון שהתחיל לכתוב בדא\"ח בימי חרפו, במלאות לו ט\"ו שנה\"<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.94.D7.93.D7.A4.D7.A1.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"הדפסתו\">הדפסתו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;הדפסתו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: הדפסתו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>יצא לראשונה בשנת <a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> על ידי <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"הרבי\">הרבי</a>. בהוצאה שניה יצא לאור בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%95\" title=\"תשל&quot;ו\">תשל\"ו</a>.\n</p><p>בהמשך השנים יצא לאור בהוצאה חדשה ומתוקנת, על ידי הוצאת ספרים קה\"ת (בשנת <a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a>), עם הוספות חשובות: בתחילת הספר נוספה רשימת המאמרים בעריכת הרבי<sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\"><span class=\"cite-bracket\">&#91;</span>6<span class=\"cite-bracket\">&#93;</span></a></sup>, נוספו ההשמטות והקיצורים שלא היו עד אז בספר<sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\"><span class=\"cite-bracket\">&#91;</span>7<span class=\"cite-bracket\">&#93;</span></a></sup>, וכן נוספו כמה מ\"מ בדרך אפשר בחצאי ריבוע (במקומות בהם נשארו ריקות בהוצאה הראשונה).\n</p>\n<h3><span id=\".D7.A1.D7.A4.D7.A8_.D7.AA.D7.A8.D7.9C.22.D7.95_.D7.97.D7.9C.D7.A7_.D7.91.27.2C_.D7.95.D7.94.D7.A0.D7.97.D7.95.D7.AA_.D7.90.D7.93.D7.9E.D7.95.22.D7.A8_.D7.94.D7.A8.D7.A9.22.D7.91\"></span><span class=\"mw-headline\" id=\"ספר_תרל&quot;ו_חלק_ב',_והנחות_אדמו&quot;ר_הרש&quot;ב\">ספר תרל\"ו חלק ב', והנחות אדמו\"ר הרש\"ב</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;ספר תרל&quot;ו חלק ב&#039;, והנחות אדמו&quot;ר הרש&quot;ב&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: ספר תרל&quot;ו חלק ב&#039;, והנחות אדמו&quot;ר הרש&quot;ב\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>בשנת תשמ\"ג יצא לאור ספר \"לקוטי תורה תורת שמואל - תרל\"ו ח\"ב\", המכיל את שאר המאמרים שנאמרו ע\"י אדמו\"ר המהר\"ש באותה שנה. כהוספה לספר (בפועל - מכיל את רוב הספר) נדפסו ה\"<a href=\"/index.php/%D7%94%D7%A0%D7%97%D7%94\" title=\"הנחה\">הנחות</a>\" מ<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> להמשך.\n</p><p>ייחודיותם של 'הנחות' אלו (כמו כל הנחות אדמו\"ר הרש\"ב למאמרי אדמו\"ר מהר\"ש, שהתחילו בשנה זו ונמשכו עד לשנת תרמ\"ב), הם שנכתבו בסגנון אמירתם ע\"י אדמו\"ר המהר\"ש (משא\"כ המאמרים כפי שנדפסו ב'המשך', נכתבו בסגנון מקוצר יותר)<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\"><span class=\"cite-bracket\">&#91;</span>8<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A8.D7.90.D7.95_.D7.92.D7.9D\"></span><span class=\"mw-headline\" id=\"ראו_גם\">ראו גם</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;ראו גם&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: ראו גם\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94_-_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C\" title=\"לקוטי תורה - תורת שמואל\">לקוטי תורה - תורת שמואל</a></li>\n<li><a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96\" title=\"המשך וככה תרל&quot;ז\">המשך וככה תרל\"ז</a></li>\n<li><a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%94%D7%97%D7%A8%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%90\" class=\"mw-redirect\" title=\"המשך והחרים תרל&quot;א\">המשך והחרים תרל\"א</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%94%D7%9E%D7%A9%D7%9A_%D7%9E%D7%99%D7%9D_%D7%A8%D7%91%D7%99%D7%9D_%D7%AA%D7%A8%D7%9C%22%D7%95&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadpedia.co.il/images/c/c3/סה%22מ_תרל%22ו_ח%22א_(מים_רבים).pdf\">המשך \"מים רבים\" תרל\"ו</a></b> <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li></ul>\n<p><br />\n</p>\n<table class=\"navbox nowraplinks\" style=\"width: 90%; clear: both; margin: 0.5em auto; margin-top: 0.5em; margin-bottom: 0.5em; padding: 0.2em; text-align: right;\">\n\n<tbody><tr>\n<th colspan=\"3\" style=\"text-align: center; padding-top: 0.1em; padding-bottom: 0.1em; color: black; background:#d1eeee; font-weight: bold;\">ספרי <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" class=\"mw-redirect\" title=\"אדמו&quot;ר המהר&quot;ש\">אדמו\"ר המהר\"ש</a>\n</th></tr>\n\n\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\">מאמרים\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94_-_%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C\" title=\"לקוטי תורה - תורת שמואל\">לקוטי תורה - תורת שמואל</a> • <a href=\"/index.php/%D7%9C%D7%A7%D7%95%D7%98%D7%99_%D7%AA%D7%95%D7%A8%D7%94_%D7%9C%D7%92%27_%D7%A4%D7%A8%D7%A9%D7%99%D7%95%D7%AA\" title=\"לקוטי תורה לג&#39; פרשיות\">לקוטי תורה לג' פרשיות</a> • <a class=\"mw-selflink selflink\">המשך מים רבים תרל\"ו</a> • <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%9B%D7%9B%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%96\" title=\"המשך וככה תרל&quot;ז\">המשך וככה תרל\"ז</a> • <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%95%D7%94%D7%97%D7%A8%D7%99%D7%9D\" title=\"המשך והחרים\">המשך והחרים תרל\"א</a> • <a href=\"/index.php/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%93%D7%A8%D7%95%D7%A9%D7%99_%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%AA%D7%A8%D7%9C%22%D7%94\" title=\"קונטרס דרושי חתונה תרל&quot;ה\">קונטרס דרושי חתונה תרל\"ה</a> • <a href=\"/index.php/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%93%D7%A8%D7%95%D7%A9%D7%99_%D7%97%D7%AA%D7%95%D7%A0%D7%94_%D7%AA%D7%A8%D7%9E%22%D7%91\" title=\"קונטרס דרושי חתונה תרמ&quot;ב\">קונטרס דרושי חתונה תרמ\"ב</a>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #F2F3F4; text-align: right; font-weight: bold; padding-left: 5px;\">שונות\n</td>\n<td style=\"padding-right: 5px; text-align: right;\"><a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_-_%D7%A1%D7%A4%D7%A8_%D7%94%D7%A9%D7%99%D7%97%D7%95%D7%AA\" title=\"תורת שמואל - ספר השיחות\">תורת שמואל - ספר השיחות</a> • <a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9_(%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9)\" title=\"אגרות קודש (אדמו&quot;ר המהר&quot;ש)\">אגרות קודש</a> • <a href=\"/index.php/%D7%A9%D7%95%22%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%9E%D7%94%D7%A8%22%D7%A9\" title=\"שו&quot;ת אדמו&quot;ר המהר&quot;ש\">שו\"ת אדמו\"ר המהר\"ש</a>\n</td></tr>\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n</tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">בשונה מכמה ספרי אדמו\"ר מהר\"ש שנדפסו אז כצילום כתב יד ר' שמואל הסופר. הסיבה לכך היא מכיוון שהיו תחת ידי הרבי לפני ההדפסה כמה כתבי יד, והוא חפץ לאחד אותם, בשונה משאר ההמשכים, שנדפסו מצילום כתב היד של ר' שמואל, להם החזיק הרבי על פי רוב בעת ההדפסה רק העתקה אחת (ראה פתח דבר מהרבי לספר).</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ראה בפתח דבר מהרבי לספר.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">ב<a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5_%D7%94%D7%A2%D7%A8%D7%95%D7%AA_%D7%95%D7%91%D7%99%D7%90%D7%95%D7%A8%D7%99%D7%9D_-_%D7%90%D7%94%D7%9C%D7%99_%D7%AA%D7%95%D7%A8%D7%94\" title=\"קובץ הערות וביאורים - אהלי תורה\">קובץ הערות וביאורים - אהלי תורה</a> הובאו השערות שחלק מההערות לא נכתבו על ידי הרבי. ראו הערת הרב <a href=\"/index.php/%D7%90%D7%9C%D7%99%D7%94%D7%95_%D7%9E%D7%98%D7%95%D7%A1%D7%95%D7%91\" title=\"אליהו מטוסוב\">אליהו מטוסוב</a>, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/drive/folders/1sVEl-IGae0vc3gXeU22ExEMXmaui3nxL\">בריאת יש מאין, דבר מלא דבר</a></b> גליון א'רפח (יא), שבת פרשת ויקהל פקודי החודש תשפ\"ו, עמוד 81 והערת הרב ניסן משה הכהן ויספיש, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://drive.google.com/drive/folders/1sVEl-IGae0vc3gXeU22ExEMXmaui3nxL\">בריאת יש מאין, דבר מלא דבר (גליון)</a></b> גליון א'רפט (יב), י\"א ניסן תשפ\"ו, עמוד 90.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">מכתב כ\"ק אדמו\"ר הרש\"ב, טבת תרל\"ח - <a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אגרות קודש אדמו&quot;ר הרש&quot;ב\">אגרות קודש אדמו\"ר הרש\"ב</a> ח\"ג ע' א.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">קובץ \"<a href=\"/index.php/%D7%94%D7%AA%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"התמים\">התמים</a>\", חוברת ג', ורשא תרצ\"ו, ע' לז-מה.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">נעתקו מ\"רשימת מאמרי דא\"ח של כ\"ק אדמו\"ר מוהר\"ש נ\"ע\" (קה\"ת, תשמ\"א), ונוספו הערות מהמו\"ל בחצאי ריבוע.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\">נדפסו בחלק ב'.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">ממכתב כ\"ק אדמו\"ר הריי\"צ, ח\"י שבט תרצ\"א: \"משנת תרל\"ו ישנם כתביו שם באר לעצמו מאמרי מהר\"ש נ\"ע, וביותר מאמר מים רבים ומאמר [ו]ככה שנאמרו בשנות תרל\"ו תרל\"ז (וידוע שבמאמרי מהר\"ש יש חילוק גדול בין הכתבים לכמו שאמרם שהכתבים מקוצרים הרבה, והנחות כ\"ק אאמו\"ר זצוקללה\"ה הם ע\"פ הרוב כמו שהיו בעת הדבור, ובמקומות הרבה נכתבו בלשון המדוברת\" (<a href=\"/index.php/%D7%90%D7%92%D7%A8%D7%95%D7%AA_%D7%A7%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%9E%D7%94%D7%95%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אגרות קודש אדמו&quot;ר מהוריי&quot;צ\">אגרות קודש אדמו\"ר מהוריי\"צ</a> ח\"ב ע' שכד. נעתק גם ב'הקדמה' להנחות כ\"ק אדמו\"ר הרש\"ב להמשך מים רבים - סה\"מ תרל\"ו ח\"ב ע' שעט).</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413153826\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.136 seconds\nReal time usage: 0.237 seconds\nPreprocessor visited node count: 640/1000000\nPost‐expand include size: 12837/2097152 bytes\nTemplate argument size: 1427/2097152 bytes\nHighest expansion depth: 10/100\nExpensive parser function count: 2/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 4698/5000000 bytes\nLua time usage: 0.070/7 seconds\nLua virtual size: 6172672/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  197.915      1 -total\n 63.41%  125.503      8 תבנית:הערה\n 23.76%   47.028      1 תבנית:ספרי_אדמו&quot;ר_המהר&quot;ש\n 22.74%   45.012      1 תבנית:ניווט_קבוצות\n  6.92%   13.686      1 תבנית:הערות_שוליים\n  4.12%    8.157      1 תבנית:מאמרי_רבותינו_נשיאינו\n  1.29%    2.549     36 תבנית:*\n  1.26%    2.498    