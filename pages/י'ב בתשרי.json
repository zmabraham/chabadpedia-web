;ק אדמו&quot;ר שליט&quot;א)\">הרבי</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%91_%D7%91%D7%AA%D7%A9%D7%A8%D7%99&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li>ה'<a href=\"/index.php/%D7%AA%D7%A7%D7%9C%22%D7%96\" title=\"תקל&quot;ז\">תקל\"ז</a> (25/09/1776 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - רבי <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%94%D7%9E%D7%9C%D7%90%D7%9A\" title=\"אברהם המלאך\">אברהם המלאך</a>, בנו של <a href=\"/index.php/%D7%94%D7%9E%D7%92%D7%99%D7%93_%D7%9E%D7%9E%D7%96%D7%A8%D7%99%D7%98%D7%A9\" title=\"המגיד ממזריטש\">המגיד ממזריטש</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%91\" title=\"תשמ&quot;ב\">תשמ\"ב</a> (10/10/1981 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%93%D7%95%D7%91_%D7%A7%D7%A1%D7%98%D7%9C\" title=\"יוסף דוב קסטל\">יוסף דובער קסטל</a></li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%95\" title=\"תשנ&quot;ו\">תשנ\"ו</a> (06/10/1995 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%A4%D7%A8%D7%99%D7%99%D7%9E%D7%9F\" title=\"מאיר פריימן\">מאיר פריימן</a>, מזכיר <a href=\"/index.php/%D7%95%D7%A2%D7%93_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ועד כפר חב&quot;ד\">ועד כפר חב\"ד</a> ומנכ\"ל <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" class=\"mw-redirect\" title=\"רשת אהלי יוסף יצחק ארץ הקודש\">רשת אהלי יוסף יצחק ארץ הקודש</a>.</li>\n<li>ה'<a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a> (13/10/1997 <a href=\"/index.php/%D7%9E%D7%A0%D7%99%D7%99%D7%9F_%D7%90%D7%95%D7%9E%D7%95%D7%AA_%D7%94%D7%A2%D7%95%D7%9C%D7%9D\" title=\"מניין אומות העולם\">למניינם</a>) - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"יוסף אלפרוביץ&#39;\">יוסף אלפרוביץ'</a>, סוכן הנסיעות של אנ\"ש, מארגן <a href=\"/index.php/%D7%94%D7%A6%27%D7%A8%D7%98%D7%A8_%D7%94%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" title=\"הצ&#39;רטר הראשון\">הצ'ארטרים הראשונים</a> ל<a href=\"/index.php/%D7%A8%D7%91%D7%99_%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%9B%22%D7%A7_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" title=\"רבי מנחם מענדל שניאורסון (כ&quot;ק אדמו&quot;ר שליט&quot;א)\">רבי</a>, ועסקן חסידי.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> -  הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%90%D7%9C%D7%99%D7%A2%D7%96%D7%A8_%D7%A4%D7%A8%D7%99%D7%93%D7%A8%D7%99%D7%9A\" title=\"יעקב אליעזר פרידריך\">יעקב אליעזר פרידריך</a>, זקן חסידי חב\"ד בעולם.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%95\" title=\"תשפ&quot;ו\">תשפ\"ו</a> - הרב <a href=\"/index.php/%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%90%D7%A9%D7%A8_%D7%91%D7%A2%D7%92%D7%95%D7%9F\" title=\"שמואל אשר בעגון\">שמואל אשר בעגון</a> - מורה חב\"די, מחבר ספרים רבים, גרפיקאי מומחה.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ב בתשרי - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>ברית כרותה לתעמולה ועבודה במועצות <a href=\"/index.php/%D7%97%D7%9B%D7%9E%D7%94\" class=\"mw-redirect\" title=\"חכמה\">חכמה</a> ובקירוב ה<a href=\"/index.php/%D7%93%D7%A2%D7%AA\" class=\"mw-redirect\" title=\"דעת\">דעת</a> שאינה חוזרת ריקם.\n</td></tr></tbody></table>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השביעי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div>\n<!-- \nNewPP limit report\nCached time: 20260414004543\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.095 seconds\nReal time usage: 0.654 seconds\nPreprocessor visited node count: 351/1000000\nPost‐expand include size: 7875/2097152 bytes\nTemplate argument size: 1075/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 4/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 151/5000000 bytes\nLua time usage: 0.070/7 seconds\nLua virtual size: 6127616/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  627.070      1 -total\n 97.58%  611.911      1 תבנית:פתיח_יום\n 