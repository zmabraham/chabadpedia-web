      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">&gt;&gt;</a></span>\n<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%90%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"א&#39; בתמוז\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ב&#39; בתמוז\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ג&#39; בתמוז\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ד&#39; בתמוז\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ה&#39; בתמוז\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ו&#39; בתמוז\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ז&#39; בתמוז\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ח&#39; בתמוז\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ט&#39; בתמוז\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&#39; בתמוז\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;א בתמוז\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ב בתמוז\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ג בתמוז\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ד בתמוז\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ט&quot;ו בתמוז\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"ט&quot;ז בתמוז\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ז בתמוז\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ט בתמוז\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&#39; בתמוז\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;א בתמוז\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ב בתמוז\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ג בתמוז\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ד בתמוז\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ה בתמוז\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ו בתמוז\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ז בתמוז\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ח בתמוז\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"כ&quot;ט בתמוז\">כט</a>\n</td></tr>\n\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%97%D7%A9%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"חודש חשוון\">חשוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9B%D7%A1%D7%9C%D7%95\" class=\"mw-redirect\" title=\"חודש כסלו\">כסלו</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%98%D7%91%D7%AA\" class=\"mw-redirect\" title=\"חודש טבת\">טבת</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A9%D7%91%D7%98\" class=\"mw-redirect\" title=\"חודש שבט\">שבט</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">\nאדר</a> <br /> <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">ניסן</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%99%D7%99%D7%A8\" title=\"חודש אייר\">אייר</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">סיוון</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">תמוז</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%9E%D7%A0%D7%97%D7%9D_%D7%90%D7%91\" class=\"mw-redirect\" title=\"חודש מנחם אב\">מנחם אב</a> · <a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%9C%D7%95%D7%9C\" title=\"חודש אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י\"ח בתמוז</b> הוא היום השמונה עשר ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%9E%D7%95%D7%96\" title=\"חודש תמוז\">חודש תמוז</a> ויומו השני של ימי <a href=\"/index.php/%D7%91%D7%99%D7%9F_%D7%94%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"בין המצרים\">בין המצרים</a>. כשחל <a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"י&quot;ז בתמוז\">י\"ז בתמוז</a> ב<a href=\"/index.php/%D7%A9%D7%91%D7%AA\" title=\"שבת\">שבת</a>, נדחית התענית ליום זה.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'תמח – <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%99%D7%A0%D7%95\" title=\"משה רבינו\">משה רבינו</a> משמיד את <a href=\"/index.php/%D7%A2%D7%92%D7%9C_%D7%94%D7%96%D7%94%D7%91\" class=\"mw-redirect\" title=\"עגל הזהב\">עגל הזהב</a> ושוב עולה ל<a href=\"/index.php/%D7%94%D7%A8_%D7%A1%D7%99%D7%A0%D7%99\" title=\"הר סיני\">הר סיני</a> להתחנן מה' שימחל ל<a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">עם ישראל</a> על חטא העגל.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> – הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%90%D7%A4%D7%97\" title=\"יוסף קאפח\">יוסף קאפח</a>, ממנהיגי קהילת יהודי תימן וממתרגמי כתבי ה<a href=\"/index.php/%D7%A8%D7%9E%D7%91%22%D7%9D\" title=\"רמב&quot;ם\">רמב\"ם</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> – רבי <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9E%D7%90%D7%99%D7%A8_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%A9%D7%A4%D7%99%D7%A8%D7%90\" title=\"חיים מאיר יחיאל שפירא\">חיים מאיר יחיאל שפירא</a> מנארול, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%91\" title=\"תרפ&quot;ב\">תרפ\"ב</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%92%D7%A8%D7%95%D7%93%D7%A7%D7%94\" title=\"דובער גרודקה\">דובער גרודקה</a>, מוותיקי קהילת חב\"ד ב<a href=\"/index.php/%D7%9C%D7%95%D7%93\" title=\"לוד\">לוד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> - <a href=\"/index.php/%D7%A6%D7%93%D7%99%D7%A7_%D7%A0%D7%A1%D7%95%D7%A4%D7%A8_(%D7%A6%27%D7%90%D7%A8%D7%9C%D7%99)\" title=\"צדיק נסופר (צ&#39;ארלי)\">צדיק נסופר (צ'ארלי)</a>, מאנשי <a href=\"/index.php/770\" class=\"mw-redirect\" title=\"770\">770</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a> – הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%95%D7%95%D7%9C%D7%A4%D7%90\" title=\"מנחם וולפא\">מנחם וולפא</a>, שליח הרבי רב הקהילה ויו\"ר מוסדות חב\"ד ב<a href=\"/index.php/%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" title=\"נתניה\">נתניה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%94\" title=\"תשכ&quot;ה\">תשכ\"ה</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A9%D7%A9%D7%95%D7%A0%D7%A7%D7%99%D7%9F\" title=\"משה ששונקין\">משה ששונקין</a>, שליח הרבי במושב מטולה שבצפון ארץ הקודש.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%90\" title=\"תשל&quot;א\">תשל\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%90%D7%9C%D7%A4%D7%A0%D7%91%D7%99%D7%99%D7%9F\" title=\"ישראל יהודה אלפנביין\">ישראל יהודה אלפנביין</a>, סופר חסידי, <a href=\"/index.php/%D7%A8%22%D7%9E\" class=\"mw-redirect\" title=\"ר&quot;מ\">ר\"מ</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A0%D7%AA%D7%A0%D7%99%D7%94\" class=\"mw-redirect\" title=\"תומכי תמימים נתניה\">תומכי תמימים נתניה</a> ורב ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בבית הכנסת חב\"ד סמילנסקי בעיר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%93\" title=\"תשל&quot;ד\">תשל\"ד</a> – הרב <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%A7_%D7%99%D7%A6%D7%97%D7%A7_%D7%9E%D7%9C%D7%9B%D7%99%D7%90%D7%9C%D7%99\" title=\"אריק יצחק מלכיאלי\">אריק יצחק מלכיאלי</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> חב\"די ומרצה ראשי בארגון \"מחנה משותף\" הפועל להפצת שיעורי תורה ויהדות ב<a href=\"/index.php/%D7%A6%D7%94%22%D7%9C\" title=\"צה&quot;ל\">צה\"ל</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%96%D7%A8%D7%97%D7%99_(%D7%9B%D7%A4%D7%A8_%D7%A1%D7%91%D7%90)\" title=\"יעקב מזרחי (כפר סבא)\">יעקב מזרחי</a>, מ<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"שליח הרבי\">שלוחי הרבי</a> ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%A1%D7%91%D7%90\" title=\"כפר סבא\">כפר סבא</a>, מנהל הפעילות ב<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"בית חב&quot;ד\">בית חב\"ד</a> של הרב <a href=\"/index.php/%D7%99%D7%95%D7%90%D7%9C_%D7%99%D7%9E%D7%99%D7%A0%D7%99\" title=\"יואל ימיני\">יואל ימיני</a> ורב בית הכנסת ישראל בעיר.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%22%D7%97_%D7%91%D7%AA%D7%9E%D7%95%D7%96&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%9E\" title=\"תש&quot;מ\">תש\"מ</a> – הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%A4%D7%A8%D7%99%D7%96)\" title=\"שניאור זלמן שניאורסון (פריז)\">שניאור זלמן שניאורסון</a>, צאצא של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7\" class=\"mw-redirect\" title=\"אדמו&quot;ר הצמח צדק\">אדמו\"ר הצמח צדק</a> שניהל פעילות מסועפת להצלת אלפי ילדים בזמן ה<a href=\"/index.php/%D7%A9%D7%95%D7%90%D7%94\" class=\"mw-redirect\" title=\"שואה\">שואה</a> ולחינוכם, ובשנותיו האחרונות ראש ישיבת 'שבט מיהודה' בניו יורק.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%90\" title=\"תשס&quot;א\">תשס\"א</a> – הרב <a href=\"/index.php/%D7%A6%D7%9E%D7%97_%D7%92%D7%95%D7%A8%D7%91%D7%99%D7%A5%27\" title=\"צמח גורביץ&#39;\">צמח גורביץ'</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%92%D7%99%D7%97\" title=\"משגיח\">משגיח</a> בישיבות תומכי תמימים המחתרתיות ברוסיה, ו<a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97\" class=\"mw-redirect\" title=\"שליח\">שליח</a> <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> להפצת יהדות בקובה.</li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י\"ח בתמוז - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">דער אלטער רבי</a> האט געזאגט אויף ר' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%95%D7%99%D7%9C%D7%A0%D7%A7%D7%A8\" title=\"משה וילנקר\">משה ווילענקער</a>: משה האט <a href=\"/index.php/%D7%9E%D7%95%D7%97%D7%99%D7%9F_%D7%93%D7%92%D7%93%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מוחין דגדלות\">מוחין דגדלות</a>, און אין די צען יאר וואס ער האט געהארעוועט, האט ער אויסגעהארעוועט מוחין רחבים.\n<p>דריי יאר האט ר' משה ווילענקער זיך מכין געווען צו <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> באם אלטען רבי'ן, און נאכדעם איז ער געבליבען זעבען יאר אין <a href=\"/index.php/%D7%9C%D7%99%D7%90%D7%96%D7%A0%D7%90\" title=\"ליאזנא\">ליאזנא</a> אויף בריינגען די <a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> אין <a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודה</a> בפועל.\n</p>\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"אדמו&quot;ר הזקן\">אדמו\"ר הזקן</a> אמר על ר' <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%95%D7%99%D7%9C%D7%A0%D7%A7%D7%A8\" title=\"משה וילנקר\">משה וילנקר</a>: משה יש לו <a href=\"/index.php/%D7%9E%D7%95%D7%97%D7%99%D7%9F_%D7%93%D7%92%D7%93%D7%9C%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מוחין דגדלות\">מוחין דגדלות</a>, ובעשר שנים שהתייגע, הוא השיג מוחין רחבים.\n</p><p>שלוש שנים הכין את עצמו ר' משה ל<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a> אצל אדמו\"ר הזקן, ואחר כך הוא נשאר שבע שנים ב<a href=\"/index.php/%D7%9C%D7%99%D7%90%D7%96%D7%A0%D7%99\" class=\"mw-redirect\" title=\"ליאזני\">ליאזני</a> בכדי להביא את היחידת לידי ב<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודה</a> בפועל.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260413203046\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.025 seconds\nReal time usage: 0.046 seconds\nPreprocessor visited node count: 110/1000000\nPost‐expand include size: 716