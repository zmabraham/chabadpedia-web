      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table class=\"toccolours\" style=\"float:left; width:230px; margin-right:20px; text-align:center;\">\n\n<tbody><tr>\n<th colspan=\"10\" style=\"background:LightSteelBlue;\">\n<p><span style=\"float:right;\"><a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">&lt;&lt;</a></span>\n<span style=\"float:left;\"><a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">&gt;&gt;</a></span>\nחודש <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a>\n</p>\n</th></tr>\n\n<tr>\n<td bgcolor=\"#EDF3F0\"><a class=\"mw-selflink selflink\">א</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%91%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ב&#39; בסיוון\">ב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%92%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ג&#39; בסיוון\">ג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%93%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ד&#39; בסיוון\">ד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%94%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ה&#39; בסיוון\">ה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%95%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ו&#39; בסיוון\">ו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%96%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ז&#39; בסיוון\">ז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%97%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ח&#39; בסיוון\">ח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ט&#39; בסיוון\">ט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&#39; בסיוון\">י</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%90_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;א בסיוון\">יא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%91_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ב בסיוון\">יב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ג בסיוון\">יג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%93_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ד בסיוון\">יד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ט&quot;ו בסיוון\">טו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%98%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ט&quot;ז בסיוון\">טז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ז בסיוון\">יז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ח בסיוון\">יח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%99%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"י&quot;ט בסיוון\">יט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&#39; בסיוון\">כ</a>\n</td></tr>\n<tr>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%90_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;א בסיוון\">כא</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%91_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ב בסיוון\">כב</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%92_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ג בסיוון\">כג</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%93_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ד בסיוון\">כד</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%94_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>א&#39; בסיוון</b> הוא היום הראשון\nבחודש התשיעי<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup> \nבלוח השנה היהודי&#160;ביום זה חנו <a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"בני ישראל\">בני ישראל</a> ב<a href=\"/index.php?title=%D7%9E%D7%93%D7%91%D7%A8_%D7%A1%D7%99%D7%A0%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מדבר סיני (הדף אינו קיים)\">מדבר סיני</a> לקראת <a href=\"/index.php/%D7%9E%D7%AA%D7%9F_%D7%AA%D7%95%D7%A8%D7%94\" title=\"מתן תורה\">מתן תורה</a>, כמתואר בפסוק<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>: \"בַּחדֶשׁ הַשְּׁלִישִׁי לְצֵאת בְּנֵי-יִשְׂרָאֵל מֵאֶרֶץ מִצְרָיִם, בַּיּוֹם הַזֶּה בָּאוּ מִדְבַּר סִינָי\", והגמרא<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup> לומדת שיום זה הוא ראש חודש סיון. הרבי מורה<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup> ללמוד ביום זה את ה<a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"מאמר\">מאמר</a> <a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8_%D7%94%D7%9E%D7%AA%D7%97%D7%99%D7%9C\" title=\"דיבור המתחיל\">דיבור המתחיל</a> \"בחודש השלישי\" ב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94_%D7%90%D7%95%D7%A8\" class=\"mw-redirect\" title=\"תורה אור\">תורה אור</a> לפרשת יתרו.\n</p><p>תאריך זה חל בתקופת ניסן&#160;והוא יכול לחול בימים&#160;ראשון, שלישי, רביעי ושישי.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>א'תרנ\"ו – מי ה<a href=\"/index.php/%D7%9E%D7%91%D7%95%D7%9C\" class=\"mw-redirect\" title=\"מבול\">מבול</a> החלו להתמעט, בסיום מאה וחמישים ימי תגבורת מים.</li>\n<li>ב'תמ\"ח – <a href=\"/index.php/%D7%A2%D7%9D_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"עם ישראל\">עם ישראל</a> חנה ב<a href=\"/index.php?title=%D7%9E%D7%93%D7%91%D7%A8_%D7%A1%D7%99%D7%A0%D7%99&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מדבר סיני (הדף אינו קיים)\">מדבר סיני</a> לקראת <a href=\"/index.php/%D7%9E%D7%AA%D7%9F_%D7%AA%D7%95%D7%A8%D7%94\" title=\"מתן תורה\">מתן תורה</a>.</li>\n<li>ג'של\"ח – <a href=\"/index.php/%D7%99%D7%97%D7%96%D7%A7%D7%90%D7%9C_%D7%94%D7%A0%D7%91%D7%99%D7%90\" title=\"יחזקאל הנביא\">יחזקאל הנביא</a> התנבא על מפלת <a href=\"/index.php/%D7%9E%D7%A6%D7%A8%D7%99%D7%9D\" title=\"מצרים\">מצרים</a>.</li>\n<li>ד'תתנ\"ו – מסע הצלב הראשון ורציחת 179 יהודי קהילת שפיירא.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%22%D7%95\" title=\"תק&quot;ו\">תק\"ו</a> – רבי מאיר הורביץ, <a href=\"/index.php/%D7%90%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"אב&quot;ד\">אב\"ד</a> טיקטין, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%97\" title=\"תרפ&quot;ח\">תרפ\"ח</a> – רבי אליעזר דוד גרינוולד, אב\"ד <a href=\"/index.php/%D7%A1%D7%90%D7%98%D7%9E%D7%A8\" class=\"mw-redirect\" title=\"סאטמר\">סאטמר</a> ומחבר הספר 'קרן לדוד', נפטר.</li>\n<li>תרפ\"ח – רבי אברהם מנחם שטיינברג, אב\"ד סניאטין ובראדי, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%96\" title=\"תש&quot;ז\">תש\"ז</a> – רבי מרדכי שפירא מקאמינקא-<a href=\"/index.php/%D7%A7%D7%95%D7%A8%D7%99%D7%A5\" title=\"קוריץ\">קוריץ</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%A1\" title=\"תש&quot;ס\">תש\"ס</a> – רבי <a href=\"/index.php/%D7%90%D7%94%D7%A8%D7%9F_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%9C%D7%99%D7%99%D7%A4%D7%A2%D7%A8\" class=\"mw-redirect\" title=\"אהרן יחיאל לייפער\">אהרן יחיאל לייפער</a> מנדבורנא צפת, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9C%22%D7%95\" title=\"תרל&quot;ו\">תרל\"ו</a> – <a href=\"/index.php/%D7%93%D7%91%D7%95%D7%A8%D7%94_%D7%9C%D7%90%D7%94_(%D7%91%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99)\" class=\"mw-redirect\" title=\"דבורה לאה (בת אדמו&quot;ר האמצעי)\">דבורה לאה</a>, בת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%90%D7%9E%D7%A6%D7%A2%D7%99\" class=\"mw-redirect\" title=\"אדמו&quot;ר האמצעי\">אדמו\"ר האמצעי</a> ואשת רבי <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%98%D7%91%D7%A8%D7%A1%D7%A7%D7%99\" title=\"יעקב ישראל טברסקי\">יעקב ישראל טברסקי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> – הרב <a href=\"/index.php/%D7%93%D7%95%D7%93_%D7%9C%D7%99%D7%99%D7%91_%D7%97%D7%9F\" title=\"דוד לייב חן\">דוד לייב חן</a>, מחסידי חב\"ד הפעילים למען <a href=\"/index.php/%D7%99%D7%A6%D7%99%D7%90%D7%AA_%D7%A8%D7%95%D7%A1%D7%99%D7%94_%D7%AA%D7%A9%22%D7%95\" title=\"יציאת רוסיה תש&quot;ו\">הבריחה הגדולה מרוסיה</a> ולאחר מכן ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"תשנ&quot;ח\">תשנ\"ח</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%91%D7%A2%D7%A8_%D7%90%D7%99%D7%99%D7%9B%D7%94%D7%95%D7%A8%D7%9F\" title=\"שלום בער אייכהורן\">שלום בער אייכהורן</a>, <a href=\"/index.php/%D7%9E%D7%A9%D7%91%22%D7%A7\" class=\"mw-redirect\" title=\"משב&quot;ק\">משב\"ק</a> אצל <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a> ומייסד <a href=\"/index.php/%D7%92%D7%9E%22%D7%97\" class=\"mw-redirect\" title=\"גמ&quot;ח\">גמ\"ח</a> בשכונת <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> על שם <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%97_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%A9%D7%9C%D7%99%D7%98%22%D7%90)\" class=\"mw-redirect\" title=\"ישראל אריה לייב שניאורסון (אח אדמו&quot;ר שליט&quot;א)\">אחיו של הרבי</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> – הרב <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A0%D7%95%D7%98%D7%99%D7%A7\" title=\"יעקב נוטיק\">יעקב נוטיק</a>, נחלת הר חב\"ד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> – הרב <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%90%D7%94%D7%A8%D7%95%D7%9F_%D7%94%D7%A0%D7%99%D7%92\" class=\"mw-redirect\" title=\"שלמה אהרון הניג\">שלמה אהרון הניג</a>, <a href=\"/index.php/%D7%A1%D7%95%D7%A4%D7%A8_%D7%A1%D7%AA%22%D7%9D\" title=\"סופר סת&quot;ם\">סופר סת\"ם</a> ב<a href=\"/index.php/%D7%9B%D7%AA%D7%91_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%96%D7%A7%D7%9F\" title=\"כתב אדמו&quot;ר הזקן\">כתב אדמו\"ר הזקן</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%90\" title=\"תשפ&quot;א\">תשפ\"א</a> – הרב <a href=\"/index.php/%D7%A4%D7%A0%D7%97%D7%A1_%D7%92%D7%93%D7%9C%D7%99%D7%94_%D7%A4%D7%90%D7%A9%D7%98%D7%A8\" title=\"פנחס גדליה פאשטר\">פנחס גדליה פאשטר</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97_%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"שליח הרבי\">שליח הרבי</a> ל<a href=\"/index.php/%D7%A4%D7%A8%D7%99%D7%96\" title=\"פריז\">פריז</a> מנהל מוסד 'האדרת והאמונה' ב<a href=\"/index.php/%D7%A6%D7%A8%D7%A4%D7%AA\" title=\"צרפת\">צרפת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%91\" title=\"תשפ&quot;ב\">תשפ\"ב</a> - הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%9C%D7%99%D7%A1\" title=\"אברהם יוסף גליס\">אברהם יוסף גליס</a>,  מנכבדי קהילת חב\"ד ב<a href=\"/index.php/%D7%91%D7%A0%D7%99_%D7%91%D7%A8%D7%A7\" title=\"בני ברק\">בני ברק</a></li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%90%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://www.mafteiach.app/likkutei_sichos/by_moad/rosh_chodesh_sivan\">לקוטי שיחות מועדים - ראש חודש סיוון</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9E%D7%A4%D7%AA%D7%97\" title=\"קישור לאתר מפתח\"><img alt=\"קישור לאתר מפתח\" src=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/30px-%D7%9E%D7%A4%D7%AA%D7%97.png\" decoding=\"async\" width=\"30\" height=\"30\" class=\"mw-file-element\" srcset=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/45px-%D7%9E%D7%A4%D7%AA%D7%97.png 1.5x, /images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/60px-%D7%9E%D7%A4%D7%AA%D7%97.png 2x\" /></a></span></li></ul>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - א' בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><i>מה לעומר, <a href=\"/index.php/%D7%A8%D7%90%D7%A9_%D7%97%D7%95%D7%93%D7%A9\" title=\"ראש חודש\">ראש חודש</a>. עד <a href=\"/index.php/%D7%99%22%D7%91_%D7%A1%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"י&quot;ב סיון\">י\"ב בחדש</a> - ועד בכלל - אין אומרים <a href=\"/index.php/%D7%AA%D7%97%D7%A0%D7%95%D7%9F\" title=\"תחנון\">תחנון</a></i>\n<p>זרוק חוטרא לאוירא אעיקריה קאי. נחלה בלי מצרים הנחילו אבותינו רבותינו הקדושים לכבוד <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסידים</a> הראשונים, אשר בני בניהם ובני בנותיהם לדורותיהם, באיזה מדינה וסביבה שיהיו, יהיה אצלם אותו ה\"עיקריה\", והוא המשכת <a href=\"/index.php/%D7%A4%D7%A0%D7%99%D7%9E%D7%99\" class=\"mw-redirect\" title=\"פנימי\">פנימיות</a> ה<a href=\"/index.php/%D7%9C%D7%91\" title=\"לב\">לב</a> אל צור מחצבתו. לפעמים העיקריה מכוסה ונעלם בכמה <a href=\"/index.php/%D7%9C%D7%91%D7%95%D7%A9\" class=\"mw-redirect\" title=\"לבוש\">לבושים</a>, וזאת היא <a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%D7%A9%D7%9D\" title=\"עבודת השם\">עבודת</a> החפץ בחיים להסיר את הכיסוים ולקבוע לו זמני למוד ב<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"תורת החסידות\">תורת החסידות</a> ולנהוג במנהגי עדת החסידים.\n</p>\n</td></tr></tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">יתרו יט, א.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\"><a href=\"/index.php/%D7%9E%D7%A1%D7%9B%D7%AA_%D7%A9%D7%91%D7%AA\" title=\"מסכת שבת\">שבת</a> פו, ב.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">שיחות ר\"ח סיון, ליל ומוצאי ג' <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> תשמ\"ח (התוועדויות ח\"ג ע' 380).</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">למניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%AA%D7%A9%D7%A8%D7%99\" class=\"mw-redirect\" title=\"חודש תשרי\">חודש תשרי</a>, והחודש השלישי\nלמניין החודשים מ<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A0%D7%99%D7%A1%D7%9F\" title=\"חודש ניסן\">חודש ניסן</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413172548\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.116 seconds\nReal time usage: 1.634 seconds\nPreprocessor visited node count: 487/1000000\nPost‐expand include size: 10985/2097152 bytes\nTemplate argument size: 2013/2097152 bytes\nHighest expansion depth: 9/100\nExpensive parser function count: 5/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 1475/5000000 bytes\nLua time usage: 0.090/7 seconds\nLua virtual size: 6291456/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00% 1353.651      1 -total\n 95.15% 1288.039      1 תבנית:פתיח_יום\n 24.31%  329.048      4 תבנית:הערה\n 20.58%  278.635      5 תבנית:מילה_אחרונה\n  9.69%  131.222      1 תבנית:הסר_מילה_ראשונה\n  9.12%  123.430      2 תבנית:מילה_ראשונה\n  7.18%   97.240      1 תבנית:חודש_סיוון\n  4.61%   62.453      1 תבנית:לוח_שנה\n  2.88%   38.969      1 תבנית:הערות_שוליים\n  1.52%   20.599      3 תבנית:רווח\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:22530-0!canonical and timestamp 20260413172548 and revision id 818518. Rendering was triggered because: page-view\n -->\n</div>"
