חיים לוי יצחק גינזבורג</a> · <a href=\"/index.php/%D7%99%D7%95%D7%90%D7%9C_%D7%9B%D7%94%D7%9F\" title=\"יואל כהן\">יואל כהן</a> · <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%27%D7%99%D7%99%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F\" title=\"יוסף יצחק ג&#39;ייקובסון\">יוסף יצחק ג'ייקובסון</a> · <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%94%D7%9B%D7%98\" title=\"יוסף הכט\">יוסף הכט</a> · <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%95%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"יוסף וינברג\">יוסף וינברג</a> · <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%A7%D7%A8%D7%A1%D7%99%D7%A7\" title=\"יוסף קרסיק\">יוסף קרסיק</a> · <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%9E%D7%A9%D7%94_%D7%95%D7%95%D7%9C%D7%91%D7%A8%D7%92\" title=\"יעקב משה וולברג\">יעקב משה וולברג</a> · <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%99%D7%94%D7%95%D7%93%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%90%D7%9C%D7%98%D7%99%D7%99%D7%9F\" title=\"יעקב יהודה לייב אלטיין\">יעקב יהודה לייב אלטיין</a> · <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%9F_%D7%94%D7%95%D7%9C%D7%A6%D7%91%D7%A8%D7%92\" title=\"נחמן הולצברג\">נחמן הולצברג</a>  · <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%9F_%D7%A9%D7%A4%D7%99%D7%A8%D7%90\" title=\"נחמן שפירא\">נחמן שפירא</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%9E%D7%95%D7%9F_%D7%92%27%D7%99%D7%A7%D7%95%D7%91%D7%A1%D7%95%D7%9F\" title=\"סימון ג&#39;יקובסון\">סימון ג'יקובסון</a> · <a href=\"/index.php/%D7%A6%D7%91%D7%99_%D7%99%D7%97%D7%99%D7%90%D7%9C_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%9C%D7%98\" title=\"צבי יחיאל גרינבלט\">צבי יחיאל גרינבלט</a> · <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%93%D7%95%D7%91%D7%A2%D7%A8_%D7%9C%D7%95%D7%99%D7%98%D7%99%D7%9F\" title=\"שלום דובער לויטין\">שלום דובער לויטין</a> · <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%9D_%D7%97%D7%A8%D7%99%D7%98%D7%95%D7%A0%D7%95%D7%91_(%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1)\" title=\"שלום חריטונוב (קראון הייטס)\">שלום חריטונוב</a>\n</td></tr>\n</tbody></table>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">\". . וואס וועט זיין דער פירוש פון ר\"ת מיט מנחם שמו, משיח צדקנו? . . (בחיוך:) מ'זאל ניט אויפרייצן די וועלט מיטן אופן הידוע וכו' . . ווערט דאס די ר\"ת <b>ת</b>הי <b>ש</b>נת <b>ד</b>ברי <b>מ</b>שיח, ובמהרה בימינו ממש לערנען תורתו של משיח מפיו של משיח, ובשמחה ובטוב לבב\". (שיחת ליל ער\"ה תשד\"מ)</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">וג' כרכים משנת <a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a>.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">החומר על חלוקות הדולרים נלקט מתוך גליונות <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%99%D7%99%D7%A0%D7%95_(%D7%92%D7%99%D7%9C%D7%99%D7%95%D7%9F)\" title=\"בית חיינו (גיליון)\">בית חיינו</a>, 'יומן <a href=\"/index.php/%D7%A4%D7%90%D7%A7%D7%A1_%D7%90_%D7%A9%D7%99%D7%97%D7%94\" title=\"פאקס א שיחה\">פאקס א שיחה</a>' ויומנים נוספים ומסרטי הוידאו של אותם שנים וחלק ממנו מתפרסם בספר בפעם הראשונה.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">יחידויות רבות נדפסות בספר לראשונה, ראו לדוגמה לחברי <a rel=\"nofollow\" class=\"external text\" href=\"http://www.teshura.com/teshurapdf/Rosenfeld-Dashif%20-%20Adar%20I%208%205779.pdf\">ה'קרן לפיתוח - מחנה ישראל'</a>.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">היומן נערך ע\"פ מספר יומנים שי\"ל בשעתו (על ידי מערכת \"פאַקס אַ שיחה\"; בגיליון \"<a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%97%D7%99%D7%99%D7%A0%D7%95_(%D7%92%D7%99%D7%9C%D7%99%D7%95%D7%9F)\" title=\"בית חיינו (גיליון)\">בית חיינו</a>\"; בשבועון \"<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93_(%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F)\" title=\"כפר חב&quot;ד (שבועון)\">כפר חב\"ד</a>\"), ובו שולבו גם קטעים מיומנים פרטיים של תלמידי התמימים שלמדו ב-770 באותה תקופה, תלמידי ה\"<a href=\"/index.php/%D7%A7%D7%91%D7%95%D7%A6%D7%94\" title=\"קבוצה\">קבוצה</a>\", אורחים וכיוצא בזה, ועוד פרטים ע\"פ קטעי וידאו, זכרונותים של בעלי המעשה וכיוצא בזה.</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">^</a></span> <span class=\"reference-text\">כי המטרה בהדפסתן היא להגיש את דברי הרבי \"כנתינתן מסיני\", ללא שינוי, גרעון ותוספת ורק במקרים אחדים נוספו תיבות-קישור אחדות בסוגריים מרובעים, וכן הערות אחדות עם ציטוט מה<a href=\"/index.php/%D7%94%D7%A0%D7%97%D7%94\" title=\"הנחה\">הנחה</a> בלה\"ק, כאשר חסרות איזה תיבות בהקלטה, או כדי להקל על הבנת הלומד.</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://torasmoshiach.com/בשורה-טובה-דברי-משיח-תשלח/\">בשורה טובה: דברי משיח תשל\"ח</a>.</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">^</a></span> <span class=\"reference-text\">התכנון הראשוני של הוצאת סדרה זו, הייתה לחלק את הסדרה לג' חלקים: שתי חלקים משנת תשנ\"ג ואחד משנת תשנ\"ד, כפי שנכתב ב\"פתח דבר\" לימי משיח תשנ\"ג ח\"א. אך בשל סיבות טכניות אוחדו חלק ב' וג' ונכנסו לכרך אחד.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260414033514\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.111 seconds\nReal time usage: 0.223 seconds\nPreprocessor visited node count: 554/1000000\nPost‐expand include size: