    "text": {
      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/1/15/%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C.jpg/250px-%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C.jpg\" decoding=\"async\" width=\"250\" height=\"166\" class=\"mw-file-element\" srcset=\"/images/thumb/1/15/%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C.jpg/375px-%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C.jpg 1.5x, /images/1/15/%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C.jpg 2x\" /></a><figcaption>ОћОеОЉ ОЎОЕОЉОбОЮ ОАОњОю</figcaption></figure>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%94%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA_%D7%91%D7%A2%D7%95%D7%9C%D7%9D.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/8/81/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%94%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA_%D7%91%D7%A2%D7%95%D7%9C%D7%9D.jpg/200px-%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%94%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA_%D7%91%D7%A2%D7%95%D7%9C%D7%9D.jpg\" decoding=\"async\" width=\"200\" height=\"302\" class=\"mw-file-element\" srcset=\"/images/thumb/8/81/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%94%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA_%D7%91%D7%A2%D7%95%D7%9C%D7%9D.jpg/300px-%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%94%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA_%D7%91%D7%A2%D7%95%D7%9C%D7%9D.jpg 1.5x, /images/thumb/8/81/%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%94%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA_%D7%91%D7%A2%D7%95%D7%9C%D7%9D.jpg/400px-%D7%A7%D7%95%D7%A0%D7%98%D7%A8%D7%A1_%D7%94%D7%94%D7%A9%D7%92%D7%97%D7%94_%D7%94%D7%90%D7%9C%D7%95%D7%A7%D7%99%D7%AA_%D7%91%D7%A2%D7%95%D7%9C%D7%9D.jpg 2x\" /></a><figcaption>ОДОЋОаОўОеОА ОћОћОЕОњОЌОћ ОћОљОюОЋОДОЎОф ОЉОбОЋОюОЮ</figcaption></figure>\n<p>ОћОеОЉ <b>ОЎОЕОЉОбОЮ ОћОюОЋОЎ ОАОњОю</b> (ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%94%27_%D7%91%D7%AA%D7%9E%D7%95%D7%96\" title=\"Оћ&#39; ОЉОфОъОЋОќ\">Оћ' ОЉОфОъОЋОќ</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%95\" title=\"ОфОеОд&quot;ОЋ\">ОфОеОд\"ОЋ</a>) ОћОЎОаОЋ ОъОеОдОћ ОЋОъОЌОЉОе ОАОцОеОЎОЮ ОЉ<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ОфОЋОеОф ОћОЌОАОЎОЊОЋОф\">ОфОЋОеОф ОћОЌОАОЎОЊОЋОф</a>, ОъОЕОъОЕ ОЏ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЉОЏОцОе ОЌОЉ\"ОЊ. ОЉОбОЉОе ОћОЎОћ <a href=\"/index.php/%D7%A9%D7%9C%D7%95%D7%97%D7%99_%D7%94%D7%A8%D7%91%D7%99\" title=\"ОЕОюОЋОЌОЎ ОћОеОЉОЎ\">ОЕОюОЎОЌ ОћОеОЉОЎ</a> ОЋОъОаОћОю ОЉОЎОф ОАОцОе ОЌОЉ\"ОЊ ОЉОъОЋОЕОЉ ОЉОеОЋОЕ.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.AA.D7.95.D7.9C.D7.93.D7.95.D7.AA_.D7.97.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОфОЋОюОЊОЋОф_ОЌОЎОЎОЮ\">ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;veaction=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;action=edit&amp;section=1\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОфОЋОюОЊОЋОф ОЌОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ОаОЋОюОЊ ОЉ<a href=\"/index.php/%D7%94%27_%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"Оћ&#39; ОфОъОЋОќ\">Оћ' ОфОъОЋОќ</a> ОЉОЕОаОф <a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%95\" title=\"ОфОеОд&quot;ОЋ\">ОфОеОд\"ОЋ</a> ОюОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A6%D7%91%D7%99_%D7%A1%D7%92%D7%9C\" title=\"ОъОЕОћ ОдОЉОЎ ОАОњОю\">ОъОЕОћ ОдОЉОЎ ОАОњОю</a>. ОЉОЎОюОЊОЋОфОЋ ОЕОюОЌ ОљОЋОфОЋ ОљОЉОЎОЋ ОюОЉОЎОф ОАОцОе 'ОњОљОЋОюОћ' ОЕОю ОфОаОЋОбОф ОћОъОќОеОЌОЎ ОЏОЊОЎ ОЕОЎОюОъОЊ ОЉОбОЉОеОЎОф, ОљОџ ОЏОЕОеОљОћ ОљОф ОћОъОдОЉ ОћОеОЋОЌОаОЎ ОћОЎОеОЋОЊ ОЕОю ОћОъОЋОеОћ ОЉОЉОЎОф ОћОАОцОе ОћОбОЉОЎОеОЋ Ою'ОЎОЉОаОћ' - ОъОЏОЎОаОћ ОЕОю <a href=\"/index.php?title=%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%97%D7%91%D7%A8%D7%95%D7%9F&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"ОЎОЕОЎОЉОф ОЌОЉОеОЋОЪ (ОћОЊОБ ОљОЎОаОЋ ОДОЎОЎОЮ)\">ОЎОЕОЎОЉОф ОЌОЉОеОЋОЪ</a>, ОбОю ОљОБ ОЕОћОюОЎОъОЋОЊ ОЉОЋ ОћОЎОћ ОЉ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"ОљОЎОЊОЎОЕ\">ОљОЎОЊОЎОЕ</a>. ОЕОЮ ОюОъОЊ ОбОЊ ОњОЎОю 16.\n</p><p>ОЌОдОЎ ОЕОаОћ ОъОфОЋОџ ОЕОаОЋОфОЎОЋ ОЉОъОЋОАОЊОЋОф ОЎОЕОЎОЉОф ОЌОЉОеОЋОЪ ОюОъОЊ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%90%D7%97%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91\" title=\"ОљОЌОЎ ОфОъОЎОъОЎОЮ ОфОю ОљОЉОЎОЉ\">ОљОЌОЎ ОфОъОЎОъОЎОЮ ОфОю ОљОЉОЎОЉ</a>. \n</p><p>ОЉОъОћОюОџ ОЕОаОЎОЮ ОљОюОЋ ОЊОљОњ ОљОЉОЎОЋ ОюОћОЉОЎОљОЋ Ою<a href=\"/index.php/%D7%94%D7%AA%D7%95%D7%95%D7%A2%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ОћОфОЋОЋОбОЊОЋОф\">ОћОфОЋОЋОбОЊОЋОЎОЋОф ОЌОАОЎОЊОЎОЋОф</a> ОЋОюОюОъОЋОЊ ОљОЎОфОЋ ОЉОљОЋОцОЪ ОцОеОўОЎ ОъОфОЋОџ ОАОцОе Оћ<a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"ОфОаОЎОљ\">ОфОаОЎОљ</a>.\n</p><p>ОћОЌОю ОъОфОДОЋОцОф ОћОюОЎОъОЋОЊОЎОЮ ОЕОљОЌОеОЎ <a href=\"/index.php/%D7%A4%D7%A1%D7%97\" title=\"ОцОАОЌ\">ОцОАОЌ</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%92\" title=\"ОфОЕОЎ&quot;Оњ\">ОфОЕОЎ\"Оњ</a> ОћОЌОю ОюОюОъОЋОЊ ОЉОЎОЕОЎОЉОф <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОЏОцОе ОЌОЉ&quot;ОЊ\">ОфОЋОъОЏОЎ ОфОъОЎОъОЎОЮ ОЉОюОЋОЊ</a> ОЉОЕОаОЋОф ОћОЎОЋ\"ОЊОЎОЮ, ОЕОЮ ОћОЎОћ ОюОъОЋОЕОцОб ОЕОю ОћОеОЉ <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%97%D7%99%D7%99%D7%9D_%D7%A7%D7%A1%D7%9C%D7%9E%D7%9F\" title=\"ОЕОюОъОћ ОЌОЎОЎОЮ ОДОАОюОъОЪ\">ОЕОюОъОћ ОЌОЎОЎОЮ ОДОАОюОъОЪ</a>.\n</p><p>ОћОфОЌОфОЪ ОЉ<a href=\"/index.php/%D7%9B%22%D7%93_%D7%A1%D7%99%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ОЏ&quot;ОЊ ОАОЎОЋОЪ\">ОЏ\"ОЊ ОАОЎОЋОЪ</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%9B%22%D7%91\" title=\"ОфОЕОЏ&quot;ОЉ\">ОфОЕОЏ\"ОЉ</a> ОбОЮ ОъОеОф ОЌОаОћ ОцОбОАОЎОљ, ОЉОфОЋ ОЕОю Ое' ОъОаОЌОЮ ОъОбОаОЊОю ОћОеОЕОДОЋОЉОЎОЦ.\n</p><p>ОћОеОЉ ОАОњОю ОаОЎОћОю ОЉОъОЕОџ ОЕОаОЎОЮ ОеОЉОЋОф ОЉОфОЎ ОАОцОе ОЌОЉ\"ОЊ ОЉОЎОЕОЋОЉ ОЉОеОЋОЕ ОЋОЉОъОДОЋОъОЋОф ОаОЋОАОцОЎОЮ ОъОўОбОЮ <a href=\"/index.php/%D7%A8%D7%A9%D7%AA_%D7%90%D7%94%D7%9C%D7%99_%D7%99%D7%95%D7%A1%D7%A3_%D7%99%D7%A6%D7%97%D7%A7\" title=\"ОеОЕОф ОљОћОюОЎ ОЎОЋОАОБ ОЎОдОЌОД\">ОеОЕОф ОљОћОюОЎ ОЎОЋОАОБ ОЎОдОЌОД</a>. \n</p><p>ОљОЌОЊ ОъОфОюОъОЎОЊОЎОЋ ОЉОЉОЎОф ОАОцОе ОЌОЉ\"ОЊ ОЉОъОЋОЕОЉ ОЉОеОЋОЕ ОћОЎОћ ОћОеОЉ <a href=\"/index.php/%D7%99%D7%95%D7%A8%D7%9D_%D7%90%D7%91%D7%A8%D7%92%27%D7%9C\" title=\"ОЎОЋОеОЮ ОљОЉОеОњ&#39;Ою\">ОЎОЋОеОЮ ОљОЉОеОњ'Ою</a>, ОбОюОЎОЋ ОћОЕОцОЎОб ОбОъОЋОДОЋОф ОЋОЌОЕОБ ОљОЋОфОЋ ОюОАОцОе Оћ<a href=\"/index.php/%D7%AA%D7%A0%D7%99%D7%90\" class=\"mw-redirect\" title=\"ОфОаОЎОљ\">ОфОаОЎОљ</a><sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>ОЏОљОЕОе ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%94%D7%9C%D7%A4%D7%A8%D7%99%D7%9F\" title=\"ОЎОЕОеОљОю ОћОюОцОеОЎОЪ\">ОЎОЕОеОљОю ОћОюОцОеОЎОЪ</a> ОћОњОЎОб ОюОЕОЉОф ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a> ОћОЋОљ ОћОфОљОеОЌ ОљОдОю ОћОеОЉ ОАОњОю ОЕОћОЕОцОЎОб ОбОюОЎОЋ ОбОъОЋОДОЋОф ОЋОћОЎОћ ОЉОћОъОЕОџ Оћ<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"ОъОЕОцОЎОб\">ОъОЕОцОЎОб</a> ОЕОюОЋ<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>. \n</p><p>ОћОеОЉ ОАОњОю ОъОЋОАОе ОЕОЎОбОЋОе ОДОЉОЋОб ОЉ<a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8\" title=\"ОъОљОъОе\">ОъОљОъОеОЎ</a> <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA_%D7%97%D7%91%22%D7%93\" title=\"ОЌОАОЎОЊОЋОф ОЌОЉ&quot;ОЊ\">ОЌОАОЎОЊОЋОф ОЌОЉ\"ОЊ</a> ОЉОЉОЎОфОЋ ОъОЎОЊОЎ ОЎОЋОЮ ОеОЉОЎОбОЎ.\n</p><p>ОЉОъОЕОџ ОЕОаОЎОЮ ОеОЉОЋОф ОћОЎОћ ОъОњОЎОб ОюОЌОЋОЊОЕ ОфОЕОеОЎ ОљОю <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a>.\n</p><p>ОћОеОЉ ОАОњОю ОфОЋОъОџ ОаОюОћОЉ ОЉОцОбОЋОюОЋОф ОЋОЏОЎОаОЋОАОЎ <a href=\"/index.php/%D7%94%D7%90%D7%92%D7%95%D7%93%D7%94_%D7%9C%D7%9E%D7%A2%D7%9F_%D7%94%D7%92%D7%90%D7%95%D7%9C%D7%94_%D7%94%D7%90%D7%9E%D7%99%D7%AA%D7%99%D7%AA_%D7%95%D7%94%D7%A9%D7%9C%D7%99%D7%9E%D7%94\" title=\"ОћОљОњОЋОЊОћ ОюОъОбОЪ ОћОњОљОЋОюОћ ОћОљОъОЎОфОЎОф ОЋОћОЕОюОЎОъОћ\">ОћОљОњОЋОЊОћ ОюОъОбОЪ ОћОњОљОЋОюОћ ОћОљОъОЎОфОЎОф ОЋОћОЕОюОЎОъОћ</a>. ОЏОъОЋ ОЏОЪ ОЎОдОљ ОъОАОцОе ОЕОаОЎОЮ ОЎОЌОЊ ОбОЮ ОћОеОЉ <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%9C%D7%95%D7%99_%D7%99%D7%A6%D7%97%D7%A7_%D7%92%D7%99%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" title=\"ОЌОЎОЎОЮ ОюОЋОЎ ОЎОдОЌОД ОњОЎОаОќОЉОЋОеОњ\">ОЌОЎОЎОЮ ОюОЋОЎ ОЎОдОЌОД ОњОЎОаОќОЉОЋОеОњ</a> ОюОдОъОфОЎОЮ ОюОћОЌОфОЎОЮ ОЎОћОЋОЊОЎОЮ ОбОю <a href=\"/index.php/%D7%A7%D7%91%D7%9C%D7%AA_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA%D7%95_%D7%A9%D7%9C_%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"ОДОЉОюОф ОъОюОЏОЋОфОЋ ОЕОю ОъОюОџ ОћОъОЕОЎОЌ\">ОДОЉОюОф ОъОюОЏОЋОфОЋ ОЕОю ОћОеОЉОЎ ОъОюОџ ОћОъОЕОЎОЌ</a>.\n</p><p>ОћОеОЉ ОЎОЕОЉОбОЮ ОЏОфОЉ ОъОљОъОеОЎОЮ ОеОЉОЎОЮ ОЉ<a href=\"/index.php/%D7%A9%D7%91%D7%95%D7%A2%D7%95%D7%9F_%D7%91%D7%99%D7%AA_%D7%9E%D7%A9%D7%99%D7%97\" class=\"mw-redirect\" title=\"ОЕОЉОЋОбОЋОЪ ОЉОЎОф ОъОЕОЎОЌ\">ОЕОЉОЋОбОЋОЪ ОЉОЎОф ОъОЕОЎОЌ</a> ОЉОаОЋОЕОљ ОЌОЕОЎОЉОЋОф ОћОљОъОЋОаОћ ОЉ<a href=\"/index.php/%D7%A0%D7%A6%D7%97%D7%99%D7%95%D7%AA_%D7%97%D7%99%D7%99%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99\" title=\"ОаОдОЌОЎОЋОф ОЌОЎОЎОЋ ОЕОю ОћОеОЉОЎ\">ОЌОЎОЎОЋ ОћОаОдОЌОЎОЎОЮ</a> ОЕОю <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a>, ОъОљОъОеОЎОЮ ОфОЋОеОаОЎОЎОЮ ОЉОДОЉОдОЎ <a href=\"/index.php/%D7%94%D7%A2%D7%A8%D7%95%D7%AA_%D7%94%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"ОћОбОеОЋОф ОћОфОъОЎОъОЎОЮ\">ОћОбОеОЋОф ОћОфОъОЎОъОЎОЮ</a> ОћОЕОЋОаОЎОЮ ОЋОЏОЪ ОцОеОАОЮ ОўОЋОеОЎОЮ ОЋОЌОЋОЉОеОЋОф ОЉОаОЋОЕОљОЎОЮ ОЕОЋОаОЎОЮ.\n</p><p>ОъОфОњОЋОеОе ОЉ<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЏОцОе ОЌОЉ\"ОЊ</a> ОЋОЎОЋОдОљ Ою<a href=\"/index.php/%D7%9E%D7%91%D7%A6%D7%A2_%D7%AA%D7%A4%D7%99%D7%9C%D7%99%D7%9F\" title=\"ОъОЉОдОб ОфОцОЎОюОЎОЪ\">ОъОЉОдОб ОфОцОЎОюОЎОЪ</a> ОЉОДОЉОЎОбОЋОф ОЉ<a href=\"/index.php/%D7%A8%D7%90%D7%A9%D7%95%D7%9F_%D7%9C%D7%A6%D7%99%D7%95%D7%9F\" title=\"ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ\">ОеОљОЕОЋОЪ ОюОдОЎОЋОЪ</a> ОћОАОъОЋОЏОћ. ОъОфОЋОъОЏОЎ <a href=\"/index.php/%D7%97%D7%93%D7%A8_%D7%90%D7%95%D7%A8_%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ОЌОЊОе ОљОЋОе ОюОЎОЋОЉОљОЋОЋОЎОўОЕ\">ОЌОЊОе ОљОЋОе ОюОЎОЋОЉОљОЋОЋОЎОўОЕ</a>. ОЉОбОЉОе ОћОЎОћ ОъОАОе ОЕОЎОбОЋОеОЎОЮ ОЉОфОЎОЏОЋОЪ <a href=\"/index.php/%D7%91%D7%99%D7%AA_%D7%A8%D7%91%D7%A7%D7%94_%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"ОЉОЎОф ОеОЉОДОћ ОЏОцОе ОЌОЉ&quot;ОЊ\">ОЉОЎОф ОеОЉОДОћ</a>.\n</p>\n<h2><span id=\".D7.9E.D7.A9.D7.A4.D7.97.D7.AA.D7.95\"></span><span class=\"mw-headline\" id=\"ОъОЕОцОЌОфОЋ\">ОъОЕОцОЌОфОЋ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;veaction=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОъОЕОцОЌОфОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;action=edit&amp;section=2\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОъОЕОцОЌОфОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div align=\"right\" style=\"border: 1px solid #ddd;font-size:smaller; text-align: right; padding:5px 1em 5px 1em; width: auto;\">ОцОеОД ОќОћ ОюОЋОДОћ ОЉОЌОАОе. ОљОаОљ <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%94:%D7%9B%D7%AA%D7%99%D7%91%D7%94_%D7%91%D7%97%D7%91%22%D7%93%D7%A4%D7%93%D7%99%D7%94\" title=\"ОбОќОеОћ:ОЏОфОЎОЉОћ ОЉОЌОЉ&quot;ОЊОцОЊОЎОћ\">ОфОеОъОЋ</a> ОюОЌОЉ\"ОЊОцОЊОЎОћ ОЋОћОЕОюОЎОъОЋ ОљОЋОфОЋ. ОЎОфОЏОЪ ОЕОЎОЕ ОбОю ОЏОџ ОцОЎОеОЋОў ОЉ<a href=\"/index.php/%D7%A9%D7%99%D7%97%D7%94:%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C\" title=\"ОЕОЎОЌОћ:ОЎОЕОЉОбОЮ ОАОњОю\">ОЊОБ ОћОЕОЎОЌОћ</a>. \n</div>\n<dl><dt>ОљОЌОЎОЋ</dt></dl>\n<ul><li>ОћОеОЉ ОбОъОЎОЕОе ОћОюОЋОЎ ОАОњОю</li>\n<li>ОћОеОЉ ОЎОЊОЋОЪ ОћОюОЋОЎ ОАОњОю</li></ul>\n<dl><dt>ОњОЎОАОЎОЋ</dt></dl>\n<ul><li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A4%D7%99%D7%99%D7%91%D7%99%D7%A9_%D7%92%D7%99%D7%A0%D7%96%D7%91%D7%95%D7%A8%D7%92\" class=\"mw-redirect\" title=\"ОЎОдОЌОД ОцОЎОЎОЉОЎОЕ ОњОЎОаОќОЉОЋОеОњ\">ОЎОдОЌОД ОцОЎОЎОЉОЎОЕ ОњОЎОаОќОЉОЋОеОњ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93)\" title=\"ОъОЕОћ ОќОюОъОЪ ОЕОаОЎОљОЋОеОАОЋОЪ (ОЏОцОе ОЌОЉ&quot;ОЊ)\">ОъОЕОћ ОќОюОъОЪ ОЕОаОЎОљОЋОеОАОЋОЪ (ОЏОцОе ОЌОЉ\"ОЊ)</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%90%D7%95%D7%A8%D7%99_%D7%A7%D7%A4%D7%9C%D7%95%D7%9F\" title=\"ОљОЋОеОЎ ОДОцОюОЋОЪ\">ОљОЋОеОЎ ОДОцОюОЋОЪ</a>.</li>\n<li>ОћОеОЉ <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A6%D7%99%D7%A8%D7%A7%D7%95%D7%A1\" title=\"ОЎОбОДОЉ ОдОЎОеОДОЋОА\">ОЎОбОДОЉ ОдОЎОеОДОЋОА</a>.</li>\n<li>ОћОеОЉ ОъОеОЊОЏОЎ ОћОеОЕОДОЋОЉОЎОЦ.</li></ul>\n<dl><dt>ОЉОаОЎОЋ ОЋОЉОаОЋОфОЎОЋ</dt></dl>\n<ul><li>ОљОЕОфОЋ ОЌОаОћ ОцОбОАОЎОљ - ОаОцОўОеОћ <a href=\"/index.php/%D7%9B%22%D7%92_%D7%90%D7%93%D7%A8_%D7%91%27\" class=\"mw-redirect\" title=\"ОЏ&quot;Оњ ОљОЊОе ОЉ&#39;\">ОЏ\"Оњ ОљОЊОе ОЉ'</a> <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"ОфОЕОа&quot;Оћ\">ОфОЕОа\"Оћ</a>.</li>\n<li>ОЉОаОЋ Ое' ОЎОЋОАОБ ОЎОдОЌОД ОАОњОю, ОЏОцОе ОЌОЉ\"ОЊ</li>\n<li>ОЉОаОЋ Ое' ОЕОюОЋОЮ ОЊОЋОЉОбОе ОАОњОю, <a href=\"/index.php/%D7%91%D7%99%D7%AA%D7%A8_%D7%A2%D7%99%D7%9C%D7%99%D7%AA\" title=\"ОЉОЎОфОе ОбОЎОюОЎОф\">ОЉОЎОфОе ОбОЎОюОЎОф</a></li>\n<li>ОЉОфОЋ ОЕОеОћ ОеОбОЎОЎОф ОћОеОЉ <a href=\"/index.php/%D7%90%D7%A8%D7%99%D7%94_%D7%A6%D7%91%D7%99_%D7%92%D7%A8%D7%99%D7%A0%D7%91%D7%A8%D7%92\" title=\"ОљОеОЎОћ ОдОЉОЎ ОњОеОЎОаОЉОеОњ\">ОљОеОЎОћ ОдОЉОЎ ОњОеОЎОаОЉОеОњ</a>, <a href=\"/index.php/%D7%A9%D7%9C%D7%99%D7%97%D7%95%D7%AA\" title=\"ОЕОюОЎОЌОЋОф\">ОЕОюОЋОЌОЎ ОћОеОЉОЎ</a> ОЉОЎОЎОЕОЋОЉ ОъОќОЏОеОф ОЉОфОЎОћ</li>\n<li>ОЉОфОЋ ОеОЉОДОћ ОеОбОЎОЎОф ОћОеОЉ ОЎОбОДОЉ ОўОљОЋОЉОе, <a href=\"/index.php/%D7%A0%D7%99%D7%95_%D7%99%D7%95%D7%A8%D7%A7\" class=\"mw-redirect\" title=\"ОаОЎОЋ ОЎОЋОеОД\">ОаОЎОЋ ОЎОЋОеОД</a></li>\n<li>ОЉОфОЋ ОаОЌОъОћ ОЊОЎОаОћ ОеОбОЎОЎОф Ое' ОЕОюОЋОЮ ОЊОЋОЉОбОе ОюОЉОаОћОеОЦ, ОЏОцОе ОЌОЉ\"ОЊ</li>\n<li>ОЉОаОЋ Ое' ОЕОъОЋОљОю ОЋОЉОф ОЕОЉОб ОАОњОю, ОЕОюОЎОЌ ОћОеОЉОЎ ОЉОЉОеОюОЎОЪ</li></ul>\n<h2><span id=\".D7.97.D7.99.D7.91.D7.95.D7.A8.D7.99.D7.95\"></span><span class=\"mw-headline\" id=\"ОЌОЎОЉОЋОеОЎОЋ\">ОЌОЎОЉОЋОеОЎОЋ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;veaction=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОЌОЎОЉОЋОеОЎОЋ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;action=edit&amp;section=3\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОЌОЎОЉОЋОеОЎОЋ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b>ОАОцОе <a href=\"/index.php/%D7%A2%D7%A8%D7%9B%D7%99%D7%9D_%D7%91%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" class=\"mw-redirect\" title=\"ОбОеОЏОЎОЮ ОЉОЌОАОЎОЊОЋОф\">ОбОеОЏОЎОЮ ОЉОЌОАОЎОЊОЋОф</a></b> - ОЉОЎОљОЋОе ОъОЋОЕОњОЎОЮ, ОъОЕОюОЎОЮ, ОцОфОњОъОЎОЮ, ОцОАОЋОДОЎОЮ ОЋОъОљОъОеОЎ ОЌОќ\"Ою ОбОю ОцОЎ <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ОфОЋОеОф ОћОЌОАОЎОЊОЋОф\">ОфОЋОеОф ОћОЌОАОЎОЊОЋОф</a>. ОЉОЌОЋОЊОЕ <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"ОЏОАОюОЋ\">ОЏОАОюОЋ</a> ОЕОаОф <a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%97\" title=\"ОфОЕОа&quot;ОЌ\">ОфОЕОа\"ОЌ</a> ОЎОдОљ ОюОљОЋОе ОћОЌОюОД ОћОеОљОЕОЋОЪ. ОћОЌОюОД ОћОЕОаОЎ ОЉОбОеОЎОЏОћ, ОЋОбОеОЏОЎОЮ ОъОъОаОЋ ОцОЋОеОАОъОЋ ОЉОъОДОЋОъОЋОф ОЕОЋОаОЎОЮ.<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%97%D7%A1%D7%99%D7%93_%D7%91%D7%90%D7%9E%D7%95%D7%A0%D7%AA%D7%95.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/c/c2/%D7%97%D7%A1%D7%99%D7%93_%D7%91%D7%90%D7%9E%D7%95%D7%A0%D7%AA%D7%95.jpg/200px-%D7%97%D7%A1%D7%99%D7%93_%D7%91%D7%90%D7%9E%D7%95%D7%A0%D7%AA%D7%95.jpg\" decoding=\"async\" width=\"200\" height=\"133\" class=\"mw-file-element\" srcset=\"/images/thumb/c/c2/%D7%97%D7%A1%D7%99%D7%93_%D7%91%D7%90%D7%9E%D7%95%D7%A0%D7%AA%D7%95.jpg/300px-%D7%97%D7%A1%D7%99%D7%93_%D7%91%D7%90%D7%9E%D7%95%D7%A0%D7%AA%D7%95.jpg 1.5x, /images/thumb/c/c2/%D7%97%D7%A1%D7%99%D7%93_%D7%91%D7%90%D7%9E%D7%95%D7%A0%D7%AA%D7%95.jpg/400px-%D7%97%D7%A1%D7%99%D7%93_%D7%91%D7%90%D7%9E%D7%95%D7%A0%D7%AA%D7%95.jpg 2x\" /></a><figcaption>ОДОЋОаОўОеОА ОЌОАОЎОЊ ОЉОљОъОЋОаОфОЋ ОЎОЌОЎОћ </figcaption></figure></li>\n<li><b>ОЌОАОЎОЊ ОЉОљОъОЋОаОфОЋ ОЎОЌОЎОћ</b> - ОДОЋОаОўОеОА ОћОъОЉОљОе ОљОф ОбОДОеОЋОаОЋОф Оћ<a href=\"/index.php/%D7%90%D7%9E%D7%95%D7%A0%D7%94\" class=\"mw-redirect\" title=\"ОљОъОЋОаОћ\">ОљОъОЋОаОћ</a> ОћОљОъОЎОфОЎОф ОЉОћ' ОЋОЉ<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99\" class=\"mw-redirect\" title=\"ОћОеОЉОЎ\">ОћОеОЉОЎ</a> ОЏ<a href=\"/index.php/%D7%9E%D7%9C%D7%9A_%D7%94%D7%9E%D7%A9%D7%99%D7%97\" title=\"ОъОюОџ ОћОъОЕОЎОЌ\">ОъОюОџ ОћОъОЕОЎОЌ</a> ОбОю ОцОЎ <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%94%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"ОфОЋОеОф ОћОЌОАОЎОЊОЋОф\">ОфОЋОеОф ОћОЌОАОЎОЊОЋОф</a>, ОюОљОЋОеОЮ ОћОфОЌОаОЏОЋ <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"ОЌОАОЎОЊ\">ОЌОАОЎОЊОЎОЮ</a> ОъОљОќ ОЋОъОбОЋОюОЮ.</li>\n<li><b>ОћОћОфОДОЕОеОЋОф</b> - ОћОъОЕОџ ОюОДОЋОаОўОеОА \"ОЌОАОЎОЊ ОЉОљОъОЋОаОфОЋ ОЎОЌОЎОћ\".</li>\n<li><b>ОъОъОЋОдОб ОћОъОЌОЉОе</b> - ОћОъОЕОџ ОюОДОЋОаОўОеОА \"ОћОћОфОДОЕОеОЋОф\".</li>\n<li><b>ОДОЪОаОўОеОА ОћОћОЕОњОЌОћ ОћОљОюОДОЎОф ОЉОбОЋОюОЮ</b>.</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"ОДОЎОЕОЋОеОЎОЮ_ОЌОЎОдОЋОаОЎОЎОЮ\">ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;veaction=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОцОАОДОћ: &quot;ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ&quot;\" class=\"mw-editsection-visualeditor\"><span>ОбОеОЎОЏОћ</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%D7%A9%D7%91%D7%A2%D7%9D_%D7%A1%D7%92%D7%9C&amp;action=edit&amp;section=4\" title=\"ОбОеОЎОЏОф ОДОЋОЊ ОћОъОДОЋОе ОЕОю ОћОцОеОД: ОДОЎОЕОЋОеОЎОЮ ОЌОЎОдОЋОаОЎОЎОЮ\"><span>ОбОеОЎОЏОф ОДОЋОЊ ОъОДОЋОе</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabadlive.org/09rl\">ОћОфОЋОЋОбОЊОЋОф ОъОбОЋОеОеОф ОбОЮ ОћОъОЕОцОЎОб ОћОеОЉ ОЎОЕОЉОбОЮ ОАОњОю</a></b>, 