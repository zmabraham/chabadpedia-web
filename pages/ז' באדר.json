D7%93%D7%A8\" title=\"כ&quot;ח באדר\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%90%D7%93%D7%A8\" title=\"כ&quot;ט באדר\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%90%D7%93%D7%A8\" title=\"ל&#39; באדר\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<dl><dd><dl><dd><small>הבהרה: ערך זה עוסק גם בז&#39; באדר א' וגם בז&#39; באדר ב'.</small></dd></dl></dd></dl>\n<p><b>ז' באדר</b> הוא היום השביעי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%90%D7%93%D7%A8\" title=\"חודש אדר\">חודש אדר</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>ב'שס\"ח (אדר ראשון<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>) - <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%A8%D7%91%D7%99%D7%A0%D7%95\" title=\"משה רבינו\">משה רבינו</a>, מקבל ונותן ה<a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>, נולד ל<a href=\"/index.php/%D7%A2%D7%9E%D7%A8%D7%9D\" title=\"עמרם\">עמרם</a> ו<a href=\"/index.php?title=%D7%99%D7%95%D7%9B%D7%91%D7%93&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"יוכבד (הדף אינו קיים)\">יוכבד</a>.</li>\n<li>ב'תפ\"ח - משה רבינו נפטר.</li>\n<li><a href=\"/index.php?title=%D7%A9%D7%A2%22%D7%98&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שע&quot;ט (הדף אינו קיים)\">שע\"ט</a> - נפטר רבי <a href=\"/index.php?title=%D7%A9%D7%9C%D7%9E%D7%94_%D7%90%D7%A4%D7%A8%D7%99%D7%9D_%D7%9C%D7%95%D7%A0%D7%98%D7%A9%D7%99%D7%A5&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"שלמה אפרים לונטשיץ (הדף אינו קיים)\">שלמה אפרים לונטשיץ</a> מחבר פירוש 'כלי יקר' על התורה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A0%22%D7%94\" title=\"תשנ&quot;ה\">תשנ\"ה</a> (אדר שני) - רבי <a href=\"/index.php/%D7%97%D7%99%D7%99%D7%9D_%D7%A6%D7%99%D7%9E%D7%A8%D7%9E%D7%9F\" class=\"mw-redirect\" title=\"חיים צימרמן\">חיים צימרמן</a>, מגדולי הרבנים בארצות הברית, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%91\" title=\"תשע&quot;ב\">תשע\"ב</a> - רבי <a href=\"/index.php/%D7%99%D7%A9%D7%A9%D7%9B%D7%A8_%D7%91%D7%A2%D7%A8_%D7%A8%D7%95%D7%96%D7%A0%D7%91%D7%95%D7%99%D7%9D\" title=\"יששכר בער רוזנבוים\">יששכר בער רוזנבוים</a>, האדמו\"ר מ<a href=\"/index.php/%D7%A0%D7%93%D7%91%D7%95%D7%A8%D7%A0%D7%90\" class=\"mw-redirect\" title=\"נדבורנא\">נדבורנא</a>, נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\">נולדו</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%96\" title=\"תרפ&quot;ז\">תרפ\"ז</a> - הרב <a href=\"/index.php/%D7%96%D7%95%D7%A1%D7%9E%D7%9F_%D7%A8%D7%91%D7%A7%D7%99%D7%9F\" title=\"זוסמן רבקין\">זוסמן רבקין</a>, מזקני אנ\"ש ב<a href=\"/index.php/%D7%9B%D7%A4%D7%A8_%D7%97%D7%91%22%D7%93\" title=\"כפר חב&quot;ד\">כפר חב\"ד</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%97\" title=\"תרפ&quot;ח\">תרפ\"ח</a> - הרב <a href=\"/index.php/%D7%99%D7%A8%D7%97%D7%9E%D7%99%D7%90%D7%9C_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"ירחמיאל אלפרוביץ&#39;\">ירחמיאל אלפרוביץ'</a>, מזקני חסידי חב\"ד ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%98%22%D7%95\" title=\"תשט&quot;ו\">תשט\"ו</a> - הרב <a href=\"/index.php/%D7%99%D7%95%D7%A1%D7%A3_%D7%91%D7%A8%D7%95%D7%9A_%D7%A4%D7%A8%D7%99%D7%93%D7%9E%D7%9F\" title=\"יוסף ברוך פרידמן\">יוסף ברוך פרידמן</a>, מנהל הוצאת ספרים קה\"ת, חבר ועד מחנה ישראל וממייסדי חברת JEM.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%97\" title=\"תשל&quot;ח\">תשל\"ח</a> - רד\"י רוטמן, בן בתו של ר' <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%91_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"ישראל אריה ליב שניאורסון\">ישראל אריה ליב שניאורסון</a>, אחיו של הרבי מה\"מ.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%96\" title=\"תרצ&quot;ז\">תרצ\"ז</a> - הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%A4%D7%9C%D7%A1%D7%A8\" title=\"שניאור זלמן פלסר\">שניאור זלמן פלסר</a>, מחסידי חב\"ד ב<a href=\"/index.php/%D7%AA%D7%9C_%D7%90%D7%91%D7%99%D7%91-%D7%99%D7%A4%D7%95\" title=\"תל אביב-יפו\">תל אביב-יפו</a>, סוחר ואיש חסד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> (אדר ראשון) - הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A7%D7%95%D7%A4%D7%A8%D7%A9%D7%98%D7%95%D7%9A\" title=\"מנחם מענדל קופרשטוך\">מנחם מענדל קופרשטוך</a>, רבן של העיירות <a href=\"/index.php?title=%D7%A4%D7%A1%D7%98%D7%95%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"פסטוב (הדף אינו קיים)\">פסטוב</a> ו<a href=\"/index.php/%D7%92%D7%9C%D7%95%D7%91%D7%A7%D7%A2\" class=\"mw-redirect\" title=\"גלובקע\">גלובקע</a> ולאחר מכן אב\"ד ב<a href=\"/index.php/%D7%97%D7%99%D7%A4%D7%94\" title=\"חיפה\">חיפה</a>, וסגן יו\"ר <a href=\"/index.php/%D7%90%D7%92%D7%95%22%D7%97_%D7%90%D7%A8%D7%94%22%D7%A7\" class=\"mw-redirect\" title=\"אגו&quot;ח ארה&quot;ק\">אגו\"ח ארה\"ק</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A0%D7%A9%22%D7%90\" title=\"תנש&quot;א\">תנש\"א</a> - ר' <a href=\"/index.php/%D7%90%D7%91%D7%A0%D7%A8_%D7%9C%D7%91%D7%99%D7%95%D7%91\" title=\"אבנר לביוב\">אבנר לביוב</a>, חסיד חב\"ד שמסר את נפשו על שמירת מצוות ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a>, ומראשי התומכים הכספיים בפעילות החב\"דית המחתרתית.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%91\" title=\"תשס&quot;ב\">תשס\"ב</a> - הרב <a href=\"/index.php/%D7%A0%D7%97%D7%95%D7%9D_%D7%95%D7%95%D7%9C%D7%95%D7%A1%D7%95%D7%91\" title=\"נחום וולוסוב\">נחום וולוסוב</a>, חסיד חב\"ד תושב <a href=\"/index.php/%D7%A7%D7%A8%D7%90%D7%95%D7%9F_%D7%94%D7%99%D7%99%D7%98%D7%A1\" title=\"קראון הייטס\">קראון הייטס</a> שהיה אחד מראשי העוסקים בניהול רשת הישיבות המחתרתיות ב<a href=\"/index.php/%D7%91%D7%A8%D7%99%D7%AA_%D7%94%D7%9E%D7%95%D7%A2%D7%A6%D7%95%D7%AA\" title=\"ברית המועצות\">ברית המועצות</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A2%22%D7%98\" title=\"תשע&quot;ט\">תשע\"ט</a> - הרב <a href=\"/index.php/%D7%A2%D7%9E%D7%A8%D7%9D_%D7%91%D7%9C%D7%95%D7%99\" title=\"עמרם בלוי\">עמרם בלוי</a>, מנחה ומרצה, ומנהל קרן חסד מנחם מענדל שעל ידי כולל חב\"ד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%93\" title=\"תשפ&quot;ד\">תשפ\"ד</a> (<a href=\"/index.php/%D7%90%D7%93%D7%A8_%D7%A8%D7%90%D7%A9%D7%95%D7%9F\" class=\"mw-redirect\" title=\"אדר ראשון\">אדר ראשון)</a> - הרב <a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C_%D7%99%D7%95%D7%A1%D7%A3_%D7%92%D7%A8%D7%95%D7%96%D7%9E%D7%9F\" title=\"ישראל יוסף גרוזמן\">ישראל יוסף גרוזמן</a> משלוחי הרבי למינסק.</li></ul>\n<h2><span id=\".D7.9E.D7.A0.D7.94.D7.92.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"מנהגי_חב&quot;ד\">מנהגי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;מנהגי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: מנהגי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>לפי <a href=\"/index.php/%D7%9E%D7%A0%D7%94%D7%92_%D7%97%D7%91%22%D7%93\" class=\"mw-redirect\" title=\"מנהג חב&quot;ד\">מנהג חב\"ד</a> אומרים <a href=\"/index.php/%D7%AA%D7%97%D7%A0%D7%95%D7%9F\" title=\"תחנון\">תחנון</a> ביום זה, אולם <a href=\"/index.php/%D7%A8%D7%91%D7%95%D7%AA%D7%99%D7%A0%D7%95_%D7%A0%D7%A9%D7%99%D7%90%D7%A0%D7%95\" class=\"mw-redirect\" title=\"רבותינו נשיאנו\">רבותינו נשיאנו</a> אינם אומרים תחנון בז' אדר – וכן לא אומרים תחנון בתפילת מנחה שלפניו. (במנהג זה נהגו רבותינו נשיאינו  דווקא לאחר שעלו לנשיאות, אבל לא לפני זה).<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>\n</p><p>הרבי אומר שיש להשתדל להוסיף ביום זה בשמחה של תורה ובשמחה של מצווה, כיוון שנולד בו משה רבינו ע\"ה, מושיען של ישראל<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\nנהוג אצל רובם ככולם שבשנה מעוברת מציינים את ז' אדר באדר ראשון, כפסק המגן אברהם<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup>.אמנם בנוגע לתוכן העניין של ז' אדר, יש מקום לעניין ד\"שבעה באדר\" גם באדר א' וגם באדר ב'<sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\"><span class=\"cite-bracket\">&#91;</span>5<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=6\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=6\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a rel=\"nofollow\" class=\"external text\" href=\"https://www.mafteiach.app/likkutei_sichos/by_moad/7_adar\">לקוטי שיחות מועדים - ז' אדר</a> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%9E%D7%A4%D7%AA%D7%97\" title=\"קישור לאתר מפתח\"><img alt=\"קישור לאתר מפתח\" src=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/30px-%D7%9E%D7%A4%D7%AA%D7%97.png\" decoding=\"async\" width=\"30\" height=\"30\" class=\"mw-file-element\" srcset=\"/images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/45px-%D7%9E%D7%A4%D7%AA%D7%97.png 1.5x, /images/thumb/9/97/%D7%9E%D7%A4%D7%AA%D7%97.png/60px-%D7%9E%D7%A4%D7%AA%D7%97.png 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/beis-medrash/653720/\">התוועדות ז' אדר תשמ\"ה - בתרגום ללשון הקודש</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%AA%D7%91%D7%A0%D7%99%D7%AA:%D7%95%D7%99%D7%93%D7%90%D7%95\" title=\"קובץ וידאו\"><img alt=\"קובץ וידאו\" src=\"/images/thumb/4/46/%D7%95%D7%99%D7%93%D7%90%D7%95.png/16px-%D7%95%D7%99%D7%93%D7%90%D7%95.png\" decoding=\"async\" width=\"16\" height=\"16\" class=\"mw-file-element\" srcset=\"/images/thumb/4/46/%D7%95%D7%99%D7%93%D7%90%D7%95.png/24px-%D7%95%D7%99%D7%93%D7%90%D7%95.png 1.5x, /images/thumb/4/46/%D7%95%D7%99%D7%93%D7%90%D7%95.png/32px-%D7%95%D7%99%D7%93%D7%90%D7%95.png 2x\" /></a></span> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"קישור לאתר חב&quot;ד אינפו\"><img alt=\"קישור לאתר חב&quot;ד אינפו\" src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/29px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"29\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/44px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/58px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/beis-medrash/654110/\">הגהות הרבי לשיחת ז' אדר תשמ\"ח</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%99%D7%A0%D7%A4%D7%95\" title=\"חב&quot;ד אינפו\"><img src=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/27px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg\" decoding=\"async\" width=\"27\" height=\"9\" class=\"mw-file-element\" srcset=\"/images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/41px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 1.5x, /images/thumb/e/ec/%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg/54px-%D7%90%D7%99%D7%A0%D7%A4%D7%95.jpg 2x\" /></a></span></li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"http://www.teshura.com/teshurapdf/%D7%AA%D7%A9%D7%95%D7%A8%D7%94%20%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99.pdf\">מענות וכתבי יד קודש בשייכות לז' אדר</a></b> <span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span></li></ul>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;veaction=edit&amp;section=7\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%96%27_%D7%91%D7%90%D7%93%D7%A8&amp;action=edit&amp;section=7\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>שערי המועדים חודש אדר [מהדורת היכל מנחם, תשע\"ט], עמ' קפג ואילך. \n</p>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">ראה <a rel=\"nofollow\" class=\"external text\" href=\"http://www.hebrewbooks.org/pdfpager.aspx?req=14949&amp;st=&amp;pgnum=294&amp;hilite=\">לקוטי שיחות חלק כ\"ו ע' 204</a>.</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">ראו: ספר-המנהגים עמ' 72. היום יום, חלק שני, סעיף 10 [וראו שם בנוגע לק\"ש שעל המיטה של ליל ז' אדר].ליקוטי שיחות חלק טז, עמ' 351, הערה 79. וראו גם \"המלך במסיבו\", חלק ב, עמ' קנט. בנוגע למנהג הרבי בזה, ראו \"מעשה מלך\", פרק לג, עמ' 317.</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\">התוועדויות' תשמ\"ח ח\"ב עמ' 388. 'התוועדויות' תשמ\"ו ח\"ב עמ' 589. ראו שם בהרחבה.</span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">התוועדויות תשד\"מ, חלק ב, עמ' 1054. עיי\"ש.</span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">^</a></span> <span class=\"reference-text\">שיחות קודש תשנ\"ב חלק ב, עמ' 721.</span>\n</li>\n</ol></div></div>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ז' באדר א' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>כל איש ב<a href=\"/index.php/%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" class=\"mw-redirect\" title=\"ישראל\">ישראל</a> עליו לדעת, כי הוא שליח אדון כל, למען הביא לפועל - בכל מקום שהוא - רצונו יתברך וכוונתו בבריאת העולם, שהם להאיר את העולם ב<a href=\"/index.php/%D7%90%D7%95%D7%A8\" title=\"אור\">אור</a> <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> ו<a href=\"/index.php/%D7%A2%D7%91%D7%95%D7%93%D7%AA_%D7%94%27\" class=\"mw-redirect\" title=\"עבודת ה&#39;\">עבודה</a>, והוא על ידי קיום <a href=\"/index.php/%D7%9E%D7%A6%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מצות\">מצות</a> מעשיות והשרשת <a href=\"/index.php/%D7%9E%D7%93%D7%95%D7%AA_%D7%98%D7%95%D7%91%D7%95%D7%AA\" class=\"mw-redirect\" title=\"מדות טובות\">מדות טובות</a>.\n</td></tr></tbody></table>\n<p><br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - ז' באדר ב' - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td>אז מען געהט אין גאס דארף מען טראכטען דברי <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a> צי אין <a href=\"/index.php/%D7%9E%D7%97%D7%A9%D7%91%D7%94\" title=\"מחשבה\">מחשבה</a> צי אין <a href=\"/index.php/%D7%93%D7%91%D7%95%D7%A8\" class=\"mw-redirect\" title=\"דבור\">דבור</a>, דאס ווענדט זיך, צי מען מעג על פי דין ריידען דארטען דברי תורה. אבער אז ער געהט און איז ניט פארנומען אין דברי תורה, זאגט אים דער שטיין אויף וועמען ער טרעט: בולאך (גולם) וואס טרעסטו אויף מיר? מיט וואס ביסטו העכער פון מיר?\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: כשהולכים ברחוב צריכים לחשוב דברי <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%94\" title=\"תורה\">תורה</a>, אם ב<a href=\"/index.php/%D7%9E%D7%97%D7%A9%D7%91%D7%94\" title=\"מחשבה\">מחשבה</a> אם ב<a href=\"/index.php/%D7%93%D7%99%D7%91%D7%95%D7%A8\" title=\"דיבור\">דיבור</a>, זה תלוי, באם על פי דין מותר לדבר שם דברי תורה. אבל כשהוא הולך ואינו עסוק בדברי תורה, אומרת לו האבן עליו הוא דורך: \"גולם, מה אתה דורך עלי? במה אתה חשוב ממני?\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414104942\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.106 seconds\nReal time usage: 0.395 seconds\nPreprocessor visited node count: 314/1000000\nPost‐expand include size: 8472/2097152 bytes\nTemplate argument size: 461/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 2271/5000000 bytes\nLua time usage: 0.040/7 seconds\nLua virtual size: 5754880/52428800 bytes\nLua estimated memory usage: 0 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%  309.019      1 -total\n 63.86%  197.336      5 תבנית:הערה\n 13.27%   40.994      1 תבנית:הערות_שוליים\n  7.93%   24.509      2 תבנית:להיום_יום\n  4.93%   15.249      1 תבנית:חודש_אדר\n  3.43%   10.585      1 תבנית:לוח_שנה\n  3.20%    9.879      1 תבנית:היום_יום/ז&#039;_אדר_ב&#039;\n  2.92%    9.024      1 תבנית:PDF\n  2.91%    9.000      1 תבנית:הערות_שוליים/מרחב_שם\n  2.74%    8.475      1 תבנית:היום_יום/ז&#039;_אדר_א&#039;\n-->\n\n<!-- Saved in parser cache with key chabadped_1-infopedia_:pcache:idhash:20703-0!canonical and timestamp 20260414104942 and revision id 831401. Rendering was triggered because: diff-page\n -->\n</div>"
