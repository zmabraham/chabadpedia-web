%95%D7%9F\" title=\"כ&quot;ה בסיוון\">כה</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%95_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ו בסיוון\">כו</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%96_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ז בסיוון\">כז</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%97_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ח בסיוון\">כח</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9B%22%D7%98_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"כ&quot;ט בסיוון\">כט</a>\n</td>\n<td bgcolor=\"#EDF3F0\"><a href=\"/index.php/%D7%9C%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"ל&#39; בסיוון\">ל</a>\n</td></tr>\n<tr>\n<th colspan=\"10\" style=\"background;\">\n<p><small><a href=\"/index.php/%D7%AA%D7%A9%D7%A8%D7%99\" title=\"תשרי\">תשרי</a> · <a href=\"/index.php/%D7%97%D7%A9%D7%95%D7%95%D7%9F\" title=\"חשוון\">חשוון</a> · <a href=\"/index.php/%D7%9B%D7%A1%D7%9C%D7%95\" title=\"כסלו\">כסלו</a> · <a href=\"/index.php/%D7%98%D7%91%D7%AA\" title=\"טבת\">טבת</a> · <a href=\"/index.php/%D7%A9%D7%91%D7%98\" title=\"שבט\">שבט</a> · <a href=\"/index.php/%D7%90%D7%93%D7%A8\" class=\"mw-redirect\" title=\"אדר\">אדר</a> <br /> <a href=\"/index.php/%D7%A0%D7%99%D7%A1%D7%9F\" class=\"mw-redirect\" title=\"ניסן\">ניסן</a> · <a href=\"/index.php/%D7%90%D7%99%D7%99%D7%A8\" class=\"mw-redirect\" title=\"אייר\">אייר</a> · <a href=\"/index.php/%D7%A1%D7%99%D7%95%D7%95%D7%9F\" class=\"mw-redirect\" title=\"סיוון\">סיוון</a> · <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> · <a href=\"/index.php/%D7%90%D7%91_(%D7%97%D7%95%D7%93%D7%A9)\" title=\"אב (חודש)\">מנחם אב</a> · <a href=\"/index.php/%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"אלול\">אלול</a></small>\n</p>\n</th></tr></tbody></table>\n<p><b>י' בסיוון</b> הוא היום העשירי ב<a href=\"/index.php/%D7%97%D7%95%D7%93%D7%A9_%D7%A1%D7%99%D7%95%D7%95%D7%9F\" title=\"חודש סיוון\">חודש סיוון</a>.\n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D_.D7.91.D7.99.D7.94.D7.93.D7.95.D7.AA\"></span><span class=\"mw-headline\" id=\"אירועים_ביהדות\">אירועים ביהדות</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;אירועים ביהדות&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: אירועים ביהדות\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%90\" title=\"תקע&quot;א\">תקע\"א</a> – רבי ישמעאל כהן, אב\"ד מודינא שבאיטליה ומחבר הספר 'זרע אמת', נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A7%D7%A2%22%D7%97\" title=\"תקע&quot;ח\">תקע\"ח</a> – רבי בנימין וואלף בוסקוביץ', אב\"ד אסאד, פרוסטיץ' ועוד, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%93\" title=\"תרנ&quot;ד\">תרנ\"ד</a> – רבי משה מרוזאדוב.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%93\" title=\"תש&quot;ד\">תש\"ד</a> – רבי מרדכי רוטנברג, <a href=\"/index.php/%D7%A8%D7%91\" title=\"רב\">רב</a> קהילת יהודי אנטוורפן-בלגיה ומחבר הספר 'יד מרדכי', הועלה על המוקד.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%92\" title=\"תשס&quot;ג\">תשס\"ג</a> – רבי שמחה רובין, ה<a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8\" title=\"אדמו&quot;ר\">אדמו\"ר</a> מ<a href=\"/index.php?title=%D7%A1%D7%90%D7%A1%D7%95%D7%91&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"סאסוב (הדף אינו קיים)\">סאסוב</a>-<a href=\"/index.php/%D7%9C%D7%95%D7%A0%D7%93%D7%95%D7%9F\" title=\"לונדון\">לונדון</a>, נפטר.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A4%22%D7%92\" title=\"תשפ&quot;ג\">תשפ\"ג</a> – הרב <a href=\"/index.php/%D7%92%D7%A8%D7%A9%D7%95%D7%9F_%D7%90%D7%93%D7%9C%D7%A9%D7%98%D7%99%D7%99%D7%9F\" class=\"mw-redirect\" title=\"גרשון אדלשטיין\">גרשון אדלשטיין</a>, מנהיג הציבור הליטאי וראש ישיבת פונוביז', נפטר.</li></ul>\n<h2><span id=\".D7.99.D7.9E.D7.99_.D7.97.D7.91.22.D7.93\"></span><span class=\"mw-headline\" id=\"ימי_חב&quot;ד\">ימי חב\"ד</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;ימי חב&quot;ד&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: ימי חב&quot;ד\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span id=\".D7.90.D7.99.D7.A8.D7.95.D7.A2.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"אירועים\">אירועים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;אירועים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: אירועים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%9B%22%D7%94\" title=\"תרכ&quot;ה\">תרכ\"ה</a> – <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> בא בקשרי <a href=\"/index.php/%D7%A9%D7%99%D7%93%D7%95%D7%9A\" title=\"שידוך\">השידוכים</a> עם מרת <a href=\"/index.php/%D7%A9%D7%98%D7%A2%D7%A8%D7%A0%D7%90_%D7%A9%D7%A8%D7%94_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%A9%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91)\" title=\"שטערנא שרה שניאורסון (אשת אדמו&quot;ר הרש&quot;ב)\">שטערנא שרה שניאורסון</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%91\" title=\"תרצ&quot;ב\">תרצ\"ב</a> – הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%94%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"מנחם מענדל הורנשטיין\">מנחם מענדל הורנשטיין</a> התחתן עם מרת <a href=\"/index.php/%D7%A9%D7%99%D7%99%D7%A0%D7%90_%D7%94%D7%95%D7%A8%D7%A0%D7%A9%D7%98%D7%99%D7%99%D7%9F\" title=\"שיינא הורנשטיין\">שיינא</a>, בת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A5\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;ץ\">אדמו\"ר הריי\"ץ</a></li></ul>\n<h3><span id=\".D7.A0.D7.95.D7.9C.D7.93.D7.95\"></span><span class=\"mw-headline\" id=\"נולדו\"><a href=\"/index.php/%D7%99%D7%95%D7%9D_%D7%94%D7%95%D7%9C%D7%93%D7%AA\" title=\"יום הולדת\">נולדו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;נולדו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: נולדו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%90\" title=\"תרפ&quot;א\">תרפ\"א</a> - הרב <a href=\"/index.php/%D7%99%D7%94%D7%95%D7%A9%D7%A2_%D7%A7%D7%9C%D7%99%D7%99%D7%A0%D7%91%D7%A2%D7%A8%D7%92\" class=\"mw-redirect\" title=\"יהושע קליינבערג\">יהושע קליינבערג</a>, <a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93\" title=\"חסיד\">חסיד</a> <a href=\"/index.php/%D7%9E%D7%A1%D7%99%D7%A8%D7%95%D7%AA_%D7%A0%D7%A4%D7%A9\" title=\"מסירות נפש\">מסירות נפש</a>, מזקני ומוותיקי הקהילה ב<a href=\"/index.php/%D7%9E%D7%95%D7%A1%D7%A7%D7%91%D7%94\" title=\"מוסקבה\">מוסקבה</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%22%D7%A6\" title=\"תר&quot;צ\">תר\"צ</a> - הרב <a href=\"/index.php/%D7%A2%D7%96%D7%A8%D7%99%D7%90%D7%9C_%D7%97%D7%99%D7%99%D7%A7%D7%99%D7%9F\" title=\"עזריאל חייקין\">עזריאל חייקין</a>, סגן יו\"ר מועצת רבני אירופה ומומחה לענייני אישות. בעבר כיהן כשליח הרבי במרוקו ודנמרק, כרב העיר בריסל וכרבה הראשי של אוקראינה.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A8%D7%A6%22%D7%95\" title=\"תרצ&quot;ו\">תרצ\"ו</a> – הרב <a href=\"/index.php/%D7%91%D7%A8%D7%95%D7%9A_%D7%A9%D7%9E%D7%95%D7%90%D7%9C_%D7%94%D7%99%D7%99%D7%A9%D7%A8%D7%99%D7%A7\" title=\"ברוך שמואל היישריק\">ברוך שמואל היישריק</a>.</li>\n<li><a href=\"/index.php/%D7%94%27%D7%AA%D7%A9%22%D7%99\" class=\"mw-redirect\" title=\"ה&#39;תש&quot;י\">ה'תש\"י</a> - הרב <a href=\"/index.php/%D7%96%D7%9C%D7%9E%D7%9F_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%A1%D7%98%D7%9E%D7%91%D7%9C%D7%A8\" title=\"זלמן מענדל סטמבלר\">זלמן מענדל סטמבלר</a>, איש עסקים חב\"די, בעל השליטה בחברת ההשקעות 'יעסור'.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%92\" title=\"תשי&quot;ג\">תשי\"ג</a> – הרב <a href=\"/index.php/%D7%90%D7%9C%D7%A2%D7%96%D7%A8_%D7%A7%D7%A2%D7%A0%D7%99%D7%92\" title=\"אלעזר קעניג\">אלעזר קעניג</a>, משפיע אנ\"ש ב<a href=\"/index.php/%D7%A0%D7%95%D7%A3_%D7%94%D7%92%D7%9C%D7%99%D7%9C\" title=\"נוף הגליל\">נוף הגליל</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%99%22%D7%96\" title=\"תשי&quot;ז\">תשי\"ז</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%95%D7%9C%D7%9D_%D7%96%D7%95%D7%A9%D7%90_%D7%90%D7%9C%D7%A4%D7%A8%D7%95%D7%91%D7%99%D7%A5%27\" title=\"משולם זושא אלפרוביץ&#39;\">משולם זושא אלפרוביץ'</a>, מ<a href=\"/index.php/%D7%94%D7%A9%D7%9C%D7%95%D7%97%D7%99%D7%9D_%D7%9C%D7%90%D7%A8%D7%A5_%D7%94%D7%A7%D7%95%D7%93%D7%A9\" title=\"השלוחים לארץ הקודש\">השלוחים לארץ הקודש</a> ו<a href=\"/index.php/%D7%9E%D7%A9%D7%A4%D7%99%D7%A2\" title=\"משפיע\">משפיע</a> בישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%A7%D7%A8%D7%99%D7%99%D7%AA_%D7%92%D7%AA\" class=\"mw-redirect mw-disambig\" title=\"תומכי תמימים קריית גת\">תומכי תמימים קריית גת</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9E%22%D7%90\" title=\"תשמ&quot;א\">תשמ\"א</a> – הרב <a href=\"/index.php/%D7%99%D7%A6%D7%97%D7%A7_%D7%A1%D7%A0%D7%93%D7%A8%D7%95%D7%99\" title=\"יצחק סנדרוי\">יצחק סנדרוי</a>, שליח הרבי ב<a href=\"/index.php/%D7%99%D7%A6%D7%94%D7%A8\" title=\"יצהר\">יצהר</a> ומנהל <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D_%D7%99%D7%A6%D7%94%D7%A8\" title=\"תומכי תמימים יצהר\">ישיבת תומכי תמימים המקומית</a>.</li></ul>\n<h3><span id=\".D7.A0.D7.A4.D7.98.D7.A8.D7.95\"></span><span class=\"mw-headline\" id=\"נפטרו\"><a href=\"/index.php/%D7%A4%D7%98%D7%99%D7%A8%D7%94\" class=\"mw-redirect\" title=\"פטירה\">נפטרו</a></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;נפטרו&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%99%27_%D7%91%D7%A1%D7%99%D7%95%D7%95%D7%9F&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: נפטרו\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<ul><li><a href=\"/index.php/%D7%AA%D7%A9%22%D7%95\" title=\"תש&quot;ו\">תש\"ו</a> – הרב <a href=\"/index.php/%D7%9E%D7%A0%D7%97%D7%9D_%D7%9E%D7%A2%D7%A0%D7%93%D7%9C_%D7%92%D7%95%D7%A8%D7%90%D7%A8%D7%99%D7%94\" title=\"מנחם מענדל גוראריה\">מנחם מענדל גוראריה</a>, נגיד חסידי ומקורב ל<a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"הרבי הרש&quot;ב\">רבי הרש\"ב</a>, ומחותנו של <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הרבי הריי&quot;צ\">הרבי הריי\"צ</a> – אבי חתנו <a href=\"/index.php/%D7%94%D7%A8%D7%A9%22%D7%92\" class=\"mw-redirect\" title=\"הרש&quot;ג\">הרש\"ג</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%9C%22%D7%91\" title=\"תשל&quot;ב\">תשל\"ב</a> – הרב <a href=\"/index.php/%D7%9E%D7%A9%D7%94_%D7%90%D7%A8%D7%99%D7%94_%D7%9C%D7%99%D7%99%D7%91_%D7%A9%D7%A4%D7%99%D7%A8%D7%90\" title=\"משה אריה לייב שפירא\">משה אריה לייב שפירא</a>, ראש ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%A8%D7%AA_%D7%90%D7%9E%D7%AA_(%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D)\" class=\"mw-redirect\" title=\"תורת אמת (ירושלים)\">תורת אמת</a> ורב שכונת 'בית ישראל' ב<a href=\"/index.php/%D7%99%D7%A8%D7%95%D7%A9%D7%9C%D7%99%D7%9D\" title=\"ירושלים\">ירושלים</a>.</li>\n<li><a href=\"/index.php/%D7%AA%D7%A9%D7%A1%22%D7%96\" title=\"תשס&quot;ז\">תשס\"ז</a> – הרב <a href=\"/index.php/%D7%90%D7%91%D7%A8%D7%94%D7%9D_%D7%9C%D7%95%D7%99%D7%98%D7%A0%D7%A1%D7%A7%D7%99\" title=\"אברהם לויטנסקי\">אברהם לויטנסקי</a>, שליח הרבי בס. מוניקה וחבר בית דין רבני חב\"ד ליובאוויטש ב<a href=\"/index.php/%D7%A7%D7%9C%D7%99%D7%A4%D7%95%D7%A8%D7%A0%D7%99%D7%94\" title=\"קליפורניה\">קליפורניה</a>.</li></ul>\n<p><br />\n<br />\n</p>\n<table class=\"toccolours\" style=\"clear: both; margin-left: auto; margin-right: auto; text-align: right; width: 65%;\">\n\n<tbody><tr>\n<th style=\"text-align: center; background-color: #CCCCFF;\">הפתגם היומי - י' בסיון - מ<a href=\"/index.php/%D7%9C%D7%95%D7%97_%D7%94%D7%99%D7%95%D7%9D_%D7%99%D7%95%D7%9D\" title=\"לוח היום יום\">לוח היום יום</a>\n</th></tr>\n<tr>\n<td><a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a> ענה לאחד בהכנסו ל<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a>: ..בני ישראל ווערען אנגערופען נרות. א נר איז כלול פון כלי פתילה שמן ואש. מען מוז אבער אנצינדען דעם אש און דעמאלט איז דאס מאיר. בא דיר אז א גוטער נר, אבער עס פעלט דיר דער אנצינדער. דורך הכאה בכח אין דעם אבן של <a href=\"/index.php/%D7%A0%D7%A4%D7%A9_%D7%94%D7%91%D7%94%D7%9E%D7%99%D7%AA\" class=\"mw-redirect\" title=\"נפש הבהמית\">נפש הבהמית</a>, געהט ארויס א ניצוץ אש, וועלכער צינדט אן דעם אש אלקי.\n<hr />\n<p><b>תרגום מ<a href=\"/index.php/%D7%90%D7%99%D7%93%D7%99%D7%A9\" class=\"mw-redirect\" title=\"אידיש\">אידיש</a></b>: <a href=\"/index.php/%D7%A8%D7%91%D7%99%D7%A0%D7%95_%D7%94%D7%96%D7%A7%D7%9F\" class=\"mw-redirect\" title=\"רבינו הזקן\">רבינו הזקן</a> ענה לאחד בהכנסו ל<a href=\"/index.php/%D7%99%D7%97%D7%99%D7%93%D7%95%D7%AA\" title=\"יחידות\">יחידות</a>: ..בני ישראל נקראים נרות. נר כלול מכלי פתילה שמן ואש. מוכרחים אבל להדליק האש ואזי זה מאיר. אצלך הנר טוב, אבל חסרה ההדלקה. על ידי ההכאה בכח באבן ה<a href=\"/index.php/%D7%A0%D7%A4%D7%A9_%D7%94%D7%91%D7%94%D7%9E%D7%99%D7%AA\" class=\"mw-redirect\" title=\"נפש הבהמית\">נפש הבהמית</a>, יוצא ניצוץ אש, המדליק את האש האלקי.\n</p>\n</td></tr></tbody></table>\n<!-- \nNewPP limit report\nCached time: 20260414123452\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.065 seconds\nReal time usage: 0.181 seconds\nPreprocessor visited node count: 118/1000000\nPost‐expand include size: 6461/2097152 bytes\nTemplate argument size: 557/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 0/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 0/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   34.547      1 -total\n 67.69%   23.385      1 תבנית:חודש_סיוון\n 43.68%   15.090      1 תבנית:לוח_שנה\n 31.88%   11.012      1 תבנית:להיום_יום\n 19.41%    6.705      1 תבנית:כתב_קטן\n 14.57%    5.032      1 תבנית:היום_יום/י&#039;_סיון\n-->\n\n<