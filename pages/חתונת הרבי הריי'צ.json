      "*": "<div class=\"mw-content-rtl mw-parser-output\" lang=\"he\" dir=\"rtl\"><table cellpadding=\"1\" style=\"float: left; border: 1px solid #8888aa; background: #f7f8ff; padding: 5px; font-size: 95%; margin: 0 15px 0 0px;\" width=\"22%\">\n<tbody><tr>\n<td style=\"background: #ccf; text-align: center;\"><b>סדרת ערכים בנושא <br />תולדות חייו של <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a></b>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6_%D7%91%D7%99%D7%9C%D7%93%D7%95%D7%AA%D7%95_%D7%95%D7%A6%D7%A2%D7%99%D7%A8%D7%95%D7%AA%D7%95\" title=\"הרבי הריי&quot;צ בילדותו וצעירותו\">הרבי הריי\"צ בילדותו וצעירותו</a> (<a href=\"/index.php/%D7%AA%D7%A8%22%D7%9E\" title=\"תר&quot;מ\">תר\"מ</a>-<a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"תרנ&quot;ז\">תרנ\"ז</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a class=\"mw-selflink selflink\">חתונת הרבי הריי\"צ</a> (<a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"תרנ&quot;ז\">תרנ\"ז</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php?title=%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6_%D7%9B%D7%9E%D7%A0%D7%94%D7%9C_%D7%99%D7%A9%D7%99%D7%91%D7%AA_%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"הרבי הריי&quot;צ כמנהל ישיבת תומכי תמימים (הדף אינו קיים)\">כמנהל ישיבת תומכי תמימים</a> (<a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"תרנ&quot;ז\">תרנ\"ז</a>-<a href=\"/index.php/%D7%AA%D7%A8%22%D7%A4\" title=\"תר&quot;פ\">תר\"פ</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php?title=%D7%A7%D7%91%D7%9C%D7%AA_%D7%94%D7%A0%D7%A9%D7%99%D7%90%D7%95%D7%AA_%D7%A9%D7%9C_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"קבלת הנשיאות של אדמו&quot;ר הריי&quot;צ (הדף אינו קיים)\">קבלת הנשיאות</a> (<a href=\"/index.php/%D7%AA%D7%A8%22%D7%A4\" title=\"תר&quot;פ\">תר\"פ</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php/%D7%A4%D7%A2%D7%95%D7%9C%D7%95%D7%AA%D7%99%D7%95_%D7%A9%D7%9C_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6_%D7%91%D7%A1%D7%93%D7%A8_%D7%9B%D7%A8%D7%95%D7%A0%D7%95%D7%9C%D7%95%D7%92%D7%99\" class=\"mw-redirect\" title=\"פעולותיו של אדמו&quot;ר הריי&quot;צ בסדר כרונולוגי\">פעולותיו של אדמו\"ר הריי\"צ בסדר כרונולוגי</a> (<a href=\"/index.php/%D7%AA%D7%A8%22%D7%9E\" title=\"תר&quot;מ\">תר\"מ</a>-<a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php?title=%D7%9E%D7%90%D7%A1%D7%A8%D7%99%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מאסריו של הרבי הריי&quot;צ (הדף אינו קיים)\">מאסריו של הרבי הריי\"צ</a> (<a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%90\" title=\"תרנ&quot;א\">תרנ\"א</a>-<a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%96\" title=\"תרפ&quot;ז\">תרפ\"ז</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php?title=%D7%9E%D7%A1%D7%A2%D7%95%D7%AA%D7%99%D7%95_%D7%A9%D7%9C_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"מסעותיו של הרבי הריי&quot;צ (הדף אינו קיים)\">מסעותיו של הרבי הריי\"צ</a> (<a href=\"/index.php/%D7%AA%D7%A8%D7%A4%22%D7%98\" title=\"תרפ&quot;ט\">תרפ\"ט</a> - <a href=\"/index.php/%D7%AA%D7%A8%22%D7%A6\" title=\"תר&quot;צ\">תר\"צ</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php/%D7%94%D7%A6%D7%9C%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" title=\"הצלת אדמו&quot;ר הריי&quot;צ\">הצלת אדמו\"ר הריי\"צ</a> (<a href=\"/index.php/%D7%AA%22%D7%A9\" title=\"ת&quot;ש\">ת\"ש</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php?title=%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6_%D7%91%D7%90%D7%A8%D7%A6%D7%95%D7%AA_%D7%94%D7%91%D7%A8%D7%99%D7%AA&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"הרבי הריי&quot;צ בארצות הברית (הדף אינו קיים)\">הרבי הריי\"צ בארצות הברית</a> (<a href=\"/index.php/%D7%AA%22%D7%A9\" title=\"ת&quot;ש\">ת\"ש</a> - <a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a>)</div>\n</td></tr>\n<tr>\n<td><div style=\"text-align:center\"><a href=\"/index.php/%D7%94%D7%A1%D7%AA%D7%9C%D7%A7%D7%95%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הסתלקות הרבי הריי&quot;צ\">הסתלקות הרבי הריי\"צ</a> (<a href=\"/index.php/%D7%AA%D7%A9%22%D7%99\" title=\"תש&quot;י\">תש\"י</a>)</div>\n</td></tr>\n</tbody></table>\n<p><b>חתונת <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a></b> עם הרבנית <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%94_%D7%93%D7%99%D7%A0%D7%94_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"נחמה דינה שניאורסון\">נחמה דינה שניאורסון</a>, נערכה ב<a href=\"/index.php/%D7%99%22%D7%92_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"י&quot;ג אלול\">י\"ג אלול</a> <a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"תרנ&quot;ז\">תרנ\"ז</a>, בעיירה <a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>. \n</p>\n<meta property=\"mw:PageProp/toc\" />\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99_.D7.94.D7.AA.D7.A0.D7.90.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורי_התנאים\">קישורי התנאים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;veaction=edit&amp;section=1\" title=\"עריכת פסקה: &quot;קישורי התנאים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;section=1\" title=\"עריכת קוד המקור של הפרק: קישורי התנאים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<figure class=\"mw-halign-left\" typeof=\"mw:File/Thumb\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%90%D7%93%D7%9E%D7%95%D7%A8_%D7%94%D7%A8%D7%99%D7%99%D7%A6_%D7%91%D7%A6%D7%A2%D7%99%D7%A8%D7%95%D7%AA%D7%95.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/3/3e/%D7%90%D7%93%D7%9E%D7%95%D7%A8_%D7%94%D7%A8%D7%99%D7%99%D7%A6_%D7%91%D7%A6%D7%A2%D7%99%D7%A8%D7%95%D7%AA%D7%95.jpg/250px-%D7%90%D7%93%D7%9E%D7%95%D7%A8_%D7%94%D7%A8%D7%99%D7%99%D7%A6_%D7%91%D7%A6%D7%A2%D7%99%D7%A8%D7%95%D7%AA%D7%95.jpg\" decoding=\"async\" width=\"250\" height=\"311\" class=\"mw-file-element\" srcset=\"/images/3/3e/%D7%90%D7%93%D7%9E%D7%95%D7%A8_%D7%94%D7%A8%D7%99%D7%99%D7%A6_%D7%91%D7%A6%D7%A2%D7%99%D7%A8%D7%95%D7%AA%D7%95.jpg 1.5x\" /></a><figcaption>אדמו\"ר הריי\"צ בצעירותו</figcaption></figure>\n<p>לקראת שידוכיו הוצעו לאדמו\"ר הריי\"צ שלוש הצעות, שתיים מהן בנות עשירים שהתחייבו להעניק <a href=\"/index.php/%D7%A0%D7%93%D7%95%D7%A0%D7%99%D7%94\" title=\"נדוניה\">נדוניה‎</a> גדולה, והשלישית הייתה הרבנית נחמה דינה, שהוריה היו עניים. אדמו\"ר הרש\"ב בחר דווקא בהצעת שידוך זו<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\"><span class=\"cite-bracket\">&#91;</span>1<span class=\"cite-bracket\">&#93;</span></a></sup>, על פני שתי הצעות אחרות בנימוק שרצונו שבנו יחידו <a href=\"/index.php/%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"הריי&quot;צ\">הריי\"צ</a> יתחתן עם בת המשפחה<sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\"><span class=\"cite-bracket\">&#91;</span>2<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p><p>התנאים בין אדמו\"ר הריי\"צ והרבנית <a href=\"/index.php/%D7%A0%D7%97%D7%9E%D7%94_%D7%93%D7%99%D7%A0%D7%94_%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8%D7%A1%D7%95%D7%9F_(%D7%90%D7%A9%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6)\" title=\"נחמה דינה שניאורסון (אשת אדמו&quot;ר הריי&quot;צ)\">נחמה דינה שניאורסון</a> נחתמו בכ\"ח בסיון <a href=\"/index.php/%D7%AA%D7%A8%D7%A0%22%D7%95\" title=\"תרנ&quot;ו\">תרנ\"ו</a> בעיירה <a href=\"/index.php?title=%D7%90%D7%9C%D7%99%D7%95%D7%95%D7%A7%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אליווקא (הדף אינו קיים)\">אליווקא</a>, במשך שבוע התוועדו הורי הכלה והחתן בחודש <a href=\"/index.php/%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"תמוז\">תמוז</a> כהמשך לקישורי תנאים.\n</p><p>אדמו\"ר הריי\"צ נשאר כמה ימים אחרי ב<a href=\"/index.php?title=%D7%90%D7%9C%D7%99%D7%95%D7%95%D7%A7%D7%90&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"אליווקא (הדף אינו קיים)\">אליווקא</a> יחד עם דודו ה<a href=\"/index.php/%D7%A8%D7%96%22%D7%90\" class=\"mw-redirect\" title=\"רז&quot;א\">רז\"א</a>, במהלך אותם ימים הרז\"א סיפר לו סיפורים חסידיים, ב<a href=\"/index.php/%D7%99%22%D7%90_%D7%AA%D7%9E%D7%95%D7%96\" class=\"mw-redirect\" title=\"י&quot;א תמוז\">י\"א תמוז</a> חזר אדמו\"ר הריי\"צ עם דודו הרז\"א בחזרה ל<a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>.\n</p><p>עקב גילה הצעיר של הכלה (בת 15), החתונה התקיימה כעבור יותר משנה<sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\"><span class=\"cite-bracket\">&#91;</span>3<span class=\"cite-bracket\">&#93;</span></a></sup>.\n</p>\n<h2><span id=\".D7.91.D7.99.D7.9F_.D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99_.D7.94.D7.AA.D7.A0.D7.90.D7.99.D7.9D_.D7.9C.D7.97.D7.AA.D7.95.D7.A0.D7.94\"></span><span class=\"mw-headline\" id=\"בין_קישורי_התנאים_לחתונה\">בין קישורי התנאים לחתונה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;veaction=edit&amp;section=2\" title=\"עריכת פסקה: &quot;בין קישורי התנאים לחתונה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;section=2\" title=\"עריכת קוד המקור של הפרק: בין קישורי התנאים לחתונה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ב<a href=\"/index.php/%D7%98%22%D7%96_%D7%90%D7%91\" class=\"mw-redirect\" title=\"ט&quot;ז אב\">ט\"ז אב</a> נסע אדמו\"ר הריי\"צ ל<a href=\"/index.php/%D7%95%D7%99%D7%98%D7%91%D7%A1%D7%A7\" title=\"ויטבסק\">ויטבסק</a> ושמע סיפורים מסבתו <a href=\"/index.php/%D7%94%D7%A8%D7%91%D7%A0%D7%99%D7%AA_%D7%97%D7%99%D7%94_%D7%9E%D7%95%D7%A9%D7%A7%D7%90_(%D7%90%D7%A9%D7%AA_%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A6%D7%9E%D7%97_%D7%A6%D7%93%D7%A7)\" class=\"mw-redirect\" title=\"הרבנית חיה מושקא (אשת אדמו&quot;ר הצמח צדק)\">הרבנית חיה מושקא</a>.\n</p><p>בזמן שבין קישורי התנאים לחתונה היו אדמו\"ר הריי\"צ ואביו נוסעים לטיולים שבמהלכם היה אדמו\"ר הרש\"ב מכין את בנו לקראת החתונה.\n</p>\n<h2><span id=\".D7.94.D7.97.D7.AA.D7.95.D7.A0.D7.94\"></span><span class=\"mw-headline\" id=\"החתונה\">החתונה</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;veaction=edit&amp;section=3\" title=\"עריכת פסקה: &quot;החתונה&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;section=3\" title=\"עריכת קוד המקור של הפרק: החתונה\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>ביום שישי<sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\"><span class=\"cite-bracket\">&#91;</span>4<span class=\"cite-bracket\">&#93;</span></a></sup> פרשת תצא <a href=\"/index.php/%D7%99%22%D7%92_%D7%90%D7%9C%D7%95%D7%9C_%D7%AA%D7%A8%D7%A0%22%D7%96\" class=\"mw-redirect\" title=\"י&quot;ג אלול תרנ&quot;ז\">י\"ג אלול תרנ\"ז</a>, בהיותו בגיל 17, התקיימה החתונה ב<a href=\"/index.php/%D7%A2%D7%99%D7%99%D7%A8%D7%94\" title=\"עיירה\">עיירה</a> <a href=\"/index.php/%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9\" title=\"ליובאוויטש\">ליובאוויטש</a>. ביום חתונתו חבש החתן <a href=\"/index.php/%D7%A9%D7%98%D7%A8%D7%99%D7%99%D7%9E%D7%9C\" title=\"שטריימל\">שטריימל</a> ובאותו מעמד אמר לו אביו שיברך <a href=\"/index.php/%D7%A9%D7%94%D7%97%D7%99%D7%99%D7%A0%D7%95\" class=\"mw-redirect\" title=\"שהחיינו\">שהחיינו</a>. לאחר החופה הובילו <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> וקהל רב את החתן והכלה בשירה, אל האולם בו נערכה הסעודה. בדרך אמר אדמו\"ר הרש\"ב לבנו: \"וחזקת והיית לאיש\". הסעודה נערכה ב<a href=\"/index.php/%D7%94%D7%96%D7%90%D7%9C_%D7%94%D7%92%D7%93%D7%95%D7%9C_(%D7%9C%D7%99%D7%95%D7%91%D7%90%D7%95%D7%95%D7%99%D7%98%D7%A9)\" title=\"הזאל הגדול (ליובאוויטש)\">זאל הגדול</a> שבליובאוויטש. בשעת הסעודה הסתובב אדמו\"ר הרש\"ב יחד עם שלושה חסידים (ר' <a href=\"/index.php/%D7%9E%D7%90%D7%99%D7%A8_%D7%9E%D7%A8%D7%93%D7%9B%D7%99_%D7%A6%27%D7%A8%D7%A0%D7%99%D7%9F\" class=\"mw-redirect\" title=\"מאיר מרדכי צ&#39;רנין\">מאיר מרדכי צ'רנין</a>, ר' <a href=\"/index.php/%D7%99%D7%A2%D7%A7%D7%91_%D7%A7%D7%90%D7%A4%D7%99%D7%9C_%D7%96%D7%9C%D7%99%D7%A7%D7%A1%D7%95%D7%9F\" class=\"mw-redirect\" title=\"יעקב קאפיל זליקסון\">יעקב קאפיל זליקסון</a> ור' <a href=\"/index.php/%D7%A9%D7%9C%D7%9E%D7%94_%D7%97%D7%99%D7%99%D7%9D_%D7%A7%D7%99%D7%98%D7%90%D7%99%D7%9F\" title=\"שלמה חיים קיטאין\">שלמה חיים קיטאין</a>) לוודא שהמלצרים מחלקים אוכל לכולם ואדמו\"ר הרש\"ב אמר עם כל אחד '<a href=\"/index.php/%D7%9C%D7%97%D7%99%D7%99%D7%9D\" class=\"mw-redirect\" title=\"לחיים\">לחיים</a>'. כמו כן, אמר אדמו\"ר הרש\"ב הרבה דרושי חסידות. לאחר החתונה התגוררו הזוג בחדר שנבנה סמוך לדירת אדמו\"ר הרש\"ב.\n</p><p>בסעודת השבע ברכות, ביום ראשון <a href=\"/index.php/%D7%98%22%D7%95_%D7%90%D7%9C%D7%95%D7%9C_%D7%AA%D7%A8%D7%A0%22%D7%96\" class=\"mw-redirect\" title=\"ט&quot;ו אלול תרנ&quot;ז\">ט\"ו אלול תרנ\"ז</a>, הודיע <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%A9%22%D7%91\" class=\"mw-redirect\" title=\"אדמו&quot;ר הרש&quot;ב\">אדמו\"ר הרש\"ב</a> על החלטתו לייסד את ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> בה ילמדו <a href=\"/index.php/%D7%A0%D7%92%D7%9C%D7%94\" class=\"mw-redirect\" title=\"נגלה\">נגלה</a> ו<a href=\"/index.php/%D7%97%D7%A1%D7%99%D7%93%D7%95%D7%AA\" title=\"חסידות\">חסידות</a>.\n</p><p>במהלך ימי ה<a href=\"/index.php/%D7%A9%D7%91%D7%A2_%D7%91%D7%A8%D7%9B%D7%95%D7%AA\" title=\"שבע ברכות\">שבע ברכות</a> אמר אדמו\"ר הרש\"ב את <a href=\"/index.php/%D7%94%D7%9E%D7%A9%D7%9A_%D7%A9%D7%9E%D7%97_%D7%AA%D7%A9%D7%9E%D7%97_%D7%AA%D7%A8%D7%A0%22%D7%96\" title=\"המשך שמח תשמח תרנ&quot;ז\">המשך שמח תשמח תרנ\"ז</a>.\n</p><p>ביום שלישי <a href=\"/index.php/%D7%99%22%D7%96_%D7%90%D7%9C%D7%95%D7%9C\" class=\"mw-redirect\" title=\"י&quot;ז אלול\">י\"ז אלול</a> בחר אדמו\"ר הרש\"ב בשמונה עשר תלמידים שהיו לגרעין בראשון של <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a>.\n</p><p>מיד אחרי החתונה מונה <a href=\"/index.php/%D7%90%D7%93%D7%9E%D7%95%22%D7%A8_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6\" class=\"mw-redirect\" title=\"אדמו&quot;ר הריי&quot;צ\">אדמו\"ר הריי\"צ</a> למנהל ישיבת <a href=\"/index.php/%D7%AA%D7%95%D7%9E%D7%9B%D7%99_%D7%AA%D7%9E%D7%99%D7%9E%D7%99%D7%9D\" class=\"mw-redirect\" title=\"תומכי תמימים\">תומכי תמימים</a> שזה עתה הוקמה.\n</p>\n<h2><span id=\".D7.9C.D7.A7.D7.A8.D7.99.D7.90.D7.94_.D7.A0.D7.95.D7.A1.D7.A4.D7.AA\"></span><span class=\"mw-headline\" id=\"לקריאה_נוספת\">לקריאה נוספת</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;veaction=edit&amp;section=4\" title=\"עריכת פסקה: &quot;לקריאה נוספת&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;section=4\" title=\"עריכת קוד המקור של הפרק: לקריאה נוספת\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב <a href=\"/index.php/%D7%A9%D7%A0%D7%99%D7%90%D7%95%D7%A8_%D7%96%D7%9C%D7%9E%D7%9F_%D7%94%D7%A8%D7%A6%D7%9C\" title=\"שניאור זלמן הרצל\">שניאור זלמן הרצל</a>, <b>נישואי הנשיאים</b> חלק ראשון</li></ul>\n<h2><span id=\".D7.A7.D7.99.D7.A9.D7.95.D7.A8.D7.99.D7.9D_.D7.97.D7.99.D7.A6.D7.95.D7.A0.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"קישורים_חיצוניים\">קישורים חיצוניים</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;veaction=edit&amp;section=5\" title=\"עריכת פסקה: &quot;קישורים חיצוניים&quot;\" class=\"mw-editsection-visualeditor\"><span>עריכה</span></a><span class=\"mw-editsection-divider\"> | </span><a href=\"/index.php?title=%D7%97%D7%AA%D7%95%D7%A0%D7%AA_%D7%94%D7%A8%D7%91%D7%99_%D7%94%D7%A8%D7%99%D7%99%22%D7%A6&amp;action=edit&amp;section=5\" title=\"עריכת קוד המקור של הפרק: קישורים חיצוניים\"><span>עריכת קוד מקור</span></a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li>הרב יוסף יצחק עמאר, <b><a rel=\"nofollow\" class=\"external text\" href=\"https://col.org.il/files/uploads/original/2020/09/5f51094b5d8dd_1599146315.pdf\">י\"ג אלול - יום חתונת אדמו\"ר הריי\"צ</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%97%D7%91%22%D7%93_%D7%90%D7%95%D7%9F_%D7%9C%D7%99%D7%99%D7%9F\" title=\"חב&quot;ד און ליין\"><img src=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/15px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg\" decoding=\"async\" width=\"15\" height=\"15\" class=\"mw-file-element\" srcset=\"/images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/23px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 1.5x, /images/thumb/8/8c/%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg/30px-%D7%A1%D7%99_%D7%90%D7%95_%D7%90%D7%9C_%D7%A1%D7%9E%D7%9C%D7%99%D7%9C.jpg 2x\" /></a></span><span typeof=\"mw:File\"><a href=\"https://chabadpedia.co.il/images/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" title=\"קובץ PDF\" rel=\"nofollow\"><img alt=\"קובץ PDF\" src=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/17px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg\" decoding=\"async\" width=\"17\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/26px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 1.5x, /images/thumb/6/6e/%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg/35px-%D7%A1%D7%9E%D7%9C%D7%99%D7%9C_PDF_%D7%97%D7%93%D7%A9.jpeg 2x\" /></a></span> תשורה מנישואי משפחות שקדי-עמאר, אלול ה'תש\"פ</li>\n<li><b><a rel=\"nofollow\" class=\"external text\" href=\"https://anash.org/who-was-the-frierdiker-rebbes-shadchan/\">מי היה השדכן של אדמו\"ר הריי\"צ?</a></b> <span typeof=\"mw:File\"><a href=\"/index.php/%D7%90%D7%A0%22%D7%A9_(%D7%90%D7%AA%D7%A8)\" title=\"קישור לאתר אנ&quot;ש\"><img alt=\"קישור לאתר אנ&quot;ש\" src=\"/images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/22px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg\" decoding=\"async\" width=\"22\" height=\"19\" class=\"mw-file-element\" srcset=\"/images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/33px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg 1.5x, /images/thumb/8/88/%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg/44px-%D7%9C%D7%95%D7%92%D7%95_%D7%90%D7%A0%D7%A9.jpg 2x\" /></a></span> (אנגלית)</li></ul>\n<h2><span id=\".D7.94.D7.A2.D7.A8.D7.95.D7.AA_.D7.A9.D7.95.D7.9C.D7.99.D7.99.D7.9D\"></span><span class=\"mw-headline\" id=\"הערות_שוליים\">הערות שוליים</span></h2>\n<div class=\"reflist references-small\">     \n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">^</a></span> <span class=\"reference-text\">שהציע הרה\"ח ר' <a href=\"/index.php/%D7%90%D7%A9%D7%A8_%D7%9E%D7%A0%D7%99%D7%A7%D7%95%D7%9C%D7%99%D7%99%D7%91\" class=\"mw-redirect\" title=\"אשר מניקולייב\">אשר מניקולייב</a> (<a rel=\"nofollow\" class=\"external text\" href=\"http://www.teshura.com/teshurapdf/Zirkind-Wolf%20-%20Menachem%20Av%2028%2C%205775.pdf\">תשורה משפחת צירקינד עמוד 10, מסיפורי הרב גרונר</a>).</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">^</a></span> <span class=\"reference-text\">בעת השידוך שלי נדברו ג' שידוכים, שניים – עם שני גבירים שנתנו הרבה נדן, ואחד – זה של הרבנית נחמה דינה, שזה היה שידוך עני, שגם על צורכי החתונה היה צריך אאמו\"ר [הרש\"ב] נ\"ע ליתן. אמי זקנתי הרבנית רבקה נ\"ע עם החסידים החזיקו אודות שידוך עם הגביר, וכש­נכנסו לשאול פי אאמו\"ר [הרש\"ב], אמר: אברהם היה לו בן יחיד ורצה להשיאו לבני משפחתו.\nואחר-כך בערב יום-הכיפורים נכנס אאמו\"ר לאמי זקנתי הרבנית רבקה ע\"ה לבקש מחילה עבור זה, וענתה לו: ייתן לך השם יתברך התעוררות תשובה אמיתית ופתיחת הלב והתגלות הנקודה, אם ימחול לנו השם יתברך כמו שאני מוחלת לך, אז נהיה טהורים ונקיים. \n(<a rel=\"nofollow\" class=\"external text\" href=\"http://chabadlibrary.org/books/default.aspx?furl=/maharyatz/sichos/680-7/10/11\">ספר השיחות תר\"פ-תרפ\"ז ע' 172</a>)</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">^</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://www.shturem.net/index.php?section=artdays&amp;id=2970\">מדוע התאחרה חתונת הרבי ביותר משנה? - שטורעם</a></span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">^</a></span> <span class=\"reference-text\">הרבי העיר שיש לברר האם החתונה הייתה ביום שישי עצמו או בליל שישי, מפאת המנהגים הקשורים במשפחת בית הרב בחתונה, אמירת <a href=\"/index.php/%D7%9E%D7%90%D7%9E%D7%A8%D7%99_%D7%93%D7%90%22%D7%97\" class=\"mw-redirect\" title=\"מאמרי דא&quot;ח\">מאמרי דא\"ח</a> באריכות, ועוד, <a rel=\"nofollow\" class=\"external text\" href=\"https://chabad.info/wp-content/uploads/2019/11/28-11-2019-17-09-18-%D7%9C%D7%99%D7%A7%D7%95%D7%98-%D7%9E%D7%A2%D7%A0%D7%95%D7%AA-%D7%A7%D7%95%D7%93%D7%A9-%D7%AA%D7%A9%D7%9E%D7%97.pdf\">ליקוט מענות קודש תשמ\"ח, אות שיז</a>.</span>\n</li>\n</ol></div></div>\n<!-- \nNewPP limit report\nCached time: 20260413232502\nCache expiry: 86400\nReduced expiry: false\nComplications: [show‐toc]\nCPU time usage: 0.096 seconds\nReal time usage: 0.282 seconds\nPreprocessor visited node count: 312/1000000\nPost‐expand include size: 3696/2097152 bytes\nTemplate argument size: 877/2097152 bytes\nHighest expansion depth: 5/100\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 3343/5000000 bytes\nLua time usage: 0.050/7 seconds\nLua virtual size: 5754