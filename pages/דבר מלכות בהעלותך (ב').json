ש</a> • <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%95%D7%99%D7%97%D7%99\" title=\"דבר מלכות ויחי\">ויחי</a>\n</td>\n<td rowspan=\"6\" align=\"center\" style=\"text-align: center; vertical-align: middle;\"><span typeof=\"mw:File/Frameless\"><a href=\"/index.php/%D7%A7%D7%95%D7%91%D7%A5:%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA.jpg\" class=\"mw-file-description\"><img src=\"/images/thumb/f/f3/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA.jpg/130px-%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA.jpg\" decoding=\"async\" width=\"130\" height=\"173\" class=\"mw-file-element\" srcset=\"/images/thumb/f/f3/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA.jpg/195px-%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA.jpg 1.5x, /images/thumb/f/f3/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA.jpg/260px-%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA.jpg 2x\" /></a></span>\n</td></tr>\n\n<tr>\n<td style=\"background-color: #8B0000; text-align: right; font-weight: bold; padding-left: 5px;\"><div style=\"text-align:center\"><span style=\"color:white;\"><b>שמות</b></span></div>\n</td>\n<td style=\"padding-right: 5px; text-align: center;\"><a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%A9%D7%9E%D7%95%D7%AA\" title=\"דבר מלכות שמות\">שמות</a> • <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%95%D7%90%D7%A8%D7%90_(%D7%90%27)\" title=\"דבר מלכות וארא (א&#39;)\">וארא (א')</a>, <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%95%D7%90%D7%A8%D7%90_(%D7%91%27)\" title=\"דבר מלכות וארא (ב&#39;)\">וארא (ב')</a> • <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%91%D7%90\" title=\"דבר מלכות בא\">בא</a> • <a href=\"/index.php/%D7%93%D7%91%D7%A8_%D7%9E%D7%9C%D7%9B%D7%95%D7%AA_%D7%A2%22%D7%93_%D7%9E%D7%A2%D7%9C%D7%AA_%D7%A0%D7%A9%D7%99_%D7%95%D7%91%D7%A0%D7%95%D7%AA_%D7%99%D7%A9%D7%A8%D7%90%D7%9C\" title=\"דבר מלכות ע&quot;ד מעלת נשי ובנות 